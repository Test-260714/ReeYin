<Application x:Class="WpfHelper.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             StartupUri="MainWindow.xaml">
    <!--放一个应用程序在这进行引用，避免生成的DLL提示找不到资源报错-->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Language/CN.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Themes/LightTheme.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Generic.xaml"/>
                <ResourceDictionary>
                    <!-- 主色（基础色值） -->
                    <Color x:Key="PrimaryColor">#BF9000</Color>

                    <!-- 主色画笔（自动关联上述颜色） -->
                    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>

                    <SolidColorBrush x:Key="MinimapItem.BackgroundBrush"
                     Color="red"
                     Opacity="0.8" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>

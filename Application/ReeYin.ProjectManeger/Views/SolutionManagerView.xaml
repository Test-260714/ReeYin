<UserControl x:Class="ReeYin.ProjectManager.Views.SolutionManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:converters="clr-namespace:ReeYin.ProjectManager.Converters"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="13"
             Height="700" Width="1100"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="700" d:DesignWidth="1100">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:StringToVisibilityConverter x:Key="StringToVis"/>

        <!-- ── 颜色 ── -->
        <SolidColorBrush x:Key="PrimaryBrush"      Color="{DynamicResource PrimaryColor}"/>
        <SolidColorBrush x:Key="SuccessBrush"      Color="#00B37E"/>
        <SolidColorBrush x:Key="DangerBrush"       Color="#E63757"/>
        <SolidColorBrush x:Key="WarningBrush"      Color="#F6C343"/>
        <SolidColorBrush x:Key="BgPanelBrush"      Color="{DynamicResource MainBackgroundColor}"/>
        <SolidColorBrush x:Key="BgCardBrush"       Color="{DynamicResource RegionBackgroundColor}"/>
        <SolidColorBrush x:Key="BgInputBrush"      Color="{DynamicResource RegionBackgroundColor}"/>
        <SolidColorBrush x:Key="BorderBrush"       Color="{DynamicResource MainBorderColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"  Color="{DynamicResource TextColor}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource MainTopTextBlockColor}"/>
        <SolidColorBrush x:Key="TextMutedBrush"    Color="{DynamicResource RegionSideColor}"/>
        <SolidColorBrush x:Key="HoverBrush"        Color="{DynamicResource HoverColor}"/>
        <SolidColorBrush x:Key="SelectedBrush"     Color="#FFF7E0"/>
        <SolidColorBrush x:Key="AccentBackgroundBrush" Color="#FFF3D1"/>
        <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF8E3"/>
        <SolidColorBrush x:Key="InfoBackgroundBrush" Color="#FFFBEF"/>

        <!-- ── 工具栏按钮 Style ── -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="14,7"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverBrush}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SelectedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 主要操作按钮（蓝色）── -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Background"  Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- ── 危险操作按钮（红色）── -->
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
        </Style>

        <!-- ── TextBox Style ── -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"   Value="{StaticResource BgInputBrush}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,5"/>
            <Setter Property="CaretBrush"   Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 标签 Style ── -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,12,0,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ── 字段值 Style ── -->
        <Style x:Key="FieldValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- ── Section 标题 ── -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
            <Setter Property="Text"       Value="{DynamicResource SolutionManagerSection}"/>
        </Style>

        <!-- ── 列表项 DataTemplate ── -->
        <DataTemplate x:Key="SolutionItemTemplate">
            <Border x:Name="ItemBd"
                    Background="Transparent"
                    BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource BorderBrush}"
                    Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 当前指示条 -->
                    <Border Grid.Column="0"
                            Width="4" Height="32"
                            CornerRadius="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- 名称 + 路径 -->
                    <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontSize="13" TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding FilePath}">
                            <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCurrent}" Value="True"/>
                                                    <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            </MultiDataTrigger>
                                            <DataTrigger Binding="{Binding FileExists}" Value="False">
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Description}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                        <TextBlock Text="{Binding DisplayLastModified, Mode=OneWay}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="11"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- 文件缺失警告 -->
                    <TextBlock Grid.Column="2" Text="⚠" ToolTip="{DynamicResource SolutionManagerFileMissing}"
                               Foreground="{StaticResource WarningBrush}"
                               FontSize="14" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FileExists}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter TargetName="ItemBd" Property="Background" Value="{StaticResource SelectedBrush}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- ── ListBox Style ── -->
        <Style x:Key="SolutionListBoxStyle" TargetType="ListBox">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding"     Value="0"/>
                        <Setter Property="Background"  Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            SnapsToDevicePixels="True">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource SelectedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 配置项目列表 Style ── -->
        <Style x:Key="ConfigTagStyle" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource BgInputBrush}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="4"/>
            <Setter Property="Padding"        Value="10,5"/>
            <Setter Property="Margin"         Value="0,0,8,8"/>
        </Style>

    </UserControl.Resources>

    <!-- ════════════════════════════════════════════════════════════════════ -->
    <!--  ROOT                                                               -->
    <!-- ════════════════════════════════════════════════════════════════════ -->
    <Grid Background="{StaticResource BgPanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 工具栏 -->
            <RowDefinition Height="*"/>     <!-- 内容区 -->
            <RowDefinition Height="Auto"/>  <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Row 0 · 工具栏                                                 -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- 新建 -->
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding NewCommand}">
                        <StackPanel Orientation="Horizontal" >
                            <TextBlock Text="＋" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource New}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 打开 -->
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding OpenCommand}">
                        <StackPanel Orientation="Horizontal" >
                            <TextBlock Text="📂" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Open}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Height="20" Background="{StaticResource BorderBrush}"/>

                    <!-- 保存 -->
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding SaveCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Save}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- 另存为 -->
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding SaveAsCommand}"
                            Content="{DynamicResource SaveAs}"/>
                    
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding ImportOldCommand}"
                            Content="{DynamicResource SolutionManagerImportLegacyProject}"/>

                    <Separator Width="1" Height="20" Background="{StaticResource BorderBrush}"/>

                    <!-- 删除选中 -->
                    <Button Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding DeleteCommand}"
                            IsEnabled="{Binding HasSelectedSolution}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🗑" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Delete}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>


                </StackPanel>

                <!-- 右侧：未保存提示 + 关闭 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Border Background="{StaticResource WarningBackgroundBrush}" BorderBrush="{StaticResource WarningBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="10,4"
                            Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{DynamicResource SolutionManagerUnsavedChanges}"
                                   Foreground="{StaticResource WarningBrush}"
                                   FontSize="12"/>
                    </Border>

                    <!-- 加载动画指示 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="⏳" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource SolutionManagerProcessing}" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Command="{Binding CloseCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Close}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Row 1 · 内容区（左列表 + 右详情/新建表单）                     -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ────────────────────────────────────────────────────────── -->
            <!-- Col 0 · 左侧：解决方案列表                                  -->
            <!-- ────────────────────────────────────────────────────────── -->
            <Grid Grid.Column="0"
                  Background="{StaticResource BgCardBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 列表头 -->
                <Border Grid.Row="0"
                        Padding="14,10"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="{DynamicResource SolutionManagerSolution}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource SolutionManagerLoadedLabel}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LoadedSolutionName}"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       MaxWidth="100"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding LoadedSolutionName}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 列表内容 -->
                <ListBox Grid.Row="1"
                         Style="{StaticResource SolutionListBoxStyle}"
                         ItemsSource="{Binding RecentSolutions}"
                         SelectedItem="{Binding SelectedSolution}"
                         ItemTemplate="{StaticResource SolutionItemTemplate}">
                    <ListBox.InputBindings>
                        <MouseBinding MouseAction="LeftDoubleClick"
                                      Command="{Binding OpenSelectedCommand}"/>
                    </ListBox.InputBindings>
                </ListBox>

                <!-- 列表底部操作 -->
                <Border Grid.Row="2"
                        Padding="12,10"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding RecentSolutions.Count}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"/>
                            <TextBlock Text="{DynamicResource SolutionManagerSolutionCountSuffix}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"/>
                        </StackPanel>
                        <Button HorizontalAlignment="Right"
                                Style="{StaticResource ToolbarButtonStyle}"
                                Command="{Binding OpenSelectedCommand}"
                                IsEnabled="{Binding HasSelectedSolution}"
                                Padding="10,5">
                            <TextBlock Text="{DynamicResource SolutionManagerOpenSelected}" FontSize="12"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── GridSplitter ── -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ────────────────────────────────────────────────────────── -->
            <!-- Col 2 · 右侧：详情面板 / 新建表单                          -->
            <!-- ────────────────────────────────────────────────────────── -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          Background="{StaticResource BgPanelBrush}">
                <Grid Margin="24,20">

                    <!-- ══════ A. 当前解决方案详情（IsCreatingNew = false） ══════ -->
                    <StackPanel Visibility="{Binding DetailsVisibility}">

                        <!-- 段落：解决方案信息 -->
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{DynamicResource SolutionManagerCurrentSolution}"/>

                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="20,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 名称 -->
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource Name}"/>
                                <Grid Grid.Row="0" Grid.Column="1" Margin="0,12,0,4">
                                    <!-- 查看模式 -->
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding NameViewVisibility}">
                                        <TextBlock Style="{StaticResource FieldValueStyle}"
                                                   Text="{Binding CurrentName}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource AccentBackgroundBrush}"
                                                BorderBrush="{StaticResource PrimaryBrush}"
                                                BorderThickness="1" CornerRadius="3"
                                                Padding="6,2" Margin="0,0,0,0"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelectedLoaded}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{DynamicResource SolutionManagerLoaded}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="11"/>
                                        </Border>
                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                Command="{Binding StartEditNameCommand}"
                                                Content="{DynamicResource Edit}"
                                                Padding="8,3" Margin="8,0,0,0"
                                                FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <!-- 编辑模式 -->
                                    <StackPanel Orientation="Horizontal"
                                                Visibility="{Binding NameEditVisibility}">
                                        <TextBox Style="{StaticResource InputStyle}"
                                                 Text="{Binding EditingName, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="200" Height="40" FontSize="12"
                                                 VerticalContentAlignment="Center"/>
                                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding SaveNameCommand}"
                                                Content="{DynamicResource Save}"
                                                Padding="12,0" Margin="6,0,0,0" Height="32"/>
                                        <Button Style="{StaticResource ToolbarButtonStyle}"
                                                Command="{Binding CancelEditNameCommand}"
                                                Content="{DynamicResource Cancel}"
                                                Padding="12,0" Margin="4,0,0,0" Height="32"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 描述 -->
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource Describe}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Style="{StaticResource FieldValueStyle}"
                                           Text="{Binding CurrentDescription}"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>

                                <!-- 路径 -->
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource FilePath}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Style="{StaticResource FieldValueStyle}"
                                           Text="{Binding CurrentPath}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding CurrentPath}"/>

                                <!-- 修改时间 -->
                                <TextBlock Grid.Row="3" Grid.Column="0"
                                           Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource LastModified}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1"
                                           Style="{StaticResource FieldValueStyle}"
                                           Text="{Binding CurrentModifiedAt, Mode=OneWay, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"/>

                                <!-- 唯一标识 -->
                                <TextBlock Grid.Row="4" Grid.Column="0"
                                           Style="{StaticResource FieldLabelStyle}" Text="{DynamicResource UniqueIdentifier}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1"
                                           Style="{StaticResource FieldValueStyle}"
                                           Text="{Binding CurrentGuid}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="11"
                                           FontFamily="Consolas"/>
                            </Grid>
                        </Border>

                        <!-- 段落：打包的配置项 --><!--
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="解决方案包含的配置项"
                                   Margin="0,20,0,8"/>

                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="20,16">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                                           Margin="0,0,0,12"
                                           Text="以下配置会随解决方案文件一起保存和加载（已加密），切换解决方案时自动还原："/>
                                <WrapPanel>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="📷  相机配置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="🔌  通信配置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="🎮  控制卡" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="⚙️  轴配置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="🔧  IO管理" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="📐  坐标系" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="🔩  固高模块" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="🖥  PLC配置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="📡  传感器" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                    <Border Style="{StaticResource ConfigTagStyle}">
                                        <TextBlock Text="💡  光源控制器" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                                    </Border>
                                </WrapPanel>

                                <Border Margin="0,8,0,0"
                                        Background="#EEF9F2"
                                        BorderBrush="{StaticResource SuccessBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,8">
                                    <TextBlock Foreground="{StaticResource SuccessBrush}" FontSize="12"
                                               Text="🔒  文件格式：AES-256-CBC 加密 + SHA-256 完整性校验，防止未授权修改"/>
                                </Border>
                            </StackPanel>
                        </Border>-->

                        <!-- 段落：使用说明 -->
                        <TextBlock Style="{StaticResource SectionTitleStyle}"
                                   Text="{DynamicResource SolutionManagerOperationInstructions}"
                                   Margin="0,20,0,8"/>
                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="20,14">
                            <StackPanel >
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                           Text="{DynamicResource SolutionManagerInstructionOpenByDoubleClick}"/>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                           Text="{DynamicResource SolutionManagerInstructionSwitchSolution}"/>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                           Text="{DynamicResource SolutionManagerInstructionSaveAs}"/>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                           Text="{DynamicResource SolutionManagerInstructionPortableFile}"/>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                           Text="{DynamicResource SolutionManagerInstructionRecentLimit}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- ══════ B. 新建解决方案表单（IsCreatingNew = true） ══════ -->
                    <StackPanel Visibility="{Binding NewFormVisibility}">

                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{DynamicResource SolutionManagerNewSolution}"/>

                        <Border Background="{StaticResource BgCardBrush}"
                                BorderBrush="{StaticResource PrimaryBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="24,20">
                            <StackPanel>

                                <!-- 名称 -->
                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                           Text="{DynamicResource SolutionManagerSolutionNameRequired}"
                                           Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource InputStyle}"
                                         Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                         Height="36"/>

                                <!-- 描述 -->
                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                           Text="{DynamicResource SolutionManagerDescriptionOptional}"/>
                                <TextBox Style="{StaticResource InputStyle}"
                                         Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Height="72"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         TextWrapping="Wrap"/>

                                <!-- 保存路径 -->
                                <TextBlock Style="{StaticResource FieldLabelStyle}"
                                           Text="{DynamicResource SolutionManagerSavePathRequired}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Style="{StaticResource InputStyle}"
                                             Text="{Binding NewFilePath, UpdateSourceTrigger=PropertyChanged}"
                                             Height="36"
                                             Margin="0,0,8,0"
                                             FontSize="12"
                                             ToolTip="{Binding NewFilePath}"/>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource ToolbarButtonStyle}"
                                            Command="{Binding BrowseNewPathCommand}"
                                            Content="{DynamicResource BrowseEllipsis}"
                                            Height="36" Padding="14,0"/>
                                </Grid>

                                <!-- 提示信息 -->
                                <Border Background="{StaticResource InfoBackgroundBrush}"
                                        BorderBrush="{StaticResource PrimaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        Margin="0,16,0,0">
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                               TextWrapping="Wrap"
                                               Text="{DynamicResource SolutionManagerNewSnapshotTip}"/>
                                </Border>

                                <!-- 操作按钮 -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Margin="0,20,0,0">
                                    <Button Style="{StaticResource ToolbarButtonStyle}"
                                            Command="{Binding CancelNewCommand}"
                                            Content="{DynamicResource Cancel}"
                                            Padding="20,9"/>
                                    <Button Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding ConfirmNewCommand}"
                                            Padding="20,9">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="✓" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource SolutionManagerCreateSolution}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!-- Row 2 · 状态栏                                                 -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                Background="{StaticResource BgCardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,7">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 状态消息 -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"/>
                </StackPanel>

                <!-- 右侧：当前解决方案 + 时间 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource SolutionManagerCurrentLabel}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding CurrentName}"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   FontSize="12" FontWeight="SemiBold"/>
                    </StackPanel>
                    <TextBlock Text="|" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{DynamicResource SolutionManagerModifiedLabel}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding CurrentModifiedAt, Mode=OneWay, StringFormat={}{0:HH:mm:ss}}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>

<UserControl x:Class="ReeYin_V.Config.Views.StyleConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:ReeYin_V.Config.Converters"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             FontSize="{DynamicResource DefaultFontSize}"
             Background="{DynamicResource RegionBackgroundBrush}"
             mc:Ignorable="d"
             d:DesignHeight="880"
             d:DesignWidth="1480">
    <UserControl.Resources>
        <converters:ColorStringToBrushConverter x:Key="ColorStringToBrushConverter" />

        <SolidColorBrush x:Key="StyleConfigPanelBrush" Color="#FAFAFA" />
        <SolidColorBrush x:Key="StyleConfigLineBrush" Color="#D8D8D8" />
        <SolidColorBrush x:Key="StyleConfigMutedTextBrush" Color="#666666" />

        <Style x:Key="StyleConfigButtonStyle" TargetType="Button" BasedOn="{StaticResource GeneralButtonStyle}">
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>

        <Style x:Key="StyleConfigPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource StyleConfigButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="StyleConfigSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{DynamicResource SubTitleFontSize}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="StyleConfigDataGridTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderThickness="0,0,0,2"
                BorderBrush="{DynamicResource PrimaryBrush}"
                Margin="5,5,5,0"
                Padding="0,5,0,5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Name="btnReturn"
                        Margin="5,0,5,0"
                        IsEnabled="{Binding IsEnabled}"
                        Style="{StaticResource GeneralButtonStyle}"
                        Width="Auto"
                        Height="30"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="ReturnMainPage">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="&#xe8a4;"
                                       VerticalAlignment="Center"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       FontFamily="{StaticResource Iconfont}" />
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
                <TextBlock VerticalAlignment="Center" Text="{DynamicResource ReturnMainPage}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="14,12,14,0"
                Padding="12"
                Background="{StaticResource StyleConfigPanelBrush}"
                BorderBrush="{StaticResource StyleConfigLineBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{DynamicResource StyleConfigTheme}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{StaticResource StyleConfigMutedTextBrush}" />
                <ComboBox Grid.Column="1"
                          Height="32"
                          ItemsSource="{Binding Themes}"
                          SelectedItem="{Binding SelectedTheme}"
                          DisplayMemberPath="DisplayName" />
                <TextBox Grid.Column="2"
                         Height="32"
                         Margin="12,0"
                         IsReadOnly="True"
                         VerticalContentAlignment="Center"
                         Text="{Binding CurrentThemeFile, Mode=OneWay}"
                         ToolTip="{Binding CurrentThemeFile}" />
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="{DynamicResource StyleConfigRefresh}"
                            Style="{StaticResource StyleConfigButtonStyle}"
                            Command="{Binding RefreshCommand}" />
                    <Button Content="{DynamicResource StyleConfigOpenFile}"
                            Style="{StaticResource StyleConfigButtonStyle}"
                            Command="{Binding OpenThemeFileCommand}" />
                    <Button Content="{DynamicResource StyleConfigReload}"
                            Style="{StaticResource StyleConfigButtonStyle}"
                            Command="{Binding ReloadCommand}" />
                    <Button Content="{DynamicResource StyleConfigApplyPreview}"
                            Style="{StaticResource StyleConfigButtonStyle}"
                            Command="{Binding ApplyCommand}" />
                    <Button Content="{DynamicResource StyleConfigResetDefaultColors}"
                            Style="{StaticResource StyleConfigButtonStyle}"
                            Command="{Binding ResetDefaultColorsCommand}" />
                    <Button Content="{DynamicResource Save}"
                            Style="{StaticResource StyleConfigPrimaryButtonStyle}"
                            Command="{Binding SaveCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Background="{StaticResource StyleConfigPanelBrush}"
                    BorderBrush="{StaticResource StyleConfigLineBrush}"
                    BorderThickness="1"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource StyleConfigSectionTitleStyle}">
                        <Run Text="{DynamicResource StyleConfigColorResources}" />
                        <Run Text=" (" />
                        <Run Text="{Binding ColorCount, Mode=OneWay}" />
                        <Run Text=")" />
                    </TextBlock>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Colors}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{DynamicResource StyleConfigColorPicker}" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <ToggleButton x:Name="ColorToggle"
                                                          Width="42"
                                                          Height="24"
                                                          HorizontalAlignment="Center"
                                                          Background="Transparent"
                                                          BorderBrush="{StaticResource StyleConfigLineBrush}"
                                                          BorderThickness="1">
                                                <Border Margin="3"
                                                        BorderBrush="#909090"
                                                        BorderThickness="1"
                                                        Background="{Binding Value, Converter={StaticResource ColorStringToBrushConverter}}" />
                                            </ToggleButton>
                                            <Popup Placement="Bottom"
                                                   PlacementTarget="{Binding ElementName=ColorToggle}"
                                                   IsOpen="{Binding IsChecked, ElementName=ColorToggle}"
                                                   StaysOpen="False"
                                                   AllowsTransparency="True"
                                                   DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <Border Background="{StaticResource StyleConfigPanelBrush}"
                                                        BorderBrush="{StaticResource StyleConfigLineBrush}"
                                                        BorderThickness="1"
                                                        Padding="8">
                                                    <hc:ColorPicker SelectedBrush="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource ColorStringToBrushConverter}}" />
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource StyleConfigResourceKey}"
                                                Width="190"
                                                Binding="{Binding Key}"
                                                ElementStyle="{StaticResource StyleConfigDataGridTextStyle}"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="{DynamicResource Describe}"
                                                Width="170"
                                                Binding="{Binding Description}"
                                                ElementStyle="{StaticResource StyleConfigDataGridTextStyle}"
                                                IsReadOnly="True" />
                            <DataGridTemplateColumn Header="{DynamicResource StyleConfigColorPreview}" Width="112">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,2">
                                            <Border Height="22"
                                                    BorderBrush="{StaticResource StyleConfigLineBrush}"
                                                    BorderThickness="1"
                                                    Background="{Binding Value, Converter={StaticResource ColorStringToBrushConverter}}" />
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource StyleConfigValue}"
                                                Width="130"
                                                Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="{DynamicResource Error}"
                                                Width="*"
                                                Binding="{Binding Error}"
                                                ElementStyle="{StaticResource StyleConfigDataGridTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="0"
                    Grid.Column="2"
                    Background="{StaticResource StyleConfigPanelBrush}"
                    BorderBrush="{StaticResource StyleConfigLineBrush}"
                    BorderThickness="1"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Style="{StaticResource StyleConfigSectionTitleStyle}">
                        <Run Text="{DynamicResource StyleConfigFontSizeResources}" />
                        <Run Text=" (" />
                        <Run Text="{Binding FontSizeCount, Mode=OneWay}" />
                        <Run Text=")" />
                    </TextBlock>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FontSizes}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{DynamicResource StyleConfigResourceKey}"
                                                Width="170"
                                                Binding="{Binding Key}"
                                                ElementStyle="{StaticResource StyleConfigDataGridTextStyle}"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="{DynamicResource Describe}"
                                                Width="145"
                                                Binding="{Binding Description}"
                                                ElementStyle="{StaticResource StyleConfigDataGridTextStyle}"
                                                IsReadOnly="True" />
                            <DataGridTextColumn Header="{DynamicResource StyleConfigValue}"
                                                Width="80"
                                                Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTextColumn Header="{DynamicResource Error}"
                                                Width="*"
                                                Binding="{Binding Error}"
                                                ElementStyle="{StaticResource StyleConfigDataGridTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Background="{DynamicResource MainBackgroundBrush}"
                    BorderBrush="{StaticResource StyleConfigLineBrush}"
                    BorderThickness="1"
                    Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Preview}"
                                   FontSize="{DynamicResource HeaderFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" />
                        <TextBlock Text="{DynamicResource StyleConfigPreviewDescription}"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="{DynamicResource DefaultFontSize}" />
                        <TextBlock Text="{Binding ThemeDirectory}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource StyleConfigMutedTextBrush}"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="44"
                                Height="28"
                                Margin="0,0,8,0"
                                Background="{DynamicResource PrimaryBrush}"
                                BorderBrush="{StaticResource StyleConfigLineBrush}"
                                BorderThickness="1" />
                        <Button Content="{DynamicResource StyleConfigSampleButton}"
                                Height="32"
                                Padding="18,0"
                                Background="{DynamicResource PrimaryBrush}"
                                BorderBrush="{DynamicResource PrimaryBrush}"
                                Foreground="White"
                                FontSize="{DynamicResource DefaultFontSize}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                Padding="14,8"
                Background="{StaticResource StyleConfigPanelBrush}"
                BorderBrush="{StaticResource StyleConfigLineBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource StyleConfigMutedTextBrush}" />
                <TextBlock HorizontalAlignment="Right"
                           Foreground="{StaticResource StyleConfigMutedTextBrush}">
                    <Run Text="{DynamicResource StyleConfigUnsavedChangesLabel}" />
                    <Run Text="{Binding HasChanges, Mode=OneWay}" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="ReeYin_V.Config.Views.HardwareConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ReeYin_V.Config.Views"
             mc:Ignorable="d"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             FontSize="14" Background="White"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1480">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border BorderThickness="0 0 0 2" BorderBrush="{DynamicResource PrimaryBrush}" Margin="5 5 5 0" Padding="0 5 0 5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Name="btnLogin" Margin="5 0 5 0" IsEnabled="{Binding IsEnabled}" Content="{Binding}"
                        Style="{StaticResource GeneralButtonStyle}" Width="auto" Height="30"
                        Command="{Binding GeneralCommand}" CommandParameter="返回主页面">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <TextBlock Text="&#xe8a4;" VerticalAlignment="Center" FontSize="24"
                                       HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
                <TextBlock VerticalAlignment="Center" Text="返回设计页面"/>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.15*" MinWidth="150" MaxWidth="200"/>
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左侧硬件列表 -->
            <ListBox Background="Transparent" Foreground="{DynamicResource PrimaryBrush}"
                     BorderThickness="0"
                     ItemsSource="{Binding ConfigItems}"
                     SelectedItem="{Binding CurSltHardware, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     SelectedIndex="0">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换页面"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="5">
                            <TextBlock Text="{Binding Icon}" FontSize="18" FontWeight="Bold"
                                       FontFamily="{StaticResource Iconfont}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Title}" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Column="1" Background="{DynamicResource PrimaryBrush}" HorizontalAlignment="Stretch"/>

            <!-- 右侧内容区域 -->
            <ContentControl Grid.Column="2"
                            prism:RegionManager.RegionName="HardwareRegion"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="ReeYin_V.Config.Views.ConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:local="clr-namespace:ReeYin_V.Config.Views"
             xmlns:prism="http://prismlibrary.com/" 
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             prism:ViewModelLocator.AutoWireViewModel="True"
             xmlns:enums="clr-namespace:ReeYin_V.Core.Enums;assembly=ReeYin_V.Core"
             mc:Ignorable="d"
             Width="800" Height="450" Background="{DynamicResource ExpanderPanelBackgroundBrush}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="languageType" MethodName="GetNames" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:LanguageType"/>
                <x:Type TypeName="enums:ThemeType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.3*" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <ListBox Width="100" ItemsSource="{Binding Items}" Background="Transparent" Foreground="{DynamicResource PrimaryBrush}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <GridSplitter Grid.Column="1" Background="{DynamicResource BackgroudBrush}" HorizontalAlignment="Stretch"/>
        <TabControl Grid.Column="2" Background="Transparent" >
            <TabControl.ItemContainerStyle>
                <Style TargetType="{x:Type TabItem}">
                    <Setter Property="Visibility" Value="Collapsed" />
                </Style>
            </TabControl.ItemContainerStyle>
            <TabItem Header="General"  Style="{StaticResource TabItemExWithUnderLineStyle}">
                <StackPanel Orientation="Vertical">
                    <WxGroupBox:WxGroupBox Header="语言设置">
                        <DockPanel>
                            <Button Content="打开" Command="{Binding SetLanguageCommand}"/>
                        </DockPanel>
                    </WxGroupBox:WxGroupBox>
                    <WxGroupBox:WxGroupBox Header="样式设置">
                        <DockPanel>


                            <Button Content="打开" Command="{Binding SetThemeCommand}"/> 
                        </DockPanel>

                    </WxGroupBox:WxGroupBox>
                </StackPanel>

            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

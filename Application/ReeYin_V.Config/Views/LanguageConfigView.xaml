<UserControl x:Class="ReeYin_V.Config.Views.LanguageConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ReeYin_V.Config.Views"
             mc:Ignorable="d"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             FontSize="14" Background="White"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1480">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部导航栏 -->
        <Border BorderThickness="0 0 0 5" BorderBrush="{DynamicResource PrimaryBrush}" Margin="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Name="btnReturn" Margin="5 0 5 0" IsEnabled="{Binding IsEnabled}"
                        Style="{StaticResource GeneralButtonStyle}" Width="auto" Height="30"
                        Command="{Binding GeneralCommand}" CommandParameter="返回主页面">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="&#xe8a4;" VerticalAlignment="Center" FontSize="26"
                                           HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>

                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Run Text="{DynamicResource ReturnMainPage}"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.15*" MinWidth="150"/>
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid >
                <!-- 左侧语言选项列表 -->
                <ListBox Background="Transparent" Foreground="{DynamicResource PrimaryBrush}"
                     BorderThickness="0" MinWidth="150" MaxWidth="200"
                     ItemsSource="{Binding LanguageItems}"
                     SelectedItem="{Binding CurrentLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     SelectedIndex="0">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectionChanged">
                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换语言"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="5">
                                <TextBlock Text="{Binding Icon}" FontSize="20" FontWeight="Bold"
                                       FontFamily="{StaticResource Iconfont}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding DisplayName}" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 操作按钮 -->
                <WxGroupBox:WxGroupBox Header="{DynamicResource Operation}" Margin="0,0,0,20" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="20">
                        <Button Content="{DynamicResource ApplyThisLanguage}" Width="120" Height="40" Margin="10"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Command="{Binding GeneralCommand}" CommandParameter="应用语言"
                                    />

                        <Button Content="{DynamicResource ResetToDefault}" Width="120" Height="40" Margin="10"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Command="{Binding GeneralCommand}" CommandParameter="重置语言"/>

                        <Button Content="{DynamicResource RefreshTheLanguagePack}" Width="120" Height="40" Margin="10"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Command="{Binding GeneralCommand}" CommandParameter="刷新语言"/>
                    </StackPanel>
                </WxGroupBox:WxGroupBox>
            </Grid>


            <GridSplitter Grid.Column="1" Background="{DynamicResource PrimaryBrush}" HorizontalAlignment="Stretch"/>

            <!-- 右侧语言详情和设置 -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <!-- 语言信息卡片 -->
                        <WxGroupBox:WxGroupBox Header="{DynamicResource LanguageInfo}" Margin="0,0,0,20" HorizontalAlignment="Stretch" Width="400">
                            <Grid Margin="20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 语言名称 -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource LanguageName}"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="0,10"/>
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="{Binding CurrentLanguage.DisplayName}"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,10"/>

                                <!-- 语言代码 -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource LanguageCode}"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="0,10"/>
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                       Text="{Binding CurrentLanguage.LanguageCode}"
                                       FontSize="16" VerticalAlignment="Center" Margin="0,10"/>

                                <!-- 描述 -->
                                <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="Bold" VerticalAlignment="Top" Margin="0,10">
                                    <Run Text="{DynamicResource Describe}"/>
                                    <Run Text=":"/>
                                </TextBlock>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                       Text="{Binding CurrentLanguage.Description}"
                                       TextWrapping="Wrap" FontSize="14" VerticalAlignment="Center" Margin="0,10"/>

                                <!-- 状态 -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource Status}"
                                       FontWeight="Bold" VerticalAlignment="Center" Margin="0,10"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,10">
                                    <Ellipse Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="Gray"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentLanguage.IsActive}" Value="True">
                                                        <Setter Property="Fill" Value="Green"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="未激活"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CurrentLanguage.IsActive}" Value="True">
                                                        <Setter Property="Text" Value="当前使用"/>
                                                        <Setter Property="Foreground" Value="Green"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </WxGroupBox:WxGroupBox>

                        <!-- 语言预览 -->
                        <WxGroupBox:WxGroupBox Header="{DynamicResource InterfacePreview}" Margin="0,0,0,20" Width="400">
                            <StackPanel Margin="20">
                                <TextBlock FontWeight="Bold" Margin="0,0,0,15">
                                    <Run Text="{DynamicResource CommonInterfaceTextPreview}"/>
                                    <Run Text=":"/>
                                </TextBlock>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,5">
                                        <Run Text="{DynamicResource OK}"/>
                                        <Run Text="："/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentLanguage.SampleTexts.Confirm}" Margin="0,5"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,5">
                                        <Run Text="{DynamicResource Cancel}"/>
                                        <Run Text="："/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentLanguage.SampleTexts.Cancel}" Margin="0,5"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,5">
                                        <Run Text="{DynamicResource Save}"/>
                                        <Run Text="："/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurrentLanguage.SampleTexts.Save}" Margin="0,5"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,5">
                                       <Run Text="{DynamicResource Delete}"/>
                                       <Run Text="："/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurrentLanguage.SampleTexts.Delete}" Margin="0,5"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,5">
                                       <Run Text="{DynamicResource settings}"/>
                                       <Run Text="："/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding CurrentLanguage.SampleTexts.Settings}" Margin="0,5"/>
                                </Grid>
                            </StackPanel>
                        </WxGroupBox:WxGroupBox>
                    </StackPanel>

                    <!-- 外部语言包加载 -->
                    <WxGroupBox:WxGroupBox Header="{DynamicResource ExternalLanguagePackage}" Margin="0,0,0,20">
                        <StackPanel Margin="20">
                            <TextBlock Text="{DynamicResource LoadLanguagePackFromAnExternalFolder}" FontWeight="Bold" Margin="0,0,0,15"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0" Height="35" VerticalContentAlignment="Center"
                                         Text="{Binding ExternalLanguagePackPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsReadOnly="True" Margin="0,0,10,0"
                                         Background="#F5F5F5" BorderBrush="{DynamicResource PrimaryBrush}"/>

                                <Button Grid.Column="1" Content="{DynamicResource SelectFolder}" Width="120" Height="35"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="选择语言包文件夹"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                <Button Content="{DynamicResource ScanTheLanguagePackage}" Width="120" Height="35" Margin="0,0,10,0"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="扫描语言包"
                                        IsEnabled="{Binding HasExternalPath}"/>

                                <Button Content="{DynamicResource LoadSelectedLanguagePackage}" Width="140" Height="35"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="加载外部语言包"
                                        IsEnabled="{Binding HasScannedPacks}"/>
                            </StackPanel>

                            <!-- 扫描结果列表 -->
                            <Border BorderThickness="1" BorderBrush="{DynamicResource PrimaryBrush}"
                                    Margin="0,15,0,0" Padding="10" Background="#FAFAFA"
                                    Visibility="{Binding HasScannedPacks, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource TheDiscoveredLanguagePackage}" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <ListBox ItemsSource="{Binding ScannedLanguagePacks}"
                                             SelectedItem="{Binding SelectedExternalPack, Mode=TwoWay}"
                                             MaxHeight="200" Background="White" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="📦" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                                    <StackPanel>
                                                        <TextBlock FontWeight="Bold">
                                                            <Run Text="{Binding Name, Mode=OneWay}"/>
                                                            <Run Text=" (" Foreground="Gray"/>
                                                            <Run Text="{Binding Code, Mode=OneWay}" Foreground="Gray"/>
                                                            <Run Text=")" Foreground="Gray"/>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="Gray"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </WxGroupBox:WxGroupBox>

                    <!-- 语言包信息 -->
                    <WxGroupBox:WxGroupBox Header="{DynamicResource LanguagePackageInformation}" Margin="0,0,0,20">
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0"  FontWeight="Bold" Margin="0,10">
                                <Run Text="{DynamicResource Versions}"/>
                                <Run Text="："/>
                            </TextBlock>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentLanguage.Version}" Margin="0,10"/>

                            <TextBlock Grid.Row="0" Grid.Column="0"  FontWeight="Bold" Margin="0,10">
                                <Run Text="{DynamicResource Versions}"/>
                                <Run Text="："/>
                            </TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="0" FontWeight="Bold" Margin="0,10">
                                <Run Text="{DynamicResource DateUpdated}"/>
                                <Run Text="："/>
                            </TextBlock>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrentLanguage.LastUpdated, StringFormat='yyyy-MM-dd'}" Margin="0,10"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" FontWeight="Bold" Margin="0,10">
                                <Run Text="{DynamicResource TranslationCompletionRate}"/>
                                <Run Text="："/>
                            </TextBlock>
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,10">
                                <ProgressBar Width="200" Height="20" Value="{Binding CurrentLanguage.CompletionRate}"
                                             Maximum="100" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentLanguage.CompletionRate, StringFormat={}{0:F1}%}"
                                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </WxGroupBox:WxGroupBox>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

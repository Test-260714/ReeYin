<UserControl x:Class="ReeYin_V.UserManager.Views.RoleManageView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ReeYin_V.UserManager.Views"
      mc:Ignorable="d" 
      Width="1000" Height="600"
      d:DesignHeight="450" d:DesignWidth="800"
      >

    <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="0.2*"></RowDefinition>
                <RowDefinition Height="0.2*"></RowDefinition>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <DataGrid  AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}" Margin="20"
                    EnableColumnVirtualization="True" EnableRowVirtualization="False"  VirtualizingPanel.IsVirtualizing="True" ItemsSource="{Binding RoleManagementModel.AllRole}" 
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"  FontSize="12"  RowHeaderWidth="20" SelectionUnit="FullRow" HeadersVisibility="Column"
                    GridLinesVisibility="All" IsReadOnly="False" CanUserAddRows="False" >
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="角色名称" IsReadOnly="True" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding RoleName}" ToolTip="{Binding RoleName}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="权限等级" IsReadOnly="True" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding PermissionID,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding PermissionID}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="操作" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Button
                                    Name="btnModify"
                                    Width="54"
                                    Height="28"
                                    Padding="1"
                                    Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="修改" />
                                        <Button
                                    Name="btnDelete"
                                    Width="54"
                                    Height="28"
                                    Margin="20,0,0,0"
                                    Padding="1"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Content="删除" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Row="1" Margin="20,0,20,0" Background="#F7F7F7" CornerRadius="4">
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid Grid.Column="0" Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="角色名称  " VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                        <TextBox Text="{Binding RoleName}" Width="100"  Height="35"   HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="1" ></TextBox>
                    </Grid>

                    <Grid Grid.Column="1" Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="权限等级  " VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                        <ComboBox ItemsSource="{Binding PermissionIDSource}" Text="{Binding PermissionID}" Width="100"  Height="35"   HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="1" ></ComboBox>
                    </Grid>

                    <Grid Grid.Column="2" Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="  " VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                        <Button Width="100" Height="35" HorizontalAlignment="Left" Command="{Binding GeneralRoleCommand}" CommandParameter="添加角色" Content="添加角色" Grid.Column="1" Style="{StaticResource GeneralButtonStyle}"/>
                    </Grid>
                </Grid>
            </Border>

    

        </Grid>
    </Border>
</UserControl>

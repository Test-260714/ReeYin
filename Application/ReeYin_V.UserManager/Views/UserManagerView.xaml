<UserControl x:Class="ReeYin_V.UserManager.Views.UserManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin_V.UserManager.Views"
             xmlns:conv="clr-namespace:ReeYin_V.UserManager.Converters"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             Height="720" Width="1200"
             d:DesignHeight="720" d:DesignWidth="1200">

    <UserControl.Resources>
        <conv:RoleIdToRoleNameConverter  x:Key="RoleIdToRoleNameConverter" />
    </UserControl.Resources>


    <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <Grid Grid.Column="0" Grid.Row="0">
                <Button Width="120" Height="40" Content="权限管理"  Margin="20,0,20,0" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="权限管理" VerticalAlignment="Center"  HorizontalAlignment="Left"/>
                <Button Width="120" Height="40" Content="角色管理"  Margin="0,0,20,0" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="角色管理" VerticalAlignment="Center"  HorizontalAlignment="Right"/>
            </Grid>

            <Grid Grid.Row="1">
                <DataGrid  AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}" Margin="20,0,20,20"
                 EnableColumnVirtualization="True" EnableRowVirtualization="False"  VirtualizingPanel.IsVirtualizing="True" ItemsSource="{Binding ModelParam.AllUser}" 
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"  FontSize="12"  RowHeaderWidth="20" SelectionUnit="FullRow" HeadersVisibility="Column"
                 GridLinesVisibility="All" CanUserAddRows="False" IsReadOnly="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="用户名" IsReadOnly="True" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Username,Mode=TwoWay}" ToolTip="{Binding Username}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="密码" IsReadOnly="true" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <hc:PasswordBox IsSafeEnabled="False"  UnsafePassword ="{Binding PasswordHash,Mode=TwoWay}"  HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"  IsHitTestVisible="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="卡号" IsReadOnly="true" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <hc:PasswordBox IsSafeEnabled="False"  UnsafePassword ="{Binding CardNo,Mode=TwoWay}"  HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"  IsHitTestVisible="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="角色名称" IsReadOnly="True" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding RoleId,Converter={StaticResource RoleIdToRoleNameConverter},Mode=TwoWay}" ToolTip="{Binding RoleId}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True">
                                    </TextBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="状态" IsReadOnly="True" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ToggleButton Style="{StaticResource ToggleButtonSwitch}"  Width="auto" HorizontalAlignment="Center" FontSize="16" 
                                    IsChecked="{Binding Status,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsHitTestVisible="False"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="操作" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <Button
                                             Name="btnModify"
                                             Width="54"
                                             Height="28"
                                             Padding="1"
                                             Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                             CommandParameter="{Binding}"
                                             Content="修改" />
                                        <Button
                                             Name="btnDelete"
                                             Width="54"
                                             Height="28"
                                             Margin="20,0,0,0"
                                             Padding="1"
                                             Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=DataGrid}}"
                                             CommandParameter="{Binding}"
                                             Content="删除" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>


            <Border Grid.Row="2" Margin="20,0,20,20" Background="#F7F7F7" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Grid >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="用户名  " VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                        <TextBox Text="{Binding UserName}" Width="100"  Height="35"   HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="1" ></TextBox>
                    </Grid>

                    <Grid Grid.Row="0" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="密码  " VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                        <hc:PasswordBox IsSafeEnabled="False" UnsafePassword ="{Binding PasswordHash}" Width="100" Height="35"  HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="1" ></hc:PasswordBox>
                    </Grid>

                    <Grid Grid.Row="0" Grid.Column="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="角色名称  " VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                        <ComboBox Text="{Binding UserRoleName}" ItemsSource ="{Binding AllRoleName}" Width="100"  Height="35"  HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="1" ></ComboBox>
                    </Grid>

                    <Grid Grid.Row="1" Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="状态  " VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                        <ToggleButton Style="{StaticResource ToggleButtonSwitch}"  Width="auto" FontSize="16" 
                          IsChecked="{Binding Status}" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="1"/>
                    </Grid>

                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="  " VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                        <Button Width="100" Height="35" HorizontalAlignment="Left" Command="{Binding GeneralCommand}" CommandParameter="添加用户" Content="添加用户" Grid.Column="1" Style="{StaticResource GeneralButtonStyle}"/>
                    </Grid>

                    <Grid Grid.Row="0" Grid.Column="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="卡号  " VerticalAlignment="Center" HorizontalAlignment="Right"></TextBlock>
                        <TextBox Text="{Binding CardNo}" Width="100"  Height="35"   HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="1" ></TextBox>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>

<UserControl x:Class="ReeYin_V.UserManager.Views.EditUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin_V.UserManager.Views"
             xmlns:conv="clr-namespace:ReeYin_V.UserManager.Converters"
             mc:Ignorable="d" 
             Width="400" Height="550">

    <UserControl.Resources>
        <conv:RoleIdToRoleNameConverter  x:Key="RoleIdToRoleNameConverter" />
    </UserControl.Resources>

    <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="60"></RowDefinition>
            </Grid.RowDefinitions>
            <Border Margin="20" Background="#F7F7F7" CornerRadius="4">
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.65*"></ColumnDefinition>
                        <ColumnDefinition Width="10"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="用户名" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="0" Grid.Column="0" />
                    <TextBox IsEnabled="{Binding IsEnable}" Text="{Binding CopyCurrentUser.Username}" Grid.Row="0" Grid.Column="2" Width="100" Height="35" HorizontalAlignment="Left"></TextBox>
                    <TextBlock Text="密码" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" />
                    <TextBox Grid.Row="1" Text="{Binding CopyCurrentUser.PasswordHash}" Grid.Column="2" Width="100" Height="35" HorizontalAlignment="Left"></TextBox>
                    <TextBlock Text="卡号" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" />
                    <TextBox Grid.Row="2" Text="{Binding CopyCurrentUser.CardNo}" Grid.Column="2" Width="100" Height="35" HorizontalAlignment="Left"></TextBox>
                    <TextBlock Text="角色名称" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" />
                    <ComboBox IsEnabled="{Binding IsEnable}"  SelectedItem="{Binding CopyCurrentUser.RoleId,Converter={StaticResource RoleIdToRoleNameConverter},Mode=TwoWay}" ItemsSource="{Binding AllRoleName}"  Grid.Row="3" Grid.Column="2" Width="100" Height="35" HorizontalAlignment="Left"></ComboBox>
                    <TextBlock  Text="状态" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="4" Grid.Column="0" />
                    <ToggleButton IsEnabled="{Binding IsEnable}" Grid.Column="2" Grid.Row="4" Style="{StaticResource ToggleButtonSwitch}"  Width="auto" HorizontalAlignment="Left" FontSize="16" 
                 IsChecked="{Binding CopyCurrentUser.Status}" />
                </Grid>
            </Border>
            <StackPanel Grid.Row="1"  HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                       WindowChrome.IsHitTestVisibleInChrome="True">

                <Button Margin="0,0,15,0" FontSize="18"
                           Command="{Binding GeneralCommand}" CommandParameter="取消"
                           Height="35" Width="80"
                           Style="{StaticResource GeneralButtonStyle}"
                           Content="取消"
                           Cursor="Hand"/>
                <Button  Margin="0,0,15,0" FontSize="18"
                           Command="{Binding GeneralCommand}" CommandParameter="确认"
                           Style="{StaticResource GeneralButtonStyle}"
                           Height="35" Width="80"
                           Content="确认"
                           Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

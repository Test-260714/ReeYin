<UserControl x:Class="ReeYin_V.UserManager.Views.RoleModificationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin_V.UserManager.Views"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             Width="400" Height="550">
    <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="1">
        <Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition Height="60"></RowDefinition>
                </Grid.RowDefinitions>


                <Border Margin="20" Background="#F7F7F7" CornerRadius="4" Grid.Column="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.65*"></ColumnDefinition>
                            <ColumnDefinition Width="10"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                            <RowDefinition></RowDefinition>
                        </Grid.RowDefinitions>
                        <TextBlock Text="角色名称" HorizontalAlignment="Right" VerticalAlignment="Center"></TextBlock>
                        <TextBox IsEnabled="{Binding IsEnable}"  Text="{Binding CopyCurrentRole.RoleName}"  Grid.Column="2" Width="100"  Height="35" HorizontalAlignment="Left" VerticalAlignment="Center"></TextBox>
                        <TextBlock Text="权限等级" HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Row="1" Grid.Column="0"></TextBlock>
                        <ComboBox IsEnabled="{Binding IsEnable}" ItemsSource="{Binding AllPermissionId}" Text="{Binding CopyCurrentRole.PermissionID}" Grid.Column="2"  Grid.Row="1" Width="100"  Height="35" HorizontalAlignment="Left" VerticalAlignment="Center"></ComboBox>

                    </Grid>
                </Border>

                <Border Grid.Row="1" CornerRadius="4" >
                    <StackPanel  HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                       WindowChrome.IsHitTestVisibleInChrome="True">

                        <Button Margin="0,0,15,0" FontSize="18"
                           Command="{Binding GeneralRoleCommand}" CommandParameter="取消"
                           Height="35" Width="80"
                           Style="{StaticResource GeneralButtonStyle}"
                           Content="取消"
                           Cursor="Hand"/>
                        <Button  Margin="0,0,15,0" FontSize="18"
                           Command="{Binding GeneralRoleCommand}" CommandParameter="确认"
                           Style="{StaticResource GeneralButtonStyle}"
                           Height="35" Width="80"
                           Content="确认"
                           Cursor="Hand"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>

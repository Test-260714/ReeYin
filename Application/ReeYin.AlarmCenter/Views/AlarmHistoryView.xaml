<UserControl x:Class="ReeYin.AlarmCenter.Views.AlarmHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:ReeYin.AlarmCenter.Models"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="False"
             d:DesignHeight="760"
             d:DesignWidth="1500"
             FontSize="12"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin.AlarmCenter;component/Styles/AlarmWorkbenchResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="HistoryJournalLayout" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Margin="0,0,0,14" Style="{StaticResource AlarmCommandBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AlarmPrimaryBrush}"
                               Text="JOURNAL SEARCH" />
                    <TextBlock Margin="0,5,0,0"
                               Style="{StaticResource SectionTitleStyle}"
                               Text="历史报警查询" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource MutedTextStyle}"
                               Text="按时间、等级、来源与关键字检索报警履历，筛选区和分页控制始终固定在表格外。" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Margin="24,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource MutedTextStyle}"
                           Text="{Binding HistoryResultText}" />
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="0,0,0,14" Style="{StaticResource QueryBarStyle}">
            <WrapPanel>
                <StackPanel Width="148" Margin="0,0,14,10">
                    <TextBlock Style="{StaticResource SmallLabelStyle}" Text="开始时间" />
                    <DatePicker Height="32" SelectedDate="{Binding FilterStartDate}" />
                </StackPanel>
                <StackPanel Width="148" Margin="0,0,14,10">
                    <TextBlock Style="{StaticResource SmallLabelStyle}" Text="结束时间" />
                    <DatePicker Height="32" SelectedDate="{Binding FilterEndDate}" />
                </StackPanel>
                <StackPanel Width="150" Margin="0,0,14,10">
                    <TextBlock Style="{StaticResource SmallLabelStyle}" Text="报警等级" />
                    <ComboBox Height="32"
                              DisplayMemberPath="Label"
                              ItemsSource="{Binding LevelOptions}"
                              SelectedValue="{Binding SelectedHistoryLevel}"
                              SelectedValuePath="Value" />
                </StackPanel>
                <StackPanel Width="180" Margin="0,0,14,10">
                    <TextBlock Style="{StaticResource SmallLabelStyle}" Text="报警来源" />
                    <ComboBox Height="32"
                              DisplayMemberPath="Label"
                              ItemsSource="{Binding SourceOptions}"
                              SelectedValue="{Binding SelectedHistorySource}"
                              SelectedValuePath="Value" />
                </StackPanel>
                <StackPanel Width="280" Margin="0,0,14,10">
                    <TextBlock Style="{StaticResource SmallLabelStyle}" Text="关键字" />
                    <TextBox Height="32"
                             VerticalContentAlignment="Center"
                             Text="{Binding HistoryKeyword, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Margin="0,18,0,10" Orientation="Horizontal">
                    <Button Margin="0,0,8,0"
                            Command="{Binding ApplyHistoryFilterCommand}"
                            Content="查询"
                            Style="{StaticResource AlarmPrimaryButtonStyle}" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding ResetHistoryFilterCommand}"
                            Content="重置"
                            Style="{StaticResource AlarmSecondaryButtonStyle}" />
                    <Button Margin="0,0,8,0"
                            Command="{Binding ExportCsvCommand}"
                            Content="CSV"
                            Style="{StaticResource AlarmSecondaryButtonStyle}" />
                    <Button Command="{Binding ExportExcelCommand}"
                            Content="Excel"
                            Style="{StaticResource AlarmSecondaryButtonStyle}" />
                </StackPanel>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Padding="0" Style="{StaticResource AlarmContentCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="18,16" BorderBrush="{StaticResource AlarmBorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding HistoryPagerText}" />
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="历史报警记录" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="当前筛选条件下的报警履历明细，表格区域独立滚动。" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <DataGrid Grid.Row="1"
                          Margin="12"
                          AlternatingRowBackground="{StaticResource AlarmAlternateRowBrush}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CellStyle="{StaticResource FlatCellStyle}"
                          ColumnHeaderStyle="{StaticResource FlatColumnHeaderStyle}"
                          EnableColumnVirtualization="True"
                          EnableRowVirtualization="True"
                          IsReadOnly="True"
                          ItemsSource="{Binding HistoryAlarms}"
                          RowStyle="{StaticResource FlatRowStyle}"
                          ScrollViewer.CanContentScroll="True"
                          Style="{StaticResource AlarmDataGridStyle}"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.ScrollUnit="Pixel">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="等级" Width="84">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:AlarmHistoryItem}">
                                    <Border Padding="8,4"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{Binding LevelBadgeBrush}"
                                            CornerRadius="12">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource AlarmOnAccentBrush}"
                                                   Text="{Binding LevelText}"
                                                   TextAlignment="Center" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Binding="{Binding Source}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="来源" Width="110" />
                        <DataGridTextColumn Binding="{Binding Location}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="位置" Width="110" />
                        <DataGridTextColumn Binding="{Binding Code}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="编码" Width="90" />
                        <DataGridTextColumn Binding="{Binding Title}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="报警项" Width="150" />
                        <DataGridTextColumn Binding="{Binding RaisedAtText}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="发生时间" Width="150" />
                        <DataGridTextColumn Binding="{Binding ClearedAtText}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="解除时间" Width="150" />
                        <DataGridTextColumn Binding="{Binding DurationText}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="持续时长" Width="90" />
                        <DataGridTextColumn Binding="{Binding OccurrenceCount}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="次数" Width="60" />
                        <DataGridTextColumn Binding="{Binding ConfirmText}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="确认状态" Width="100" />
                        <DataGridTextColumn Binding="{Binding Message}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="报警信息" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="0,12,0,0" Style="{StaticResource AlarmContentCardStyle}">
            <DockPanel LastChildFill="False">
                <TextBlock VerticalAlignment="Center"
                           Style="{StaticResource MutedTextStyle}"
                           Text="{Binding HistoryResultText}" />
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding PreviousPageCommand}"
                            Content="上一页"
                            Style="{StaticResource AlarmSecondaryButtonStyle}" />
                    <TextBlock Margin="14,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AlarmTextBrush}"
                               Text="{Binding HistoryPagerText}" />
                    <Button Command="{Binding NextPageCommand}"
                            Content="下一页"
                            Style="{StaticResource AlarmSecondaryButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

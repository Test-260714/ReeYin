<UserControl x:Class="ReeYin.AlarmCenter.Views.AlarmRealtimeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:ReeYin.AlarmCenter.Models"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="False"
             d:DesignHeight="760"
             d:DesignWidth="1500"
             FontSize="12"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin.AlarmCenter;component/Styles/AlarmWorkbenchResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RealtimeTriageGrid" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="0,0,0,14" Style="{StaticResource AlarmCommandBarStyle}">
            <StackPanel>
                <TextBlock FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AlarmPrimaryBrush}"
                           Text="REALTIME TRIAGE" />
                <Border Margin="0,8,0,0"
                        Padding="10,7"
                        Background="{StaticResource AlarmPrimarySoftBrush}"
                        CornerRadius="12">
                    <TextBlock Style="{StaticResource AlarmPageIntroTextStyle}"
                               Text="查看当前活动报警、报警详情与实时事件流。" />
                </Border>
                <TextBlock Margin="0,10,0,0"
                           Style="{StaticResource SectionTitleStyle}"
                           Text="实时报警监控" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           Text="默认只刷新活动报警和实时事件，确认或清除后延迟同步，降低进入页面时的阻塞。" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch">
            <TabItem Header="当前活动报警">
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="340" />
                    </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="0" Style="{StaticResource AlarmContentCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="18,16" BorderBrush="{StaticResource AlarmBorderBrush}" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right"
                                            MinWidth="180"
                                            VerticalAlignment="Center">
                                    <TextBlock HorizontalAlignment="Right"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding ActiveAlarmViewCountText}" />
                                    <ListBox Margin="0,6,0,0"
                                             MinWidth="244"
                                             Padding="2"
                                             Background="{StaticResource AlarmPrimarySoftBrush}"
                                             BorderBrush="{StaticResource AlarmBorderBrush}"
                                             BorderThickness="1"
                                             DisplayMemberPath="Label"
                                             ItemsSource="{Binding ActiveAlarmViewOptions}"
                                             SelectedValue="{Binding SelectedActiveAlarmView, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             SelectedValuePath="Value">
                                        <ListBox.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ListBox.ItemsPanel>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Margin" Value="2" />
                                                <Setter Property="Padding" Value="12,6" />
                                                <Setter Property="MinWidth" Value="72" />
                                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                                <Setter Property="Foreground" Value="{StaticResource AlarmPrimaryBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="RootBorder"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    Background="Transparent"
                                                                    CornerRadius="9">
                                                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource RegionBackgroundBrush}" />
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource PrimaryBrush}" />
                                                                    <Setter Property="Foreground" Value="{StaticResource AlarmOnAccentBrush}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{Binding ActiveAlarmListTitle}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding ActiveAlarmListDescription}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  Margin="12"
                                  AlternatingRowBackground="{StaticResource AlarmAlternateRowBrush}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CellStyle="{StaticResource FlatCellStyle}"
                                  ColumnHeaderStyle="{StaticResource FlatColumnHeaderStyle}"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding ActiveAlarms}"
                                  RowStyle="{StaticResource FlatRowStyle}"
                                  ScrollViewer.CanContentScroll="True"
                                  SelectedItem="{Binding SelectedActiveAlarm}"
                                  Style="{StaticResource AlarmDataGridStyle}"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.ScrollUnit="Pixel">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="等级" Width="84">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:AlarmActiveItem}">
                                            <Border Padding="8,4"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding LevelBadgeBrush}"
                                                    CornerRadius="12">
                                                <TextBlock HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource AlarmOnAccentBrush}"
                                                           Text="{Binding LevelText}"
                                                           TextAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Binding="{Binding Source}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="来源" Width="110" />
                                <DataGridTextColumn Binding="{Binding Location}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="位置" Width="110" />
                                <DataGridTextColumn Binding="{Binding Code}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="编码" Width="90" />
                                <DataGridTextColumn Binding="{Binding Title}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="报警项" Width="150" />
                                <DataGridTextColumn Binding="{Binding Message}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="报警信息" Width="*" />
                                <DataGridTextColumn Binding="{Binding RaisedAtText}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="触发时间" Width="150" />
                                <DataGridTextColumn Binding="{Binding DurationText}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="持续时长" Width="88" />
                                <DataGridTextColumn Binding="{Binding OccurrenceCount}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="次数" Width="60" />
                                <DataGridTextColumn Binding="{Binding ConfirmText}" ElementStyle="{StaticResource CenteredDataGridTextElementStyle}" Header="确认状态" Width="105" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource AlarmContentCardStyle}">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                        <DockPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="报警详情" />
                            <Border DockPanel.Dock="Right"
                                    Padding="8,3"
                                    Background="{Binding SelectedActiveAlarm.LevelSoftBrush, TargetNullValue={StaticResource AlarmFallbackSoftBrush}}"
                                    CornerRadius="10">
                                <TextBlock Foreground="{Binding SelectedActiveAlarm.LevelBadgeBrush, TargetNullValue={StaticResource AlarmFallbackBadgeBrush}}"
                                           Text="{Binding SelectedActiveAlarm.LevelText, TargetNullValue=未选择}" />
                            </Border>
                        </DockPanel>

                        <TextBlock Margin="0,16,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AlarmTextBrush}"
                                   Text="{Binding SelectedActiveAlarm.Title, TargetNullValue=--}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding SelectedActiveAlarm.Subtitle, TargetNullValue=--}" />
                        <TextBlock Margin="0,14,0,0"
                                   Foreground="{StaticResource AlarmTextBrush}"
                                   Text="{Binding SelectedActiveAlarm.Message, TargetNullValue=--}"
                                   TextWrapping="Wrap" />

                        <StackPanel Margin="0,16,0,0" Orientation="Vertical">
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource SmallLabelStyle}" Text="触发时间" />
                                <TextBlock Foreground="{StaticResource AlarmTextBrush}" Text="{Binding SelectedActiveAlarm.RaisedAtText, TargetNullValue=--}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource SmallLabelStyle}" Text="最近触发" />
                                <TextBlock Foreground="{StaticResource AlarmTextBrush}" Text="{Binding SelectedActiveAlarm.LastRaisedAtText, TargetNullValue=--}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Style="{StaticResource SmallLabelStyle}" Text="持续时长" />
                                <TextBlock Foreground="{StaticResource AlarmTextBrush}" Text="{Binding SelectedActiveAlarm.DurationText, TargetNullValue=--}" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SmallLabelStyle}" Text="确认状态" />
                                <TextBlock Foreground="{StaticResource AlarmTextBrush}" Text="{Binding SelectedActiveAlarm.ConfirmText, TargetNullValue=--}" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>

                        <WrapPanel Margin="0,18,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                            <Button Margin="0,0,10,8"
                                    Command="{Binding ConfirmSelectedCommand}"
                                    Content="确认报警"
                                    Style="{StaticResource AlarmPrimaryButtonStyle}" />
                            <Button Margin="0,0,0,8"
                                    Command="{Binding ClearSelectedCommand}"
                                    Content="清除报警"
                                    Style="{StaticResource AlarmSecondaryButtonStyle}"
                                    ToolTip="手动清除当前活动报警；若报警源仍处于异常状态，会再次触发报警。" />
                        </WrapPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
                </Grid>
            </TabItem>

            <TabItem Header="实时事件流">
            <Border Margin="0,12,0,0" Padding="0" Style="{StaticResource AlarmContentCardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="18,16" BorderBrush="{StaticResource AlarmBorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Margin="0,0,16,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding FeedStateText}" />
                                <Button Command="{Binding ToggleRealtimeCommand}"
                                        Content="{Binding RealtimeToggleText}"
                                        Style="{StaticResource AlarmSecondaryButtonStyle}" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="实时事件流" />
                                <TextBlock Margin="0,4,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="仅显示最近 24 条实时事件，高频报警会自动滚动保留最新记录；完整查询请使用历史记录。" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  Margin="12"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RealtimeFeed}" />
                    </ScrollViewer>
                </Grid>
            </Border>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

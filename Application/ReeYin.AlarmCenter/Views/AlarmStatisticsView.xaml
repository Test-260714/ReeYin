<UserControl x:Class="ReeYin.AlarmCenter.Views.AlarmStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:charts="clr-namespace:ReeYin.AlarmCenter.Controls"
             xmlns:models="clr-namespace:ReeYin.AlarmCenter.Models"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="False"
             d:DesignHeight="760"
             d:DesignWidth="1500"
             FontSize="12"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin.AlarmCenter;component/Styles/AlarmWorkbenchResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="StatisticsAnalyticsLayout" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Margin="0,0,0,12" Style="{StaticResource QueryBarStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12">
                    <TextBlock DockPanel.Dock="Right"
                               MaxWidth="760"
                               Margin="24,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AlarmMutedBrush}"
                               Text="{Binding StatisticsSummaryText}"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding StatisticsSummaryText}" />
                    <StackPanel>
                        <TextBlock FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AlarmPrimaryBrush}"
                                   Text="STATISTICS FILTER" />
                        <TextBlock Margin="0,5,0,0"
                                   Style="{StaticResource SectionTitleStyle}"
                                   Text="统计分析查询" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="按时间、等级、来源和关键字筛选报警数据，图表将在页面空闲时刷新。" />
                    </StackPanel>
                </DockPanel>

                <WrapPanel Grid.Row="1">
                    <StackPanel Width="136" Margin="0,0,14,8">
                        <TextBlock Style="{StaticResource SmallLabelStyle}" Text="报警等级" />
                        <ComboBox Height="32"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding LevelOptions}"
                                  SelectedValue="{Binding SelectedHistoryLevel}"
                                  SelectedValuePath="Value" />
                    </StackPanel>
                    <StackPanel Width="168" Margin="0,0,14,8">
                        <TextBlock Style="{StaticResource SmallLabelStyle}" Text="报警来源" />
                        <ComboBox Height="32"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{Binding SourceOptions}"
                                  SelectedValue="{Binding SelectedHistorySource}"
                                  SelectedValuePath="Value" />
                    </StackPanel>
                    <StackPanel Width="240" Margin="0,0,14,8">
                        <TextBlock Style="{StaticResource SmallLabelStyle}" Text="关键字" />
                        <TextBox Height="32"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding HistoryKeyword, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Margin="0,18,0,8" Orientation="Horizontal">
                        <Button Margin="0,0,8,0"
                                Command="{Binding ApplyHistoryFilterCommand}"
                                Content="查询"
                                Style="{StaticResource AlarmPrimaryButtonStyle}" />
                        <Button Command="{Binding ResetHistoryFilterCommand}"
                                Content="重置"
                                Style="{StaticResource AlarmSecondaryButtonStyle}" />
                    </StackPanel>
                </WrapPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    HorizontalContentAlignment="Stretch"
                    SelectedIndex="{Binding SelectedStatisticsTabIndex, Mode=TwoWay}"
                    VerticalContentAlignment="Stretch">
            <TabItem Header="柱状分类" Content="{Binding}">
                <TabItem.ContentTemplate>
                    <DataTemplate>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="0.85*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Padding="0" Style="{StaticResource AlarmContentCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Padding="18,16" BorderBrush="{StaticResource AlarmBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="时段 / 报警次数" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Text="保留原柱状图外观，图表视图按需创建并缓存，避免切页时重复初始化 DirectX。" />
                                            </StackPanel>
                                            <WrapPanel Grid.Row="1" Margin="0,12,0,0">
                                                <StackPanel Width="136" Margin="0,0,10,8">
                                                    <TextBlock Style="{StaticResource SmallLabelStyle}" Text="开始日期" />
                                                    <DatePicker Height="32" SelectedDate="{Binding BarFilterStartDate}" />
                                                </StackPanel>
                                                <StackPanel Width="96" Margin="0,0,14,8">
                                                    <TextBlock Style="{StaticResource SmallLabelStyle}" Text="开始时间" />
                                                    <TextBox Height="32"
                                                             ToolTip="格式 HH:mm:ss，例如 08:30:00"
                                                             VerticalContentAlignment="Center"
                                                             Text="{Binding BarFilterStartTimeText, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Margin="0,18,0,8" Orientation="Horizontal">
                                                    <Button Margin="0,0,8,0"
                                                            Command="{Binding ShiftBarTimeRangeBackwardCommand}"
                                                            Content="前一段"
                                                            Style="{StaticResource AlarmSecondaryButtonStyle}" />
                                                    <Button Margin="0,0,8,0"
                                                            Command="{Binding ShiftBarTimeRangeForwardCommand}"
                                                            Content="后一段"
                                                            Style="{StaticResource AlarmSecondaryButtonStyle}" />
                                                    <Button Command="{Binding ApplyBarFilterCommand}"
                                                            Content="查询柱状"
                                                            Style="{StaticResource AlarmPrimaryButtonStyle}" />
                                                </StackPanel>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                    <Grid Grid.Row="1" MinHeight="320" Margin="14">
                                        <charts:AlarmTrendBarLightningChart ItemsSource="{Binding BarTrendPoints}" />
                                        <Border Padding="18"
                                                Background="#CCFFFFFF"
                                                CornerRadius="14"
                                                IsHitTestVisible="False"
                                                Visibility="{Binding IsBarStatisticsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock HorizontalAlignment="Center"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource AlarmTextBrush}"
                                                           Text="当前范围暂无报警" />
                                                <TextBlock Margin="0,8,0,0"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{StaticResource AlarmMutedBrush}"
                                                           Text="调整时间范围或触发 Demo 报警后再查询。" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2" Padding="0" Style="{StaticResource AlarmContentCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Padding="18,16" BorderBrush="{StaticResource AlarmBorderBrush}" BorderThickness="0,0,0,1">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="类型占比" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="饼图继续使用 LightningChart，但不再使用内部标题模板，避免只读标题异常。" />
                                        </StackPanel>
                                    </Border>
                                    <Grid Grid.Row="1" Margin="14">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="260" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" MinHeight="240">
                                            <charts:AlarmTypePieLightningChart ItemsSource="{Binding TypePieSlices}" />
                                            <Border Padding="18"
                                                    Background="#CCFFFFFF"
                                                    CornerRadius="14"
                                                    IsHitTestVisible="False"
                                                    Visibility="{Binding IsTypePieStatisticsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AlarmTextBrush}"
                                                               Text="暂无类型占比" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               HorizontalAlignment="Center"
                                                               Foreground="{StaticResource AlarmMutedBrush}"
                                                               Text="当前查询范围没有可统计的报警类型。" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                        <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding TypePieSlices}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="{x:Type models:AlarmPieSliceItem}">
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="10" Height="10" VerticalAlignment="Center" Background="{Binding FillBrush}" CornerRadius="5" />
                                                            <TextBlock Grid.Column="1" Margin="8,0" Foreground="{StaticResource AlarmTextBrush}" Text="{Binding Label}" TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Grid.Column="2" Foreground="{StaticResource AlarmMutedBrush}" Text="{Binding LegendText}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </TabItem.ContentTemplate>
            </TabItem>

            <TabItem Header="趋势分析" Content="{Binding}">
                <TabItem.ContentTemplate>
                    <DataTemplate>
                        <Border Margin="0,12,0,0" Padding="0" Style="{StaticResource AlarmContentCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Padding="18,16" BorderBrush="{StaticResource AlarmBorderBrush}" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="报警趋势" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Text="趋势页使用轻量化卡片渲染，避免隐藏页也初始化图表资源。" />
                                        </StackPanel>
                                        <WrapPanel Grid.Row="1" Margin="0,12,0,0">
                                            <StackPanel Width="136" Margin="0,0,10,8">
                                                <TextBlock Style="{StaticResource SmallLabelStyle}" Text="开始日期" />
                                                <DatePicker Height="32" SelectedDate="{Binding TrendFilterStartDate}" />
                                            </StackPanel>
                                            <StackPanel Width="136" Margin="0,0,10,8">
                                                <TextBlock Style="{StaticResource SmallLabelStyle}" Text="结束日期" />
                                                <DatePicker Height="32" SelectedDate="{Binding TrendFilterEndDate}" />
                                            </StackPanel>
                                            <StackPanel Margin="0,18,0,8" Orientation="Horizontal">
                                                <Button Margin="0,0,8,0"
                                                        Command="{Binding ShiftTrendTimeRangeBackwardCommand}"
                                                        Content="前一段"
                                                        Style="{StaticResource AlarmSecondaryButtonStyle}" />
                                                <Button Margin="0,0,8,0"
                                                        Command="{Binding ShiftTrendTimeRangeForwardCommand}"
                                                        Content="后一段"
                                                        Style="{StaticResource AlarmSecondaryButtonStyle}" />
                                                <Button Command="{Binding ApplyTrendFilterCommand}"
                                                        Content="查询趋势"
                                                        Style="{StaticResource AlarmPrimaryButtonStyle}" />
                                            </StackPanel>
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1" MinHeight="320" Margin="14">
                                    <charts:AlarmTrendLineLightningChart ItemsSource="{Binding TrendPoints}" />
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </TabItem.ContentTemplate>
            </TabItem>

            <TabItem Header="分布排行" Content="{Binding}">
                <TabItem.ContentTemplate>
                    <DataTemplate>
                        <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Padding="0" Style="{StaticResource AlarmContentCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Padding="18,16" BorderBrush="{StaticResource AlarmBorderBrush}" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="类型分布" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Text="按报警类型统计 Top 项，列表启用虚拟化降低切页开销。" />
                                            </StackPanel>
                                        </Border>
                                        <ListBox Grid.Row="1"
                                                 MinHeight="320"
                                                 Margin="14"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ItemsSource="{Binding TypeStatistics}"
                                                 ScrollViewer.CanContentScroll="True"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling" />
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2" Padding="0" Style="{StaticResource AlarmContentCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Padding="18,16" BorderBrush="{StaticResource AlarmBorderBrush}" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="来源分布" />
                                                <TextBlock Margin="0,4,0,0"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Text="按设备来源聚合报警数量，辅助定位高频来源。" />
                                            </StackPanel>
                                        </Border>
                                        <ListBox Grid.Row="1"
                                                 MinHeight="320"
                                                 Margin="14"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ItemsSource="{Binding SourceStatistics}"
                                                 ScrollViewer.CanContentScroll="True"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </DataTemplate>
                </TabItem.ContentTemplate>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

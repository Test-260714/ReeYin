<UserControl x:Class="ReeYin.AlarmCenter.Views.AlarmWorkbenchShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:ReeYin.AlarmCenter.Models"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:views="clr-namespace:ReeYin.AlarmCenter.Views"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="900"
             d:DesignWidth="1500"
             FontSize="12"
             mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin.AlarmCenter;component/Styles/AlarmWorkbenchResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="AlarmShellRoot" Style="{StaticResource AlarmShellRootStyle}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="204" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="AlarmWorkbenchNavigationPanel" Grid.Column="0" Style="{StaticResource AlarmRailStyle}">
            <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top"
                        Margin="0,0,0,18"
                        Padding="2,0,2,16"
                        BorderBrush="{StaticResource AlarmRailBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="44"
                                    Height="44"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource AlarmCyanBrush}"
                                    CornerRadius="16">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AlarmOnAccentBrush}"
                                           Text="AC" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AlarmCyanBrush}"
                                           Text="ALARM COMMAND CENTER" />
                                <TextBlock Margin="0,4,0,0"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AlarmTextBrush}"
                                           Text="报警中心" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Margin="0,12,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="监控活动报警、历史记录、趋势分布和硬件报警状态。" />
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Bottom"
                        Margin="0,16,0,0"
                        Padding="12"
                        Background="{StaticResource AlarmRailCardBrush}"
                        BorderBrush="{StaticResource AlarmRailBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <StackPanel>
                        <TextBlock FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AlarmCyanBrush}"
                                   Text="NAVIGATION" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="11"
                                   Foreground="{StaticResource AlarmRailMutedBrush}"
                                   Text="页面按需刷新" />
                    </StackPanel>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding PageItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:AlarmWorkbenchPageItem}">
                                <Button Command="{Binding DataContext.NavigatePageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Content="{Binding}"
                                        ToolTip="{Binding Description}"
                                        Style="{StaticResource AlarmPageNavButtonStyle}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="16,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource AlarmCommandBarStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ItemsControl x:Name="AlarmHeaderSummaryPanel"
                                  ItemTemplate="{StaticResource AlarmCompactSummaryCardTemplate}"
                                  ItemsSource="{Binding SummaryCards}"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Left" ItemWidth="142" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <WrapPanel Grid.Column="1"
                               Margin="18,0,0,0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top">
                        <Button Margin="0,0,8,0"
                                Command="{Binding OpenAlarmDemoPopupCommand}"
                                Content="报警测试"
                                Style="{StaticResource AlarmPrimaryButtonStyle}"
                                ToolTip="Debug/测试版本用于打开非阻塞报警测试窗口"
                                Visibility="{Binding IsAlarmDemoAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Button Command="{Binding OpenAlarmDefinitionsPopupCommand}"
                                Content="报警定义配置"
                                Style="{StaticResource AlarmSecondaryButtonStyle}"
                                ToolTip="仅设计/工程相关人员可修改报警定义" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource AlarmContentCardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="14,10,14,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ProgressBar Height="6" IsIndeterminate="True" Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{StaticResource AlarmMutedBrush}" Text="{Binding StatusText}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                            <Button Grid.Column="1" Margin="8,0,0,0" Command="{Binding OpenLastExportLocationCommand}" Content="打开位置" Style="{StaticResource AlarmSecondaryButtonStyle}" Visibility="{Binding HasExportedFileLocation, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Grid>
                    <ContentControl Grid.Row="1" prism:RegionManager.RegionName="AlarmWorkbenchContentRegion" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="AlarmDefinitionsPopupOverlay"
              Grid.ColumnSpan="2"
              Panel.ZIndex="50"
              Background="{StaticResource AlarmModalOverlayBrush}"
              Visibility="{Binding IsAlarmDefinitionsPopupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Width="1280"
                    MaxWidth="1380"
                    MaxHeight="820"
                    Margin="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Padding="18,14" BorderBrush="{StaticResource AlarmBorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    Margin="16,0,0,0"
                                    Command="{Binding CloseAlarmDefinitionsPopupCommand}"
                                    Content="关闭"
                                    Style="{StaticResource AlarmSecondaryButtonStyle}" />
                            <StackPanel>
                                <TextBlock FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AlarmPrimaryBrush}"
                                           Text="ALARM DESIGN CONFIG" />
                                <TextBlock Margin="0,5,0,0"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Text="报警定义配置" />
                                <TextBlock Margin="0,5,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="此窗口用于修改软件报警定义和硬件报警规则，仅设计/工程相关人员可操作。" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <views:AlarmDefinitionsView Grid.Row="1" Margin="0" />
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>

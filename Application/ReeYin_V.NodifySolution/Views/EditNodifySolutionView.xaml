<UserControl x:Class="ReeYin_V.NodifySolution.Views.EditNodifySolutionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin_V.NodifySolution.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="380" Width="580"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="380" d:DesignWidth="580">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding loadCommand}"/>
        </i:EventTrigger>
        <!--<i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding ConfirmCommand}"/>
        </i:EventTrigger>-->
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <StackPanel Orientation="Vertical">

            <Expander Width="auto" MaxHeight="700" Margin="5,5,5,0" Header="操作" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                <StackPanel Orientation="Vertical" Margin="5">
                    <Button Margin="0,10,0,0" IsEnabled="False" FontSize="18" Height="30" Content="双击条目打开方案" Style="{StaticResource GeneralButtonStyle}" Cursor="Hand" Background="Gray"
                                                    Command="{Binding GeneralCommand}" CommandParameter="打开"/>
                    <Button Margin="0,10,0,0" FontSize="18" Style="{StaticResource GeneralButtonStyle}" Height="30" Content="设为默认启动" Cursor="Hand"
                                                    Command="{Binding GeneralCommand}" CommandParameter="设为默认启动"/>
                    <Button Margin="0,10,0,0" FontSize="18" Style="{StaticResource GeneralButtonStyle}" Height="30" Content="添加新解决方案" Cursor="Hand"
                                                    Command="{Binding GeneralCommand}" CommandParameter="添加新解决方案"/>
                    <Button Margin="0,10,0,0" FontSize="18" Height="30" Style="{StaticResource GeneralButtonStyle}" Content="删除选中方案" Cursor="Hand"
                                                    Command="{Binding GeneralCommand}" CommandParameter="删除选中方案"/>
                </StackPanel>
            </Expander>
            <Expander Width="auto" MaxHeight="700" Margin="5,5,5,0" Header="细节描述" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                <StackPanel Orientation="Vertical" Margin="5">
                    <TextBlock Text="名称:" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock HorizontalAlignment="Center"
                                      Text="{Binding SltCurSolutionItem.Name,UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="标识符:" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock HorizontalAlignment="Center"
                                      Text="{Binding SltCurSolutionItem.Guid,UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="路径:" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBlock HorizontalAlignment="Center" ToolTip="{Binding SltCurSolutionItem.FilePath}"
                                      Text="{Binding SltCurSolutionItem.FilePath,UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="修改时间:" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBox Text="{Binding SltCurSolutionItem.ModifyTime}" IsReadOnly="True" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>

                    <TextBlock Text="描述:" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                    <TextBox ToolTip="{Binding Description}" HorizontalAlignment="Center" BorderThickness="0" Width="220" Height="100" 
                                     TextWrapping="Wrap"
                                      Text="{Binding SltCurSolutionItem.Description,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Expander>
        </StackPanel>
    </Grid>
</UserControl>

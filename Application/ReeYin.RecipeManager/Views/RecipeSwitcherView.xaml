<UserControl x:Class="ReeYin.RecipeManager.Views.RecipeSwitcherView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="Transparent"
             FontSize="13">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="4">
        <WxGroupBox:WxGroupBox Header="配方切换">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               Foreground="#667085"
                               Text="配方" />

                    <ComboBox Grid.Column="1" MinWidth="150"
                              Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              ItemsSource="{Binding Recipes}"
                              SelectedItem="{Binding SelectedRecipe}"
                              DisplayMemberPath="Name" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Margin="0,0,8,0"
                                Padding="18,6"
                                Command="{Binding LoadCommand}"
                                Content="刷新" />
                        <Button Padding="18,6"
                                Command="{Binding SwitchRecipeCommand}"
                                Content="切换配方" />
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1"
                           Margin="0,10,0,0"
                           Foreground="#667085"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </Grid>
        </WxGroupBox:WxGroupBox>
    </Grid>
</UserControl>

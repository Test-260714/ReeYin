<UserControl x:Class="ReeYin_V.Login.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin_V.Login.Views"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:core="clr-namespace:ReeYin_V.Core;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="1920">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>

        <i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding UnLoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <UserControl.Resources>
        <ResourceDictionary>

        </ResourceDictionary>
    </UserControl.Resources>
    <Grid >
        <Grid.Background>
            <ImageBrush  ImageSource="{DynamicResource Icon_Login_BG}" Stretch="UniformToFill" Opacity="1"/>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.65*"/>
            <ColumnDefinition Width="0.35*"/>
        </Grid.ColumnDefinitions>

        <!--left-->
        <Grid Grid.Column="0">

        </Grid>
        <!--right-->
        <Grid Grid.Column="1" Background="White" Opacity="0.8">
            <Grid.RowDefinitions>
                <RowDefinition Height="250"/>
                <RowDefinition/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>
            
            <DockPanel Margin="0,0,0,0" >
                <Image MaxWidth="380"
           HorizontalAlignment="Center"
           VerticalAlignment="Bottom"
           Source="{Binding LoginIconPath}"
           MouseRightButtonDown="Image_MouseRightButtonDown"/>
            </DockPanel>

            <StackPanel Grid.Row="1" Margin="0,0,0,0">
                <TextBlock Text="{DynamicResource WelcomeToLogin}" FontSize="32" FontWeight="Bold" Height="51" Margin="10" HorizontalAlignment="Center"/>

                <TabControl Name="tabLogin" Grid.Row="5" Margin="60 0 60 0" Style="{StaticResource TabControlWithUnderLineStyle}">

                    <TabItem Width="160" Height="49" Padding="0" FontSize="20" HorizontalAlignment="Center" Style="{StaticResource TabItemExWithUnderLineStyle}" Header="{DynamicResource PasswordLanding}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="91*"/>
                                <ColumnDefinition Width="439*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="145" />
                                <RowDefinition Height="85" />
                                <RowDefinition />
                                <RowDefinition Height="64" />
                                <RowDefinition Height="64" />
                            </Grid.RowDefinitions>
                            <Border Grid.ColumnSpan="2" Height="70" Margin="0,45,0,30" CornerRadius="5" SnapsToDevicePixels="True" Background="#F2F4F9">
                                <Grid Margin="10 0 10 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xe610;" FontFamily="{StaticResource Iconfont}" FontSize="20"
                                               VerticalAlignment="Center" Foreground="Black" Margin="0 0 8 0"/>
                                    <ComboBox x:Name="cmbUser" Grid.Column="1" FontSize="20" Style="{StaticResource ComboBoxExtend}"
                                              hc:InfoElement.Placeholder="{DynamicResource PleaseSelectAUser}"
                                              Background="Transparent" BorderThickness="0"
                                              HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                              VerticalAlignment="Center" IsEditable="True"
                                              Loaded="CmbUser_Loaded"
                                              ItemsSource="{Binding AllUserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Text="{Binding CurUser.UserName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                            </Border>

                            <Border Grid.ColumnSpan="2" Grid.Row="1" Height="70" Margin="0,8,0,7" CornerRadius="5" SnapsToDevicePixels="True" Background="#F2F4F9">
                                <Grid Margin="10 0 10 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xe7b8;" FontFamily="{StaticResource Iconfont}" FontSize="20"
                                               VerticalAlignment="Center" Foreground="Black" Margin="0 0 8 0"/>
                                    <PasswordBox Grid.Column="1" Style="{StaticResource PasswordBoxExtend}"
                                                 hc:InfoElement.Placeholder="{DynamicResource EnterYourPIN}"
                                                 hc:InfoElement.Necessary="True"
                                                 Background="Transparent" BorderThickness="0"
                                                 HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                 VerticalAlignment="Center">
                                        <i:Interaction.Behaviors>
                                            <local:PasswordBindingBehavior
                                                BoundPassword="{Binding CurUser.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                PasswordChangedCommand="{Binding AutoLoginCommand}"/>
                                        </i:Interaction.Behaviors>
                                    </PasswordBox>
                                </Grid>
                            </Border>


                            <Label Name="lblWait" Grid.Row="2" HorizontalAlignment="Left" VerticalContentAlignment="Bottom"
                                Content="{Binding Model.LblWait}"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="Transparent"
                                Visibility="Hidden" Grid.Column="1" Margin="163,0,0,0" />

                            <Button Name="btnLogin" Grid.Row="3" IsEnabled="{Binding IsEnabled}" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="auto" Height="50"
                                    Command="{Binding LoginCommand}" CommandParameter="{Binding Name}" Grid.ColumnSpan="2">
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Text="&#xe610;" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="24" FontFamily="{StaticResource Iconfont}" />
                                            <TextBlock Text="{DynamicResource Login}" TextWrapping="Wrap" FontSize="24" Margin="20,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                        </Grid>
                    </TabItem>

                    <TabItem Width="160" Height="49" Padding="0" HorizontalAlignment="Center" FontSize="20" Header="{DynamicResource CardLanding}"
                             Style="{StaticResource TabItemExWithUnderLineStyle}"  >
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.8*"></RowDefinition>
                                <RowDefinition Height="0.1*"></RowDefinition>
                            </Grid.RowDefinitions>
                            <Image Height="216" Width="216" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Source="{DynamicResource Icon_Login_Card}" Margin="0,50,0,0"/>

                            <TextBlock Grid.Row="1" HorizontalAlignment="Center" FontSize="22" FontWeight="Bold"  Text="{DynamicResource PleaseTapYourCard}"   Visibility="{Binding Model.LblWaitVisibly}" Margin="0,30,0,0"></TextBlock>

                        </Grid>
                    </TabItem>
                </TabControl>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                <RadioButton x:Name="CN" FontSize="14" Width="83" Height="32" Content="CN"  IsChecked="True" Foreground="Black"
                             Style="{StaticResource ImgHomeBtn}"/>
                <RadioButton x:Name="US" FontSize="14" Width="83" Height="32"  Content="EN" Foreground="Black"
                             Style="{StaticResource ImgHomeBtn}" />

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

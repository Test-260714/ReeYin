<UserControl x:Class="Nodify.FlowApp.Views.Subjoin.SubJoinView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Nodify.FlowApp.Views.Subjoin"
             mc:Ignorable="d" 
             xmlns:FastDrawer="clr-namespace:ReeYin_V.UI.UserControls.FastDrawer;assembly=ReeYin_V.UI"
             xmlns:WxSearchBox="clr-namespace:ReeYin_V.UI.UserControls.WxSearchBox;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/" 
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="1080" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary x:Name="Resource">

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Nodify;component/Themes/Dark.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.NodifyManager;component/UI/Style/Dark.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.NodifyManager;component/UI/Style/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="PrimaryTextColor" Color="#FFFFFF"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="400"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="0.6*" MinHeight="300"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Vertical" Width="auto">
            <Border CornerRadius="0" Padding="5" Background="{DynamicResource PrimaryTextColor}">
                <TabControl Width="auto" Height="auto" Style="{StaticResource TabControlWithUnderLineStyle}"
                                    MinHeight="350" MaxHeight="600">
                    <TabItem Header="{DynamicResource Image}" Height="35" MinWidth="100" FontSize="16" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid Margin="5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{DynamicResource PleaseSelectAnImage}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <ComboBox Width="auto" MinWidth="300" Height="25" BorderThickness="0 0 0 1" Style="{StaticResource ComboBoxExtend}"
                                              ItemsSource="{Binding DisplayableNames}" SelectedItem="{Binding SltDisplayableName ,Mode=TwoWay}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="SelectionChanged">
                                                <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换图片"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <StackPanel Grid.Row="1" Margin="5">
                                <Controls:ImageEditView Image="{Binding Image,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                        Height="Auto" MinHeight="300" MaxHeight="500"/>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="{DynamicResource ModuleResults}" Height="35" MinWidth="100" FontSize="16" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <Grid>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center">


                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                  Margin="5" Background="Transparent" MaxHeight="200">
                <ListBox ItemsSource="{Binding ImageInfos}"
                                 SelectedItem="{Binding SelectedImageInfo,Mode=TwoWay}"
                                 SelectionMode="Single"
                                 Background="Transparent"
                                 BorderThickness="0">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" Margin="5"
                                               HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="BorderThickness" Value="2"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="2"/>
                            <Setter Property="Margin" Value="3"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrushOpacity20}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrushOpacity13}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrushOpacity53}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="2">
                                <Image Source="{Binding ImageSource}"
                                               Width="120" Height="120"
                                               Stretch="UniformToFill">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDown">
                                            <i:InvokeCommandAction Command="{Binding DataContext.ImageClickCommand, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBox}}"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </Image>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </StackPanel>
        <GridSplitter Background="{StaticResource BackgroundBrush}" Grid.Row="1" Height="2" Width="auto" HorizontalAlignment="Stretch"/>
        <StackPanel Orientation="Vertical" Grid.Row="2" Width="auto">
            <Border CornerRadius="0" Padding="5" Background="{DynamicResource PrimaryTextColor}">
                <TabControl Width="auto" Height="auto" Style="{StaticResource TabControlWithUnderLineStyle}"
                                    MinHeight="250" MaxHeight="400">
                    <TabItem Header="{DynamicResource HistoricalOutcome}" Height="35" MinWidth="100" FontSize="16" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <StackPanel>
                            <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              VirtualizingPanel.VirtualizationMode="Recycling"
                                              ItemsSource="{Binding ModelParam.InputParams}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              Height="Auto" MaxHeight="300"
                                              FontSize="12"
                                              RowHeaderWidth="20"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="All"
                                              IsReadOnly="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="{DynamicResource ExecutionNumber}" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name}" ToolTip="{Binding Name}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="{DynamicResource ExecutionTime}" IsReadOnly="True" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>

                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="{DynamicResource Module}" IsReadOnly="true" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value}" IsReadOnly="True" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="{DynamicResource Resultdata}" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </TabItem>

                    <TabItem Header="{DynamicResource CurrentModuleResults}" Height="35" MinWidth="100" FontSize="16" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <Grid>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                                  EnableColumnVirtualization="True"
                                                  EnableRowVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                                  ItemsSource="{Binding ModelParam.InputParams}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  Height="Auto" MaxHeight="300"
                                                  FontSize="12"
                                                  RowHeaderWidth="20"
                                                  SelectionUnit="FullRow"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="All"
                                                  IsReadOnly="False" CanUserAddRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="{DynamicResource SerialNumber}" IsReadOnly="True" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Name}" ToolTip="{Binding Name}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{DynamicResource ResultInformation}" IsReadOnly="True" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>

                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="{DynamicResource Resultvalues}" IsReadOnly="true" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value}" IsReadOnly="True" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{DynamicResource Other}" Height="35" MinWidth="100" FontSize="16" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <Grid>
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center">


                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>

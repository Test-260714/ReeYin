<UserControl x:Class="ReeYin_V.Main.Views.PrimaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:local="clr-namespace:ReeYin_V.Main.Views"
             xmlns:FastDrawer="clr-namespace:ReeYin_V.UI.UserControls.FastDrawer;assembly=ReeYin_V.UI"
             xmlns:WxSearchBox="clr-namespace:ReeYin_V.UI.UserControls.WxSearchBox;assembly=ReeYin_V.UI"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:prism="http://prismlibrary.com/" 
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             Background="#1E1E1E"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <FastDrawer:FastDrawer Style="{StaticResource RightMode}" IsShow="False" Margin ="0,5,0,0" 
                         HorizontalAlignment="Left" VerticalAlignment="Top" >
            <Border Background="#80808080" CornerRadius="10 0 10 10 " Margin="0 0 5 0" MinHeight="500" MaxHeight="800">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <WxSearchBox:WxSearchBox Margin="4" IsRealTime="True" WaterMark="Input a key" Title="搜索框"
                                             SearchStarted="SearchBar_OnSearchStarted"/>
                    <!--<TextBlock Text="搜索" FontSize="18" Margin="10,10,10,0" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />-->
                    <ScrollViewer Grid.Row="1">
                        <StackPanel Margin="10,0,10,10">
                            <Expander Width="300" Margin="5,5,5,0" Header="00.常用工具" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                                <ItemsControl ItemsSource="{Binding MainBtnList}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <!-- 使用 UniformGrid 并设置 Columns=5 -->
                                            <UniformGrid Columns="5" Margin="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <Button Content="{Binding Icon}" Style="{StaticResource NavOperateButtonStyle}" ToolTip="{Binding Name}" 
Command="{Binding ExecuteEventCommand}" CommandParameter="{Binding}" IsEnabled="{Binding IsEnabled}"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                            <Expander Header="01.逻辑工具" Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                                <ItemsControl ItemsSource="{Binding MainBtnList}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <!-- 使用 UniformGrid 并设置 Columns=5 -->
                                            <UniformGrid Columns="5" Margin="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <Button Content="{Binding Icon}" Style="{StaticResource NavOperateButtonStyle}" ToolTip="{Binding Name}" 
                                Command="{Binding ExecuteEventCommand}" CommandParameter="{Binding}" IsEnabled="{Binding IsEnabled}"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                            <Expander Header="02.检测识别" Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                                <ItemsControl ItemsSource="{Binding MainBtnList}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <!-- 使用 UniformGrid 并设置 Columns=5 -->
                                            <UniformGrid Columns="5" Margin="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <DockPanel>
                                                <Button Content="{Binding Icon}" Style="{StaticResource NavOperateButtonStyle}" ToolTip="{Binding Name}" 
Command="{Binding ExecuteEventCommand}" CommandParameter="{Binding}" IsEnabled="{Binding IsEnabled}"/>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                            <Expander Header="03...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>
                            <Expander Header="04...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>
                            <Expander Header="05...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>
                            <Expander Header="06...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>
                            <Expander Header="07...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>
                            <Expander Header="08...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>
                            <Expander Header="09...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>
                            <Expander Header="10...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>
                            <Expander Header="11...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>
                            <Expander Header="12...." Width="300" Margin="5,5,5,0" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}"/>

                            <Button Content="快捷面板"  Width="300" Margin="5,5,5,5"/>
                        </StackPanel>
                    </ScrollViewer>
                    <TextBlock Grid.Row="2" Text="" FontSize="12" Margin="10,10,10,0" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Border>

        </FastDrawer:FastDrawer>

        <StackPanel>
            <!--悬浮框-->
            <FastDrawer:FastDrawer Style="{StaticResource LeftMode}" IsShow="False" Margin ="0,5,0,0" 
                         HorizontalAlignment="Right" VerticalAlignment="Top" >
                
                <Border Background="#80808080" CornerRadius="0 10 10 10 " Margin="0 0 5 0" MinHeight="500" MaxHeight="800">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="日志" FontSize="18" Margin="10,10,10,0" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <ScrollViewer Grid.Row="1">
                            <StackPanel Margin="10,0,10,10">


                                <Button Content="快捷面板"  Width="300" Margin="5,5,5,5"/>
                            </StackPanel>
                        </ScrollViewer>
                        <TextBlock Grid.Row="2" Text="连接状态" FontSize="18" Margin="10,10,10,0" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <ScrollViewer Grid.Row="3">
                            <StackPanel Margin="10,0,10,10">
                                <Button Content="快捷面板"  Width="300" Margin="5,5,5,5"/>
                            </StackPanel>
                        </ScrollViewer>
                        <TextBlock Grid.Row="4" Text="" FontSize="12" Margin="10,10,10,0" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>

            </FastDrawer:FastDrawer>
        </StackPanel>


    </Grid>
</UserControl>

<UserControl x:Class="ReeYin_V.Main.Views.OpBtnView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin_V.Main.Views"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="400">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>

        <i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding UnLoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <WxGroupBox:WxGroupBox Header="状态及操作" >
        <ScrollViewer Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Background="Transparent">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Margin="10 0 0 0">
                    <Button Content="&#xe61b;" Style="{StaticResource NavOperateButtonStyle}" ToolTip="运行一次" 
                                Command="{Binding GeneralCommand}" CommandParameter="运行一次" IsEnabled="{Binding IsEnabled}"/>

                    <Button Content="&#xea76;" Style="{StaticResource NavOperateButtonStyle}" ToolTip="停止" 
                                Command="{Binding GeneralCommand}" CommandParameter="停止" IsEnabled="{Binding IsEnabled}"/>

                    <Button Content="&#xe64c;" Style="{StaticResource NavOperateButtonStyle}" ToolTip="重置" 
                                Command="{Binding GeneralCommand}" CommandParameter="重置" IsEnabled="{Binding IsEnabled}"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10 0 0 0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin=" 10,0,0,0" MinWidth="60">
                        <Run Text="{DynamicResource ActiveUser}"/>
                        <LineBreak/>
                        <Run Text="{Binding CurUser.UserName,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0 0 0 0">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin=" 10,0,0,0" MinWidth="60">
                        <Run Text="{DynamicResource CurOperatingStatus}"/>
                        <LineBreak/>
                        <Run Text="{Binding CurStatus,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </WxGroupBox:WxGroupBox>
</UserControl>

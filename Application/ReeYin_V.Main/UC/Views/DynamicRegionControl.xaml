<UserControl x:Class="ReeYin_V.Main.UC.Views.DynamicRegionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin_V.Main.UC.Views"
             mc:Ignorable="d" x:Name="Root"
             xmlns:prism="http://prismlibrary.com/"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="PageActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1F2933"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EEF4FF"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#60A5FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FloatingPageToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="78"/>
            <Setter Property="Height" Value="78"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="39">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  Opacity="0.24"
                                                  ShadowDepth="4"
                                                  Color="#5B6B7B"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#0F766E"/>
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#0F766E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="Transparent">
        <ContentControl x:Name="LayoutHost"/>

        <Canvas x:Name="FloatingLayer"
                Panel.ZIndex="5"
                SizeChanged="FloatingLayer_OnSizeChanged">
            <Border x:Name="PageOperationPanel"
                    Width="456"
                    MaxWidth="456"
                    Padding="18"
                    Background="#FCFDFE"
                    BorderBrush="#D7DEE6"
                    BorderThickness="1"
                    CornerRadius="20"
                    Visibility="Collapsed"
                    SizeChanged="FloatingOverlayElement_OnSizeChanged">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      Opacity="0.16"
                                      ShadowDepth="4"
                                      Color="#6B7280"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid x:Name="PageOperationHeaderDragHandle"
                          Cursor="SizeAll"
                          PreviewMouseLeftButtonDown="FloatingDragHandle_OnPreviewMouseLeftButtonDown"
                          PreviewMouseMove="FloatingDragHandle_OnPreviewMouseMove"
                          PreviewMouseLeftButtonUp="FloatingDragHandle_OnPreviewMouseLeftButtonUp"
                          LostMouseCapture="FloatingDragHandle_OnLostMouseCapture">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="PagePanelTitleText"
                                       Text="页面管理"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2933"/>
                            <TextBlock x:Name="PagePanelSummaryText"
                                       Margin="0,4,0,0"
                                       Text="当前页面：页面 1"
                                       FontSize="12"
                                       Foreground="#52606D"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Padding="12,6"
                                Background="#EAF2FF"
                                CornerRadius="10"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="PageCountText"
                                       Text="共 1 页"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#1D4ED8"/>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="页面切换"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2933"/>
                        <TextBlock Margin="0,4,0,0"
                                   Text="悬浮面板可随时展开收起，每个页面都会独立保存拆分布局和已加载视图状态。"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"/>

                        <ScrollViewer Margin="0,10,0,0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ListBox x:Name="PageListBox"
                                     SelectionChanged="PageListBox_OnSelectionChanged"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,10,0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="ItemBorder"
                                                            Padding="16,10"
                                                            Background="#FFFFFF"
                                                            BorderBrush="#D7DEE6"
                                                            BorderThickness="1"
                                                            CornerRadius="12"
                                                            Cursor="Hand">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#F8FBFF"/>
                                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#93C5FD"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="ItemBorder" Property="Background" Value="#EAF2FF"/>
                                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2563EB"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="ItemBorder" Property="Opacity" Value="0.55"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"
                                                   MinWidth="116"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1F2933"
                                                   TextAlignment="Center"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </StackPanel>

                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="PreviousPageButton"
                                    Style="{StaticResource PageActionButtonStyle}"
                                    Click="PreviousPageButton_OnClick"
                                    Content="上一页"/>
                            <Button x:Name="NextPageButton"
                                    Style="{StaticResource PageActionButtonStyle}"
                                    Click="NextPageButton_OnClick"
                                    Content="下一页"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button x:Name="AddPageButton"
                                    Style="{StaticResource PageActionButtonStyle}"
                                    Click="AddPageButton_OnClick"
                                    Content="新增页面"/>
                            <Button x:Name="DeletePageButton"
                                    Margin="0"
                                    Style="{StaticResource PageActionButtonStyle}"
                                    Click="DeletePageButton_OnClick"
                                    Content="删除当前页"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="PageOperationBorder"
                    Width="78"
                    Height="78"
                    Background="Transparent"
                    Cursor="SizeAll"
                    SizeChanged="FloatingOverlayElement_OnSizeChanged"
                    PreviewMouseLeftButtonDown="FloatingDragHandle_OnPreviewMouseLeftButtonDown"
                    PreviewMouseMove="FloatingDragHandle_OnPreviewMouseMove"
                    PreviewMouseLeftButtonUp="FloatingDragHandle_OnPreviewMouseLeftButtonUp"
                    LostMouseCapture="FloatingDragHandle_OnLostMouseCapture">
                <ToggleButton x:Name="PageOperationToggleButton"
                              Style="{StaticResource FloatingPageToggleButtonStyle}"
                              IsHitTestVisible="False"
                              Focusable="False"
                              Checked="PageOperationToggleButton_OnChecked"
                              Unchecked="PageOperationToggleButton_OnUnchecked">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="PageFloatingCurrentIndexText"
                                   Text="1"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PageFloatingPageCountText"
                                   Grid.Row="1"
                                   Margin="0,1,0,0"
                                   Text="/1"
                                   FontSize="11"
                                   Foreground="#DBEAFE"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PageFloatingStateText"
                                   Grid.Row="2"
                                   Margin="0,4,0,0"
                                   Text="展开"
                                   FontSize="10"
                                   Foreground="#E0F2FE"
                                   HorizontalAlignment="Center"/>
                    </Grid>
                </ToggleButton>
            </Border>
        </Canvas>

        <Border x:Name="BusyOverlay"
                Background="#9AEAF0F5"
                Panel.ZIndex="10"
                Visibility="Collapsed">
            <Border Width="320"
                    Padding="24,20"
                    Background="White"
                    BorderBrush="#D7DEE6"
                    BorderThickness="1"
                    CornerRadius="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="区域视图加载中"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#1F2933"
                               HorizontalAlignment="Center"/>
                    <ProgressBar Margin="0,16,0,0"
                                 Height="5"
                                 IsIndeterminate="True"/>
                    <TextBlock x:Name="BusyMessageText"
                               Margin="0,14,0,0"
                               FontSize="12"
                               Foreground="#52606D"
                               Text="请等待主页面加载完成，正在准备区域视图..."
                               TextAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>

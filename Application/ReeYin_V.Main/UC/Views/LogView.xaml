<UserControl x:Class="ReeYin_V.Main.UC.Views.LogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ReeYin_V.Main.UC.Views"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="300">
    <Grid>
        <WxGroupBox:WxGroupBox Header="日志显示">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 日志控制工具栏（垂直排列） -->
                <Border Grid.Row="0" Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1" Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <CheckBox x:Name="AutoScrollCheckBox" Content="自动滚动" IsChecked="True"
                                  Margin="5,0" VerticalAlignment="Center" FontSize="11"/>
                        <Button x:Name="ClearLogButton" Content="清空日志" Click="ClearLogButton_Click"
                                Padding="8,2" Margin="5,0" FontSize="11"
                                Style="{StaticResource GeneralButtonStyle}" Height="24" Width="70"/>
                        <TextBlock Text="日志级别:" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="11"/>
                        <ComboBox x:Name="LogLevelFilter" SelectionChanged="LogLevelFilter_SelectionChanged"
                                  Width="80" Height="24" FontSize="11" SelectedIndex="0">
                            <ComboBoxItem Content="全部"/>
                            <ComboBoxItem Content="调试"/>
                            <ComboBoxItem Content="信息"/>
                            <ComboBoxItem Content="警告"/>
                            <ComboBoxItem Content="错误"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- 日志显示区域：使用 RichTextBox 支持彩色文本 -->
                <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto"
                              ScrollChanged="LogScrollViewer_ScrollChanged">
                    <RichTextBox x:Name="LogRichTextBox"
                                 IsReadOnly="True"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 Background="Transparent"
                                 FontSize="12"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"
                                 IsDocumentEnabled="True">
                        <RichTextBox.Resources>
                            <!-- 移除默认的段落间距 -->
                            <Style TargetType="Paragraph">
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </RichTextBox.Resources>
                        <FlowDocument x:Name="LogDocument" PagePadding="5" PageWidth="2000">
                            <!-- 日志内容将动态添加到这里 -->
                        </FlowDocument>
                    </RichTextBox>
                </ScrollViewer>

                <!-- 兼容旧代码：隐藏的 TextBox -->
                <TextBox x:Name="LogTextBox" Visibility="Collapsed" TextChanged="LogTextBox_OnTextChanged"/>
            </Grid>
        </WxGroupBox:WxGroupBox>
    </Grid>
</UserControl>

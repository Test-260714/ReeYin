<UserControl x:Class="ReeYin_V.Main.UC.Views.RegionManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Height="760" Width="1180"
             d:DesignHeight="760" d:DesignWidth="1180">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <Grid Background="#EEF2F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="16,16,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.02*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1.38*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="20,16"
                    Background="#11293B"
                    CornerRadius="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="区域管理面板"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Margin="0,6,0,0"
                                   Text="左侧处理当前区域和布局操作，右侧主区域优先展示视图列表与详情。"
                                   FontSize="12"
                                   Foreground="#D5E2EC"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Padding="14,10"
                            Background="#1F4661"
                            CornerRadius="12"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="当前区域" FontSize="11" Foreground="#B6C8D5"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding CurrentRegionName}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="16"
                    Background="White"
                    BorderBrush="#D7DEE6"
                    BorderThickness="1"
                    CornerRadius="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="视图仓库" FontSize="15" FontWeight="SemiBold" Foreground="#1F2933"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="搜索、筛选和仓库统计放到顶部，主体区域留给可用视图列表与选中详情。"
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <Border Margin="0,0,8,0"
                                    Padding="12,8"
                                    Background="#F4F8FB"
                                    BorderBrush="#D7DEE6"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="通用" FontSize="10" Foreground="#607687"/>
                                    <TextBlock Text="{Binding GeneralViewCount}" FontSize="18" FontWeight="SemiBold" Foreground="#1F2933"/>
                                </StackPanel>
                            </Border>
                            <Border Margin="0,0,8,0"
                                    Padding="12,8"
                                    Background="#F2FBF8"
                                    BorderBrush="#C7E9E1"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="定制" FontSize="10" Foreground="#5A7E77"/>
                                    <TextBlock Text="{Binding CustomViewCount}" FontSize="18" FontWeight="SemiBold" Foreground="#0F766E"/>
                                </StackPanel>
                            </Border>
                            <Border Padding="12,8"
                                    Background="#FFF7ED"
                                    BorderBrush="#FED7AA"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="节点映射" FontSize="10" Foreground="#9A6825"/>
                                    <TextBlock Text="{Binding NodeMapViewCount}" FontSize="18" FontWeight="SemiBold" Foreground="#C2410C"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="210"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="搜索视图" FontSize="11" Foreground="#7B8794"/>
                            <TextBox Height="36"
                                     Padding="10,6"
                                     BorderBrush="#C8D2DC"
                                     BorderThickness="1"
                                     Background="#FBFCFD"
                                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="类型筛选" FontSize="11" Foreground="#7B8794"/>
                            <ComboBox Height="36"
                                      Padding="8,4"
                                      ItemsSource="{Binding TypeFilters}"
                                      SelectedItem="{Binding SelectedTypeFilter, Mode=TwoWay}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="286"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="18"
                    Background="White"
                    BorderBrush="#D7DEE6"
                    BorderThickness="1"
                    CornerRadius="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="当前区域状态" FontSize="15" FontWeight="SemiBold" Foreground="#1F2933"/>
                        <TextBlock Margin="0,6,0,0"
                                   Text="{Binding CurrentRegionState}"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"/>

                        <Border Margin="0,14,0,0"
                                Padding="14"
                                Background="#F6F9FC"
                                BorderBrush="#D7DEE6"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Text="已加载视图" FontSize="11" Foreground="#7B8794"/>
                                <TextBlock Text="{Binding CurrentLoadedViewDisplayName}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#1F2933"
                                           TextWrapping="Wrap"/>
                                <TextBlock Margin="0,14,0,0" Text="视图类型" FontSize="11" Foreground="#7B8794"/>
                                <TextBlock Text="{Binding CurrentLoadedViewTypeDisplayName}"
                                           FontSize="13"
                                           Foreground="#1F2933"
                                           TextWrapping="Wrap"/>
                                <TextBlock Margin="0,14,0,0" Text="控件信息" FontSize="11" Foreground="#7B8794"/>
                                <TextBlock Text="{Binding CurrentLoadedViewControlInfo}"
                                           FontSize="13"
                                           Foreground="#1F2933"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Margin="0,22,0,0" Text="布局操作" FontSize="15" FontWeight="SemiBold" Foreground="#1F2933"/>
                        <TextBlock Margin="0,6,0,0"
                                   Text="拆分后当前节点会变成容器节点，重新加载视图前需要先合并。"
                                   FontSize="12"
                                   Foreground="#6B7280"
                                   TextWrapping="Wrap"/>

                        <Button Command="{Binding SplitHorizontalCommand}"
                                IsEnabled="{Binding CanSplitCurrentRegion}"
                                Margin="0,14,0,8"
                                Height="40"
                                Style="{StaticResource GeneralButtonStyle}"
                                Background="#2563EB"
                                BorderBrush="#2563EB"
                                Foreground="White"
                                Content="上下拆分区域"/>

                        <Button Command="{Binding SplitVerticalCommand}"
                                IsEnabled="{Binding CanSplitCurrentRegion}"
                                Margin="0,0,0,12"
                                Height="40"
                                Style="{StaticResource GeneralButtonStyle}"
                                Background="#0F766E"
                                BorderBrush="#0F766E"
                                Foreground="White"
                                Content="左右拆分区域"/>

                        <Button Command="{Binding MergeRegionCommand}"
                                IsEnabled="{Binding CanMergeCurrentRegion}"
                                Margin="0,0,0,8"
                                Height="40"
                                Style="{StaticResource GeneralButtonStyle}"
                                Background="#EA580C"
                                BorderBrush="#EA580C"
                                Foreground="White"
                                Content="合并当前区域"/>

                        <Button Command="{Binding ResetLayoutCommand}"
                                Height="40"
                                Style="{StaticResource GeneralButtonStyle}"
                                Background="#DC2626"
                                BorderBrush="#DC2626"
                                Foreground="White"
                                Content="重置整个布局"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.05*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1.12*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Padding="16"
                            Background="White"
                            BorderBrush="#D7DEE6"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="可用视图列表" FontSize="15" FontWeight="SemiBold" Foreground="#1F2933"/>
                                    <TextBlock Margin="0,6,0,0"
                                               Text="双击行或点击加载按钮可直接使用，列表仅保留必要摘要信息。"
                                               FontSize="12"
                                               Foreground="#6B7280"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Padding="10,6"
                                        Background="#F6F9FC"
                                        BorderBrush="#D7DEE6"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        VerticalAlignment="Top">
                                    <TextBlock FontSize="12" Foreground="#52606D">
                                        <Run Text="结果 "/>
                                        <Run Text="{Binding FilteredViewCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <Border Grid.Row="2"
                                    Padding="12,9"
                                    Background="#F7F9FC"
                                    BorderBrush="#E1E8EF"
                                    BorderThickness="1"
                                    CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.2*"/>
                                        <ColumnDefinition Width="0.9*"/>
                                        <ColumnDefinition Width="1.2*"/>
                                        <ColumnDefinition Width="0.9*"/>
                                        <ColumnDefinition Width="84"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="视图名称" FontSize="11" FontWeight="SemiBold" Foreground="#5B6B7B"/>
                                    <TextBlock Grid.Column="1" Text="类型" FontSize="11" FontWeight="SemiBold" Foreground="#5B6B7B" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="归属 / 节点" FontSize="11" FontWeight="SemiBold" Foreground="#5B6B7B" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="状态" FontSize="11" FontWeight="SemiBold" Foreground="#5B6B7B" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="操作" FontSize="11" FontWeight="SemiBold" Foreground="#5B6B7B" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <ListBox Grid.Row="4"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ItemsSource="{Binding FilteredViews}"
                                     SelectedItem="{Binding SelectedView, Mode=TwoWay}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="True"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     VirtualizingPanel.VirtualizationMode="Recycling">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,6"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="ViewRow"
                                                Padding="12,10"
                                                Background="#FBFCFD"
                                                BorderBrush="#DDE5ED"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Border.ToolTip>
                                                <StackPanel MaxWidth="360">
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="#1F2933"/>
                                                    <TextBlock Margin="0,6,0,0" Text="{Binding ViewName}" FontSize="12" Foreground="#52606D" TextWrapping="Wrap"/>
                                                    <TextBlock Margin="0,8,0,0" Text="{Binding ControlInfo}" FontSize="12" Foreground="#334E68" TextWrapping="Wrap"/>
                                                    <TextBlock Margin="0,8,0,0" Text="{Binding AvailabilityText}" FontSize="12" Foreground="#7C5A17" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </Border.ToolTip>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftDoubleClick"
                                                              Command="{Binding DataContext.LoadViewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2.2*"/>
                                                    <ColumnDefinition Width="0.9*"/>
                                                    <ColumnDefinition Width="1.2*"/>
                                                    <ColumnDefinition Width="0.9*"/>
                                                    <ColumnDefinition Width="84"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1F2933"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Margin="0,3,0,0"
                                                               Text="{Binding ViewName}"
                                                               FontSize="11"
                                                               Foreground="#6B7280"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        Padding="8,3"
                                                        Margin="8,0"
                                                        Background="{Binding TypeAccentColor}"
                                                        CornerRadius="10"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TypeDisplayName}" FontSize="11" Foreground="White"/>
                                                </Border>

                                                <TextBlock Grid.Column="2"
                                                           Margin="8,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding ListIdentityText}"
                                                           FontSize="12"
                                                           Foreground="#334E68"
                                                           TextAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <Border Grid.Column="3"
                                                        Padding="8,3"
                                                        Margin="8,0"
                                                        Background="{Binding AvailabilityBackground}"
                                                        BorderBrush="{Binding AvailabilityBackground}"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding AvailabilityShortText}"
                                                               FontSize="11"
                                                               Foreground="{Binding AvailabilityForeground}"/>
                                                </Border>

                                                <Button Grid.Column="4"
                                                        Width="68"
                                                        Height="28"
                                                        Margin="8,0,0,0"
                                                        Command="{Binding DataContext.LoadViewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding CanLoad}"
                                                        Style="{StaticResource GeneralButtonStyle}"
                                                        Background="#2563EB"
                                                        BorderBrush="#2563EB"
                                                        Foreground="White"
                                                        Content="加载"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter TargetName="ViewRow" Property="Background" Value="#F1F6FF"/>
                                                <Setter TargetName="ViewRow" Property="BorderBrush" Value="#2563EB"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CanLoad}" Value="False">
                                                <Setter TargetName="ViewRow" Property="Opacity" Value="0.76"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="16"
                            Background="White"
                            BorderBrush="#D7DEE6"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="选中视图详情" FontSize="15" FontWeight="SemiBold" Foreground="#1F2933"/>
                                    <TextBlock Margin="0,6,0,0"
                                               Text="右侧集中展示当前选中项的说明、绑定信息和加载条件。"
                                               FontSize="12"
                                               Foreground="#6B7280"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Border Grid.Column="1"
                                        Padding="9,5"
                                        Background="{Binding SelectedView.AvailabilityBackground, TargetNullValue=#F3F4F6, FallbackValue=#F3F4F6}"
                                        CornerRadius="10"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding SelectedView.AvailabilityShortText, TargetNullValue=未选择, FallbackValue=未选择}"
                                               FontSize="11"
                                               Foreground="{Binding SelectedView.AvailabilityForeground, TargetNullValue=#6B7280, FallbackValue=#6B7280}"/>
                                </Border>
                            </Grid>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <Border Padding="14" Background="#F7FAFC" BorderBrush="#D7DEE6" BorderThickness="1" CornerRadius="12">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding SelectedViewDisplayName}" FontSize="16" FontWeight="SemiBold" Foreground="#1F2933" VerticalAlignment="Center"/>
                                                <Border Margin="10,0,0,0"
                                                        Padding="8,2"
                                                        Background="{Binding SelectedView.TypeAccentColor, TargetNullValue=#607D8B, FallbackValue=#607D8B}"
                                                        CornerRadius="10">
                                                    <TextBlock Text="{Binding SelectedViewTypeDisplayName}" FontSize="11" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="#52606D" Text="{Binding SelectedViewName}"/>
                                        </StackPanel>
                                    </Border>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Padding="12" Background="#FBFCFD" BorderBrush="#D7DEE6" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Text="视图类型" FontSize="11" Foreground="#7B8794"/>
                                                <TextBlock Margin="0,4,0,0" Text="{Binding SelectedViewTypeDisplayName}" FontSize="13" FontWeight="SemiBold" Foreground="#1F2933"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Padding="12" Background="#FBFCFD" BorderBrush="#D7DEE6" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Text="{Binding SelectedViewIdentityTitle}" FontSize="11" Foreground="#7B8794"/>
                                                <TextBlock Margin="0,4,0,0" Text="{Binding SelectedViewSubjection}" FontSize="13" FontWeight="SemiBold" Foreground="#1F2933" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <TextBlock Margin="0,16,0,4" Text="类型说明" FontSize="11" Foreground="#7B8794"/>
                                    <Border Padding="12" Background="#FBFCFD" BorderBrush="#D7DEE6" BorderThickness="1" CornerRadius="10">
                                        <TextBlock Text="{Binding SelectedViewTypeDescription}" FontSize="13" Foreground="#1F2933" TextWrapping="Wrap"/>
                                    </Border>

                                    <TextBlock Margin="0,16,0,4" Text="控件信息" FontSize="11" Foreground="#7B8794"/>
                                    <Border Padding="12" Background="#FBFCFD" BorderBrush="#D7DEE6" BorderThickness="1" CornerRadius="10">
                                        <TextBlock Text="{Binding SelectedViewControlInfo}" FontSize="13" Foreground="#1F2933" TextWrapping="Wrap"/>
                                    </Border>

                                    <TextBlock Margin="0,16,0,4" Text="可用性说明" FontSize="11" Foreground="#7B8794"/>
                                    <Border Padding="12" Background="#FFF8EE" BorderBrush="#F6C990" BorderThickness="1" CornerRadius="10">
                                        <TextBlock Text="{Binding SelectedViewAvailabilityText}" FontSize="13" Foreground="#1F2933" TextWrapping="Wrap"/>
                                    </Border>

                                    <TextBlock Margin="0,16,0,4" Text="加载提示" FontSize="11" Foreground="#7B8794"/>
                                    <Border Padding="12" Background="#EEF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="10">
                                        <TextBlock Text="{Binding SelectedViewLoadHint}" FontSize="13" Foreground="#1F2933" TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <Button Grid.Row="3"
                                    Command="{Binding LoadSelectedViewCommand}"
                                    IsEnabled="{Binding CanExecuteLoadSelectedView}"
                                    Height="42"
                                    Margin="0,16,0,0"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Background="#2563EB"
                                    BorderBrush="#2563EB"
                                    Foreground="White"
                                    Content="加载到当前区域"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Margin="16,0,16,16"
                Padding="16,12"
                Background="White"
                BorderBrush="#D7DEE6"
                BorderThickness="1"
                CornerRadius="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="12" Foreground="#52606D">
                        <Run Text="筛选结果："/>
                        <Run Text="{Binding FilteredViewCount, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" 个"/>
                    </TextBlock>
                    <TextBlock Margin="20,0,0,0" FontSize="12" Foreground="#52606D">
                        <Run Text="当前选中："/>
                        <Run Text="{Binding SelectedViewDisplayName, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding CloseCommand}"
                        Height="38"
                        Width="108"
                        Style="{StaticResource GeneralButtonStyle}"
                        Background="White"
                        BorderBrush="#C8D2DC"
                        Foreground="#334E68"
                        Content="关闭"/>
            </Grid>
        </Border>

        <Border Grid.RowSpan="3" Background="#AAEEF2F6"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="220" Height="4" Margin="0 0 0 16"/>
                <TextBlock Text="正在整理区域与视图信息..." FontSize="15" Foreground="#334E68" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="ReeYin.RootManager.Views.ModuleLoadConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:converters="clr-namespace:ReeYin.RootManager.Converters"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.Resources>
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--顶部工具栏-->
        <Border Grid.Row="0" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!--搜索框-->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBox Width="250" hc:InfoElement.Placeholder="搜索模块名称..."
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource TextBoxExtend}"/>
                </StackPanel>

                <!--操作按钮-->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="新增" Command="{Binding AddCommand}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Width="80" Height="35" Margin="0,0,10,0"/>
                    <Button Content="刷新" Command="{Binding RefreshCommand}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Width="80" Height="35" Margin="0,0,10,0"/>
                    <Button Content="全部保存" Command="{Binding SaveAllCommand}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Width="100" Height="35"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--主内容区域-->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--左侧列表-->
            <Border Grid.Column="0" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                    CornerRadius="5" Margin="0,0,10,0">
                <DataGrid ItemsSource="{Binding Configs}"
                          SelectedItem="{Binding SelectedConfig}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="模块名称" Binding="{Binding ModuleName}" Width="150"/>
                        <DataGridTextColumn Header="显示名称" Binding="{Binding DisplayName}" Width="100"/>
                        <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!--右侧编辑区域-->
            <Border Grid.Column="1" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                    CornerRadius="5" Padding="15">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel DataContext="{Binding SelectedConfig}">
                        <TextBlock Text="模块配置详情" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

                        <!--基本信息-->
                        <GroupBox Header="基本信息" Margin="0,0,0,15"
                                  hc:TitleElement.Background="{DynamicResource TitleBarBrush}">
                            <StackPanel Margin="10">
                                <TextBox hc:InfoElement.Title="模块名称："
                                         hc:InfoElement.TitlePlacement="Left"
                                         hc:InfoElement.TitleWidth="120"
                                         Text="{Binding ModuleName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource TextBoxExtend}"
                                         Margin="0,0,0,10"/>

                                <TextBox hc:InfoElement.Title="显示名称："
                                         hc:InfoElement.TitlePlacement="Left"
                                         hc:InfoElement.TitleWidth="120"
                                         Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource TextBoxExtend}"
                                         Margin="0,0,0,10"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="是否启用：" Width="120" VerticalAlignment="Center"/>
                                    <ToggleButton IsChecked="{Binding IsEnabled}"
                                                  Style="{StaticResource ToggleButtonSwitch}"/>
                                </StackPanel>

                                <hc:NumericUpDown hc:InfoElement.Title="排序："
                                                  hc:InfoElement.TitlePlacement="Left"
                                                  hc:InfoElement.TitleWidth="120"
                                                  Value="{Binding Sort}"
                                                  Minimum="0"
                                                  Style="{StaticResource NumericUpDownExtendGlobal}"
                                                  Margin="0,0,0,10"/>
                            </StackPanel>
                        </GroupBox>

                        <!--规则配置-->
                        <GroupBox Header="加载规则" Margin="0,0,0,15"
                                  hc:TitleElement.Background="{DynamicResource TitleBarBrush}">
                            <StackPanel Margin="10">
                                <ComboBox hc:InfoElement.Title="规则类型："
                                          hc:InfoElement.TitlePlacement="Left"
                                          hc:InfoElement.TitleWidth="120"
                                          ItemsSource="{Binding DataContext.RuleTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValue="{Binding RuleType}"
                                          SelectedValuePath="Value"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource ComboBoxExtend}"
                                          Margin="0,0,0,10"/>

                                <!--互斥组配置-->
                                <StackPanel Visibility="{Binding RuleType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=MutualExclusive}">
                                    <TextBox hc:InfoElement.Title="互斥组名称："
                                             hc:InfoElement.TitlePlacement="Left"
                                             hc:InfoElement.TitleWidth="120"
                                             Text="{Binding MutualExclusiveGroup, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TextBoxExtend}"
                                             Margin="0,0,0,10"/>

                                    <hc:NumericUpDown hc:InfoElement.Title="优先级："
                                                      hc:InfoElement.TitlePlacement="Left"
                                                      hc:InfoElement.TitleWidth="120"
                                                      Value="{Binding MutualExclusivePriority}"
                                                      Minimum="0"
                                                      Style="{StaticResource NumericUpDownExtendGlobal}"
                                                      Margin="0,0,0,10"/>
                                    <TextBlock Text="提示：同一互斥组中，优先级值越小越优先加载，同组只能加载一个模块"
                                               Foreground="Gray" FontSize="12" TextWrapping="Wrap" Margin="120,0,0,10"/>
                                </StackPanel>

                                <!--站点配置-->
                                <StackPanel Visibility="{Binding RuleType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=BySite}">
                                    <TextBox hc:InfoElement.Title="适用站点："
                                             hc:InfoElement.TitlePlacement="Left"
                                             hc:InfoElement.TitleWidth="120"
                                             Text="{Binding ApplicableSites, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TextBoxExtend}"
                                             Margin="0,0,0,10"/>
                                    <TextBlock Text="提示：多个站点用逗号分隔，如：站点A,站点B,站点C"
                                               Foreground="Gray" FontSize="12" Margin="120,0,0,10"/>
                                </StackPanel>

                                <!--依赖配置-->
                                <StackPanel Visibility="{Binding RuleType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Dependency}">
                                    <TextBox hc:InfoElement.Title="依赖模块："
                                             hc:InfoElement.TitlePlacement="Left"
                                             hc:InfoElement.TitleWidth="120"
                                             Text="{Binding DependsOn, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TextBoxExtend}"
                                             Margin="0,0,0,10"/>
                                    <TextBlock Text="提示：多个依赖模块用逗号分隔，所有依赖模块都加载后才会加载此模块"
                                               Foreground="Gray" FontSize="12" TextWrapping="Wrap" Margin="120,0,0,10"/>
                                </StackPanel>

                                <!--许可证配置-->
                                <StackPanel Visibility="{Binding RuleType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=ByLicense}">
                                    <TextBox hc:InfoElement.Title="许可证Key："
                                             hc:InfoElement.TitlePlacement="Left"
                                             hc:InfoElement.TitleWidth="120"
                                             Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource TextBoxExtend}"
                                             Margin="0,0,0,10"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!--其他信息-->
                        <GroupBox Header="其他信息" Margin="0,0,0,15"
                                  hc:TitleElement.Background="{DynamicResource TitleBarBrush}">
                            <StackPanel Margin="10">
                                <TextBox hc:InfoElement.Title="跳过原因："
                                         hc:InfoElement.TitlePlacement="Left"
                                         hc:InfoElement.TitleWidth="120"
                                         Text="{Binding SkipReason, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource TextBoxExtend}"
                                         Margin="0,0,0,10"/>

                                <TextBox hc:InfoElement.Title="描述："
                                         hc:InfoElement.TitlePlacement="Left"
                                         hc:InfoElement.TitleWidth="120"
                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource TextBoxExtend}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Height="80"
                                         VerticalContentAlignment="Top"
                                         Margin="0,0,0,10"/>
                            </StackPanel>
                        </GroupBox>

                        <!--操作按钮-->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                            <Button Content="保存此项"
                                    Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Width="100" Height="35" Margin="0,0,10,0"/>
                            <Button Content="删除"
                                    Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Width="80" Height="35"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!--底部状态栏-->
        <Border Grid.Row="2" Padding="10" Margin="0,10,0,0">
            <TextBlock Text="提示：修改配置后需要重启应用才能生效" Foreground="Gray" FontSize="12"/>
        </Border>
    </Grid>
</UserControl>


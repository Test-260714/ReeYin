<UserControl x:Class="ReeYin.RootManager.Views.ComponentPreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" Background="Transparent"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="640" d:DesignWidth="980">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--左侧模块分类-->
        <Border Grid.Column="0" BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource BorderBrush}" Padding="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="模块分类" FontSize="13" FontWeight="Bold"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="12,4,0,4"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                         DisplayMemberPath="Header"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         FontSize="13"/>
            </Grid>
        </Border>

        <!--右侧内容区-->
        <Grid Grid.Column="1" Margin="16,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!--工具栏-->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                <Button Command="{Binding GeneralCommand}" CommandParameter="全选"
                        Style="{StaticResource GeneralButtonStyle}"
                        Height="34" Width="68" FontSize="14"
                        Content="全选" Margin="0,0,8,0" Cursor="Hand"/>
                <Button Command="{Binding GeneralCommand}" CommandParameter="全不选"
                        Style="{StaticResource GeneralButtonStyle}"
                        Height="34" Width="80" FontSize="14"
                        Content="全不选" Margin="0,0,8,0" Cursor="Hand"/>
                <Button Command="{Binding GeneralCommand}" CommandParameter="刷新条件"
                        Style="{StaticResource GeneralButtonStyle}"
                        Height="34" Width="92" FontSize="14"
                        Content="刷新条件" Cursor="Hand"/>
            </StackPanel>

            <!--模块分组列表-->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ModuleInfos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,20">

                                <!--分组标题行-->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Header}"
                                               FontSize="14" FontWeight="Medium"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Border Grid.Column="1" Height="1" VerticalAlignment="Center"
                                            Background="{DynamicResource BorderBrush}"/>
                                </Grid>

                                <!--模块卡片-->
                                <ItemsControl ItemsSource="{Binding Children}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="128" Margin="0,0,10,10"
                                                    CornerRadius="10" BorderThickness="1"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!--图标 + 名称-->
                                                    <StackPanel Grid.Row="0" VerticalAlignment="Center"
                                                                HorizontalAlignment="Center" Margin="10,14,10,8">
                                                        <TextBlock Text="{Binding Icon}" FontSize="40"
                                                                   FontFamily="{StaticResource Iconfont}"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Title}" FontSize="13"
                                                                   TextAlignment="Center" TextWrapping="Wrap"
                                                                   MaxWidth="108" Margin="0,6,0,0"/>
                                                    </StackPanel>

                                                    <!--启用开关-->
                                                    <Border Grid.Row="1" Padding="0,6,0,10">
                                                        <ToggleButton IsChecked="{Binding IsUsing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      IsEnabled="{Binding CanLoad}"
                                                                      Style="{StaticResource ToggleButtonSwitch}"
                                                                      HorizontalAlignment="Center"/>
                                                    </Border>

                                                    <!--加载失败条-->
                                                    <Border Grid.Row="2" Background="OrangeRed" Padding="6,4"
                                                            Visibility="{Binding CanLoad, Converter={StaticResource Boolean2VisibilityReConverter}}">
                                                        <TextBlock Text="{Binding LoadFailReason}"
                                                                   Foreground="White" FontSize="10"
                                                                   TextAlignment="Center" TextWrapping="Wrap"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>

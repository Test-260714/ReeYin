<UserControl x:Class="ReeYin.RootManager.Views.UpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ReeYin.RootManager.Views"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" Background="Transparent"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="900" Height="650"
             d:DesignHeight="650" d:DesignWidth="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--标题和版本信息-->
        <Border Grid.Row="0" Padding="10" Margin="0,0,0,10"
                Background="{DynamicResource RegionBrush}" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="软件更新" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="支持在线更新和离线包更新两种方式" FontSize="12" Foreground="Gray" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Text="当前版本" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Model.CurrentVersion}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--模式切换-->
        <Border Grid.Row="1" Padding="10" Margin="0,0,0,10"
                Background="{DynamicResource RegionBrush}" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <RadioButton Grid.Column="0" GroupName="UpdateMode" Content="在线更新"
                             IsChecked="{Binding Model.IsOfflineMode, Converter={StaticResource Boolean2BooleanReConverter}}"
                             Command="{Binding SwitchToOnlineCommand}"
                             Style="{StaticResource RadioButtonIcon}" FontSize="16"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <RadioButton Grid.Column="1" GroupName="UpdateMode" Content="离线更新"
                             IsChecked="{Binding Model.IsOfflineMode}"
                             Command="{Binding SwitchToOfflineCommand}"
                             Style="{StaticResource RadioButtonIcon}" FontSize="16"
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!--主内容区域-->
        <Grid Grid.Row="2">
            <!--在线更新面板-->
            <Grid Visibility="{Binding Model.IsOfflineMode, Converter={StaticResource Boolean2VisibilityReConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!--在线配置-->
                <WxGroupBox:WxGroupBox Header="服务器配置" Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="服务器地址："
                                     Style="{StaticResource TextBoxExtend}"
                                     Text="{Binding Model.ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     hc:InfoElement.TitleWidth="90" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="授权码："
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding Model.LicenseKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         hc:InfoElement.TitleWidth="90" Margin="0,0,10,0"/>
                                <CheckBox Grid.Column="1" Content="包含预发布版本"
                                          IsChecked="{Binding Model.IncludePreRelease, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                        <Button Grid.Column="1" Content="检查更新" Command="{Binding CheckOnlineCommand}"
                                Style="{StaticResource GeneralButtonStyle}"
                                Height="50" Width="100" Margin="15,0,0,0"
                                IsEnabled="{Binding Model.IsChecking, Converter={StaticResource Boolean2BooleanReConverter}}"
                                Cursor="Hand"/>
                    </Grid>
                </WxGroupBox:WxGroupBox>

                <!--可用更新列表-->
                <WxGroupBox:WxGroupBox Header="可用更新" Grid.Row="1" Margin="0,10,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0" ItemsSource="{Binding Model.AvailableUpdates}"
                                  SelectedItem="{Binding Model.SelectedUpdate, Mode=TwoWay}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  Background="Transparent" BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="70"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding UpdateType}" Width="70"/>
                                <DataGridTextColumn Header="大小" Binding="{Binding FileSize, StringFormat={}{0:N0} B}" Width="90"/>
                                <DataGridTextColumn Header="发布日期" Binding="{Binding ReleaseDate, StringFormat=yyyy-MM-dd}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!--更新详情-->
                        <Border Grid.Column="1" Margin="10,0,0,0" Padding="10"
                                Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="5">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel DataContext="{Binding Model.SelectedUpdate}">
                                    <TextBlock Text="更新详情" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="Gray"
                                               TextWrapping="Wrap" Margin="0,5,0,8"/>
                                    <Separator Margin="0,5"/>
                                    <TextBlock Text="更新日志" FontSize="12" FontWeight="SemiBold" Margin="0,5,0,3"/>
                                    <TextBlock Text="{Binding ChangeLog}" FontSize="11" TextWrapping="Wrap"
                                               Foreground="{DynamicResource SecondaryTextBrush}" MaxHeight="150"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </WxGroupBox:WxGroupBox>
            </Grid>

            <!--离线更新面板-->
            <Grid Visibility="{Binding Model.IsOfflineMode, Converter={StaticResource Boolean2VisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!--选择离线包-->
                <WxGroupBox:WxGroupBox Header="选择更新包" Grid.Row="0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" IsReadOnly="True"
                                 Text="{Binding Model.OfflinePackagePath, Mode=OneWay}"
                                 hc:InfoElement.Placeholder="点击右侧按钮选择更新包文件..."
                                 Style="{StaticResource TextBoxExtend}"/>
                        <Button Grid.Column="1" Content="浏览..." Command="{Binding SelectOfflinePackageCommand}"
                                Style="{StaticResource GeneralButtonStyle}"
                                Height="35" Width="80" Margin="10,0,0,0"
                                Cursor="Hand"/>
                        <Button Grid.Column="2" Content="清除" Command="{Binding ClearOfflinePackageCommand}"
                                Style="{StaticResource GeneralButtonStyle}"
                                Height="35" Width="60" Margin="10,0,0,0"
                                Cursor="Hand"/>
                    </Grid>
                </WxGroupBox:WxGroupBox>

                <!--离线包信息-->
                <WxGroupBox:WxGroupBox Header="更新包信息" Grid.Row="1" Margin="0,10,0,0">
                    <Grid DataContext="{Binding Model.OfflinePackageInfo}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <!--无包时的提示-->
                        <StackPanel Grid.Row="0" Grid.RowSpan="2"
                                    Visibility="{Binding DataContext.Model.OfflinePackageInfo, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource Object2VisibilityReConverter}}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe636;" FontFamily="{StaticResource Iconfont}" FontSize="80"
                                       Foreground="Gray" HorizontalAlignment="Center"/>
                            <TextBlock Text="请选择离线更新包" FontSize="16" Foreground="Gray"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="支持 .zip 和 .reeyin 格式" FontSize="12" Foreground="DarkGray"
                                       HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!--包信息显示-->
                        <Grid Visibility="{Binding DataContext.Model.OfflinePackageInfo, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource Object2VisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!--图标-->
                            <Border Grid.Column="0" Width="120" Height="120" Margin="0,0,20,0"
                                    Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="10">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xe7b2;" FontFamily="{StaticResource Iconfont}" FontSize="50"
                                               Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Version, StringFormat=v{0}}" FontSize="14" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>

                            <!--详细信息-->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="文件名：" FontWeight="SemiBold" Width="70"/>
                                    <TextBlock Text="{Binding FileName}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="文件大小：" FontWeight="SemiBold" Width="70"/>
                                    <TextBlock Text="{Binding FormattedSize}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="创建时间：" FontWeight="SemiBold" Width="70"/>
                                    <TextBlock Text="{Binding CreateTime, StringFormat=yyyy-MM-dd HH:mm:ss}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="验证状态：" FontWeight="SemiBold" Width="70"/>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding ValidationMessage}"/>
                                                <Setter Property="Foreground" Value="Green"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsValid}" Value="False">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </WxGroupBox:WxGroupBox>
            </Grid>
        </Grid>

        <!--底部操作区域-->
        <Border Grid.Row="3" Margin="0,10,0,0" Padding="12"
                Background="{DynamicResource RegionBrush}" CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!--进度显示-->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Model.UpdateStatus}" FontSize="13" Margin="0,0,0,5"/>
                    <ProgressBar Value="{Binding Model.UpdateProgress}" Height="18"
                                 Visibility="{Binding Model.IsUpdating, Converter={StaticResource Boolean2VisibilityConverter}}"/>
                </StackPanel>

                <!--操作按钮-->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!--取消按钮-->
                    <Button Content="取消" Command="{Binding CancelUpdateCommand}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="40" Width="80" Margin="0,0,10,0"
                            Visibility="{Binding Model.IsUpdating, Converter={StaticResource Boolean2VisibilityConverter}}"
                            Cursor="Hand"/>

                    <!--在线模式：下载安装按钮-->
                    <Button Content="下载并安装" Command="{Binding DownloadInstallCommand}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="40" Width="110"
                            Visibility="{Binding Model.IsOfflineMode, Converter={StaticResource Boolean2VisibilityReConverter}}"
                            IsEnabled="{Binding Model.IsUpdating, Converter={StaticResource Boolean2BooleanReConverter}}"
                            Cursor="Hand"/>

                    <!--离线模式：安装按钮-->
                    <Button Content="安装更新" Command="{Binding InstallOfflineCommand}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="40" Width="110"
                            Visibility="{Binding Model.IsOfflineMode, Converter={StaticResource Boolean2VisibilityConverter}}"
                            IsEnabled="{Binding Model.IsUpdating, Converter={StaticResource Boolean2BooleanReConverter}}"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="ReeYin_V.Initialize.Views.LoadingWaitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ReeYin_V.Initialize.Views"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="600" Height="400"
             d:DesignHeight="400" d:DesignWidth="600">

    <UserControl.Resources>
        <!-- 旋转动画 -->
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1"/>
        </Storyboard>

        <!-- 脉冲点动画 -->
        <Storyboard x:Key="DotPulse" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0.15"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.15"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.15"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="0.15"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.15"/>
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0.0" Value="0.15"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.15"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- 内容入场动画 -->
        <Storyboard x:Key="EntranceAnimation">
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentSlide"
                             Storyboard.TargetProperty="Y"
                             From="30" To="0" Duration="0:0:0.8">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SpinAnimation}"/>
            <BeginStoryboard Storyboard="{StaticResource DotPulse}"/>
            <BeginStoryboard Storyboard="{StaticResource EntranceAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <!-- 背景图 -->
        <Grid.Background>
            <ImageBrush ImageSource="{DynamicResource Icon_Login_BG}"
                        Stretch="UniformToFill" Opacity="0.35"/>
        </Grid.Background>

        <!-- 深色渐变遮罩 -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#CC1A1C24" Offset="0"/>
                    <GradientStop Color="#EE101218" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- 内容卡片 -->
        <Border x:Name="ContentPanel" Opacity="0"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                CornerRadius="16" Padding="56,40"
                MinWidth="360">
            <Border.RenderTransform>
                <TranslateTransform x:Name="ContentSlide" Y="30"/>
            </Border.RenderTransform>
            <Border.Background>
                <SolidColorBrush Color="#18FFFFFF"/>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="48" Opacity="0.35" ShadowDepth="0" Color="Black"/>
            </Border.Effect>

            <StackPanel HorizontalAlignment="Center">
                <!-- Logo -->
                <Image Source="{DynamicResource Icon_MainLogo}"
                       Height="44" Margin="0,0,0,36"
                       HorizontalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>

                <!-- 自定义旋转加载环 -->
                <Canvas Width="60" Height="60" HorizontalAlignment="Center" Margin="0,0,0,28">
                    <!-- 轨道圆环 -->
                    <Ellipse Canvas.Left="4" Canvas.Top="4" Width="52" Height="52"
                             Stroke="#18FFFFFF" StrokeThickness="3" Fill="Transparent"/>
                    <!-- 旋转弧线 -->
                    <Path Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="3" 
                          Data="M30,4 A26,26 0 0 1 54,39">
                        <Path.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" CenterX="30" CenterY="30"/>
                        </Path.RenderTransform>
                    </Path>
                </Canvas>

                <!-- 状态消息 -->
                <TextBlock Text="{Binding Message}"
                           Foreground="#CCFFFFFF" FontSize="14"
                           FontWeight="Light"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"/>

                <!-- 脉冲指示点 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse x:Name="Dot1" Width="6" Height="6" Fill="{DynamicResource PrimaryBrush}" Margin="0,0,8,0" Opacity="0.15"/>
                    <Ellipse x:Name="Dot2" Width="6" Height="6" Fill="{DynamicResource PrimaryBrush}" Margin="0,0,8,0" Opacity="0.15"/>
                    <Ellipse x:Name="Dot3" Width="6" Height="6" Fill="{DynamicResource PrimaryBrush}" Opacity="0.15"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

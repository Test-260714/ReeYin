<UserControl x:Class="ReeYin_V.License.Views.LicenseActivationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="860"
             Width="860"
             Height="650"
             FontSize="{DynamicResource DefaultFontSize}"
             Foreground="{DynamicResource TextBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{DynamicResource MainBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WxGroupBox:WxGroupBox Grid.Row="0"
                                       Header="机器码"
                                       Icon="">
                    <Border Background="{DynamicResource RegionBackgroundBrush}"
                            BorderBrush="{DynamicResource MainTopSepBrush}"
                            BorderThickness="1"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox Text="{Binding MachineCode, Mode=OneWay}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource RegionBackgroundBrush}"
                                     BorderBrush="{StaticResource TextBox.Static.Border}"
                                     Foreground="{DynamicResource TextBrush}"
                                     FontFamily="Consolas"
                                     FontSize="13"
                                     Padding="10"
                                     Height="38" />

                            <StackPanel Grid.Row="1"
                                        Margin="0,12,0,0"
                                        Orientation="Horizontal">
                                <Button Style="{StaticResource GeneralButtonStyle}"
                                        Margin="0,0,8,0"
                                        MinWidth="110"
                                        Content="刷新机器码"
                                        Command="{Binding RefreshMachineCodeCommand}" />
                                <Button Style="{StaticResource GeneralButtonStyle}"
                                        Margin="0,0,8,0"
                                        MinWidth="120"
                                        Content="校验当前授权"
                                        Command="{Binding ValidateCurrentLicenseCommand}" />
                                <Button Style="{StaticResource GeneralButtonStyle}"
                                        Margin="0,0,8,0"
                                        MinWidth="130"
                                        Content="导入 License 文件"
                                        Command="{Binding ImportLicenseCommand}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </WxGroupBox:WxGroupBox>

                <WxGroupBox:WxGroupBox Grid.Row="1"
                                       Header="授权状态"
                                       Icon=""
                                       Margin="0,14,0,0">
                    <Border Background="{DynamicResource RegionBackgroundBrush}"
                            BorderBrush="{DynamicResource MainTopSepBrush}"
                            BorderThickness="1"
                            Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Ellipse Width="12"
                                     Height="12"
                                     Margin="0,3,8,0"
                                     Fill="{Binding StatusBrush}" />

                            <StackPanel Grid.Column="1">
                                <TextBlock Foreground="{Binding StatusBrush}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           Text="{Binding StatusText}" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                           Text="{Binding LastCheckTime, StringFormat=最后校验: {0}}" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                           TextWrapping="Wrap"
                                           Text="{Binding LicenseFilePath, StringFormat=License 文件: {0}}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </WxGroupBox:WxGroupBox>

                <WxGroupBox:WxGroupBox Grid.Row="2"
                                       Header="授权信息"
                                       Icon=""
                                       Margin="0,14,0,0">
                    <Border Background="{DynamicResource RegionBackgroundBrush}"
                            BorderBrush="{DynamicResource MainTopSepBrush}"
                            BorderThickness="1"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                       Text="客户名称" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Foreground="{DynamicResource TextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding CustomerName}" />

                            <TextBlock Grid.Row="1"
                                       Grid.Column="0"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                       Text="授权类型" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource TextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding LicenseType}" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                       Text="到期时间" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource TextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding ExpireTime}" />

                            <TextBlock Grid.Row="3"
                                       Grid.Column="0"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                       Text="版本" />
                            <TextBlock Grid.Row="3"
                                       Grid.Column="1"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource TextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding Version}" />
                        </Grid>
                    </Border>
                </WxGroupBox:WxGroupBox>

                <WxGroupBox:WxGroupBox Grid.Row="3"
                                       Header="模块权限"
                                       Icon=""
                                       Margin="0,14,0,0">
                    <Border Background="{DynamicResource RegionBackgroundBrush}"
                            BorderBrush="{DynamicResource MainTopSepBrush}"
                            BorderThickness="1"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Foreground="{DynamicResource TextBrush}"
                                       TextWrapping="Wrap"
                                       Text="{Binding Modules}" />
                            <Button Grid.Row="1"
                                    HorizontalAlignment="Right"
                                    Margin="0,14,0,0"
                                    MinWidth="90"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Content="关闭"
                                    Command="{Binding CloseCommand}" />
                        </Grid>
                    </Border>
                </WxGroupBox:WxGroupBox>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>

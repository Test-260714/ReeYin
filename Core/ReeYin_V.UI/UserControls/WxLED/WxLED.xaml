<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cx="clr-namespace:ReeYin_V.UI.UserControls.WxLED">
    
    <!-- 在App.xaml或资源字典中添加样式 -->
    <Style TargetType="{x:Type cx:WxLED}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cx:WxLED}">
                    <Border x:Name="PART_LightBorder"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Background="{TemplateBinding Background}">
                        <Border.Effect>
                            <DropShadowEffect x:Name="PART_GlowEffect" 
                                         ShadowDepth="0" 
                                         BlurRadius="10"
                                         Color="{Binding Background.Color, RelativeSource={RelativeSource TemplatedParent}}"
                                         Opacity="0.7"/>
                        </Border.Effect>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Black"/>
    </Style>

</ResourceDictionary>
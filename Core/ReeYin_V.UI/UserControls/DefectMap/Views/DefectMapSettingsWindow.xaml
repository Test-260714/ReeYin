<Window x:Class="ReeYin_V.UI.UserControls.DefectMap.DefectMapSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="缺陷类型设置"
        Width="980"
        Height="620"
        MinWidth="820"
        MinHeight="480"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <SolidColorBrush x:Key="DefectMapSettingsPanelBrush" Color="#F7FAFD" />
        <SolidColorBrush x:Key="DefectMapSettingsBorderBrush" Color="#D8E4EF" />
        <SolidColorBrush x:Key="DefectMapSettingsTextBrush" Color="#243547" />
        <SolidColorBrush x:Key="DefectMapSettingsHintBrush" Color="#66798B" />
    </Window.Resources>

    <Grid Margin="14" Background="{StaticResource DefectMapSettingsPanelBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button MinWidth="86"
                        Height="30"
                        Margin="0,0,8,0"
                        Content="新增"
                        Command="{Binding AddTypeStyleCommand}" />
                <Button MinWidth="86"
                        Height="30"
                        Margin="0,0,8,0"
                        Content="删除"
                        Command="{Binding RemoveTypeStyleCommand}" />
                <Button MinWidth="96"
                        Height="30"
                        Content="重置默认"
                        Command="{Binding ResetTypeStylesCommand}" />
            </StackPanel>
            <TextBlock Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="{StaticResource DefectMapSettingsHintBrush}"
                       Text="可编辑缺陷类型名称、颜色、大小、形状和默认等级，修改后映射图立即刷新。" />
        </DockPanel>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource DefectMapSettingsBorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <DataGrid AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      ItemsSource="{Binding DefectTypeStyles}"
                      SelectedItem="{Binding SelectedTypeStyle, Mode=TwoWay}"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="启用"
                                            Width="70"
                                            Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <DataGridTextColumn Header="类型标识"
                                        Width="120"
                                        Binding="{Binding TypeKey, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                    <DataGridTextColumn Header="名称"
                                        Width="130"
                                        Binding="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                    <DataGridTemplateColumn Header="颜色" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="16"
                                            Height="16"
                                            Margin="0,0,6,0"
                                            Background="{Binding MarkerBrush}"
                                            BorderBrush="#66000000"
                                            BorderThickness="1" />
                                    <TextBlock Text="{Binding ColorText}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding ColorText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="大小"
                                        Width="80"
                                        Binding="{Binding MarkerSize, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F0}" />
                    <DataGridTemplateColumn Header="形状" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MarkerShape}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.MarkerShapeOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding MarkerShape, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="等级" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DefaultSeverity}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.SeverityOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                          SelectedItem="{Binding DefaultSeverity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="描述"
                                        Width="*"
                                        Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button MinWidth="88"
                    Height="30"
                    Content="关闭"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>

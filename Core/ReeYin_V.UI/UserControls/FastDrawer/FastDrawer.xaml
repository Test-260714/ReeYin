<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:ReeYin_V.UI.UserControls.FastDrawer"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/FontAwesome.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Converter.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/CustomBrush.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <local:MultiplyConverter x:Key="multiplyConverter" />

    <Style x:Key="QToggleButton" TargetType="{x:Type ToggleButton}">
        <Setter Property="FontFamily" Value="{StaticResource Iconfont}" />
        <Setter Property="FontSize" Value="25"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="Transparent"></Setter>
        <Setter Property="Padding" Value="3"></Setter>
        <Setter Property="Height" Value="auto"></Setter>
        <Setter Property="SnapsToDevicePixels" Value="true"></Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Grid x:Name="grid" VerticalAlignment="Center">
                        <Border BorderThickness="{TemplateBinding BorderThickness}" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" HorizontalAlignment="Center"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" Margin="{TemplateBinding Padding}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </Grid>
                    <!--触发器：设置选中状态符号-->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed"  Value="true">
                            <Setter Property="Foreground" Value="#4EAD42"></Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    
    <Style TargetType="{x:Type local:FastDrawer}">
        <Setter Property="FontFamily" Value="{StaticResource Iconfont}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:FastDrawer}">

                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" Opacity="1"
                                Height="38" VerticalAlignment="Top" CornerRadius="10 0 0 10">

                            <ToggleButton x:Name="tbLeft" Style="{StaticResource QToggleButton}" Cursor="Hand"
                                          IsChecked="{Binding IsShow, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" FontFamily="{StaticResource Iconfont}"/>

                        </Border>

                        <ScrollViewer Grid.Column="1" x:Name="ExpanderContentScrollView"
                                      HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden">
                            <ScrollViewer.Tag>
                                <sys:Double>0.0</sys:Double>
                            </ScrollViewer.Tag>
                            <ScrollViewer.Width>
                                <MultiBinding Converter="{StaticResource multiplyConverter}">
                                    <Binding Path="ActualWidth" ElementName="ExpanderContent"/>
                                    <Binding Path="Tag" RelativeSource="{RelativeSource Self}" />
                                </MultiBinding>
                            </ScrollViewer.Width>
                            <ContentPresenter x:Name="ExpanderContent"/>
                        </ScrollViewer>

                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--激活状态-->
                        <Trigger Property="IsShow" Value="true">
                            <Setter Property="Content" Value="&#xe648;" TargetName="tbLeft"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard >
                                    <Storyboard >
                                        <DoubleAnimation 
                                            Storyboard.TargetName="ExpanderContentScrollView" Storyboard.TargetProperty="Tag"
                                            From="0" To="1" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard >
                                    <Storyboard >
                                        <DoubleAnimation 
                                            Storyboard.TargetName="ExpanderContentScrollView" Storyboard.TargetProperty="Tag"
                                            From="1" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!--非激活状态-->
                        <Trigger Property="IsShow" Value="false">
                            <Setter Property="Content" Value="&#xe613;" TargetName="tbLeft"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    
    <Style x:Key="LeftMode" TargetType="{x:Type local:FastDrawer}">
        <Setter Property="FontFamily" Value="{StaticResource Iconfont}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:FastDrawer}">

                    <Grid HorizontalAlignment="Right">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="38"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" Opacity="1" 
                                Height="38" VerticalAlignment="Top" CornerRadius="10 0 0 10" Margin="0 0 0 0">

                            <ToggleButton x:Name="tbLeft" Style="{StaticResource QToggleButton}" Cursor="Hand"
                                          IsChecked="{Binding IsShow, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                        </Border>

                        <ScrollViewer Grid.Column="1" x:Name="ExpanderContentScrollView"
                                      HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden">
                            <ScrollViewer.Tag>
                                <sys:Double>0.0</sys:Double>
                            </ScrollViewer.Tag>
                            <ScrollViewer.Width>
                                <MultiBinding Converter="{StaticResource multiplyConverter}">
                                    <Binding Path="ActualWidth" ElementName="ExpanderContent"/>
                                    <Binding Path="Tag" RelativeSource="{RelativeSource Self}" />
                                </MultiBinding>
                            </ScrollViewer.Width>
                            <ContentPresenter x:Name="ExpanderContent"/>
                        </ScrollViewer>

                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--激活状态-->
                        <Trigger Property="IsShow" Value="true">
                            <Setter Property="Content" Value="&#xe648;" TargetName="tbLeft"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard >
                                    <Storyboard >
                                        <DoubleAnimation 
                                            Storyboard.TargetName="ExpanderContentScrollView" Storyboard.TargetProperty="Tag"
                                            From="0" To="1" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard >
                                    <Storyboard >
                                        <DoubleAnimation 
                                            Storyboard.TargetName="ExpanderContentScrollView" Storyboard.TargetProperty="Tag"
                                            From="1" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!--非激活状态-->
                        <Trigger Property="IsShow" Value="false">
                            <Setter Property="Content" Value="&#xe613;" TargetName="tbLeft"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="RightMode" TargetType="{x:Type local:FastDrawer}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:FastDrawer}">
                    <!-- 整体布局改为从右侧开始 -->
                    <Grid HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>

                        <!-- 按钮移至右侧，圆角方向调整 -->
                        <Border Grid.Column="1" Background="{StaticResource PrimaryBrush}" Opacity="1" 
                            Height="38" VerticalAlignment="Top" CornerRadius="0 10 10 0" Margin="-5 0 0 0">
                            <ToggleButton x:Name="tbLeft" Style="{StaticResource QToggleButton}" Cursor="Hand"
                                      IsChecked="{Binding IsShow, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Border>

                        <!-- 内容区域移至左侧 -->
                        <ScrollViewer Grid.Column="0" x:Name="ExpanderContentScrollView"
                                  HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden">
                            <ScrollViewer.Tag>
                                <sys:Double>0.0</sys:Double>
                            </ScrollViewer.Tag>
                            <ScrollViewer.Width>
                                <MultiBinding Converter="{StaticResource multiplyConverter}">
                                    <Binding Path="ActualWidth" ElementName="ExpanderContent"/>
                                    <Binding Path="Tag" RelativeSource="{RelativeSource Self}" />
                                </MultiBinding>
                            </ScrollViewer.Width>
                            <ContentPresenter x:Name="ExpanderContent"/>
                        </ScrollViewer>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- 激活状态：修改图标为向左箭头 -->
                        <Trigger Property="IsShow" Value="true">
                            <Setter Property="Content" Value="&#xe613;" TargetName="tbLeft"/>
                            <!-- 改为向左箭头 -->
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation 
                                        Storyboard.TargetName="ExpanderContentScrollView" Storyboard.TargetProperty="Tag"
                                        From="0" To="1" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation 
                                        Storyboard.TargetName="ExpanderContentScrollView" Storyboard.TargetProperty="Tag"
                                        From="1" To="0" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- 非激活状态：修改图标为向右箭头 -->
                        <Trigger Property="IsShow" Value="false">
                            <Setter Property="Content" Value="&#xe648;" TargetName="tbLeft"/>
                            <!-- 改为向右箭头 -->
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
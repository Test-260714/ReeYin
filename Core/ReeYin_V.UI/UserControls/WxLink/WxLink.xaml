<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:cx="clr-namespace:ReeYin_V.UI.UserControls.WxLink"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:i="http://schemas.microsoft.com/xaml/behaviors">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/FontAwesome.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Converter.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Button.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type cx:WxLink}">
        <Setter Property="Foreground" Value="Black"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="FontSize" Value="{DynamicResource SmallFontSize}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type cx:WxLink}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid Background="{Binding Path=TitleBackground, RelativeSource={RelativeSource TemplatedParent}}">
                            <TextBlock TextAlignment="Left" Padding="5,2" IsHitTestVisible="False" VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                       Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}"
                                       Width="{Binding Path=TitleWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                       Text="{Binding Path=Title, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Grid>

                        <Border Grid.Column="1" x:Name="PART_Border" Background="Transparent"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{Binding Path=CornerRadius, RelativeSource={RelativeSource TemplatedParent}}"
                                Cursor="IBeam">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PART_TextBox" BorderBrush="Transparent" BorderThickness="0"
                                         HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                         VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                         FontSize="{TemplateBinding FontSize}" Padding="{TemplateBinding Padding}"
                                         Foreground="{TemplateBinding Foreground}" Background="Transparent"
                                         Text="{Binding Text, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType={x:Type TextBox}}}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="2 0 0 0">
                                    <!-- 链接按钮 -->
                                    <Button x:Name="PART_ButtonLink"
                                            FontFamily="{StaticResource Iconfont}" Content="&#xe60e;"
                                            FontSize="{TemplateBinding FontSize}"
                                            BorderBrush="Transparent" Background="Transparent"
                                            Foreground="#666666"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            ToolTip="链接参数"
                                            Cursor="Hand"
                                            Margin="0 0 2 0">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Click">
                                                <i:InvokeCommandAction Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ButtonLinkClickCommand}"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Button>
                                    <!-- 取消链接按钮 -->
                                    <Button x:Name="PART_ButtonCancel"
                                            FontFamily="{StaticResource Iconfont}" Content="&#xeaf2;"
                                            FontSize="{TemplateBinding FontSize}"
                                            BorderBrush="Transparent" Background="Transparent"
                                            Foreground="#999999"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            ToolTip="取消链接"
                                            Cursor="Hand">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="Click">
                                                <i:InvokeCommandAction Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ButtonCancelClickCommand}"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- 鼠标悬浮：边框高亮 + 按钮变色 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="PART_ButtonLink" Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="PART_ButtonCancel" Property="Foreground" Value="#F44336"/>
                        </Trigger>
                        <!-- 获得焦点：边框高亮 -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.7"/>
            </Trigger>
            <!-- 未链接状态：Text为空时边框灰色 -->
            <Trigger Property="Text" Value="">
                <Setter Property="BorderBrush" Value="#CCCCCC"/>
            </Trigger>
            <Trigger Property="Text" Value="{x:Null}">
                <Setter Property="BorderBrush" Value="#CCCCCC"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>

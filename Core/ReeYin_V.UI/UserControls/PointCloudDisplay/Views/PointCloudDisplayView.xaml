<UserControl x:Class="ReeYin_V.UI.UserControls.PointCloudDisplay.PointCloudDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lcusb="http://schemas.arction.com/ChartingMVVM/ultimate/"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded"
             d:DesignHeight="800"
             d:DesignWidth="1200">
    <UserControl.Resources>
        <Style x:Key="OverlayButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinWidth" Value="84" />
        </Style>
        <Style x:Key="OverlayLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="OverlayComboStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Width" Value="130" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Height" Value="28" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <lcusb:LightningChart ActiveView="View3D"
                              ChartName="{Binding ChartTitle}">
            <lcusb:LightningChart.View3D>
                <lcusb:View3D Lights="{Binding Lights3D}"
                              PointLineSeries3D="{Binding SeriesCollection}">
                    <lcusb:View3D.FrameBox>
                        <lcusb:FrameBox Style="AllEdges" />
                    </lcusb:View3D.FrameBox>
                    <lcusb:View3D.XAxisPrimary3D>
                        <lcusb:AxisX3D Minimum="{Binding AxisXMin}" Maximum="{Binding AxisXMax}">
                            <lcusb:AxisX3D.Units>
                                <lcusb:AxisTitle3D Text="X" />
                            </lcusb:AxisX3D.Units>
                        </lcusb:AxisX3D>
                    </lcusb:View3D.XAxisPrimary3D>
                    <lcusb:View3D.YAxisPrimary3D>
                        <lcusb:AxisY3D Minimum="{Binding AxisYMin}" Maximum="{Binding AxisYMax}">
                            <lcusb:AxisY3D.Units>
                                <lcusb:AxisTitle3D Text="Y" />
                            </lcusb:AxisY3D.Units>
                        </lcusb:AxisY3D>
                    </lcusb:View3D.YAxisPrimary3D>
                    <lcusb:View3D.ZAxisPrimary3D>
                        <lcusb:AxisZ3D Minimum="{Binding AxisZMin}" Maximum="{Binding AxisZMax}">
                            <lcusb:AxisZ3D.Units>
                                <lcusb:AxisTitle3D Text="Z" />
                            </lcusb:AxisZ3D.Units>
                        </lcusb:AxisZ3D>
                    </lcusb:View3D.ZAxisPrimary3D>
                    <lcusb:View3D.OrientationArrows>
                        <lcusb:OrientationArrowsOptions3D Visible="True" />
                    </lcusb:View3D.OrientationArrows>
                    <lcusb:View3D.Dimensions>
                        <lcusb:SizeDoubleXYZ Width="{Binding DimensionWidth}"
                                             Height="{Binding DimensionHeight}"
                                             Depth="{Binding DimensionDepth}" />
                    </lcusb:View3D.Dimensions>
                    <lcusb:View3D.ZoomPanOptions>
                        <lcusb:ZoomPanOptions3D DeviceSecondaryButtonAction="None"
                                                DevicePrimaryButtonDoubleClickAction="Off" />
                    </lcusb:View3D.ZoomPanOptions>
                    <lcusb:View3D.Camera>
                        <lcusb:Camera3D OrientationMode="{Binding CameraOrientationMode}"
                                        RotationX="{Binding RotationX, Mode=TwoWay}"
                                        RotationY="{Binding RotationY, Mode=TwoWay}"
                                        RotationZ="{Binding RotationZ, Mode=TwoWay}"
                                        ViewDistance="{Binding ViewDistance, Mode=TwoWay}"
                                        Projection="{Binding ProjectionType, Mode=TwoWay}" />
                    </lcusb:View3D.Camera>
                    <lcusb:View3D.WallOnTop><lcusb:WallXZ Visible="False" /></lcusb:View3D.WallOnTop>
                    <lcusb:View3D.WallOnRight><lcusb:WallYZ Visible="False" /></lcusb:View3D.WallOnRight>
                    <lcusb:View3D.WallOnLeft><lcusb:WallYZ Visible="False" /></lcusb:View3D.WallOnLeft>
                    <lcusb:View3D.WallOnFront><lcusb:WallXY Visible="False" /></lcusb:View3D.WallOnFront>
                    <lcusb:View3D.WallOnBottom><lcusb:WallXZ Visible="False" /></lcusb:View3D.WallOnBottom>
                    <lcusb:View3D.WallOnBack><lcusb:WallXY Visible="False" /></lcusb:View3D.WallOnBack>
                </lcusb:View3D>
            </lcusb:LightningChart.View3D>
            <lcusb:LightningChart.Title>
                <lcusb:ChartTitle Text="{Binding ChartTitle}" />
            </lcusb:LightningChart.Title>
            <lcusb:LightningChart.ChartBackground>
                <lcusb:Fill Color="#FF1B1E23"
                            GradientColor="#FF050607"
                            GradientDirection="-45"
                            GradientFill="Linear" />
            </lcusb:LightningChart.ChartBackground>
        </lcusb:LightningChart>

        <Expander Header="Show / Hide Panel"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Bottom"
                  Margin="10"
                  Background="#88000000"
                  Foreground="White"
                  IsExpanded="True">
            <Border Width="430"
                    CornerRadius="4"
                    Padding="12"
                    Background="#B2171A1F">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Load File" Click="OpenFileButton_Click" Style="{StaticResource OverlayButtonStyle}" />
                        <Button Content="Reset View" Click="ResetViewButton_Click" Style="{StaticResource OverlayButtonStyle}" />
                        <Button Content="Top View" Click="TopViewButton_Click" Style="{StaticResource OverlayButtonStyle}" />
                    </StackPanel>
                    <TextBox Margin="0,0,0,8"
                             IsReadOnly="True"
                             Text="{Binding SourceDescription, Mode=OneWay}" />
                    <WrapPanel>
                        <TextBlock Text="Color By" Style="{StaticResource OverlayLabelStyle}" Margin="0,0,8,8" />
                        <ComboBox x:Name="cb_ColorSource" SelectedIndex="3" SelectionChanged="DisplaySettingChanged" Style="{StaticResource OverlayComboStyle}">
                            <ComboBoxItem Content="Single" Tag="SingleColor" />
                            <ComboBoxItem Content="X Axis" Tag="XAxis" />
                            <ComboBoxItem Content="Y Axis" Tag="YAxis" />
                            <ComboBoxItem Content="Z Axis" Tag="ZAxis" />
                            <ComboBoxItem Content="Intensity" Tag="Intensity" />
                        </ComboBox>
                        <TextBlock Text="Palette" Style="{StaticResource OverlayLabelStyle}" Margin="0,0,8,8" />
                        <ComboBox x:Name="cb_PaletteType" SelectedIndex="0" SelectionChanged="DisplaySettingChanged" Style="{StaticResource OverlayComboStyle}">
                            <ComboBoxItem Content="Classic" Tag="Classic" />
                            <ComboBoxItem Content="Heatmap" Tag="Heatmap" />
                        </ComboBox>
                    </WrapPanel>
                    <WrapPanel>
                        <TextBlock Text="Point Shape" Style="{StaticResource OverlayLabelStyle}" Margin="0,0,8,8" />
                        <ComboBox x:Name="cb_PointShape" SelectedIndex="0" SelectionChanged="DisplaySettingChanged" Style="{StaticResource OverlayComboStyle}">
                            <ComboBoxItem Content="Sphere" Tag="Sphere" />
                            <ComboBoxItem Content="Box" Tag="Box" />
                            <ComboBoxItem Content="Cone" Tag="Cone" />
                        </ComboBox>
                        <TextBlock Text="Projection" Style="{StaticResource OverlayLabelStyle}" Margin="0,0,8,8" />
                        <ComboBox x:Name="cb_Projection" SelectedIndex="0" SelectionChanged="DisplaySettingChanged" Style="{StaticResource OverlayComboStyle}">
                            <ComboBoxItem Content="Perspective" Tag="Perspective" />
                            <ComboBoxItem Content="Orthographic" Tag="Orthographic" />
                        </ComboBox>
                    </WrapPanel>
                    <WrapPanel>
                        <CheckBox x:Name="cb_ConnectPoints"
                                  Margin="0,0,12,8"
                                  VerticalAlignment="Center"
                                  Foreground="White"
                                  IsChecked="True"
                                  Checked="DisplaySettingChanged"
                                  Unchecked="DisplaySettingChanged"
                                  Content="Connect Points" />
                        <CheckBox x:Name="cb_PlaneSmooth"
                                  Margin="0,0,12,8"
                                  VerticalAlignment="Center"
                                  Foreground="White"
                                  IsChecked="False"
                                  Checked="DisplaySettingChanged"
                                  Unchecked="DisplaySettingChanged"
                                  Content="Plane Smooth" />
                    </WrapPanel>
                    <Grid Margin="0,0,0,8"
                          IsEnabled="{Binding ElementName=cb_ConnectPoints, Path=IsChecked}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Point Size" Style="{StaticResource OverlayLabelStyle}" Margin="0,0,8,0" />
                        <Slider Grid.Column="1"
                                x:Name="slider_PointSize"
                                Minimum="0.2"
                                Maximum="6"
                                Value="1.5"
                                TickFrequency="0.2"
                                ValueChanged="DisplaySettingChanged" />
                        <TextBlock Grid.Column="2"
                                   Style="{StaticResource OverlayLabelStyle}"
                                   Margin="8,0,0,0"
                                   Text="{Binding ElementName=slider_PointSize, Path=Value, StringFormat={}{0:F1}}" />
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Line Width" Style="{StaticResource OverlayLabelStyle}" Margin="0,0,8,0" />
                        <Slider Grid.Column="1"
                                x:Name="slider_LineWidth"
                                Minimum="0.2"
                                Maximum="4"
                                Value="1.1"
                                TickFrequency="0.1"
                                ValueChanged="DisplaySettingChanged" />
                        <TextBlock Grid.Column="2"
                                   Style="{StaticResource OverlayLabelStyle}"
                                   Margin="8,0,0,0"
                                   Text="{Binding ElementName=slider_LineWidth, Path=Value, StringFormat={}{0:F1}}" />
                    </Grid>
                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Foreground="#FFF7F7F7" FontSize="11" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding DisplayModeText}" TextWrapping="Wrap" Foreground="#FFD0D7DE" FontSize="10" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding RangeText}" TextWrapping="Wrap" Foreground="#FFD0D7DE" FontSize="10" />
                </StackPanel>
            </Border>
        </Expander>
    </Grid>
</UserControl>

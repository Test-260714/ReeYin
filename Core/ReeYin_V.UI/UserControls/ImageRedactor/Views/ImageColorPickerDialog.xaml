<Window x:Class="ReeYin_V.UI.UserControls.ImageRedactor.ImageColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pick Draw Color"
        Width="420"
        Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="PreviewBorder"
                Grid.Row="0"
                Height="68"
                CornerRadius="6"
                BorderBrush="#FF9AA6B2"
                BorderThickness="1"
                Background="#FFFFA500">
            <TextBlock HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="Preview" />
        </Border>

        <Grid Grid.Row="1" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="52" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="A" />
            <Slider x:Name="AlphaSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="255"
                    ValueChanged="Slider_ValueChanged" />
            <TextBox x:Name="AlphaTextBox"
                     Grid.Column="2"
                     Margin="8,0,0,0"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center" />
        </Grid>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="52" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="R" />
            <Slider x:Name="RedSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="255"
                    ValueChanged="Slider_ValueChanged" />
            <TextBox x:Name="RedTextBox"
                     Grid.Column="2"
                     Margin="8,0,0,0"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center" />
        </Grid>

        <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="52" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="G" />
            <Slider x:Name="GreenSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="255"
                    ValueChanged="Slider_ValueChanged" />
            <TextBox x:Name="GreenTextBox"
                     Grid.Column="2"
                     Margin="8,0,0,0"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center" />
        </Grid>

        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="52" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="B" />
            <Slider x:Name="BlueSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="255"
                    ValueChanged="Slider_ValueChanged" />
            <TextBox x:Name="BlueTextBox"
                     Grid.Column="2"
                     Margin="8,0,0,0"
                     IsReadOnly="True"
                     VerticalContentAlignment="Center" />
        </Grid>

        <StackPanel Grid.Row="5"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="88"
                    Margin="0,0,8,0"
                    Content="OK"
                    Click="OkButton_Click" />
            <Button Width="88"
                    Content="Cancel"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>

<UserControl x:Class="ReeYin_V.UI.UserControls.ImageRedactor.ImageRedactorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lcusb="http://schemas.arction.com/ChartingMVVM/ultimate/"
             mc:Ignorable="d"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded"
             MinWidth="720"
             MinHeight="420"
             d:DesignWidth="1080"
             d:DesignHeight="640">
    <Grid Background="#FF1B1E23">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="300" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="12"
                BorderBrush="#334D5966"
                BorderThickness="1"
                CornerRadius="8"
                Background="#FF101418">
            <lcusb:LightningChart x:Name="PART_Chart"
                                  ActiveView="ViewXY"
                                  ChartName="Image Redactor">
                <lcusb:LightningChart.ViewXY>
                    <lcusb:ViewXY XAxes="{Binding XAxes}"
                                  YAxes="{Binding YAxes}"
                                  Annotations="{Binding Annotations}"
                                  FreeformPointLineSeries="{Binding FreeformPointLineSeries}"
                                  PolygonSeries="{Binding PolygonSeriesCollection}"
                                  Margins="0">
                        <lcusb:ViewXY.AxisLayout>
                            <lcusb:AxisLayout XAxisAutoPlacement="Off"
                                              YAxisAutoPlacement="Off"
                                              AutoAdjustMargins="False" />
                        </lcusb:ViewXY.AxisLayout>
                    </lcusb:ViewXY>
                </lcusb:LightningChart.ViewXY>
                <lcusb:LightningChart.Title>
                    <lcusb:ChartTitle Text="Image Redactor" />
                </lcusb:LightningChart.Title>
                <lcusb:LightningChart.ChartBackground>
                    <lcusb:Fill Color="#FF11161A"
                                GradientColor="#FF090C10"
                                GradientDirection="-45"
                                GradientFill="Linear" />
                </lcusb:LightningChart.ChartBackground>
            </lcusb:LightningChart>
        </Border>

        <Border Grid.Column="1"
                Margin="0,12,12,12"
                Padding="12"
                BorderBrush="#334D5966"
                BorderThickness="1"
                CornerRadius="8"
                Background="#FF171B20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <GroupBox Header="Background Image" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <WrapPanel Margin="0,0,0,8">
                                <Button Width="118"
                                        Margin="0,0,8,0"
                                        Content="Open Image"
                                        Click="OpenImageButton_Click" />
                                <Button Width="118"
                                        Content="Fit View"
                                        Click="ZoomToFitButton_Click" />
                            </WrapPanel>
                            <TextBlock Text="{Binding StatusText}"
                                       TextWrapping="Wrap"
                                       Foreground="#FFD9E1EA" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Text Annotation" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <TextBlock Margin="0,0,0,4"
                                       Foreground="#FFD9E1EA"
                                       Text="Annotation Text" />
                            <TextBox Margin="0,0,0,8"
                                     Text="{Binding AnnotationText, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Content="Add Text"
                                    Click="AddTextAnnotationButton_Click" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Bitmap Annotation" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <WrapPanel Margin="0,0,0,8">
                                <Button Width="118"
                                        Margin="0,0,8,0"
                                        Content="Select Bitmap"
                                        Click="SelectAnnotationImageButton_Click" />
                                <Button Width="118"
                                        Content="Add Bitmap"
                                        Click="AddBitmapAnnotationButton_Click" />
                            </WrapPanel>
                            <Border Width="160"
                                    Height="100"
                                    HorizontalAlignment="Left"
                                    BorderBrush="#334D5966"
                                    BorderThickness="1"
                                    Background="#FF0E1318">
                                <Image Stretch="Uniform"
                                       Source="{Binding AnnotationImagePreview}" />
                            </Border>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Draw" Margin="0,0,0,12">
                        <StackPanel Margin="8">
                            <WrapPanel Margin="0,0,0,8">
                                <TextBlock Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Foreground="#FFD9E1EA"
                                           Text="Color" />
                                <Button Width="80"
                                        Margin="0,0,8,0"
                                        Click="PickColorButton_Click">
                                    <Button.Background>
                                        <SolidColorBrush Color="{Binding DrawColor}" />
                                    </Button.Background>
                                </Button>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#FFD9E1EA"
                                           Text="{Binding DrawColor}" />
                            </WrapPanel>

                            <TextBlock Margin="0,0,0,4"
                                       Foreground="#FFD9E1EA"
                                       Text="Line Width" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="56" />
                                </Grid.ColumnDefinitions>
                                <Slider x:Name="LineWidthSlider"
                                        Minimum="1"
                                        Maximum="8"
                                        Value="2"
                                        TickFrequency="0.5"
                                        IsSnapToTickEnabled="False"
                                        ValueChanged="LineWidthSlider_ValueChanged" />
                                <TextBlock Grid.Column="1"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#FFD9E1EA"
                                           Text="{Binding ElementName=LineWidthSlider, Path=Value, StringFormat={}{0:F1}}" />
                            </Grid>

                            <WrapPanel Margin="0,0,0,8">
                                <Button Width="118"
                                        Margin="0,0,8,0"
                                        Content="Polygon"
                                        Click="DrawPolygonButton_Click" />
                                <Button Width="118"
                                        Content="Polyline"
                                        Click="DrawPolylineButton_Click" />
                            </WrapPanel>

                            <WrapPanel Margin="0,0,0,8">
                                <Button Width="118"
                                        Margin="0,0,8,0"
                                        Content="Ring Point"
                                        Click="DrawRingPointButton_Click" />
                            </WrapPanel>

                            <WrapPanel>
                                <Button Width="118"
                                        Margin="0,0,8,0"
                                        Content="Clear Overlays"
                                        Click="ClearOverlayButton_Click" />
                                <Button Width="118"
                                        Content="Reset Mouse"
                                        Click="ResetModeButton_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Hints">
                        <TextBlock Margin="8"
                                   Text="{Binding HintText}"
                                   TextWrapping="Wrap"
                                   Foreground="#FFD9E1EA" />
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

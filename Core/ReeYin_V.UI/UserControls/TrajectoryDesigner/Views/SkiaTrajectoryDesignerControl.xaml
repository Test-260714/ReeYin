<UserControl x:Class="ReeYin_V.UI.UserControls.TrajectoryDesigner.Views.SkiaTrajectoryDesignerControl"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ReeYin_V.UI.UserControls.TrajectoryDesigner.Models"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             mc:Ignorable="d"
             Focusable="True"
             d:DesignWidth="720"
             d:DesignHeight="480">
    <UserControl.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="RadioButton">
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="ToolButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToolButtonChrome" Property="Background" Value="#FFF1F3F5" />
                                <Setter TargetName="ToolButtonChrome" Property="BorderBrush" Value="#FFD8E2EE" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToolButtonChrome" Property="Background" Value="#FFE1E5EA" />
                                <Setter TargetName="ToolButtonChrome" Property="BorderBrush" Value="#FFBFC9D4" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToolButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ViewButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Border Background="#FFF7FAFD"
            BorderBrush="#FFD8E2EE"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       Margin="8"
                       LastChildFill="False">
                <StackPanel x:Name="ToolStackPanel"
                            Orientation="Horizontal">
                    <RadioButton x:Name="SelectToolButton"
                                 Style="{StaticResource ToolButtonStyle}"
                                 Tag="{x:Static local:TrajectoryDesignerTool.Select}"
                                 ToolTip="选择"
                                 Checked="ToolButton_Checked">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Path Data="M2,1 L12,8 L8,9 L10,14 L8,15 L6,10 L3,13 Z"
                                      Fill="#FF36556F"
                                      Stroke="#FF36556F"
                                      StrokeThickness="1" />
                            </Canvas>
                        </Viewbox>
                    </RadioButton>
                    <RadioButton x:Name="PointToolButton"
                                 Style="{StaticResource ToolButtonStyle}"
                                 Tag="{x:Static local:TrajectoryDesignerTool.Point}"
                                 ToolTip="点"
                                 Checked="ToolButton_Checked">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Ellipse Canvas.Left="5"
                                         Canvas.Top="5"
                                         Width="6"
                                         Height="6"
                                         Fill="#FF36556F" />
                            </Canvas>
                        </Viewbox>
                    </RadioButton>
                    <RadioButton x:Name="LineToolButton"
                                 Style="{StaticResource ToolButtonStyle}"
                                 Tag="{x:Static local:TrajectoryDesignerTool.Line}"
                                 ToolTip="线段"
                                 Checked="ToolButton_Checked">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Line X1="2"
                                      Y1="12"
                                      X2="14"
                                      Y2="4"
                                      Stroke="#FF36556F"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Ellipse Canvas.Left="0.5"
                                         Canvas.Top="10.5"
                                         Width="3"
                                         Height="3"
                                         Fill="#FF36556F" />
                                <Ellipse Canvas.Left="12.5"
                                         Canvas.Top="2.5"
                                         Width="3"
                                         Height="3"
                                         Fill="#FF36556F" />
                            </Canvas>
                        </Viewbox>
                    </RadioButton>
                    <RadioButton x:Name="PolylineToolButton"
                                 Style="{StaticResource ToolButtonStyle}"
                                 Tag="{x:Static local:TrajectoryDesignerTool.Polyline}"
                                 ToolTip="多线段"
                                 Checked="ToolButton_Checked">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Line X1="1.5"
                                      Y1="12"
                                      X2="6.5"
                                      Y2="5"
                                      Stroke="#FF36556F"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Line X1="6.5"
                                      Y1="5"
                                      X2="10"
                                      Y2="10"
                                      Stroke="#FF36556F"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Line X1="10"
                                      Y1="10"
                                      X2="14.5"
                                      Y2="3"
                                      Stroke="#FF36556F"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Ellipse Canvas.Left="0"
                                         Canvas.Top="10.5"
                                         Width="3"
                                         Height="3"
                                         Fill="#FF36556F" />
                                <Ellipse Canvas.Left="5"
                                         Canvas.Top="3.5"
                                         Width="3"
                                         Height="3"
                                         Fill="#FF36556F" />
                                <Ellipse Canvas.Left="8.5"
                                         Canvas.Top="8.5"
                                         Width="3"
                                         Height="3"
                                         Fill="#FF36556F" />
                                <Ellipse Canvas.Left="13"
                                         Canvas.Top="1.5"
                                         Width="3"
                                         Height="3"
                                         Fill="#FF36556F" />
                            </Canvas>
                        </Viewbox>
                    </RadioButton>
                    <RadioButton x:Name="CircleToolButton"
                                 Style="{StaticResource ToolButtonStyle}"
                                 Tag="{x:Static local:TrajectoryDesignerTool.Circle}"
                                 ToolTip="圆"
                                 Checked="ToolButton_Checked">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Ellipse Canvas.Left="2.5"
                                         Canvas.Top="2.5"
                                         Width="11"
                                         Height="11"
                                         Stroke="#FF36556F"
                                         StrokeThickness="2" />
                            </Canvas>
                        </Viewbox>
                    </RadioButton>
                    <RadioButton x:Name="RectangleToolButton"
                                 Style="{StaticResource ToolButtonStyle}"
                                 Tag="{x:Static local:TrajectoryDesignerTool.Rectangle}"
                                 ToolTip="矩形"
                                 Checked="ToolButton_Checked">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Rectangle Canvas.Left="2.5"
                                           Canvas.Top="4"
                                           Width="11"
                                           Height="8"
                                           Stroke="#FF36556F"
                                           StrokeThickness="2" />
                            </Canvas>
                        </Viewbox>
                    </RadioButton>
                    <RadioButton x:Name="ArcToolButton"
                                 Style="{StaticResource ToolButtonStyle}"
                                 Tag="{x:Static local:TrajectoryDesignerTool.Arc}"
                                 ToolTip="圆弧"
                                 Checked="ToolButton_Checked">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Path Data="M3,12 A7,7 0 0 1 13,4"
                                      Stroke="#FF36556F"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Ellipse Canvas.Left="1.5"
                                         Canvas.Top="10.5"
                                         Width="3"
                                         Height="3"
                                         Fill="#FF36556F" />
                                <Ellipse Canvas.Left="11.5"
                                         Canvas.Top="2.5"
                                         Width="3"
                                         Height="3"
                                         Fill="#FF36556F" />
                            </Canvas>
                        </Viewbox>
                    </RadioButton>
                </StackPanel>

                <StackPanel Margin="8,0,0,0"
                            Orientation="Horizontal">
                    <Button x:Name="ZoomInButton"
                            Style="{StaticResource ViewButtonStyle}"
                            ToolTip="放大"
                            Click="ZoomInButton_Click">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Ellipse Canvas.Left="2"
                                         Canvas.Top="2"
                                         Width="9"
                                         Height="9"
                                         Stroke="#FF36556F"
                                         StrokeThickness="2" />
                                <Line X1="10"
                                      Y1="10"
                                      X2="15"
                                      Y2="15"
                                      Stroke="#FF36556F"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Line X1="4.5"
                                      Y1="6.5"
                                      X2="8.5"
                                      Y2="6.5"
                                      Stroke="#FF36556F"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Line X1="6.5"
                                      Y1="4.5"
                                      X2="6.5"
                                      Y2="8.5"
                                      Stroke="#FF36556F"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button x:Name="ZoomOutButton"
                            Style="{StaticResource ViewButtonStyle}"
                            ToolTip="缩小"
                            Click="ZoomOutButton_Click">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Ellipse Canvas.Left="2"
                                         Canvas.Top="2"
                                         Width="9"
                                         Height="9"
                                         Stroke="#FF36556F"
                                         StrokeThickness="2" />
                                <Line X1="10"
                                      Y1="10"
                                      X2="15"
                                      Y2="15"
                                      Stroke="#FF36556F"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                                <Line X1="4.5"
                                      Y1="6.5"
                                      X2="8.5"
                                      Y2="6.5"
                                      Stroke="#FF36556F"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button x:Name="ResetZoomButton"
                            Style="{StaticResource ViewButtonStyle}"
                            ToolTip="还原"
                            Click="ResetZoomButton_Click">
                        <Viewbox Width="16"
                                 Height="16">
                            <Canvas Width="16"
                                    Height="16">
                                <Path Data="M5,4 L5,1 L2,4 M5,1 A6,6 0 1 1 4,12"
                                      Stroke="#FF36556F"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>

                <TextBlock Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#FF586D81"
                           Text="{Binding ElementName=Root, Path=StatusText}" />
            </DockPanel>

            <Border Grid.Row="1"
                    Margin="8,0,8,8"
                    Background="White"
                    BorderBrush="#FFCCD8E4"
                    BorderThickness="1">
                <skia:SKElement x:Name="DrawingSurface"
                                Focusable="True"
                                MouseLeftButtonDown="DrawingSurface_MouseLeftButtonDown"
                                MouseLeftButtonUp="DrawingSurface_MouseLeftButtonUp"
                                MouseMove="DrawingSurface_MouseMove"
                                MouseLeave="DrawingSurface_MouseLeave"
                                MouseRightButtonDown="DrawingSurface_MouseRightButtonDown"
                                MouseRightButtonUp="DrawingSurface_MouseRightButtonUp"
                                MouseWheel="DrawingSurface_MouseWheel"
                                PaintSurface="DrawingSurface_PaintSurface" />
            </Border>
        </Grid>
    </Border>
</UserControl>


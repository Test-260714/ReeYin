<Window x:Class="ReeYin_V.UI.Controls.Loading.LoadingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReeYin_V.UI.Controls.Loading"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#80FFFFFF"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" WindowState="Maximized"
        ShowInTaskbar="False" Topmost="True">
    <Border CornerRadius="10" Background="White" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center" Height="120" Width="250">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="算法处理中，请稍候..." Name="Tips" Margin="0,10" 
                       HorizontalAlignment="Center" FontSize="16"/>

            <ProgressBar IsIndeterminate="True" Width="200" Height="20"/>
        </StackPanel>
    </Border>
</Window>

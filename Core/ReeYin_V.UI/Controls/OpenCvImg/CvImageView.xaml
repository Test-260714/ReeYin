<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:control="clr-namespace:ReeYin_V.UI.Controls.OpenCvImg"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <Style TargetType="{x:Type control:CvImageView}">
        <Setter Property="Background" Value="DarkGray"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type control:CvImageView}">
                    <Grid Background="{TemplateBinding Background}">

                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="绘制" Foreground="Black">
                                    <MenuItem x:Name="PART_Rectangle" Header="绘制矩形 (Rectangle)" />
                                    <MenuItem x:Name="PART_Ellipse" Header="绘制椭圆 (Ellipse)" />
                                </MenuItem>
                                <Separator/>
                                <MenuItem x:Name="PART_Clear" Header="清空所有绘制" />
                            </ContextMenu>
                        </Grid.ContextMenu>

                        <Grid x:Name="PART_Container">
                            <Border BorderBrush="#333" BorderThickness="1">
                                <Viewbox Stretch="Uniform">
                                    <Grid x:Name="PART_MainGrid" RenderTransformOrigin="0.5, 0.5">
                                        <Image x:Name="PART_ImageDisplay" 
                                               Stretch="None" 
                                               HorizontalAlignment="Left" 
                                               VerticalAlignment="Top" />

                                        <Canvas x:Name="PART_OverlayCanvas" 
                                                Background="Transparent"
                                                HorizontalAlignment="Left" 
                                                VerticalAlignment="Top" />
                                    </Grid>
                                </Viewbox>
                            </Border>

                            <TextBlock
                                x:Name="PART_MSG"
                                Margin="5"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Panel.ZIndex="10"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="Red" 
                                Text="Ready"/>

                            <TextBlock
                                x:Name="PART_POS"
                                Margin="5"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Panel.ZIndex="10"
                                FontSize="16"
                                FontWeight="Bold"
                                Foreground="LightGreen" 
                                Text="X: 0 Y: 0"/>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
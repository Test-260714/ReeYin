<Window x:Class="ReeYin_V.UI.Style.Dialogs.DialogWindowView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ReeYin_V.UI.Style.Dialogs"
        local:MaximizeOnClickOutsideBehavior.IsEnabled="True"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        WindowChrome.IsHitTestVisibleInChrome="True"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Visibility="{Binding Visibility}"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        BorderThickness="0"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStyle="None">
    <!--当使用WindowChrome来自定义窗体样式时，它可能会覆盖窗体内容，导致无法交互。如果自定义窗体中使用了WindowChrome，
    且没有给顶部的交互控件添加WindowChrome.IsHitTestVisibleInChrome="True"这个附加属性，就会出现点击不到的情况。
    例如，在隐藏标题栏位置放置按钮时，若不添加该属性，按钮将无法响应点击事件。-->
    <!--当 WPF 窗口设置 AllowsTransparency="True" 时，窗口会变为 分层窗口（Layered Window），这可能导致 WindowsFormsHost 内的 WinForm 控件渲染异常-->
    <Window.Resources>
        <Style x:Key="SystemTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontFamily" Value="{StaticResource Iconfont}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style x:Key="DialogTitleButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="{DynamicResource TitleBarBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TitleBarBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource TitleBarBrush}" />
                                <Setter TargetName="PART_Border" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PART_Border" Property="Background" Value="{DynamicResource TitleBarBrush}" />
                                <Setter TargetName="PART_Border" Property="Opacity" Value="0.65" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PART_Border" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.Style>
        <Style TargetType="{x:Type Window}">
            <Setter Property="ShowInTaskbar" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Window}">
                        <Border x:Name="PART_WindowBorder"
                                Background="{DynamicResource RegionBackgroundBrush}"
                                BorderBrush="{DynamicResource RegionSideBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True"
                                ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30" />
                                        <RowDefinition />
                                     </Grid.RowDefinitions>

                                    <!--标题栏样式-->
                                    <Border Background="{DynamicResource TitleBarBrush}"
                                            CornerRadius="8,8,0,0"
                                            WindowChrome.IsHitTestVisibleInChrome="False">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                                                <!--标题-->
                                                <TextBlock
                                                Margin="10,0,0,0"
                                                HorizontalAlignment="Left"
                                                FontSize="18"
                                                Style="{StaticResource SystemTitleStyle}"
                                                Text="{TemplateBinding Title}" />

                                            </StackPanel>

                                            <StackPanel
                                                Grid.Column="1" Margin="0,0,0,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                                                <Button
                                                    Margin="0,0,5,0"
                                                    Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                                                    CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                                                    FontFamily="{StaticResource Iconfont}"
                                                    Height="30" Width="30" FontSize="20"
                                                    Content="&#xea6a;"
                                                    Cursor="Hand"
                                                    Style="{StaticResource DialogTitleButtonStyle}" />
                                                <Button
                                                    Margin="0,0,5,0"
                                                    Command="ApplicationCommands.Close"
                                                    FontFamily="{StaticResource Iconfont}"
                                                    Height="30" Width="30" FontSize="20"
                                                    Content="&#xeaf2;"
                                                    Cursor="Hand"
                                                    Style="{StaticResource DialogTitleButtonStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Row="1"
                                            Background="{DynamicResource RegionBackgroundBrush}"
                                            CornerRadius="0,0,8,8"
                                            ClipToBounds="True">
                                        <ContentPresenter Content="{TemplateBinding Content}" />
                                    </Border>
                                </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Style>
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="30"
            CornerRadius="8"
            GlassFrameThickness="0"
            NonClientFrameEdges="None"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
</Window>

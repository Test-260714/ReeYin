<Window x:Class="ReeYin_V.UI.MessageView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReeYin_V.UI"
        WindowStartupLocation="CenterScreen"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:prism="http://prismlibrary.com/"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowChrome.IsHitTestVisibleInChrome="True"
        WindowStyle="None"
        AllowsTransparency ="False"
        Title="MessageView" Height="450" Width="800">
    <Border BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="3" Height="450" Width="800">
        <Grid Background="LightGray">
            <Grid.RowDefinitions>
                <RowDefinition MinHeight="150" Height="*"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
            </Grid.ColumnDefinitions>


            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="30">
                <TextBlock x:Name="tbIcon" FontFamily="{StaticResource Iconfont}"   Text="{Binding Icon}"  FontSize="30"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
                    <TextBlock Text="{Binding Message}" TextWrapping="Wrap" LineHeight="22" FontSize="18" VerticalAlignment="Center" MaxWidth="800" Foreground="Black" Margin="10,0,0,0"/>
                </ScrollViewer>
            </StackPanel>

            <Border Grid.Row="1" Grid.Column="1"  CornerRadius="4" Margin="20">
                <StackPanel x:Name="spContainer" Orientation="Horizontal" HorizontalAlignment="Center">
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>

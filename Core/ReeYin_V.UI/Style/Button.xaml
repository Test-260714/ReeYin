<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/FontAwesome.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Converter.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/CustomBrush.xaml"/>
        <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/TextBox.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- 自定义按钮样式 -->
    <Style x:Key="GeneralButtonStyle" TargetType="Button">
        <!-- 基础属性设置 -->
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12 6"/>
        <Setter Property="Height" Value="35"/>
        <Setter Property="FontSize" Value="{DynamicResource DefaultFontSize}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Medium"/>

        <!-- 控件模板 -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- 外层容器 -->
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            RenderTransformOrigin="0.5,0.5">

                        <!-- 阴影效果 -->
                        <Border.Effect>
                            <DropShadowEffect x:Name="ButtonShadow" 
                                           BlurRadius="8" 
                                           Opacity="0"
                                           ShadowDepth="2"
                                           Color="#40000000"/>
                        </Border.Effect>

                        <!-- 缩放变换 -->
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                            </TransformGroup>
                        </Border.RenderTransform>

                        <!-- 内容容器 -->
                        <Grid>
                            <!-- 图标容器（请替换为您的图标） -->
                            <Viewbox x:Name="IconContainer" 
                                   Width="20" Height="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                                <Path Data="{Binding ContentPresenter}"
                                      Fill="{TemplateBinding Foreground}"/>
                            </Viewbox>

                            <!-- 文本内容 -->
                            <ContentPresenter x:Name="ContentHost"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="6 0"/>
                        </Grid>
                    </Border>

                    <!-- 交互触发器 -->
                    <ControlTemplate.Triggers>
                        <!-- 鼠标悬停效果 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 图标放大 1.2 倍 -->
                                        <DoubleAnimation Storyboard.TargetName="IconContainer"
                                                       Storyboard.TargetProperty="Width"
                                                       To="24" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="IconContainer"
                                                       Storyboard.TargetProperty="Height"
                                                       To="24" Duration="0:0:0.2"/>
                                        <!-- 阴影显示 -->
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                       Storyboard.TargetProperty="Opacity"
                                                       To="0.3" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 恢复原始大小 -->
                                        <DoubleAnimation Storyboard.TargetName="IconContainer"
                                                       Storyboard.TargetProperty="Width"
                                                       To="20" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="IconContainer"
                                                       Storyboard.TargetProperty="Height"
                                                       To="20" Duration="0:0:0.15"/>
                                        <!-- 隐藏阴影 -->
                                        <DoubleAnimation Storyboard.TargetName="ButtonShadow"
                                                       Storyboard.TargetProperty="Opacity"
                                                       To="0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <!-- 点击效果 -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 按钮缩小 0.8 倍 -->
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="0.8" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="0.8" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <!-- 恢复原始大小 -->
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleX"
                                                       To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                       Storyboard.TargetProperty="ScaleY"
                                                       To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


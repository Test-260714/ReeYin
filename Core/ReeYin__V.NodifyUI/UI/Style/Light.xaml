<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="ForegroundColor">Black</Color>
    <Color x:Key="DisabledForegroundColor">Gray</Color>

    <Color x:Key="BackgroundColor">#D4DCF2</Color>
    <Color x:Key="ContrastBackgroundColor">#CCD6ED</Color>
    <Color x:Key="HighlightedBackgroundColor">#B1C5FF</Color>

    <Color x:Key="BorderColor">#CBCCDF</Color>
    <Color x:Key="DisabledBorderColor">Gray</Color>
    <StaticResource x:Key="HighlightedBorderColor" ResourceKey="PrimaryColor" />
    <StaticResource x:Key="FocusedBorderColor" ResourceKey="PrimaryColor" />

    <StaticResource x:Key="GridLinesColor" ResourceKey="PrimaryColor" />
    <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}"/>


    <Color x:Key="PanelBackgroundColor">#E9EEFE</Color>

    <Color x:Key="ActiveStateColor">#8DD28A</Color>
    <Color x:Key="ReadOnlyStateColor">#E6AF86</Color>
    <Color x:Key="LineConnection.StrokeColor">#FD5618</Color>
</ResourceDictionary>

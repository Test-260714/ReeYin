<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:nodify="https://miroiu.github.io/nodify"
                    xmlns:local="clr-namespace:ReeYin_V.NodifyManager"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--矩形-->
    <ControlTemplate x:Key="SquareConnector" TargetType="Control">
        <Rectangle Width="10"
                       Height="10"
                       StrokeDashCap="Round"
                       StrokeLineJoin="Round"
                       StrokeStartLineCap="Round"
                       StrokeEndLineCap="Round"
                       Stroke="{TemplateBinding BorderBrush}"
                       Fill="{TemplateBinding Background}"
                       StrokeThickness="2" />
    </ControlTemplate>

    <!--三角形-->
    <ControlTemplate x:Key="TriangleConnector" TargetType="Control">
        <Polygon Width="10"
                     Height="10"
                     Points="1,13 13,13 7,1"
                     StrokeDashCap="Round"
                     StrokeLineJoin="Round"
                     StrokeStartLineCap="Round"
                     StrokeEndLineCap="Round"
                     Stroke="{TemplateBinding BorderBrush}"
                     Fill="{TemplateBinding Background}"
                     StrokeThickness="2" />
    </ControlTemplate>

    <!--圆形-->
    <ControlTemplate x:Key="ConnectorThumbTemplate" TargetType="Control">
        <Ellipse Width="10"
                 Height="10" Margin="0,0,0,0" 
                 HorizontalAlignment="Center" VerticalAlignment="Center"
                 Stroke="{TemplateBinding BorderBrush}"
                 Fill="{TemplateBinding Background}"
                 StrokeThickness="2" />
    </ControlTemplate>

    <!--节点输入样式-->
    <Style TargetType="{x:Type nodify:NodeInput}" BasedOn="{StaticResource {x:Type nodify:NodeInput}}">
        <Setter Property="ConnectorTemplate" Value="{StaticResource ConnectorThumbTemplate}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Margin" Value="0,5,0,0" />
        <Setter Property="Header" Value="{Binding}" />
        <Setter Property="IsConnected" Value="{Binding IsConnected}" />
        <Setter Property="Anchor" Value="{Binding Anchor, Mode=OneWayToSource}" />
        <Setter Property="ToolTip" Value="{Binding Value}" />
        <!--<Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate DataType="{x:Type local:ConnectorViewModel}">
                    <StackPanel Orientation="Horizontal">
                        --><!--暂时不需要显示什么-->
                        <!--<TextBlock >
                            <Run Text="{Binding Title}"/>
                        </TextBlock>-->
                        <!--<TextBox Text="{Binding Value}" Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}" />--><!--
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>-->
    </Style>

    <!--节点输出样式-->
    <Style TargetType="{x:Type nodify:NodeOutput}" BasedOn="{StaticResource {x:Type nodify:NodeOutput}}">
        <Setter Property="ConnectorTemplate" Value="{StaticResource ConnectorThumbTemplate}" />
        <Setter Property="Margin" Value="0,5,0,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Header" Value="{Binding}" />
        <Setter Property="IsConnected" Value="{Binding IsConnected}" />
        <Setter Property="Anchor" Value="{Binding Anchor, Mode=OneWayToSource}" />
        <Setter Property="ToolTip" Value="{Binding Value}" />
        <!--<Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate DataType="{x:Type local:ConnectorViewModel}">
                    --><!--暂时不需要显示什么-->
                    <!--<TextBox Text="" IsEnabled="False" />--><!--
                </DataTemplate>
            </Setter.Value>
        </Setter>-->
    </Style>

    <!--用来做导航的样式-->
    <Style x:Key="CustomNodeStyle" TargetType="{x:Type nodify:Node}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type nodify:Node}">
                    <Border 
                    x:Name="PART_NodeBorder"
                    CornerRadius="20"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
                        <Grid>
                            <!-- 内容和连接器区域 -->
                            <Border Style="{TemplateBinding ContentContainerStyle}" 
                                Grid.Row="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--Data IN-->
                                    <ItemsControl x:Name="PART_Input"  HorizontalAlignment="Center"
                                              ItemsSource="{TemplateBinding Input}"
                                              VerticalAlignment="Center"
                                              ItemTemplate="{TemplateBinding InputConnectorTemplate}"
                                              Focusable="False" />

                                    <!--Content - 修改Padding为0,0,0,0-->
                                    <Border Grid.Column="1"
                                        Padding="0,0,0,0" 
                                        Background="Transparent">
                                        <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                    </Border>

                                    <!--Data OUT-->
                                    <ItemsControl x:Name="PART_Output" 
                                              ItemsSource="{TemplateBinding Output}"
                                              ItemTemplate="{TemplateBinding OutputConnectorTemplate}"
                                              VerticalAlignment="Center"
                                              Grid.Column="2"
                                              Focusable="False" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
<UserControl x:Class="ImageTool.GrabImage.Views.ContinuousGrabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             mc:Ignorable="d" 
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="1500" Height="900"
             FontSize="14">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.NodifyManager;component/UI/Style/Converter.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="640"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：采集设置 -->
            <WxGroupBox:WxGroupBox Grid.Column="0" Header="采集设置" Margin="0,0,8,0">
                <Grid Margin="18,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Text="采集源:" VerticalAlignment="Center" Margin="0,0,0,15"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="真机采集和伪采集分开配置、分开启动" VerticalAlignment="Center" Foreground="#6B7280"/>
                    </StackPanel>

                    <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,12" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="170"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,5">
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="真机相机列表" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Model.MultiCameraSummary}" DockPanel.Dock="Right" Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <Grid Grid.Row="1" Margin="8,6,8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Height="26"
                                          ItemsSource="{Binding Model.CameraModels}"
                                          SelectedItem="{Binding SelectedMultiCameraCandidate}"
                                          DisplayMemberPath="CameraNo"
                                          BorderThickness="0,0,0,1"/>
                                <Button Grid.Column="1" Content="&#xe630;" Height="26" Margin="6,0,0,0"
                                        FontFamily="{StaticResource Iconfont}" FontSize="14"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        ToolTip="添加到当前节点"
                                        Command="{Binding AddMultiCameraCommand}"/>
                                <Button Grid.Column="2" Content="&#xe74b;" Height="26" Margin="6,0,0,0"
                                        FontFamily="{StaticResource Iconfont}" FontSize="14"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        ToolTip="从当前节点移除"
                                        Command="{Binding RemoveMultiCameraCommand}"/>
                            </Grid>
                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding Model.MultiCameraItems}"
                                      SelectedItem="{Binding SelectedMultiCameraItem, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      Style="{StaticResource DefaultDataGridStyle}"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      RowHeaderWidth="0"
                                      FontSize="11"
                                      RowHeight="26"
                                      ColumnHeaderHeight="28"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="34"/>
                                    <DataGridTextColumn Header="相机" Binding="{Binding CameraNo}" Width="74"/>
                                    <DataGridTextColumn Header="输出" Binding="{Binding OutputName}" Width="58"/>
                                    <DataGridTextColumn Header="连接" Binding="{Binding ConnectedText}" Width="66"/>
                                    <DataGridTextColumn Header="收图" Binding="{Binding ReceiveStatus}" Width="64"/>
                                    <DataGridTextColumn Header="发图" Binding="{Binding SendStatus}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,7,8,8">
                                <Button Content="开始真机" Width="95" Height="30" Margin="0,0,8,0"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Background="#4CAF50" Foreground="White"
                                        Command="{Binding StartGrabCommand}"/>
                                <Button Content="停止真机" Width="95" Height="30"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Background="#F44336" Foreground="White"
                                        Command="{Binding StopGrabCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,12" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="150"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,5">
                                <DockPanel LastChildFill="True">
                                    <TextBlock Text="伪相机列表" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Model.PseudoImageSummary}" DockPanel.Dock="Right" Foreground="#6B7280" FontSize="12" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <Grid Grid.Row="1" Margin="8,6,8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="92"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="只按伪相机目录发图，不绑定真机来源" Foreground="#6B7280" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="添加伪相机" Height="26" Margin="6,0,0,0"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding AddPseudoCameraCommand}"/>
                                <Button Grid.Column="2" Content="&#xe74b;" Height="26" Margin="6,0,0,0"
                                        FontFamily="{StaticResource Iconfont}" FontSize="14"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        ToolTip="移除伪相机"
                                        Command="{Binding RemovePseudoCameraCommand}"/>
                            </Grid>
                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding Model.PseudoCameraItems}"
                                      SelectedItem="{Binding SelectedPseudoCameraItem, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      Style="{StaticResource DefaultDataGridStyle}"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      RowHeaderWidth="0"
                                      FontSize="11"
                                      RowHeight="26"
                                      ColumnHeaderHeight="28"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="34"/>
                                    <DataGridTextColumn Header="伪相机" Binding="{Binding CameraNo}" Width="86"/>
                                    <DataGridTextColumn Header="输出" Binding="{Binding OutputName}" Width="58"/>
                                    <DataGridTextColumn Header="目录" Binding="{Binding PseudoImageFolderDisplay}" Width="*"/>
                                    <DataGridTemplateColumn Header="选择" Width="48">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="..."
                                                        Width="34"
                                                        Height="22"
                                                        HorizontalAlignment="Center"
                                                        Style="{DynamicResource GeneralButtonStyle}"
                                                        ToolTip="选择该伪相机的采集图片目录"
                                                        Command="{Binding DataContext.SelectPseudoFolderForCameraCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                        CommandParameter="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="收图" Binding="{Binding ReceiveStatus}" Width="64"/>
                                    <DataGridTextColumn Header="发图" Binding="{Binding SendStatus}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="8,7,8,8">
                                <Button Content="开始伪采集" Width="105" Height="30" Margin="0,0,8,0"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Background="#4CAF50" Foreground="White"
                                        Command="{Binding StartPseudoGrabCommand}"/>
                                <Button Content="停止伪采集" Width="105" Height="30"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Background="#F44336" Foreground="White"
                                        Command="{Binding StopPseudoGrabCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Row="3" Text="原图保存" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="目录..." Width="62" Height="30" Margin="0,0,8,0"
                                Style="{DynamicResource GeneralButtonStyle}"
                                Command="{Binding SelectDebugRawImageSaveDirectoryCommand}"/>
                        <TextBlock Text="{Binding Model.DebugRawImageSaveRootDirectoryDisplay}"
                                   Width="150"
                                   VerticalAlignment="Center"
                                   Foreground="#6B7280"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Model.DebugRawImageSaveRootDirectoryDisplay}"
                                   Margin="0,0,10,0"/>
                        <Button Content="开始保存" Width="85" Height="30" Margin="0,0,8,0"
                                Style="{DynamicResource GeneralButtonStyle}"
                                Background="#4CAF50" Foreground="White"
                                Command="{Binding StartDebugRawImageSaveCommand}"/>
                        <Button Content="停止保存" Width="85" Height="30" Margin="0,0,10,0"
                                Style="{DynamicResource GeneralButtonStyle}"
                                Background="#F44336" Foreground="White"
                                Command="{Binding StopDebugRawImageSaveCommand}"/>
                        <TextBlock Text="{Binding Model.DebugRawImageSaveSummary}"
                                   VerticalAlignment="Center"
                                   Foreground="#6B7280"
                                   Width="170"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Text="伪发图间隔:" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox Text="{Binding Model.GrabInterval}" Width="200" Height="28"
                                 Style="{DynamicResource TextBoxExtend}" BorderThickness="0,0,0,1"/>
                        <TextBlock Text=" ms" VerticalAlignment="Center"/>
                        <CheckBox Content="循环发送"
                                  Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   IsChecked="{Binding Model.PseudoLoopEnabled}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="5" Text="伪采集策略:" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <CheckBox Grid.Row="5" Grid.Column="1"
                              Content="等待流程完成后再读取下一张"
                              Margin="0,0,0,12"
                              VerticalAlignment="Center"
                              IsChecked="{Binding Model.PseudoWaitForFlowCompletionBeforeRead}"/>

                    <TextBlock Grid.Row="6" Text="循环次数:" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBox Text="{Binding Model.PseudoLoopCount}" Width="200" Height="28"
                                 Style="{DynamicResource TextBoxExtend}" BorderThickness="0,0,0,1"
                                 ToolTip="0 表示不限次数"/>
                        <TextBlock Text=" 次" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="7" Text="伪相机状态:" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <StackPanel Grid.Row="7" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="{Binding Model.PseudoImageSummary}" Foreground="#374151" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Model.PseudoModeSummary}" Foreground="#6B7280" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>

                    <TextBlock Grid.Row="8" Text="采集状态:" VerticalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Grid.Row="8" Grid.Column="1" FontSize="14" VerticalAlignment="Center" Margin="0,0,0,12"
                               Text="{Binding Model.GrabStatusSummary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#757575"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Model.IsGrabbing}" Value="True">
                                        <Setter Property="Foreground" Value="#FF9800"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                </Grid>
            </WxGroupBox:WxGroupBox>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.1*"/>
                    <RowDefinition Height="0.8*"/>
                </Grid.RowDefinitions>

                <WxGroupBox:WxGroupBox Grid.Row="0" Header="伪相机状态" Margin="0,0,0,5">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="{Binding Model.PseudoCurrentImageSummary}"
                                   Foreground="#374151" FontSize="12" Margin="0,0,0,6"/>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Model.PseudoCameraItems}"
                                  AutoGenerateColumns="False"
                                  Style="{StaticResource DefaultDataGridStyle}"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  RowHeaderWidth="0"
                                  FontSize="10"
                                  RowHeight="22"
                                  ColumnHeaderHeight="24"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="输出" Binding="{Binding OutputName}" Width="70"/>
                                <DataGridTextColumn Header="相机" Binding="{Binding CameraNo}" Width="90"/>
                                <DataGridTextColumn Header="当前文件" Binding="{Binding CurrentPseudoFileName}" Width="*"/>
                                <DataGridTextColumn Header="伪目录" Binding="{Binding PseudoImageFolderDisplay}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </WxGroupBox:WxGroupBox>

                <WxGroupBox:WxGroupBox Grid.Row="1" Header="输出参数" Margin="0,8,0,0">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <ComboBox Width="420" Height="32"
                                      ItemsSource="{Binding Model.OutputParamNames}"
                                      SelectedItem="{Binding SltOutputParamName, Mode=TwoWay}"
                                      BorderThickness="0,0,0,1"/>
                            <Button Content="&#xe630;" Width="42" Height="32" Margin="10,0,0,0"
                                    FontFamily="{StaticResource Iconfont}" FontSize="16"
                                    Style="{DynamicResource GeneralButtonStyle}"
                                    ToolTip="添加"
                                    Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                            <Button Content="生成真机输出" Width="116" Height="32" Margin="10,0,0,0"
                                    Style="{DynamicResource GeneralButtonStyle}"
                                    ToolTip="按真机列表生成 Image1~ImageN 输出"
                                    Command="{Binding AddRealCameraOutputsCommand}"/>
                            <Button Content="生成伪输出" Width="116" Height="32" Margin="8,0,0,0"
                                    Style="{DynamicResource GeneralButtonStyle}"
                                    ToolTip="按伪相机列表生成 Image1~ImageN 输出"
                                    Command="{Binding AddPseudoCameraOutputsCommand}"/>
                        </StackPanel>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Model.OutputParams}"
                                  AutoGenerateColumns="False"
                                  Style="{StaticResource DefaultDataGridStyle}"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  RowHeaderWidth="0"
                                  FontSize="13"
                                  RowHeight="32"
                                  ColumnHeaderHeight="34">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="参数名称" Binding="{Binding Name}" Width="*" IsReadOnly="True"/>
                                <DataGridCheckBoxColumn Header="全局" Binding="{Binding IsGlobal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                <DataGridTemplateColumn Header="删除" Width="56">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="&#xe74b;"
                                                    Width="34"
                                                    Height="26"
                                                    HorizontalAlignment="Center"
                                                    FontFamily="{StaticResource Iconfont}"
                                                    FontSize="14"
                                                    Style="{DynamicResource GeneralButtonStyle}"
                                                    ToolTip="删除该输出参数"
                                                    Command="{Binding DataContext.RemoveOutputParamCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </WxGroupBox:WxGroupBox>
            </Grid>
        </Grid>

        <!-- 底部按钮 -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button Content="执行" Width="80" Height="35"
                        Style="{DynamicResource GeneralButtonStyle}"
                        Command="{Binding GeneralCommand}" CommandParameter="执行"/>
                <Button Content="伪采一包" Width="100" Height="35" Margin="10,0,0,0"
                        Style="{DynamicResource GeneralButtonStyle}"
                        Command="{Binding GrabOnceCommand}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="取消" Width="80" Height="35" Margin="0,0,10,0"
                        Style="{DynamicResource GeneralButtonStyle}"
                        Command="{Binding GeneralCommand}" CommandParameter="取消"/>
                <Button Content="确认" Width="80" Height="35"
                        Style="{DynamicResource GeneralButtonStyle}"
                        Background="#4CAF50" Foreground="White"
                        Command="{Binding GeneralCommand}" CommandParameter="确认"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

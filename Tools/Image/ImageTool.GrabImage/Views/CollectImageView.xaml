<UserControl x:Class="ImageTool.GrabImage.Views.CollectImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:local="clr-namespace:ImageTool.GrabImage.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <Button Name="btnLogin" Margin="5 0 5 0" IsEnabled="{Binding IsEnabled}" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ImportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe645;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导入配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button IsEnabled="{Binding IsEnabled}" Margin="5 0 5 0" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ExportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe646;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导出配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <!--主体-->
        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="基础配置" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="采集模式" Margin="5 5 5 10">
                                    <Grid >
                                        <Border CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center"
                                                >
                                            <TabControl Width="600" Height="550" SelectedIndex="{Binding ModelParam.SltTriggerPicIndex,Mode=TwoWay}" Style="{DynamicResource TabControlStyle}">
                                                <TabItem Header="指定图像"  Style="{DynamicResource SingleTabItemStyle}" >
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center">
                                                                <RadioButton FontSize="14" Margin="0 0 0 0" Width="83" Height="32" IsChecked="True" Content="选择文件" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="选择文件"/>

                                                                <RadioButton FontSize="14" Margin="100 0 0 0" Width="83" Height="32" Content="链接路径" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="链接路径"/>

                                                            </StackPanel>

                                                            <Grid>
                                                                <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center">
                                                                    <TextBox Text="{Binding ModelParam.FilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                    <Button Width="30" Height="30" Content="&#xe7b9;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="打开文件"/>
                                                                </StackPanel>

                                                                <StackPanel Visibility="{Binding ModelParam.IsLinkVisibility,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                                    <TextBox Text="{Binding ModelParam.LinkPath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                    <Button Width="30" Height="30" Content="&#xe60e;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="链接图片"/>
                                                                    <Button Width="30" Height="30" Content="&#xeaf2;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="取消链接"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="文件目录" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <CheckBox Content="循环" FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                                                <TextBox Text="{Binding FilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                <Button Content="&#xe7b9;" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="打开文件"/>
                                                            </StackPanel>
                                                            
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                                <Button Content="&#xe693;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter=""/>
                                                                <Button Content="&#xe6dd;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter=""/>
                                                                <Button Content="&#xe652;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter=""/>
                                                                <Button Content="&#xe6d5;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter=""/>

                                                                <CheckBox Content="自动切换" FontSize="16" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                                            </StackPanel>

                                                            <StackPanel>
                                                                <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                                                      EnableColumnVirtualization="True"
                                                                      EnableRowVirtualization="True"
                                                                      VirtualizingPanel.IsVirtualizing="True"
                                                                      ItemsSource="{Binding }" 
                                                                      SelectedItem="{Binding CurrentOutputParam}"
                                                                      FontSize="12" 
                                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                      Height="160"
                                                                      RowHeaderWidth="20"
                                                                      SelectionUnit="FullRow"
                                                                      HeadersVisibility="Column"
                                                                      GridLinesVisibility="All"
                                                                      IsReadOnly="False" CanUserAddRows="False" >
                                                                    <DataGrid.Columns>
                                                                        <DataGridTemplateColumn Header="启用" IsReadOnly="False" Width="50">
                                                                            <DataGridTemplateColumn.CellTemplate>
                                                                                <DataTemplate>
                                                                                    <CheckBox IsChecked="{Binding }"  HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                                                                </DataTemplate>
                                                                            </DataGridTemplateColumn.CellTemplate>
                                                                        </DataGridTemplateColumn>
                                                                        <DataGridTemplateColumn Header="索引" IsReadOnly="False" Width="auto">
                                                                            <DataGridTemplateColumn.CellTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                                                </DataTemplate>
                                                                            </DataGridTemplateColumn.CellTemplate>
                                                                        </DataGridTemplateColumn>
                                                                        <DataGridTemplateColumn Header="名称" IsReadOnly="True" Width="*">
                                                                            <DataGridTemplateColumn.CellTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                                                </DataTemplate>
                                                                            </DataGridTemplateColumn.CellTemplate>
                                                                        </DataGridTemplateColumn>
                                                                        <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                                                            <DataGridTemplateColumn.CellTemplate>
                                                                                <DataTemplate>
                                                                                    <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                                                                </DataTemplate>
                                                                            </DataGridTemplateColumn.CellTemplate>
                                                                        </DataGridTemplateColumn>

                                                                    </DataGrid.Columns>
                                                                </DataGrid>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="相机采集" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                                                            <UniformGrid Columns="2" Margin="0,0,0,8" HorizontalAlignment="Center" VerticalAlignment="Top">
                                                                <TextBlock Text="相机选择:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" 
                                                                          ItemsSource="{Binding ModelParam.CameraModels}" DisplayMemberPath="CameraNo" SelectedItem="{Binding ModelParam.SelectedCameraModel,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                                <TextBlock Text="相机旋转:" Foreground="Black" VerticalAlignment="Center" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Margin="5"
                                                                          ItemsSource="{Binding }" SelectedItem="{Binding ModelParam.CamSltRotate }"/>

                                                                <TextBlock Text="采集模式:" Foreground="Black" VerticalAlignment="Center" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Margin="5"
                                                                          ItemsSource="{Binding ModelParam.SelectedCameraModel.TrigModes}" SelectedItem="{Binding ModelParam.SelectedCameraModel.TrigMode}"/>

                                                                <TextBlock Text="相机备注:" Foreground="Black" VerticalAlignment="Center" />
                                                                <TextBox Width="200"  Height="25" BorderThickness="0 0 0 1" Margin="5 0" Text="{Binding ModelParam.SelectedCameraModel.Remarks,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                                <TextBlock Text="曝光时间:" Foreground="Black" VerticalAlignment="Center" />
                                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="0 0" SmallChange="1" BorderThickness="0 0 0 1"
                                                                    Value="{Binding ModelParam.SelectedCameraModel.ExposeTime,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                                <TextBlock Text="增益:" Foreground="Black" VerticalAlignment="Center" />
                                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="0 0" SmallChange="0.1"  BorderThickness="0 0 0 1"
                                                                    Value="{Binding ModelParam.SelectedCameraModel.Gain,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                            </UniformGrid>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="预处理:" Foreground="Black" VerticalAlignment="Center" />
                                                                <UniformGrid Columns="2" Margin="0,0,0,0" HorizontalAlignment="Center" VerticalAlignment="Top">
                                                                    <CheckBox Content="水平镜像" IsChecked="{Binding ModelParam.SltWhiteBalance}" Margin="10" FontSize="16"/>
                                                                    <CheckBox Content="垂直镜像" IsChecked="{Binding ModelParam.SltExposureCompensation}" Margin="10" FontSize="16"/>
                                                                    <CheckBox Content="旋转90°" IsChecked="{Binding ModelParam.SltAutoExposure}" Margin="10" FontSize="16"/>
                                                                    <CheckBox Content="旋转-90°" IsChecked="{Binding ModelParam.SltAutoWhiteBalance}" Margin="10" FontSize="16"/>
                                                                </UniformGrid>
                                                                
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                            </TabControl>
                                        </Border>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="图像参数" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="显示窗体:" Foreground="Black" VerticalAlignment="Center"  />
                                        <ComboBox Width="130" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
                                                  />
                                    </StackPanel>
                                    
                                    
                                    <CheckBox Content="流程结束时显示结果图像" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" HorizontalAlignment="Left"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>
                                    <CheckBox Content="链接测量标定" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>
                                    <CheckBox Content="链接拍照位置数据" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>
                                    <CheckBox Content="离线图像增加标记" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>
                                    <CheckBox Content="链接畸变标定" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>
                                    <CheckBox Content="裁剪镭射图像" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>
                                    <CheckBox Content="镭射方向扫描" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>
                                    <CheckBox Content="手动阈值" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>
                                    <CheckBox Content="输出亮度图" Margin="10" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>

                                    <Button Content="触发Line1" Style="{StaticResource GeneralButtonStyle}"  Height="30"
        Command="{Binding GeneralCommand}" CommandParameter="打开文件"/>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="其他配置" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>
                                
                            </Grid>
                        </TabItem>

                        <TabItem Header="输出信息" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>
                                
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <Controls:ImageEditView Image="{Binding ModelParam.Image,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Height="300" Background="{StaticResource BackgroudBrush}"/>
                        </StackPanel>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
             Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                     ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                 Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                     ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      ItemsSource="{Binding ModelParam.OutputParams}" 
                      SelectedItem="{Binding CurrentOutputParam}"
                      FontSize="12" 
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Height="160"
                      RowHeaderWidth="20"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
         SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                <!--<TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>-->
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="执行"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                    Height="auto" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="auto" Width="80"
                                                    Content="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

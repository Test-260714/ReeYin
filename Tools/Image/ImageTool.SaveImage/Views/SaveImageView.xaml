<UserControl x:Class="ImageTool.SaveImage.Views.SaveImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ImageTool.SaveImage.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="640" Width="640"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="640" d:DesignWidth="640">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
        <!--<i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding ConfirmCommand}"/>
        </i:EventTrigger>-->
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Vertical">
            <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="图片源>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="输入图像:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                    <WxLink:WxLink Width="400" InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" OutputParam="{Binding ModelParam.InputImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 20" Text="{Binding ModelParam.InputImage.Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </WxGroupBox:WxGroupBox>
            <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="存储类型>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                <StackPanel Orientation="Horizontal" Margin="5 20" HorizontalAlignment="Center">
                    <RadioButton FontSize="14" Margin="0 0 0 0" Width="83" Height="32" IsChecked="True" Content="原图" Foreground="Black" FontFamily="{StaticResource Iconfont}"
Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="原图"/>

                    <RadioButton FontSize="14" Margin="100 0 0 0" Width="83" Height="32" Content="截图" Foreground="Black" FontFamily="{StaticResource Iconfont}"
Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="截图"/>

                </StackPanel>
            </WxGroupBox:WxGroupBox>
            <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="文件设置>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                        <TextBlock Text="存图路径:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                        <WxLink:WxLink Width="500" Margin="5 0" Order="OpenFile" Text="{Binding ModelParam.SavePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <UniformGrid Columns="2" Margin="0,0,0,8" HorizontalAlignment="Center" VerticalAlignment="Top">

                        <TextBlock Text="图像格式:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                        <ComboBox Width="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center"
              ItemsSource="{Binding ImageTypess,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  SelectedItem="{Binding ModelParam.ImageType}"/>

                        <TextBlock Text="保存天数:" Foreground="Black" VerticalAlignment="Center" />
                        <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="5 0" SmallChange="1"
                                                                 Value="{Binding ModelParam.SaveDays}"/>

                        <TextBlock Text="图片名称:" Foreground="Black" VerticalAlignment="Center" />
                        <TextBox Width="200" BorderThickness="0 0 0 1" Margin="5" Text="{Binding ModelParam.ImageName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <CheckBox Content="以当前时间命名:" Margin="5" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="Black" FontSize="16"
                                                  IsChecked="{Binding ModelParam.SltWhiteBalance}"/>
                        <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='(yyyy-MM-dd-HH-mm-ss)'}"  Foreground="Black" VerticalAlignment="Center" />
                    </UniformGrid>

                </StackPanel>
            </WxGroupBox:WxGroupBox>
        </StackPanel>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" Background="{DynamicResource TitleForegroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>

                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" Content="执行" FontSize="18" Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80"
                                                    Command="{Binding GeneralCommand}"
                                                    CommandParameter="执行"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" Content="取消" FontSize="18" Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80"
                                                    Command="{Binding GeneralCommand}"
                                                    CommandParameter="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" Content="确认" FontSize="18" Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80"
                                                    Command="{Binding GeneralCommand}"
                                                    CommandParameter="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

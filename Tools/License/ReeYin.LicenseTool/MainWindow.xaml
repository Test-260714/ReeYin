<Window x:Class="ReeYin.LicenseTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
        mc:Ignorable="d"
        Title="ReeYin License 注册工具"
        Width="980"
        Height="850"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MainBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontSize="{DynamicResource DefaultFontSize}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Themes/LightTheme.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="License 生成"
                           FontSize="{DynamicResource HeaderFontSize}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" />
                <TextBlock Margin="0,4,0,0"
                           Text="填写机器码、客户和授权范围后生成 license.json。"
                           Foreground="{DynamicResource MainPrimaryTextIconBrush}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Width="120"
                    Style="{StaticResource GeneralButtonStyle}"
                    Content="生成"
                    Click="GenerateButton_Click" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.5*" MinHeight="280" />
                <RowDefinition Height="14" />
                <RowDefinition Height="0.5*" MinHeight="170" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0">
                <StackPanel>
                    <WxGroupBox:WxGroupBox Header="授权参数" Icon="">
                        <Border Background="{DynamicResource RegionBackgroundBrush}"
                                BorderBrush="{DynamicResource MainTopSepBrush}"
                                BorderThickness="1"
                                Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="92" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                           Text="机器码" />
                                <Grid Grid.Row="0" Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MachineCodeTextBox"
                                             MinHeight="34"
                                             VerticalContentAlignment="Center"
                                             TextWrapping="Wrap"
                                             Background="{DynamicResource RegionBackgroundBrush}"
                                             BorderBrush="{StaticResource TextBox.Static.Border}"
                                             Foreground="{DynamicResource TextBrush}" />
                                    <Button Grid.Column="2"
                                            Width="92"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Content="读取本机"
                                            Click="ReadCurrentMachineButton_Click" />
                                    <CheckBox x:Name="UseCurrentMachineCheckBox"
                                              Grid.Row="1"
                                              Grid.ColumnSpan="3"
                                              Margin="0,8,0,0"
                                              Content="生成时使用本机机器码"
                                              Foreground="{DynamicResource TextBrush}"
                                              IsChecked="True"
                                              Checked="UseCurrentMachineCheckBox_Changed"
                                              Unchecked="UseCurrentMachineCheckBox_Changed" />
                                </Grid>

                                <TextBlock Grid.Row="1"
                                           Grid.Column="0"
                                           Margin="0,14,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                           Text="客户名称" />
                                <TextBox x:Name="CustomerNameTextBox"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="0,14,0,0"
                                         MinHeight="34"
                                         VerticalContentAlignment="Center"
                                         Background="{DynamicResource RegionBackgroundBrush}"
                                         BorderBrush="{StaticResource TextBox.Static.Border}"
                                         Foreground="{DynamicResource TextBrush}" />

                                <TextBlock Grid.Row="2"
                                           Grid.Column="0"
                                           Margin="0,14,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                           Text="版本" />
                                <TextBox x:Name="VersionTextBox"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         Margin="0,14,0,0"
                                         MinHeight="34"
                                         VerticalContentAlignment="Center"
                                         Text="1.0"
                                         Background="{DynamicResource RegionBackgroundBrush}"
                                         BorderBrush="{StaticResource TextBox.Static.Border}"
                                         Foreground="{DynamicResource TextBrush}" />

                                <TextBlock Grid.Row="3"
                                           Grid.Column="0"
                                           Margin="0,14,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                           Text="模块" />
                                <TextBox x:Name="ModulesTextBox"
                                         Grid.Row="3"
                                         Grid.Column="1"
                                         Margin="0,14,0,0"
                                         MinHeight="34"
                                         VerticalContentAlignment="Center"
                                         Text="ALL"
                                         Background="{DynamicResource RegionBackgroundBrush}"
                                         BorderBrush="{StaticResource TextBox.Static.Border}"
                                         Foreground="{DynamicResource TextBrush}" />

                                <TextBlock Grid.Row="4"
                                           Grid.Column="0"
                                           Margin="0,14,0,0"
                                           VerticalAlignment="Top"
                                           Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                           Text="授权类型" />
                                <StackPanel Grid.Row="4"
                                            Grid.Column="1"
                                            Margin="0,14,0,0">
                                    <WrapPanel>
                                        <RadioButton x:Name="PermanentRadio"
                                                     Content="永久授权"
                                                     IsChecked="True"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     Checked="LicenseTypeRadio_Checked" />
                                        <RadioButton x:Name="TimeLimitedRadio"
                                                     Margin="18,0,0,0"
                                                     Content="限时授权"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     Checked="LicenseTypeRadio_Checked" />
                                        <RadioButton x:Name="TrialRadio"
                                                     Margin="18,0,0,0"
                                                     Content="试用授权"
                                                     Foreground="{DynamicResource TextBrush}"
                                                     Checked="LicenseTypeRadio_Checked" />
                                    </WrapPanel>
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="1.2*" MinWidth="130" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" MinWidth="90" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" MinWidth="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                                   Text="到期日期" />
                                        <DatePicker x:Name="ExpireDatePicker"
                                                    Grid.Column="2"
                                                    SelectedDateFormat="Short" />
                                        <TextBlock Grid.Column="4"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                                   Text="时间" />
                                        <TextBox x:Name="ExpireTimeTextBox"
                                                 Grid.Column="6"
                                                 MinHeight="30"
                                                 Text="23:59:59"
                                                 VerticalContentAlignment="Center"
                                                 Background="{DynamicResource RegionBackgroundBrush}"
                                                 BorderBrush="{StaticResource TextBox.Static.Border}"
                                                 Foreground="{DynamicResource TextBrush}" />
                                        <TextBlock Grid.Column="8"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                                   Text="试用天数" />
                                        <TextBox x:Name="TrialDaysTextBox"
                                                 Grid.Column="10"
                                                 MinHeight="30"
                                                 Text="30"
                                                 VerticalContentAlignment="Center"
                                                 Background="{DynamicResource RegionBackgroundBrush}"
                                                 BorderBrush="{StaticResource TextBox.Static.Border}"
                                                 Foreground="{DynamicResource TextBrush}" />
                                    </Grid>
                                </StackPanel>

                                <TextBlock Grid.Row="5"
                                           Grid.Column="0"
                                           Margin="0,14,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                           Text="输出文件" />
                                <Grid Grid.Row="5"
                                      Grid.Column="1"
                                      Margin="0,14,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="OutputPathTextBox"
                                             MinHeight="34"
                                             VerticalContentAlignment="Center"
                                             Background="{DynamicResource RegionBackgroundBrush}"
                                             BorderBrush="{StaticResource TextBox.Static.Border}"
                                             Foreground="{DynamicResource TextBrush}" />
                                    <Button Grid.Column="2"
                                            Width="72"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Content="选择"
                                            Click="BrowseOutputButton_Click" />
                                </Grid>
                            </Grid>
                        </Border>
                    </WxGroupBox:WxGroupBox>

                    <WxGroupBox:WxGroupBox Margin="0,14,0,0" Header="签名密钥" Icon="">
                        <Border Background="{DynamicResource RegionBackgroundBrush}"
                                BorderBrush="{DynamicResource MainTopSepBrush}"
                                BorderThickness="1"
                                Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PrivateKeyFileTextBox"
                                         MinHeight="34"
                                         VerticalContentAlignment="Center"
                                         Background="{DynamicResource RegionBackgroundBrush}"
                                         BorderBrush="{StaticResource TextBox.Static.Border}"
                                         Foreground="{DynamicResource TextBrush}" />
                                <Button Grid.Column="2"
                                        Width="72"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Content="选择"
                                        Click="BrowsePrivateKeyButton_Click" />
                            </Grid>
                        </Border>
                    </WxGroupBox:WxGroupBox>
                </StackPanel>
            </ScrollViewer>

            <WxGroupBox:WxGroupBox Grid.Row="2"
                                   Header="生成结果"
                                   Icon="">
                <Border Background="{DynamicResource RegionBackgroundBrush}"
                        BorderBrush="{DynamicResource MainTopSepBrush}"
                        BorderThickness="1"
                        Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="StatusTextBlock"
                                   Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                                   TextWrapping="Wrap"
                                   Text="尚未生成 License。" />
                    </Grid>
                </Border>
            </WxGroupBox:WxGroupBox>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource MainPrimaryTextIconBrush}"
                   Text="命令行参数仍可继续使用；直接启动程序时打开当前可视化页面。" />
    </Grid>
</Window>

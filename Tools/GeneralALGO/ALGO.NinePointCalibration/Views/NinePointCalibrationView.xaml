<UserControl x:Class="ALGO.NinePointCalibration.Views.NinePointCalibrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             Width="1280"
             Height="880"
             FontSize="14"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignWidth="1280"
             d:DesignHeight="880">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Generic.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="NpcTextBoxStyle" TargetType="{x:Type TextBox}">
                <Setter Property="Height" Value="28"/>
                <Setter Property="Padding" Value="6 3"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="BorderBrush" Value="{DynamicResource RegionSideBrush}"/>
                <Setter Property="BorderThickness" Value="0 0 0 1"/>
            </Style>
            <Style x:Key="NpcActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource GeneralButtonStyle}">
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Margin" Value="0 0 8 0"/>
            </Style>
            <Style x:Key="NpcCaptionStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0 0 8 0"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Background="{DynamicResource MainBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="82"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="58"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource RegionBackgroundBrush}"
                BorderBrush="{DynamicResource SelectedBrush}"
                BorderThickness="0 0 0 2">
            <Grid Margin="22 0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="九点标定"
                               Foreground="{DynamicResource SelectedBrush}"
                               FontSize="30"
                               FontWeight="Bold"/>
                    <TextBlock Text="预留像素坐标输入，使用 Halcon 仿射矩阵转换到 XY 机械坐标"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="13"
                               Margin="0 4 0 0"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="控制卡"
                               Foreground="{DynamicResource TextBrush}"
                               VerticalAlignment="Center"
                               Margin="0 0 8 0"/>
                    <ComboBox Width="220"
                              Height="30"
                              ItemsSource="{Binding ModelParam.Models}"
                              DisplayMemberPath="NickName"
                              SelectedItem="{Binding ModelParam.ControlCard, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0 0 8 0"/>
                    <Button Content="刷新"
                            Style="{StaticResource NpcActionButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="刷新控制卡"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.64*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="0.36*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="{DynamicResource RegionSideBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Background="{DynamicResource ExpanderPanelBackgroundBrush}"
                            BorderBrush="{DynamicResource RegionSideBrush}"
                            BorderThickness="0 0 0 1"
                            Padding="14 0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="标定点"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="生成九点"
                                        Style="{StaticResource NpcActionButtonStyle}"
                                        Command="{Binding GeneralCommand}"
                                        CommandParameter="生成九点"/>
                                <Button Content="清空像素"
                                        Style="{StaticResource NpcActionButtonStyle}"
                                        Command="{Binding GeneralCommand}"
                                        CommandParameter="清空像素"/>
                                <Button Content="计算标定"
                                        Style="{StaticResource NpcActionButtonStyle}"
                                        Command="{Binding GeneralCommand}"
                                        CommandParameter="计算标定"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1"
                              Style="{StaticResource DefaultDataGridStyle}"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding ModelParam.Points}"
                              SelectedItem="{Binding ModelParam.SelectedPoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              CanUserAddRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              RowHeaderWidth="0"
                              BorderThickness="0"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="点位" Binding="{Binding DisplayName}" IsReadOnly="True" Width="70"/>
                            <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsUsed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="64"/>
                            <DataGridTextColumn Header="像素X" Binding="{Binding PixelX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" Width="*"/>
                            <DataGridTextColumn Header="像素Y" Binding="{Binding PixelY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}" Width="*"/>
                            <DataGridTextColumn Header="机械X" Binding="{Binding MachineX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F6}" Width="*"/>
                            <DataGridTextColumn Header="机械Y" Binding="{Binding MachineY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F6}" Width="*"/>
                            <DataGridTextColumn Header="拟合X" Binding="{Binding FitMachineX, StringFormat=F6}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="拟合Y" Binding="{Binding FitMachineY, StringFormat=F6}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="误差" Binding="{Binding Error, StringFormat=F6}" IsReadOnly="True" Width="*"/>
                            <DataGridTemplateColumn Header="移动" Width="86">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="移动"
                                                Height="26"
                                                MinWidth="58"
                                                Margin="4 0"
                                                Style="{StaticResource NpcActionButtonStyle}"
                                                Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                CommandParameter="移动到选中点"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource BtnOverColor}"
                          Width="12"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="White"
                        BorderBrush="{DynamicResource RegionSideBrush}"
                        BorderThickness="1"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="九点机械网格"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Margin="0 0 0 12"/>
                        <UniformGrid Columns="2" Rows="2">
                            <StackPanel Margin="0 0 8 8">
                                <TextBlock Text="中心X" Style="{StaticResource NpcCaptionStyle}"/>
                                <TextBox Style="{StaticResource NpcTextBoxStyle}" Text="{Binding ModelParam.CenterMachineX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F6}"/>
                            </StackPanel>
                            <StackPanel Margin="0 0 0 8">
                                <TextBlock Text="中心Y" Style="{StaticResource NpcCaptionStyle}"/>
                                <TextBox Style="{StaticResource NpcTextBoxStyle}" Text="{Binding ModelParam.CenterMachineY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F6}"/>
                            </StackPanel>
                            <StackPanel Margin="0 0 8 0">
                                <TextBlock Text="X间距" Style="{StaticResource NpcCaptionStyle}"/>
                                <TextBox Style="{StaticResource NpcTextBoxStyle}" Text="{Binding ModelParam.PointSpacingX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F6}"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Y间距" Style="{StaticResource NpcCaptionStyle}"/>
                                <TextBox Style="{StaticResource NpcTextBoxStyle}" Text="{Binding ModelParam.PointSpacingY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F6}"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="White"
                        BorderBrush="{DynamicResource RegionSideBrush}"
                        BorderThickness="1"
                        Padding="14"
                        Margin="0 12 0 0">
                    <StackPanel>
                        <TextBlock Text="预留像素输入"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Margin="0 0 0 12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="像素X" Style="{StaticResource NpcCaptionStyle}"/>
                                <TextBox Style="{StaticResource NpcTextBoxStyle}" Text="{Binding ModelParam.PreviewPixelX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="像素Y" Style="{StaticResource NpcCaptionStyle}"/>
                                <TextBox Style="{StaticResource NpcTextBoxStyle}" Text="{Binding ModelParam.PreviewPixelY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0 12 0 0">
                            <Button Content="验证转换"
                                    Style="{StaticResource NpcActionButtonStyle}"
                                    Command="{Binding GeneralCommand}"
                                    CommandParameter="验证转换"/>
                            <Button Content="移动到转换点"
                                    Style="{StaticResource NpcActionButtonStyle}"
                                    Command="{Binding GeneralCommand}"
                                    CommandParameter="移动到转换点"/>
                        </StackPanel>
                        <Border Background="{DynamicResource ExpanderPanelBackgroundBrush}" Padding="10" Margin="0 8 0 0">
                            <TextBlock Foreground="{DynamicResource SelectedBrush}">
                                <Run Text="X="/>
                                <Run Text="{Binding ModelParam.PreviewMachineX, Mode=OneWay, StringFormat=F6}"/>
                                <Run Text="   Y="/>
                                <Run Text="{Binding ModelParam.PreviewMachineY, Mode=OneWay, StringFormat=F6}"/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="White"
                        BorderBrush="{DynamicResource RegionSideBrush}"
                        BorderThickness="1"
                        Padding="14"
                        Margin="0 12 0 0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="输出信息"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="17"
                                   FontWeight="SemiBold"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 12 0 8">
                            <TextBlock Text="平均误差" Style="{StaticResource NpcCaptionStyle}"/>
                            <TextBlock Text="{Binding ModelParam.AverageError, StringFormat=F6}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0 0 18 0"/>
                            <TextBlock Text="最大误差" Style="{StaticResource NpcCaptionStyle}"/>
                            <TextBlock Text="{Binding ModelParam.MaxError, StringFormat=F6}"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBox Grid.Row="2"
                                 Style="{StaticResource NpcTextBoxStyle}"
                                 Height="64"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding ModelParam.HomMat2DText, Mode=OneWay}"/>
                        <Grid Grid.Row="3" Margin="0 12 0 0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox Width="250"
                                          Height="28"
                                          ItemsSource="{Binding ModelParam.OutputParamNames}"
                                          SelectedItem="{Binding SltOutputParamName, Mode=TwoWay}"
                                          Margin="0 0 8 0"/>
                                <Button Content="添加"
                                        Style="{StaticResource NpcActionButtonStyle}"
                                        Command="{Binding DataOperateCommand}"
                                        CommandParameter="Add"/>
                                <Button Content="删除"
                                        Style="{StaticResource NpcActionButtonStyle}"
                                        Command="{Binding DataOperateCommand}"
                                        CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="1"
                                      Style="{StaticResource DefaultDataGridStyle}"
                                      Margin="0 8 0 0"
                                      AutoGenerateColumns="False"
                                      ItemsSource="{Binding ModelParam.OutputParams}"
                                      SelectedItem="{Binding CurrentOutputParam, Mode=TwoWay}"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      RowHeaderWidth="0"
                                      GridLinesVisibility="All">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    <DataGridTextColumn Header="值" Binding="{Binding Value}" IsReadOnly="True" Width="*"/>
                                    <DataGridCheckBoxColumn Header="全局" Binding="{Binding IsGlobal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource RegionBackgroundBrush}"
                BorderBrush="{DynamicResource SelectedBrush}"
                BorderThickness="0 2 0 0"
                Padding="14 0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ModelParam.StatusMessage}"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="执行"
                            Style="{StaticResource NpcActionButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="执行"/>
                    <Button Content="取消"
                            Style="{StaticResource NpcActionButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="取消"/>
                    <Button Content="确认"
                            Style="{StaticResource NpcActionButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="确认"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

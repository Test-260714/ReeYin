<UserControl x:Class="ALGO.MeasureCircle.Views.MeasureCircleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:local="clr-namespace:ALGO.MeasureCircle.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:measureCircle="clr-namespace:ALGO.MeasureCircle.Controls"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             Loaded="UserControl_Loaded"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <!--<UserControl.Resources>
        <LinearGradientBrush x:Key="TabItem.Selected.BordernCjh" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FFE8A6" Offset="0.07" />
            <GradientStop Color="#FFFAEA" Offset="0.1" />
            <GradientStop Color="#FFFAEA" Offset="0.4" />
            <GradientStop Color="#FFE8A6" Offset="0.5" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="PrimaryBlueColor" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="SecundaryBlueColor" Color="#EFF2EF"/>
        <SolidColorBrush x:Key="PrimaryTextColor" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SecundaryTextColor" Color="#BBC1D1"/>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecundaryTextColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0 0 5 0"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Padding" Value="10 10"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Margin="{TemplateBinding Margin}"
                            />
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                      SnapsToDevicePixels="True"
                                      RecognizesAccessKey="True"
                                      Margin="{TemplateBinding Padding}"
                                      ContentSource="Header"
                                      Focusable="True"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SecundaryBlueColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBlueColor}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource PrimaryBlueColor}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SecundaryBlueColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource SecundaryBlueColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="50"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            --><!--TabPanel 可以设置 HorizontalAlignment 属性改变选项卡的对齐方式--><!--
                            <TabPanel Grid.Row="0" Background="Transparent" IsItemsHost="True" HorizontalAlignment="Center"/>

                            <Border Grid.Row="1"
                            CornerRadius="5"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}"                                    
                            >
                                <ContentPresenter ContentSource="SelectedContent"
                                          SnapsToDevicePixels="True"
                                          Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>-->
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>


        <!--主体-->
        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="基础参数" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid x:Name="gd">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="78*"/>
                                    <ColumnDefinition Width="235*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120"/>
                                    <RowDefinition Height="490"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                    <GroupBox Header="图像链接">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500">
                                                <TextBlock Width="150" Text="输入图像:" Foreground="Black" VerticalAlignment="Center" Margin="0"/>
                                                <WxLink:WxLink Width="350" InputParams="{Binding ModelParam.InputParams, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" 
                                                               OutputParam="{Binding ModelParam.InputImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  
                                                               Order="OpenParam" 
                                                               Margin="0 15 0 15"
                                                               Text="{Binding ModelParam.InputImage.Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                <Border Grid.Row="1" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                    <GroupBox Header="ROI信息">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500">
                                                <TextBlock Width="150" Text="圆心X:" Foreground="Black"  VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" Margin="0 15 0 15" 
                                                        InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                                        OutputParam="{Binding ModelParam.InitCircleCenterX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  
                                                        Order="OpenParam" Text="{Binding ModelParam.InitCircleCenterX,Mode=TwoWay,UpdateSourceTrigger=LostFocus,StringFormat=F4}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500">
                                                <TextBlock Width="150" Text="圆心Y:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" VerticalAlignment="Center" Margin="0 15 0 15" 
                                                                   InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                                                   OutputParam="{Binding ModelParam.InitCircleCenterY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  
                                                                   Order="OpenParam" Text="{Binding ModelParam.InitCircleCenterY,Mode=TwoWay,UpdateSourceTrigger=LostFocus,StringFormat=F4}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500">
                                                <TextBlock Width="150" Text="半径:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" VerticalAlignment="Center" Margin="0 15 0 15" 
                                                                   InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                                                   OutputParam="{Binding ModelParam.InitCircleRadius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  
                                                                   Order="OpenParam" Text="{Binding ModelParam.InitCircleRadius,Mode=TwoWay,UpdateSourceTrigger=LostFocus,StringFormat=F4}"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="卡尺设置" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}" VerticalAlignment="Top">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid x:Name="gd1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Margin="0,5,0,0">
                                        <GroupBox Header="测量参数" Grid.ColumnSpan="2" Margin="0,5,0,0">
                                            <UniformGrid Columns="2" VerticalAlignment="Top">
                                                <TextBlock Text="卡尺宽度:" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="5 5" SmallChange="1"
                                                    Value="{Binding ModelParam.Length2,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="卡尺高度:" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="5 5" SmallChange="1"
                                                    Value="{Binding ModelParam.Length1,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="灰度阈值:" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="5 5" SmallChange="1"
                                                     Value="{Binding ModelParam.Threshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="卡尺间隔:" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="5 5" SmallChange="1"
                                                    Value="{Binding ModelParam.MeasDis,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <TextBlock Text="边缘平滑:" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0.4" Maximum="100" Width="200" Margin="5 5" SmallChange="0.1"
                                                    Value="{Binding ModelParam.MeasureSigma,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="颜色模式:" VerticalAlignment="Center" />
                                                <ComboBox BorderThickness="0 0 0 1" Width="200" Margin="5 0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" VerticalAlignment="Center"
                                                    SelectedItem="{Binding ModelParam.MeasMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding MeasModes}"/>
                                                <TextBlock Text="筛选点:" VerticalAlignment="Center" />
                                                <ComboBox BorderThickness="0 0 0 1" Width="200" Margin="5 0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" VerticalAlignment="Center"
                                                    SelectedItem="{Binding ModelParam.MeasSelect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding MeasSelects}"/>
                                            </UniformGrid>
                                        </GroupBox>
                                    </Border>

                                    <Border Grid.Row="1" Margin="0,5,0,0">
                                        <GroupBox Header="抓圆增强参数" Grid.ColumnSpan="2" Margin="0,5,0,0">
                                            <UniformGrid Columns="2" VerticalAlignment="Top">
                                                <TextBlock Text="最低得分(0关闭):" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="1" Width="200" Margin="5 5" SmallChange="0.05"
                                                    Value="{Binding ModelParam.MinScore,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="最少有效点:" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="3" Maximum="99999999" Width="200" Margin="5 5" SmallChange="1"
                                                    Value="{Binding ModelParam.MinMeasurePointCount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="离群点容差(0关闭):" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="5 5" SmallChange="0.5"
                                                    Value="{Binding ModelParam.PointDistanceTolerance,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="最小半径(0不限):" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="5 5" SmallChange="1"
                                                    Value="{Binding ModelParam.MinRadius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="最大半径(0不限):" VerticalAlignment="Center"/>
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="5 5" SmallChange="1"
                                                    Value="{Binding ModelParam.MaxRadius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </UniformGrid>
                                        </GroupBox>
                                    </Border>
                                </Grid>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="显示设置" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}" VerticalAlignment="Top">
                            <Grid>
                                <Border Margin="0,5,0,0">
                                    <GroupBox Header="显示设置" Margin="0,5,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                <CheckBox Content="显示结果点" FontSize="20" IsChecked="{Binding ModelParam.ShowResultPoint}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                <CheckBox Content="显示结果圆" FontSize="20" IsChecked="{Binding ModelParam.ShowResultCircle}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                <CheckBox Content="显示圆心" FontSize="20" IsChecked="{Binding ModelParam.ShowCircleCenter}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                <CheckBox Content="显示圆心/半径信息" FontSize="20" IsChecked="{Binding ModelParam.ShowCircleInfo}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5">
                                                <CheckBox Content="显示测量轮廓" FontSize="20" IsChecked="{Binding ModelParam.ShowMeasContour}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="标定设置" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}" VerticalAlignment="Top">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="250"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Margin="0,5,0,0">
                                    <GroupBox Header="标定配置" Margin="0,5,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="10,10,10,5">
                                                <CheckBox Content="启用标定" FontSize="20"
                                                          IsChecked="{Binding ModelParam.EnableCalibration,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,5">
                                                <TextBlock Text="标定文件:" VerticalAlignment="Center"/>
                                                <TextBox Width="400"
                                                         Margin="10,0,5,0"
                                                         Text="{Binding ModelParam.CalibrationFilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{Binding ModelParam.CalibrationFilePath}"
                                                         BorderThickness="0 0 0 1"
                                                         IsEnabled="{Binding ModelParam.EnableCalibration}"/>
                                                <Button Content="选择"
                                                        Width="80"
                                                        Height="30"
                                                        Style="{StaticResource GeneralButtonStyle}"
                                                        Command="{Binding GeneralCommand}"
                                                        CommandParameter="选择标定文件"
                                                        IsEnabled="{Binding ModelParam.EnableCalibration}"/>
                                            </StackPanel>

                                            <TextBlock Margin="20,10,20,5"
                                                       Foreground="DarkOrange"
                                                       Text="{Binding ModelParam.CalibrationStatusText}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Margin="20,0,20,0"
                                                       Foreground="Gray"
                                                       Text="启用标定后必须配置标定文件；标定生效时输出标定板坐标系下的圆心和实际半径，未生效时输出像素坐标和像素半径。"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <Grid>
                            <measureCircle:MeasureCircleHalconControl x:Name="imageHost" Height="500" Margin="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Grid>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                     Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                                             ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                     Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                                         ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                      EnableColumnVirtualization="True"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      ItemsSource="{Binding ModelParam.OutputParams}" 
                                      SelectedItem="{Binding CurrentOutputParam}"
                                      FontSize="12" 
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      Height="160"
                                      RowHeaderWidth="20"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
                                                          SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                <!--<TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>-->
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="执行"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                    Height="auto" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="auto" Width="80"
                                                    Content="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

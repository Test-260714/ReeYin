<UserControl x:Class="ALGO.DeepLearning.Views.DeepLearningView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:enums="clr-namespace:ReeYin_V.Core.Enums;assembly=ReeYin_V.Core"
             xmlns:local="clr-namespace:ALGO.DeepLearning.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>


        <!--主体-->
        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="747" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="基础参数" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid x:Name="gd">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Margin="0,5,0,0">
                                    <GroupBox Header="图像链接">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="150"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="输入图像:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="400" InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                                             OutputParam="{Binding ModelParam.InputImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 15" Text="{Binding ModelParam.InputImageName,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="输入深度图:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="400" InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                                             OutputParam="{Binding ModelParam.InputDepth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 15" Text="{Binding ModelParam.InputDepthName,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                <Border Grid.Row="1" Margin="0,5,0,0">
                                    <GroupBox Header="模型配置">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="130"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="模型路径:" Foreground="Black" VerticalAlignment="Center" Margin="0 15 0 0" />
                                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <TextBox Text="{Binding ModelParam.ModelFilePath}" Width="370" Margin="5,15,0,0"
                                                             VerticalAlignment="Center" IsReadOnly="True" FontSize="15"/>
                                                    <Button Content="&#xe7b9;" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="25"
                                                            Command="{Binding GeneralCommand}" CommandParameter="选择模型文件" Margin="0,15,0,0"/>
                                                </StackPanel>

                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="推理设备:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                <ComboBox Grid.Row="1" Grid.Column="1" Width="400" Margin="5 15 5 5"
                                                          BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center"
                                                          VerticalContentAlignment="Center"
                                                          SelectedItem="{Binding ModelParam.DeviceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          ItemsSource="{Binding DeviceTypes}"/>

                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="模型类型:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                <ComboBox Grid.Row="2" Grid.Column="1" Width="400" Margin="5 5 5 5"
                                                          BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center"
                                                          VerticalContentAlignment="Center"
                                                          SelectedItem="{Binding ModelParam.ModelType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          ItemsSource="{Binding ModelTypes}"/>

                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="BatchSize:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxNumericUpDown:WxNumericUpDown Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="99999999" Width="400" Margin="5 5" SmallChange="1"
                                                                                 Value="{Binding ModelParam.BatchSize,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <!-- 动态参数部分 -->
                                                <ContentControl Grid.Row="4" Grid.ColumnSpan="2" Content="{Binding ModelParam}" Margin="0,10,0,0">
                                                    <ContentControl.Resources>

                                                        <!-- 默认模板：分类模型 -->
                                                        <DataTemplate x:Key="TplDefault">
                                                        </DataTemplate>

                                                        <!--目标检测、旋转框检测模型模板-->
                                                        <DataTemplate x:Key="TplDetectionBBox">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="130"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="置信度:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="400"  Margin="5 5 5 5"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               OutputParam="{Binding ConfidenceThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding ConfidenceThreshold,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="交并比:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="400"  Margin="5 5 5 5"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               OutputParam="{Binding IoUThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding IoUThreshold,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            </Grid>
                                                        </DataTemplate>

                                                        <!--实例分割模型模板-->
                                                        <DataTemplate x:Key="TplDetectionSeg">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="130"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="置信度:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="400"  Margin="5 5 5 5"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               OutputParam="{Binding ConfidenceThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding ConfidenceThreshold,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="交并比:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="400"  Margin="5 5 5 5"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               OutputParam="{Binding IoUThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding IoUThreshold,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="分割阈值:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <WxLink:WxLink Grid.Row="2" Grid.Column="1" Width="400"  Margin="5 5 5 5"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               OutputParam="{Binding SegmentationThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding SegmentationThreshold,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            </Grid>
                                                        </DataTemplate>

                                                        <!--关键点模型模板-->
                                                        <DataTemplate x:Key="TplDetectionKpt">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="130"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="置信度:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="400"  Margin="5 5 5 5"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               OutputParam="{Binding ConfidenceThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding ConfidenceThreshold,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="交并比:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="400"  Margin="5 5 5 5"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               OutputParam="{Binding IoUThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding IoUThreshold,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="关键点阈值:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <WxLink:WxLink Grid.Row="2" Grid.Column="1" Width="400"  Margin="5 5 5 5"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               OutputParam="{Binding KeypointThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding KeypointThreshold,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            </Grid>
                                                        </DataTemplate>

                                                        <!--实例分割模型模板-->
                                                        <DataTemplate x:Key="TplAnomalySeg">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="130"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="分割阈值:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="400"  Margin="5 5 5 5"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               OutputParam="{Binding SegmentationThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding SegmentationThreshold,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            </Grid>
                                                        </DataTemplate>

                                                    </ContentControl.Resources>

                                                    <!-- 模板选择逻辑 -->
                                                    <ContentControl.Style>
                                                        <Style TargetType="ContentControl">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource TplDefault}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Content.ModelType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:eDeepLearningModelType.目标检测}">
                                                                    <Setter Property="ContentTemplate" Value="{StaticResource TplDetectionBBox}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Content.ModelType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:eDeepLearningModelType.实例分割}">
                                                                    <Setter Property="ContentTemplate" Value="{StaticResource TplDetectionSeg}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Content.ModelType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:eDeepLearningModelType.旋转框检测}">
                                                                    <Setter Property="ContentTemplate" Value="{StaticResource TplDetectionBBox}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Content.ModelType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:eDeepLearningModelType.关键点检测}">
                                                                    <Setter Property="ContentTemplate" Value="{StaticResource TplDetectionKpt}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Content.ModelType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:eDeepLearningModelType.语义分割}">
                                                                    <Setter Property="ContentTemplate" Value="{StaticResource TplDefault}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Content.ModelType, RelativeSource={RelativeSource Self}}" Value="{x:Static enums:eDeepLearningModelType.异常检测}">
                                                                    <Setter Property="ContentTemplate" Value="{StaticResource TplAnomalySeg}"/>
                                                                </DataTrigger>

                                                            </Style.Triggers>
                                                        </Style>
                                                    </ContentControl.Style>
                                                </ContentControl>

                                                <!-- 模型加载按钮 -->
                                                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <Button Margin="0,0,0,10" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                            Command="{Binding GeneralCommand}" CommandParameter="加载模型"
                                                            Style="{StaticResource GeneralButtonStyle}"
                                                            Height="35" Width="85"
                                                            Content="加载模型"
                                                            Cursor="Hand"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                <Border Grid.Row="2" Margin="0,5,0,0">
                                    <GroupBox Header="其他设置">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <CheckBox Grid.Row="0" Content="急速模式" FontSize="20" IsChecked="{Binding ModelParam.IsFastModeEnabled}" Margin="55 5 5 5"/>

                                            </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Width="28"
                                        Height="24"
                                        Command="{Binding GeneralCommand}"
                                        CommandParameter="上一张图"
                                        Content="&lt;"
                                        FontSize="14"
                                        IsEnabled="{Binding ModelParam.CanMovePreviousPreviewImage}"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        ToolTip="上一张图" />
                                <TextBlock Grid.Column="1"
                                           MinWidth="46"
                                           Margin="6,0"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Text="{Binding ModelParam.CurrentPreviewImageDisplayText}" />
                                <Button Grid.Column="3"
                                        Width="28"
                                        Height="24"
                                        Command="{Binding GeneralCommand}"
                                        CommandParameter="下一张图"
                                        Content="&gt;"
                                        FontSize="14"
                                        IsEnabled="{Binding ModelParam.CanMoveNextPreviewImage}"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        ToolTip="下一张图" />
                            </Grid>

                            <local:DeepLearningPreviewControl Grid.Row="1"
                                                              Model="{Binding ModelParam}" />
                        </Grid>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
             FontFamily="{StaticResource Iconfont}"
                     ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                 FontFamily="{StaticResource Iconfont}" Margin="5 0"
                     ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      ItemsSource="{Binding ModelParam.OutputParams}" 
                      SelectedItem="{Binding CurrentOutputParam}"
                      FontSize="12" 
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Height="160"
                      RowHeaderWidth="20"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
         SelectedItem="{Binding Type,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="预览图片"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="auto"
                                                    Content="预览图片"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="执行"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                    Height="auto" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="auto" Width="80"
                                                    Content="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

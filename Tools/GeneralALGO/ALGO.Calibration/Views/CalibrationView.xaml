<UserControl x:Class="ALGO.Calibration.Views.CalibrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ALGO.Calibration.Views"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <!--主体-->
        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="模式配置" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2">
                                    <Grid>
                                        <Border CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" Height="670" >
                                            <TabControl Width="600" Height="630" SelectedIndex="{Binding ModelParam.SltTriggerIndex,Mode=TwoWay}" Style="{DynamicResource TabControlStyle}">
                                                <TabItem Header="标定" Style="{DynamicResource SingleTabItemStyle}" HorizontalAlignment="Center" Margin="0,2,0,0">
                                                    <Grid Margin="0,0,0,0">
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                                                <TextBlock Text="相机ID:" Foreground="Black" VerticalAlignment="Center" Margin="0,5,0,0"/>
                                                                <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Width="460" Margin="0,5"
                                                                               InputParams="{Binding ModelParam.InputParams,Mode=TwoWay}"
                                                                               OutputParam="{Binding ModelParam.CameraId,Mode=TwoWay}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding ModelParam.CameraId,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBox Text="{Binding ModelParam.CalibrationImageDir,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="510" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1" FontSize="15"/>
                                                                <Button Content="&#xe7b9;" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="获取图片路径"/>
                                                            </StackPanel>

                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                                <Button Content="&#xe693;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter=""/>
                                                                <Button Content="&#xe6dd;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter=""/>
                                                            </StackPanel>

                                                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                                                      EnableColumnVirtualization="True"
                                                                      EnableRowVirtualization="True"
                                                                      VirtualizingPanel.IsVirtualizing="True"
                                                                      ItemsSource="{Binding ModelParam.CalibImageNameList}" 
                                                                      SelectedItem="{Binding CurrentOutputParam}"
                                                                      FontSize="12" 
                                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                                      ScrollViewer.CanContentScroll="True"
                                                                      Height="390"
                                                                      RowHeaderWidth="20"
                                                                      SelectionUnit="FullRow"
                                                                      HeadersVisibility="Column"
                                                                      GridLinesVisibility="All"
                                                                      IsReadOnly="False" CanUserAddRows="False" >
                                                                <DataGrid.Columns>
                                                                    <DataGridTemplateColumn Header="启用" IsReadOnly="False" Width="50">
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <CheckBox IsChecked="{Binding IsSelected}"  HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                    </DataGridTemplateColumn>
                                                                    <DataGridTemplateColumn Header="索引" IsReadOnly="False" Width="auto">
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBox Text="{Binding ID,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                    </DataGridTemplateColumn>
                                                                    <DataGridTemplateColumn Header="名称" IsReadOnly="True" Width="*">
                                                                        <DataGridTemplateColumn.CellTemplate>
                                                                            <DataTemplate>
                                                                                <TextBox Text="{Binding ImageName,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                                            </DataTemplate>
                                                                        </DataGridTemplateColumn.CellTemplate>
                                                                    </DataGridTemplateColumn>


                                                                </DataGrid.Columns>
                                                            </DataGrid>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                                
                                                <TabItem Header="使用标定"  Style="{DynamicResource SingleTabItemStyle}" HorizontalAlignment="Center" Margin="0,2,0,0" >
                                                    <Grid Margin="0,0,0,0">
                                                        <StackPanel Orientation="Vertical">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                                <TextBlock Text="模式:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                <ComboBox Width="300"
                                                                          BorderThickness="0 0 0 1"
                                                                          HorizontalContentAlignment="Center"
                                                                          VerticalContentAlignment="Center"
                                                                          SelectedItem="{Binding ModelParam.CalibUsageModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ItemsSource="{Binding CalibUsageModels}"/>
                                                            </StackPanel>

                                                            <!-- 根据 UseModelType 切换不同模式 -->
                                                            <ContentControl Content="{Binding ModelParam}">
                                                                <ContentControl.Resources>
                                                                    <!-- ========== 像素坐标转物理坐标 ========== -->
                                                                    <DataTemplate x:Key="TplPixelToWorld">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                                                            <TextBlock Text="输入点集:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                            <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Width="285" Margin="5,15"
                                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                           OutputParam="{Binding InputPointSet,Mode=TwoWay}"
                                                                                           Order="OpenParam"
                                                                                           Text="{Binding InputPointSet.Name,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                    <!-- ========== 物理坐标转像素坐标 ========== -->
                                                                    <DataTemplate x:Key="TplWorldToPixel">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                                                            <TextBlock Text="输入点集:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                            <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Width="285" Margin="5,15"
                                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                           OutputParam="{Binding InputPointSet,Mode=TwoWay}"
                                                                                           Order="OpenParam"
                                                                                           Text="{Binding InputPointSet.Name,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                    <!-- ========== 图像校正 ========== -->
                                                                    <DataTemplate x:Key="TplImageCorrection">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                            <TextBlock Text="输入图像:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                                            <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Width="285" Margin="5,15"
                                                                                           InputParams="{Binding InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                                                                           OutputParam="{Binding InputImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  
                                                                                           Order="OpenParam"
                                                                                           Text="{Binding InputImage.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ContentControl.Resources>

                                                                <!-- 用触发器根据 UseModelType 切换不同模式 -->
                                                                <ContentControl.Style>
                                                                    <Style TargetType="ContentControl">
                                                                        <!-- 默认：像素坐标转物理坐标 -->
                                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplPixelToWorld}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding DataContext.ModelParam.CalibUsageModel, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="世界坐标转像素">
                                                                                <Setter Property="ContentTemplate" Value="{StaticResource TplWorldToPixel}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding DataContext.ModelParam.CalibUsageModel, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="图像校正">
                                                                                <Setter Property="ContentTemplate" Value="{StaticResource TplImageCorrection}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ContentControl.Style>
                                                            </ContentControl>


                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                                
                                            </TabControl>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </TabItem>


                        <TabItem Header="标定配置" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid Margin="0" Background="{DynamicResource LightBackgroundBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <Border CornerRadius="0" Padding="30,24,30,20" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                        <Grid>
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled"
                                                              CanContentScroll="False"
                                                              Padding="0,0,8,0">
                                                    <StackPanel>
                                                    <!-- 选择【标定板类型】 -->
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                        <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="标定板类型:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                            <ComboBox Grid.Row="0" Grid.Column="1" Width="285" Margin="0,0,10,0"
                                                                      BorderThickness="0 0 0 1"
                                                                      HorizontalContentAlignment="Center"
                                                                      VerticalContentAlignment="Center"
                                                                      SelectedItem="{Binding ModelParam.CalibBoardType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      ItemsSource="{Binding CalibBoardTypes}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                        <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="高度补偿(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <TextBox Grid.Row="0" Grid.Column="1" Width="285" Margin="0,0,10,0"
                                                                     BorderThickness="0 0 0 1"
                                                                     Text="{Binding ModelParam.HeightCompensation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                    <!-- 根据 BoardType 切换不同模板 -->
                                                    <ContentControl Content="{Binding ModelParam}">
                                                        <ContentControl.Resources>
                                                            <!-- ========== 棋盘格模板 ========== -->
                                                            <DataTemplate x:Key="TplChessboard">
                                                                <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="150"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="图案行数:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="0" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding PatternRows,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding PatternRows,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="图案列数:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="1" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding PatternCols,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding PatternCols,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="方格尺寸(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="2" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding SquareSize,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding SquareSize,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                            <!-- ========== Charuco 模板 ========== -->
                                                            <DataTemplate x:Key="TplCharuco">
                                                                <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="150"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="图案行数:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="0" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding PatternRows,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding PatternRows,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="图案列数:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="1" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding PatternCols,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding PatternCols,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="方格尺寸(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="2" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding SquareSize,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding SquareSize,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="二维码尺寸(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="3" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding MarkerSize,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding MarkerSize,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="方格像素(px):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="4" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding SquareSizePixel,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding SquareSizePixel,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="二维码像素(px):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="5" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding MarkerSizePixel,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding MarkerSizePixel,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="二维码类型:" Foreground="Black" VerticalAlignment="Center" Margin="0,20,10,0"/>
                                                                    <ComboBox Grid.Row="6" Grid.Column="1" Width="285" BorderThickness="0 0 0 1" Margin="0,20,10,0"
                                                                              HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                                              SelectedItem="{Binding DictionaryId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              ItemsSource="{Binding DataContext.DictionaryIds, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                            <!-- ========== 像素比 模式模板 ========== -->
                                                            <DataTemplate x:Key="TplPixelRatio">
                                                                <Grid  Margin="0,0,0,0" HorizontalAlignment="Center">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="150"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>

                                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="实际距离(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="0" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding RealDistance,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding RealDistance,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="线段1:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="1" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding Line1,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding Line1.Name,Mode=OneWay}"/>

                                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="线段2:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                    <WxLink:WxLink HorizontalContentAlignment="Stretch" TextAlignment="Center" Grid.Row="2" Grid.Column="1" Width="285" Margin="5,15"
                                                                                   InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                                   OutputParam="{Binding Line2,Mode=TwoWay}"
                                                                                   Order="OpenParam"
                                                                                   Text="{Binding Line2.Name,Mode=OneWay}"/>

                                                                </Grid>
                                                            </DataTemplate>
                                                        </ContentControl.Resources>
                                                        <!-- 用触发器根据 BoardType 切换模板 -->
                                                        <ContentControl.Style>
                                                            <Style TargetType="ContentControl">
                                                                <!-- 默认：棋盘格 -->
                                                                <Setter Property="ContentTemplate" Value="{StaticResource TplChessboard}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.ModelParam.CalibBoardType, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="Charuco">
                                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplCharuco}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DataContext.ModelParam.CalibBoardType, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="像素比">
                                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplPixelRatio}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                    </ContentControl>
                                                    </StackPanel>
                                                </ScrollViewer>
                                        </Grid>
                                    </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="标定结果" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}" VerticalAlignment="Top">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>


                                <!-- 功能按钮区域 -->
                                <Border Grid.Row="0" Background="{DynamicResource LightBackgroundBrush}" Padding="10" Margin="0,0,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <!-- 导出按钮 -->
                                        <Button Content="导出" Style="{StaticResource GeneralButtonStyle}" Margin="0,0,10,0" ToolTip="将标定结果导出到指定目录"
                                                Command="{Binding GeneralCommand}" CommandParameter="导出标定文件"/>

                                        <!-- 导出目录选择 -->
                                        <TextBlock Text="导出目录:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBox Text="{Binding ModelParam.CalibFileOutputDir}" Width="420" Margin="0,0,5,0"
                                                 VerticalAlignment="Center" IsReadOnly="True" FontSize="15"/>
                                        <Button Content="&#xe7b9;" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30"
                                                Command="{Binding GeneralCommand}" CommandParameter="选择标定文件导出目录"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Background="{DynamicResource LightBackgroundBrush}" Padding="10" Margin="0,0,0,0">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <!-- 导入按钮 -->
                                        <Button Content="导入" Style="{StaticResource GeneralButtonStyle}" Margin="0,0,10,0" ToolTip="从文件导入标定结果"
                                                Command="{Binding GeneralCommand}" CommandParameter="导入标定文件"/>
                                        <TextBlock Text="标定文件:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBox Text="{Binding ModelParam.CalibrationFilePath}" Width="620" Margin="0,0,5,0"
                                                 VerticalAlignment="Center" IsReadOnly="True" FontSize="15"/>
                                    </StackPanel>
                                </Border>


                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                    <Grid Margin="10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 基本信息 -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="相机ID:" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ModelParam.CameraId}" Margin="0" FontSize="15"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="标定板类型:" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModelParam.CalibBoardType}" Margin="0" FontSize="15"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="图案行数:" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ModelParam.PatternRows}" Margin="0" FontSize="15"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="图案列数:" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ModelParam.PatternCols}" Margin="0" FontSize="15"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="方格尺寸(mm):" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ModelParam.SquareSize}" Margin="0" FontSize="15"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="二维码字典ID:" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ModelParam.DictionaryId}" Margin="0" FontSize="15"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="二维码尺寸(mm):" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ModelParam.MarkerSize}" Margin="0" FontSize="15"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" Text="像素当量X(mm):" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ModelParam.IntervalX}" Margin="0" FontSize="15"/>

                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="像素当量Y(mm):" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ModelParam.IntervalY}" Margin="0" FontSize="15"/>

                                        <TextBlock Grid.Row="9" Grid.Column="0" Text="标定误差:" Margin="0" FontSize="15"/>
                                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding ModelParam.Error}" Margin="0" FontSize="15"/>



                                        <!-- 内参矩阵 -->
                                        <Expander Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Header="内参矩阵" Margin="5" IsExpanded="False">
                                            <ItemsControl ItemsSource="{Binding ModelParam.IntrinsicMatrix}" FontSize="12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="3" Columns="3"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0:F6}}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>

                                        <!-- 畸变系数 -->
                                        <Expander Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Header="畸变系数" Margin="5" IsExpanded="False">
                                            <ItemsControl ItemsSource="{Binding ModelParam.DistortionCoefficients}" FontSize="12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="8" Rows="1"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0:F6}}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>

                                        <!-- 旋转向量 -->
                                        <Expander Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" Header="旋转向量" Margin="5" IsExpanded="False">
                                            <ItemsControl ItemsSource="{Binding ModelParam.RotationVector}" FontSize="12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="3" Rows="1"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0:F6}}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>

                                        <!-- 平移向量 -->
                                        <Expander Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2" Header="平移向量" Margin="5" IsExpanded="False">
                                            <ItemsControl ItemsSource="{Binding ModelParam.TranslationVector}" FontSize="12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Columns="3" Rows="1"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0:F6}}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>

                                        <!-- 外参矩阵 -->
                                        <Expander Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" Header="外参矩阵" Margin="5" IsExpanded="False">
                                            <ItemsControl ItemsSource="{Binding ModelParam.ExtrinsicMatrix}" FontSize="12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="4" Columns="4"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0:F6}}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>

                                        <!-- 单应性矩阵 -->
                                        <Expander Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="2" Header="单应性矩阵" Margin="5" IsExpanded="False">
                                            <ItemsControl ItemsSource="{Binding ModelParam.HomographyMatrix}" FontSize="12">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <UniformGrid Rows="3" Columns="3"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat={}{0:F6}}" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           Margin="2"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Expander>



                                    </Grid>
                                </ScrollViewer>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <Controls:ImageEditView Image="{Binding ModelParam.Image,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Height="300" Background="{StaticResource BackgroudBrush}"/>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
         Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                 ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
             Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                 ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                  EnableColumnVirtualization="True"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  ItemsSource="{Binding ModelParam.OutputParams}" 
                  SelectedItem="{Binding CurrentOutputParam}"
                  FontSize="12" 
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  Height="160"
                  RowHeaderWidth="20"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
     SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                <!--<TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>-->
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                    WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                    <Run Text="耗时:"/>
                    <Run Text="{Binding ModelParam.Output.RunTime}"/>
                    <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                    <Run Text="执行状态:"/>
                    <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                Command="{Binding GeneralCommand}" CommandParameter="执行"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                Height="35" Width="80"
                                                Content="执行"
                                                Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                Height="auto" Width="80"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                Content="取消"
                                                Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                Height="auto" Width="80"
                                                Content="确认"
                                                Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="ALGO.ImagePerProcessing.Views.ImagePerProcessingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:local="clr-namespace:ALGO.ImagePerProcessing.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:converters="clr-namespace:ALGO.ImagePerProcessing.ViewModels"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <UserControl.Resources>
        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter"/>
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
    </UserControl.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>


        <!--主体-->
        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="基础参数" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid x:Name="gd">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120"/>
                                    <RowDefinition Height="100"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Margin="0,5,0,0">
                                    <GroupBox Header="图像链接">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Text="输入图像:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="400" InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                                                           OutputParam="{Binding ModelParam.InputImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 15" Text="{Binding ModelParam.InputImage.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                <Border Grid.Row="1" Margin="0,5,0,0">
                                    <GroupBox Header="ROI类型">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="5 5" HorizontalAlignment="Center">
                                                <RadioButton Content="全图" FontSize="20" Margin="0 0 0 0" Width="100" Height="40"
                                                             IsChecked="{Binding ModelParam.SelectedROIType,
                                                                                 Converter={StaticResource EnumToBooleanConverter},
                                                                                 ConverterParameter=全图}" />

                                                <RadioButton Content="链接ROI" FontSize="20" Margin="80 0 0 0" Width="100" Height="40"
                                                             IsChecked="{Binding ModelParam.SelectedROIType,
                                                                                 Converter={StaticResource EnumToBooleanConverter},
                                                                                 ConverterParameter=链接ROI}" />

                                                <RadioButton Content="绘制ROI" FontSize="20" Margin="80 0 0 0" Width="100" Height="40"
                                                             IsChecked="{Binding ModelParam.SelectedROIType,
                                                                                 Converter={StaticResource EnumToBooleanConverter},
                                                                                 ConverterParameter=绘制ROI}" />

                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                <Border Grid.Row="2" Margin="0,5,0,0">
                                    <GroupBox Header="ROI信息">
                                        <StackPanel>
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedROIType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=链接ROI}">
                                                <StackPanel>
                                                    <CheckBox Content="输出ROI裁剪图像" FontSize="20" IsChecked="{Binding ModelParam.IsOutImageReduced}" Margin="0 10 0 10"/>
                                                </StackPanel>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ROI:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" Width="80" />
                                                        <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="400" InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                                                       OutputParam="{Binding ModelParam.InputROI,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 15" Text="{Binding ModelParam.InputROI.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                    </Grid>
                                                </StackPanel>

                                            </StackPanel>
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedROIType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=绘制ROI}">
                                                <StackPanel>
                                                    <CheckBox Content="输出ROI裁剪图像" FontSize="20" IsChecked="{Binding ModelParam.IsOutImageReduced}" Margin="0 10 0 10"/>
                                                </StackPanel>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ROI类型:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="80" />
                                                        <ComboBox Grid.Row="0" Grid.Column="1" Width="400" Margin="10,10,0,0"
                                                                  BorderThickness="0 0 0 1"
                                                                  HorizontalContentAlignment="Center"
                                                                  VerticalContentAlignment="Center"
                                                                  SelectedItem="{Binding ModelParam.CreateROIType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  ItemsSource="{Binding CreateROITypes}"/>
                                                    </Grid>
                                                </StackPanel>

                                                <ContentControl Content="{Binding ModelParam}">
                                                    <ContentControl.Resources>
                                                        <!-- ========== 矩形模板 ========== -->
                                                        <DataTemplate x:Key="TplRectangle">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="长度1:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="400" Margin="5,15"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                               OutputParam="{Binding Rect2Len1,Mode=TwoWay}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding Rect2Len1,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="长度2:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="400" Margin="5,15"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                               OutputParam="{Binding Rect2Len2,Mode=TwoWay}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding Rect2Len2,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="中心X:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                <WxLink:WxLink Grid.Row="2" Grid.Column="1" Width="400" Margin="5,15"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                               OutputParam="{Binding Rect2CenterX,Mode=TwoWay}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding Rect2CenterX,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="3" Grid.Column="0" Text="中心Y:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                <WxLink:WxLink Grid.Row="3" Grid.Column="1" Width="400" Margin="5,15"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                               OutputParam="{Binding Rect2CenterY,Mode=TwoWay}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding Rect2CenterY,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="4" Grid.Column="0" Text="角度:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                <WxLink:WxLink Grid.Row="4" Grid.Column="1" Width="400" Margin="5,15"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                               OutputParam="{Binding Rect2Deg,Mode=TwoWay}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding Rect2Deg,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                        <!-- ========== 圆形模板 ========== -->
                                                        <DataTemplate x:Key="TplCircle">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>

                                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="圆心X:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="400" Margin="5,15"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                               OutputParam="{Binding CircleX,Mode=TwoWay}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding CircleX,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="圆心Y:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="400" Margin="5,15"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                               OutputParam="{Binding CircleY,Mode=TwoWay}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding CircleY,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>

                                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="半径:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                                <WxLink:WxLink Grid.Row="2" Grid.Column="1" Width="400" Margin="5,15"
                                                                               InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                               OutputParam="{Binding CircleRadius,Mode=TwoWay}"
                                                                               Order="OpenParam"
                                                                               Text="{Binding CircleRadius,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>


                                                            </Grid>
                                                        </DataTemplate>
                                                    </ContentControl.Resources>
                                                    <ContentControl.Style>
                                                        <Style TargetType="ContentControl">
                                                            <Setter Property="ContentTemplate" Value="{StaticResource TplRectangle}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.ModelParam.CreateROIType, RelativeSource={RelativeSource AncestorType=TabItem}}" Value="圆形">
                                                                    <Setter Property="ContentTemplate" Value="{StaticResource TplCircle}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ContentControl.Style>
                                                </ContentControl>


                                            </StackPanel>



                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="模式配置" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}" VerticalAlignment="Top">
                            <Grid x:Name="gd1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="50"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                    <StackPanel Orientation="Horizontal" Grid.Row="0" Cursor="">
                                        <Menu VerticalAlignment="Center" Margin="10,0,0,0" ToolTip="添加">
                                            <MenuItem HorizontalAlignment="Center" VerticalContentAlignment="Center" >
                                                <MenuItem.Icon>
                                                    <Grid Margin="-10,-10,-20,-10">
                                                        <TextBlock Text="&#xe60a;" 
                                                                   FontFamily="{StaticResource Iconfont}" 
                                                                   FontSize="28"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </MenuItem.Icon>
                                                <MenuItem Header="图像调整" HorizontalAlignment="Center" VerticalContentAlignment="Center" >
                                                    <MenuItem Header="RGB转BGR" Command="{Binding GeneralCommand}" CommandParameter="add_RGB转BGR"/>
                                                    <MenuItem Header="彩色转灰" Command="{Binding GeneralCommand}" CommandParameter="add_彩色转灰"/>
                                                    <MenuItem Header="反色" Command="{Binding GeneralCommand}" CommandParameter="add_反色"/>
                                                    <MenuItem Header="图像镜像" Command="{Binding GeneralCommand}" CommandParameter="add_图像镜像"/>
                                                    <MenuItem Header="图像旋转" Command="{Binding GeneralCommand}" CommandParameter="add_图像旋转"/>
                                                    <MenuItem Header="修改图像尺寸" Command="{Binding GeneralCommand}" CommandParameter="add_修改图像尺寸"/>
                                                </MenuItem>
                                                <MenuItem Header="滤波" HorizontalAlignment="Center" VerticalContentAlignment="Center" >
                                                    <MenuItem Header="均值滤波" Command="{Binding GeneralCommand}" CommandParameter="add_均值滤波"/>
                                                    <MenuItem Header="中值滤波" Command="{Binding GeneralCommand}" CommandParameter="add_中值滤波"/>
                                                    <MenuItem Header="高斯滤波" Command="{Binding GeneralCommand}" CommandParameter="add_高斯滤波"/>
                                                </MenuItem>
                                                <MenuItem Header="形态学运算" HorizontalAlignment="Center" VerticalContentAlignment="Center" >
                                                    <MenuItem Header="灰度膨胀" Command="{Binding GeneralCommand}" CommandParameter="add_灰度膨胀"/>
                                                    <MenuItem Header="灰度腐蚀" Command="{Binding GeneralCommand}" CommandParameter="add_灰度腐蚀"/>
                                                    <MenuItem Header="灰度开运算" Command="{Binding GeneralCommand}" CommandParameter="add_灰度开运算"/>
                                                    <MenuItem Header="灰度闭运算" Command="{Binding GeneralCommand}" CommandParameter="add_灰度闭运算"/>
                                                </MenuItem>
                                                <MenuItem Header="图像增强" HorizontalAlignment="Center" VerticalContentAlignment="Center" >
                                                    <MenuItem Header="锐化" Command="{Binding GeneralCommand}" CommandParameter="add_锐化"/>
                                                    <MenuItem Header="对比度" Command="{Binding GeneralCommand}" CommandParameter="add_对比度"/>
                                                    <MenuItem Header="亮度调节" Command="{Binding GeneralCommand}" CommandParameter="add_亮度调节"/>
                                                </MenuItem>
                                                <MenuItem Header="二值化" HorizontalAlignment="Center" VerticalContentAlignment="Center" >
                                                    <MenuItem Header="二值化" Command="{Binding GeneralCommand}" CommandParameter="add_二值化"/>
                                                    <MenuItem Header="均值二值化" Command="{Binding GeneralCommand}" CommandParameter="add_均值二值化"/>
                                                </MenuItem>
                                            </MenuItem>
                                        </Menu>
                                        <Button Content="&#xe74b;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                Command="{Binding GeneralCommand}" CommandParameter="remove"/>
                                        <Button Content="&#xe6dd;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                Command="{Binding GeneralCommand}" CommandParameter="up"/>
                                        <Button Content="&#xe693;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                Command="{Binding GeneralCommand}" CommandParameter="down"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                    <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              ItemsSource="{Binding ModelParam.ModelToolList}" 
                                              SelectedItem="{Binding ModelParam.SelectedModel}"
                                              SelectedIndex="{Binding ModelParam.SelectedModelIndex}"
                                              FontSize="14" 
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.CanContentScroll="True"
                                              RowHeaderWidth="20"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="All"
                                              IsReadOnly="False" CanUserAddRows="False" >
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="启用" IsReadOnly="False" Width="80">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding m_enable}"  HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="类型" IsReadOnly="False" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding m_name, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="参数" IsReadOnly="True" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding m_value, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>


                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                                <Border Grid.Row="2" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                    <GroupBox Header="参数" Grid.ColumnSpan="2" Margin="0,5,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition />
                                            </Grid.RowDefinitions>

                                            <!--彩色转灰-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=彩色转灰}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="转换类型:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100" />
                                                    <ComboBox Width="380" Margin="10,10,0,0"
                                                              BorderThickness="0 0 0 1"
                                                              HorizontalContentAlignment="Center"
                                                              VerticalContentAlignment="Center"
                                                              SelectedItem="{Binding ModelParam.SelectedModel.m_TransImageType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ItemsSource="{Binding ModelParam.SelectedModel.TransImageTypes}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--图像镜像-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=图像镜像}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="镜像方法:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100" />
                                                    <ComboBox Width="380" Margin="10,10,0,0"
                                                              BorderThickness="0 0 0 1"
                                                              HorizontalContentAlignment="Center"
                                                              VerticalContentAlignment="Center"
                                                              SelectedItem="{Binding ModelParam.SelectedModel.m_MirrorImageType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ItemsSource="{Binding ModelParam.SelectedModel.MirrorImageTypes}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--图像旋转-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=图像旋转}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="旋转角度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100" />
                                                    <ComboBox Width="380" Margin="10,10,0,0"
                                                              BorderThickness="0 0 0 1"
                                                              HorizontalContentAlignment="Center"
                                                              VerticalContentAlignment="Center"
                                                              SelectedItem="{Binding ModelParam.SelectedModel.m_RotateImageAngle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ItemsSource="{Binding ModelParam.SelectedModel.RotateImageAngles}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--修改图像尺寸-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=修改图像尺寸}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_ChangeImageWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_ChangeImageHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--均值滤波-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=均值滤波}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_MeanImageWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_MeanImageHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--中值滤波-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=中值滤波}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_MedianImageWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_MedianImageHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--高斯滤波-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=高斯滤波}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="大小:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="3" Maximum="11" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_GaussImageSize,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--灰度膨胀-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=灰度膨胀}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Maximum="99999" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_GrayDilationWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Maximum="99999" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_GrayDilationHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--灰度腐蚀-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=灰度腐蚀}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_GrayErosionWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_GrayErosionHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--锐化-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=锐化}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="3" Maximum="201" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_EmphaSizeWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="3" Maximum="201" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_EmphaSizeHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="对比因子:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="0.3" Maximum="20" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_EmphaSizeFactor,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--对比度-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=对比度}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="3" Maximum="299" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_IlluminateWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="3" Maximum="299" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_IlluminateHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="对比因子:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="5" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_IlluminateFactor,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--亮度调节-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=亮度调节}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="Mult:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="0" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_ScaleImageMult,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="add:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="0" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_ScaleImageAdd,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--灰度开运算-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=灰度开运算}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_OpeningWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_OpeningHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--灰度闭运算-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=灰度闭运算}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_ClosingWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_ClosingHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--反色-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=反色}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <CheckBox Content="反色" FontSize="20" IsChecked="{Binding ModelParam.SelectedModel.m_InvertImageLogic}" Margin="0 10 0 10"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--二值化-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=二值化}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="低阈值:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="255" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_ThresholdLow,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高阈值:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="255" Width="380" Margin="5 5" SmallChange="1"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_ThresholdHight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <CheckBox Content="黑白反转" FontSize="20" IsChecked="{Binding ModelParam.SelectedModel.m_ThresholdReverse}" Margin="0 10 0 10"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <!--均值二值化-->
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="500" Visibility="{Binding ModelParam.SelectedModel.m_name, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=均值二值化}">
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="宽度:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_VarThresholdWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="高度:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_VarThresholdHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="阈值偏移:"  Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100"/>
                                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Width="380" Margin="5 5" SmallChange="0.001"  Precision="6"
                                                                                     Value="{Binding ModelParam.SelectedModel.m_VarThresholdSkew,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="5">
                                                    <TextBlock Text="比较类型:" Foreground="Black" VerticalAlignment="Center" Margin="0 10 0 0" Width="100" />
                                                    <ComboBox Width="380" Margin="10,10,0,0"
                                                              BorderThickness="0 0 0 1"
                                                              HorizontalContentAlignment="Center"
                                                              VerticalContentAlignment="Center"
                                                              SelectedItem="{Binding ModelParam.SelectedModel.m_VarThresholdType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ItemsSource="{Binding ModelParam.SelectedModel.VarThresholdTypes}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <local:ImagePerProcessingPreviewControl Model="{Binding ModelParam}"/>
                        </StackPanel>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
             Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                     ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                 Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                     ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      ItemsSource="{Binding ModelParam.OutputParams}" 
                      SelectedItem="{Binding CurrentOutputParam}"
                      FontSize="12" 
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Height="160"
                      RowHeaderWidth="20"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
         SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                <!--<TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>-->
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="执行"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                    Height="auto" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="auto" Width="80"
                                                    Content="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

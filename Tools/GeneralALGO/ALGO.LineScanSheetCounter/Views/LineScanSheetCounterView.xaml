<UserControl x:Class="ALGO.LineScanSheetCounter.Views.LineScanSheetCounterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:local="clr-namespace:ALGO.LineScanSheetCounter.Views"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             mc:Ignorable="d"
             FontSize="14"
             Height="880"
             Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880"
             d:DesignWidth="1280">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="86" />
        </Grid.RowDefinitions>

        <Grid Margin="0,37,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.6*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="0.4*" />
            </Grid.ColumnDefinitions>

            <Border Padding="5">
                <TabControl Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                    <TabItem Header="基础参数" Width="100" FontSize="18" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8" TextElement.FontSize="12">
                                <GroupBox Header="图像链接" Margin="0,0,0,10">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500">
                                            <TextBlock Width="150" Text="输入图像：" VerticalAlignment="Center" />
                                            <WxLink:WxLink Width="350"
                                                           InputParams="{Binding ModelParam.InputParams, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                           OutputParam="{Binding InputImage, Mode=TwoWay}"
                                                           Order="OpenParam"
                                                           Margin="5,15"
                                                           Text="{Binding InputImage.Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500">
                                            <TextBlock Width="150" Text="掩膜图像：" VerticalAlignment="Center" />
                                            <WxLink:WxLink Width="350"
                                                           InputParams="{Binding ModelParam.InputParams, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                           OutputParam="{Binding MaskImage, Mode=TwoWay}"
                                                           Order="OpenParam"
                                                           Margin="5,15"
                                                           Text="{Binding MaskImage.Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="计数参数" Margin="0,0,0,10">
                                    <Grid Margin="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="70" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="36" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="缩放系数：" VerticalAlignment="Center" />
                                        <Slider Grid.Column="1"
                                                Minimum="0.05"
                                                Maximum="1"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding ScaleFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="{Binding ScaleFactor, StringFormat={}{0:F2}}" VerticalAlignment="Center" Margin="8,0,0,0" />

                                        <TextBlock Grid.Row="1" Text="平滑 Sigma：" VerticalAlignment="Center" />
                                        <Slider Grid.Row="1"
                                                Grid.Column="1"
                                                Minimum="0.1"
                                                Maximum="80"
                                                TickFrequency="0.5"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding SmoothSigma, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding SmoothSigma, StringFormat={}{0:F1}}" VerticalAlignment="Center" Margin="8,0,0,0" />

                                        <TextBlock Grid.Row="2" Text="边缘阈值：" VerticalAlignment="Center" />
                                        <Slider Grid.Row="2"
                                                Grid.Column="1"
                                                Minimum="1"
                                                Maximum="255"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding EdgeThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding EdgeThreshold, StringFormat={}{0:F1}}" VerticalAlignment="Center" Margin="8,0,0,0" />

                                        <TextBlock Grid.Row="3" Text="卡尺列坐标：" VerticalAlignment="Center" />
                                        <Slider Grid.Row="3"
                                                Grid.Column="1"
                                                Minimum="0"
                                                Maximum="{Binding ModelParam.PreviewImageWidth}"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding MeasureCenterColumn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding MeasureCenterColumn, StringFormat={}{0:F1}}" VerticalAlignment="Center" Margin="8,0,0,0" />

                                        <TextBlock Grid.Row="4" Text="ROI宽度：" VerticalAlignment="Center" />
                                        <Slider Grid.Row="4"
                                                Grid.Column="1"
                                                Minimum="1"
                                                Maximum="{Binding ModelParam.PreviewRoiWidthMaximum}"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding MeasureRoiWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding MeasureRoiWidth, StringFormat={}{0:F1}}" VerticalAlignment="Center" Margin="8,0,0,0" />

                                        <TextBlock Grid.Row="5" Text="裁剪比例：" VerticalAlignment="Center" />
                                        <Slider Grid.Row="5"
                                                Grid.Column="1"
                                                Minimum="0"
                                                Maximum="1"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding CropRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding CropRatio, StringFormat={}{0:F2}}" VerticalAlignment="Center" Margin="8,0,0,0" />

                                        <CheckBox Grid.Row="6"
                                                  Grid.ColumnSpan="2"
                                                  Content="下次执行前重置计数和残留图像"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding ResetBeforeNextRun, Mode=TwoWay}" />
                                        <CheckBox Grid.Row="6"
                                                  Grid.Column="1"
                                                  Content="急速模式"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding IsFastModeEnabled, Mode=TwoWay}" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="保存设置" Margin="0,0,0,10">
                                    <Grid Margin="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="36" />
                                            <RowDefinition Height="42" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal">
                                            <CheckBox Content="保存片材图"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,28,0"
                                                      IsChecked="{Binding SaveSheetImages, Mode=TwoWay}" />
                                            <CheckBox Content="保存拼接图"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,28,0"
                                                      IsChecked="{Binding SaveConcatImage, Mode=TwoWay}" />
                                            <CheckBox Content="保存残留图"
                                                      VerticalAlignment="Center"
                                                      IsChecked="{Binding SaveRemainImage, Mode=TwoWay}" />
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Text="保存路径：" VerticalAlignment="Center" />
                                        <WxLink:WxLink Grid.Row="1"
                                                       Grid.Column="1"
                                                       Height="28"
                                                       Order="OpenFile"
                                                       Text="{Binding SaveDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="实时计数状态">
                                    <StackPanel Orientation="Horizontal" Margin="10">
                                        <TextBlock Text="本次新增：" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding ModelParam.IncrementCount}" FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="50" />
                                        <TextBlock Text="累计数量：" VerticalAlignment="Center" Margin="24,0,0,0" />
                                        <TextBlock Text="{Binding ModelParam.TotalCount}" FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="50" />
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch" />

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <local:LineScanSheetCounterPreviewControl Model="{Binding ModelParam}"/>
                    </Expander>

                    <Expander MaxHeight="230" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <Grid Margin="5,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="36" />
                                    <ColumnDefinition Width="36" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="数据：" VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1" MinWidth="80" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName, Mode=TwoWay}" Height="25" BorderThickness="0,0,0,1" Margin="5,0" />
                                <Button Grid.Column="2" Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                        FontFamily="{StaticResource Iconfont}"
                                        ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add" />
                                <Button Grid.Column="3" Content="&#xe74b;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                        FontFamily="{StaticResource Iconfont}"
                                        ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete" />
                            </Grid>
                            <DataGrid AutoGenerateColumns="False"
                                      Style="{StaticResource DefaultDataGridStyle}"
                                      ItemsSource="{Binding ModelParam.OutputParams}"
                                      SelectedItem="{Binding CurrentOutputParam}"
                                      FontSize="12"
                                      Height="170"
                                      RowHeaderWidth="20"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      IsReadOnly="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="参数名称" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="*" IsReadOnly="True" />
                                    <DataGridTextColumn Header="备注" Binding="{Binding Describe, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BorderThickness="0,2,0,0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical">
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时：" />
                        <Run Text="{Binding ModelParam.Output.RunTime}" />
                        <Run Text="ms" />
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="执行状态：" />
                        <Run Text="{Binding ModelParam.Output.RunStatus}" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="执行"
                            Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80" Content="执行" Cursor="Hand" />
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="重置"
                            Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80" Content="重置" Cursor="Hand" />
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="取消"
                            Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80" Content="取消" Cursor="Hand" />
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="确认"
                            Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80" Content="确认" Cursor="Hand" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>


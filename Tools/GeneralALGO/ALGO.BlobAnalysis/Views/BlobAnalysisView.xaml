<UserControl x:Class="ALGO.BlobAnalysis.Views.BlobAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:blobAnalysis="clr-namespace:ALGO.BlobAnalysis.Controls"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             FontSize="14"
             Height="880"
             Width="1280"
             Loaded="UserControl_Loaded"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880"
             d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="110" />
        </Grid.RowDefinitions>

        <Grid Margin="0,24,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.55*" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="0.45*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="8">
                <TabControl>
                    <TabItem Header="基础参数">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <GroupBox Header="图像链接" Margin="0,0,0,8">
                                    <StackPanel Margin="8">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <TextBlock Width="130" Text="输入图像：" VerticalAlignment="Center" />
                                            <WxLink:WxLink Width="350"
                                                           InputParams="{Binding ModelParam.InputParams, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                           OutputParam="{Binding ModelParam.InputImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                           Order="OpenParam"
                                                           Text="{Binding ModelParam.InputImage.Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="分析区域" Margin="0,0,0,8">
                                    <UniformGrid Columns="2" Margin="8">
                                        <TextBlock Text="中心X：" VerticalAlignment="Center" />
                                        <WxLink:WxLink InputParams="{Binding ModelParam.InputParams, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       OutputParam="{Binding ModelParam.InitRegionCenterX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       Order="OpenParam"
                                                       Text="{Binding ModelParam.InitRegionCenterX, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F4}" />
                                        <TextBlock Text="中心Y：" VerticalAlignment="Center" />
                                        <WxLink:WxLink InputParams="{Binding ModelParam.InputParams, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       OutputParam="{Binding ModelParam.InitRegionCenterY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       Order="OpenParam"
                                                       Text="{Binding ModelParam.InitRegionCenterY, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F4}" />
                                        <TextBlock Text="角度(°)：" VerticalAlignment="Center" />
                                        <WxLink:WxLink InputParams="{Binding ModelParam.InputParams, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       OutputParam="{Binding ModelParam.InitRegionAngleDeg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       Order="OpenParam"
                                                       Text="{Binding ModelParam.InitRegionAngleDeg, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F4}" />
                                        <TextBlock Text="半长：" VerticalAlignment="Center" />
                                        <WxLink:WxLink InputParams="{Binding ModelParam.InputParams, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       OutputParam="{Binding ModelParam.InitRegionLength1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       Order="OpenParam"
                                                       Text="{Binding ModelParam.InitRegionLength1, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F4}" />
                                        <TextBlock Text="半宽：" VerticalAlignment="Center" />
                                        <WxLink:WxLink InputParams="{Binding ModelParam.InputParams, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       OutputParam="{Binding ModelParam.InitRegionLength2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       Order="OpenParam"
                                                       Text="{Binding ModelParam.InitRegionLength2, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F4}" />
                                    </UniformGrid>
                                </GroupBox>

                                <GroupBox Header="阈值设置" Margin="0,0,0,8">
                                    <UniformGrid Columns="2" Margin="8">
                                        <TextBlock Text="阈值模式：" VerticalAlignment="Center" />
                                        <ComboBox BorderThickness="0,0,0,1"
                                                  SelectedItem="{Binding ModelParam.ThresholdMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding ThresholdModes}" />
                                        <TextBlock Text="固定下限：" VerticalAlignment="Center" />
                                        <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="255"
                                                                         Value="{Binding ModelParam.FixedMinGray, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="固定上限：" VerticalAlignment="Center" />
                                        <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="255"
                                                                         Value="{Binding ModelParam.FixedMaxGray, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="掩膜高度：" VerticalAlignment="Center" />
                                        <WxNumericUpDown:WxNumericUpDown Minimum="1" Maximum="9999"
                                                                         Value="{Binding ModelParam.LocalMaskH, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="掩膜宽度：" VerticalAlignment="Center" />
                                        <WxNumericUpDown:WxNumericUpDown Minimum="1" Maximum="9999"
                                                                         Value="{Binding ModelParam.LocalMaskW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="标准差系数：" VerticalAlignment="Center" />
                                        <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="9999" SmallChange="0.05"
                                                                         Value="{Binding ModelParam.LocalStdFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="绝对阈值：" VerticalAlignment="Center" />
                                        <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="9999"
                                                                         Value="{Binding ModelParam.LocalAbsThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="局部类型：" VerticalAlignment="Center" />
                                        <ComboBox BorderThickness="0,0,0,1"
                                                  SelectedItem="{Binding ModelParam.LocalThresholdType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding LocalThresholdTypes}" />
                                    </UniformGrid>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Blob筛选">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <GroupBox Header="特征筛选" Margin="0,0,0,8">
                                    <StackPanel Margin="8">
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="48" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="60" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="筛选" HorizontalAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="特征" VerticalAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2" Text="下限" HorizontalAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="3" Text="上限" HorizontalAlignment="Center" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="4" Text="输出" HorizontalAlignment="Center" FontWeight="SemiBold" />
                                        </Grid>

                                        <ScrollViewer Height="320" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding ModelParam.PropertyDefinitions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="48" />
                                                                <ColumnDefinition Width="150" />
                                                                <ColumnDefinition Width="140" />
                                                                <ColumnDefinition Width="140" />
                                                                <ColumnDefinition Width="60" />
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox Grid.Column="0"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding Name}"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="12" />
                                                            <WxNumericUpDown:WxNumericUpDown Grid.Column="2"
                                                                                             Minimum="-99999999"
                                                                                             Maximum="99999999"
                                                                                             FontSize="12"
                                                                                             SmallChange="{Binding SmallChange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Value="{Binding MinValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <WxNumericUpDown:WxNumericUpDown Grid.Column="3"
                                                                                             Minimum="-99999999"
                                                                                             Maximum="99999999"
                                                                                             FontSize="12"
                                                                                             SmallChange="{Binding SmallChange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                             Value="{Binding MaxValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <CheckBox Grid.Column="4"
                                                                      IsChecked="{Binding IsOut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="结果设置" Margin="0,0,0,8">
                                    <StackPanel Margin="8">
                                        <UniformGrid Columns="2">
                                            <TextBlock Text="过滤模式：" VerticalAlignment="Center" />
                                            <ComboBox BorderThickness="0,0,0,1"
                                                      SelectedItem="{Binding ModelParam.FilterMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding FilterModes}" />
                                            <TextBlock Text="排序特征：" VerticalAlignment="Center" />
                                            <ComboBox BorderThickness="0,0,0,1"
                                                      DisplayMemberPath="Name"
                                                      SelectedValuePath="HName"
                                                      SelectedValue="{Binding ModelParam.SortFeature, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding ModelParam.PropertyDefinitions}" />
                                            <TextBlock Text="选择序号：" VerticalAlignment="Center" />
                                            <WxNumericUpDown:WxNumericUpDown Minimum="1" Maximum="9999"
                                                                             Value="{Binding ModelParam.SelectedBlobIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </UniformGrid>
                                        <CheckBox Margin="0,8,0,0" Content="按降序排序" IsChecked="{Binding ModelParam.SortDescending}" />
                                        <CheckBox Margin="0,4,0,0" Content="填充孔洞" IsChecked="{Binding ModelParam.FillUp}" />
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="显示设置">
                                    <StackPanel Margin="8">
                                        <CheckBox Content="显示筛选区域" IsChecked="{Binding ModelParam.ShowFilteredRegion}" />
                                        <CheckBox Margin="0,4,0,0" Content="显示选中区域" IsChecked="{Binding ModelParam.ShowSelectedRegion}" />
                                        <CheckBox Margin="0,4,0,0" Content="显示中心点" IsChecked="{Binding ModelParam.ShowCenterPoint}" />
                                        <CheckBox Margin="0,4,0,0" Content="显示质心点" IsChecked="{Binding ModelParam.ShowCentroidPoint}" />
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource BtnOverColor}" />

            <Grid Grid.Column="2">
                <StackPanel>
                    <Expander Header="图像预览" Margin="5,5,5,0" Style="{DynamicResource ExpanderStyle}" IsExpanded="True">
                        <blobAnalysis:BlobAnalysisHalconControl x:Name="imageHost" Height="500" Margin="5" />
                    </Expander>

                    <Expander Header="输出参数" Margin="5,5,5,0" Style="{DynamicResource ExpanderStyle}" IsExpanded="True">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5,2">
                                <TextBlock Text="数据项：" VerticalAlignment="Center" />
                                <ComboBox Width="500"
                                          ItemsSource="{Binding ModelParam.OutputParamNames}"
                                          SelectedItem="{Binding SltOutputParamName, Mode=TwoWay}"
                                          Height="25"
                                          BorderThickness="0,0,0,1"
                                          Margin="5,0" />
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White"
                                        ToolTip="新增" Command="{Binding DataOperateCommand}" CommandParameter="Add" />
                                <Button Content="&#xe74b;" Width="30" Height="26" FontSize="18"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White"
                                        Margin="5,0" ToolTip="删除"
                                        Command="{Binding DataOperateCommand}" CommandParameter="Delete" />
                            </StackPanel>

                            <DataGrid AutoGenerateColumns="False"
                                      Style="{StaticResource DefaultDataGridStyle}"
                                      ItemsSource="{Binding ModelParam.OutputParams}"
                                      SelectedItem="{Binding CurrentOutputParam}"
                                      Height="160"
                                      FontSize="12"
                                      RowHeaderWidth="20"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="类型" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          Height="25"
                                                          BorderThickness="0,0,0,1"
                                                          Margin="5,0"
                                                          Background="Transparent"
                                                          SelectedItem="{Binding Type}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" IsReadOnly="True" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BorderThickness="0,2,0,0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Margin="10,0,0,0" FontSize="14">
                        <Run Text="耗时：" />
                        <Run Text="{Binding ModelParam.Output.RunTime}" />
                        <Run Text=" ms" />
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" FontSize="14">
                        <Run Text="状态：" />
                        <Run Text="{Binding ModelParam.Output.RunStatus}" />
                    </TextBlock>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="执行"
                            Style="{StaticResource GeneralButtonStyle}" Height="35" Width="90" Content="执行" />
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="取消"
                            Style="{StaticResource GeneralButtonStyle}" Width="90" Content="取消" />
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="确认"
                            Style="{StaticResource GeneralButtonStyle}" Width="90" Content="确认" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

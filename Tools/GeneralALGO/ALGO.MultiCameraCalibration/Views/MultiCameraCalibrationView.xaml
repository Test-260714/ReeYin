<UserControl x:Class="ALGO.MultiCameraCalibration.Views.MultiCameraCalibrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             FontSize="14"
             Height="880"
             Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880"
             d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="92"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,37,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0" Margin="5,0,5,15" Style="{StaticResource TabControlWithUnderLineStyle}">
                <TabItem Header="模式配置" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                    <Border Padding="30" HorizontalAlignment="Center" VerticalAlignment="Top">
                        <TabControl Width="600" Height="630" SelectedIndex="{Binding ModelParam.SltTriggerIndex, Mode=TwoWay}" Style="{DynamicResource TabControlStyle}">
                            <TabItem Header="标定" Style="{DynamicResource SingleTabItemStyle}">
                                <Grid Margin="0,10,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                                        <TextBlock Text="相机ID:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Text="{Binding ModelParam.CameraId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="455"
                                                 BorderThickness="0 0 0 1"
                                                 FontSize="15"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5">
                                        <TextBox Text="{Binding ModelParam.CalibrationImageDir, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="510"
                                                 Foreground="Black"
                                                 BorderThickness="0 0 0 1"
                                                 FontSize="15"/>
                                        <Button Content="&#xe7b9;"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                FontFamily="{StaticResource Iconfont}"
                                                Height="30"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="获取图片路径"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Button Content="&#xe74b;"
                                                ToolTip="删除"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                Margin="5"
                                                FontFamily="{StaticResource Iconfont}"
                                                Height="30"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="删除标定图片"/>
                                    </StackPanel>

                                    <DataGrid Grid.Row="3"
                                              AutoGenerateColumns="False"
                                              Style="{StaticResource DefaultDataGridStyle}"
                                              ItemsSource="{Binding ModelParam.CalibImageNameList}"
                                              SelectedItem="{Binding ModelParam.SelectedCalibrationImage, Mode=TwoWay}"
                                              FontSize="12"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.CanContentScroll="True"
                                              Margin="0,5,0,0"
                                              RowHeaderWidth="20"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="All"
                                              IsReadOnly="False"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="启用" Width="50">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="索引" Binding="{Binding ID}" IsReadOnly="True" Width="55"/>
                                            <DataGridTextColumn Header="相机 ID" Binding="{Binding CameraId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                                            <DataGridTextColumn Header="标定板位姿" Binding="{Binding CaptureId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                                            <DataGridTextColumn Header="名称" Binding="{Binding ImageName}" IsReadOnly="True" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>

                            <TabItem Header="使用标定" Style="{DynamicResource SingleTabItemStyle}">
                                <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                                    <Grid Width="460" HorizontalAlignment="Center" Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="152"/>
                                            <ColumnDefinition Width="308"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="模式:" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                        <ComboBox Grid.Column="1" Width="300"
                                                  HorizontalAlignment="Left"
                                                  BorderThickness="0 0 0 1"
                                                  HorizontalContentAlignment="Center"
                                                  VerticalContentAlignment="Center"
                                                  SelectedItem="{Binding ModelParam.CalibUsageModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding CalibUsageModels}"/>
                                    </Grid>

                                    <ContentControl Content="{Binding ModelParam}">
                                        <ContentControl.Resources>
                                            <DataTemplate x:Key="TplPixelToWorld">
                                                <Grid Width="460" HorizontalAlignment="Center" Margin="0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="152"/>
                                                        <ColumnDefinition Width="308"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="相机ID:" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding UseCameraId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" BorderThickness="0 0 0 1"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="输入点集:" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5,8,0"/>
                                                    <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="300"
                                                                   HorizontalAlignment="Left"
                                                                   Margin="0,5,0,0"
                                                                   InputParams="{Binding InputParams, Mode=TwoWay}"
                                                                   OutputParam="{Binding InputPointSet, Mode=TwoWay}"
                                                                   Order="OpenParam"
                                                                   Text="{Binding InputPointSet.Name, Mode=OneWay}"/>
                                                </Grid>
                                            </DataTemplate>

                                            <DataTemplate x:Key="TplWorldToPixel">
                                                <Grid Width="460" HorizontalAlignment="Center" Margin="0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="152"/>
                                                        <ColumnDefinition Width="308"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="相机ID:" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding UseCameraId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="300" HorizontalAlignment="Left" BorderThickness="0 0 0 1"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="输入点集:" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,5,8,0"/>
                                                    <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="300"
                                                                   HorizontalAlignment="Left"
                                                                   Margin="0,5,0,0"
                                                                   InputParams="{Binding InputParams, Mode=TwoWay}"
                                                                   OutputParam="{Binding InputPointSet, Mode=TwoWay}"
                                                                   Order="OpenParam"
                                                                   Text="{Binding InputPointSet.Name, Mode=OneWay}"/>
                                                </Grid>
                                            </DataTemplate>

                                            <DataTemplate x:Key="TplStitch">
                                                <StackPanel Orientation="Vertical">
                                                    <Grid Width="460" HorizontalAlignment="Center" Margin="0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="152"/>
                                                            <ColumnDefinition Width="308"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="融合方式:" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                                        <ComboBox Grid.Column="1" Width="300"
                                                                  HorizontalAlignment="Left"
                                                                  BorderThickness="0 0 0 1"
                                                                  HorizontalContentAlignment="Center"
                                                                  VerticalContentAlignment="Center"
                                                                  ItemsSource="{Binding DataContext.StitchBlendModes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding StitchBlendMode, Mode=TwoWay}"/>
                                                    </Grid>

                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="25,0,0,4">
                                                        <Button Content="&#xe630;" ToolTip="添加" Width="30" Height="26" Style="{StaticResource GeneralButtonStyle}"
                                                                FontFamily="{StaticResource Iconfont}"
                                                                Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="添加拼接输入"/>
                                                        <Button Content="&#xe74b;" ToolTip="删除" Width="30" Height="26" Margin="5,0,0,0" Style="{StaticResource GeneralButtonStyle}"
                                                                FontFamily="{StaticResource Iconfont}"
                                                                Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="删除拼接输入"/>
                                                    </StackPanel>

                                                    <DataGrid AutoGenerateColumns="False"
                                                              Style="{StaticResource DefaultDataGridStyle}"
                                                              ItemsSource="{Binding StitchInputImages}"
                                                              SelectedItem="{Binding SelectedStitchInputImage, Mode=TwoWay}"
                                                              Height="460"
                                                              Margin="25,0"
                                                              RowHeaderWidth="20"
                                                              SelectionUnit="FullRow"
                                                              HeadersVisibility="Column"
                                                              GridLinesVisibility="All"
                                                              CanUserAddRows="False">
                                                        <DataGrid.Columns>
                                                            <DataGridTemplateColumn Header="启用" Width="50">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTextColumn Header="相机 ID" Binding="{Binding CameraId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="130"/>
                                                            <DataGridTemplateColumn Header="图片文件" Width="210">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <DockPanel LastChildFill="True">
                                                                            <Button DockPanel.Dock="Right"
                                                                                    Content="&#xe7b9;"
                                                                                    ToolTip="选择图片文件"
                                                                                    Width="28"
                                                                                    Height="24"
                                                                                    Margin="4,0,0,0"
                                                                                    Style="{StaticResource GeneralButtonStyle}"
                                                                                    FontFamily="{StaticResource Iconfont}"
                                                                                    Command="{Binding DataContext.SelectStitchImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                    CommandParameter="{Binding}"/>
                                                                            <TextBox Text="{Binding ImagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                     BorderThickness="0"
                                                                                     Background="Transparent"
                                                                                     ToolTip="{Binding ImagePath}"/>
                                                                        </DockPanel>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                            <DataGridTemplateColumn Header="输入图像" Width="*">
                                                                <DataGridTemplateColumn.CellTemplate>
                                                                    <DataTemplate>
                                                                        <WxLink:WxLink InputParams="{Binding DataContext.ModelParam.InputParams, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                       OutputParam="{Binding InputImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                       Order="OpenParam"
                                                                                       Text="{Binding InputImage.Name, Mode=OneWay}"/>
                                                                    </DataTemplate>
                                                                </DataGridTemplateColumn.CellTemplate>
                                                            </DataGridTemplateColumn>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ContentControl.Resources>
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="ContentTemplate" Value="{StaticResource TplPixelToWorld}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.ModelParam.CalibUsageModel, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="公共世界坐标转像素">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplWorldToPixel}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.ModelParam.CalibUsageModel, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="多视角拼接">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplStitch}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </Border>
                </TabItem>

                <TabItem Header="标定配置" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                    <StackPanel>
                        <Grid>
                            <Border CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TabControl Width="600" Height="590" SelectedIndex="{Binding ModelParam.SltTriggerIndex,Mode=TwoWay}" Style="{DynamicResource TabControlStyle}">
                                    <Grid>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="标定板类型:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <ComboBox Grid.Row="0" Grid.Column="1" Width="285" Margin="0,0,10,0"
                                                              BorderThickness="0 0 0 1"
                                                              HorizontalContentAlignment="Center"
                                                              VerticalContentAlignment="Center"
                                                              SelectedItem="{Binding ModelParam.CalibBoardType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              ItemsSource="{Binding CalibBoardTypes}"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                                                <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="高度补偿(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBox Grid.Row="0" Grid.Column="1" Width="285" Margin="0,0,10,0"
                                                             BorderThickness="0 0 0 1"
                                                             Text="{Binding ModelParam.HeightCompensation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>

                                            <ContentControl Content="{Binding ModelParam}">
                                                <ContentControl.Resources>
                                                    <DataTemplate x:Key="TplChessboard">
                                                        <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="图案行数:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding PatternRows,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding PatternRows,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="图案列数:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding PatternCols,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding PatternCols,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="方格尺寸(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="2" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding SquareSize,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding SquareSize,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                        </Grid>
                                                    </DataTemplate>

                                                    <DataTemplate x:Key="TplCharuco">
                                                        <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="图案行数:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding PatternRows,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding PatternRows,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="图案列数:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding PatternCols,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding PatternCols,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="方格尺寸(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="2" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding SquareSize,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding SquareSize,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="二维码尺寸(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="3" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding MarkerSize,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding MarkerSize,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="二维码类型:" Foreground="Black" VerticalAlignment="Center" Margin="0,20,10,0"/>
                                                            <ComboBox Grid.Row="4" Grid.Column="1" Width="285" BorderThickness="0 0 0 1" Margin="0,20,10,0"
                                                                      HorizontalContentAlignment="Center"
                                                                      VerticalContentAlignment="Center"
                                                                      ItemsSource="{Binding DataContext.DictionaryIds, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      SelectedItem="{Binding DictionaryId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        </Grid>
                                                    </DataTemplate>

                                                    <DataTemplate x:Key="TplPixelRatio">
                                                        <Grid Margin="0,0,0,0" HorizontalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="150"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="实际距离(mm):" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding RealDistance,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding RealDistance,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="线段1:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="1" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding InputLine1,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding InputLine1.Name,Mode=OneWay}"/>
                                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="线段2:" Foreground="Black" VerticalAlignment="Center" Margin="0,0,0,0"/>
                                                            <WxLink:WxLink Grid.Row="2" Grid.Column="1" Width="285" Margin="5,15"
                                                                           InputParams="{Binding InputParams,Mode=TwoWay}"
                                                                           OutputParam="{Binding InputLine2,Mode=TwoWay}"
                                                                           Order="OpenParam"
                                                                           Text="{Binding InputLine2.Name,Mode=OneWay}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ContentControl.Resources>
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource TplChessboard}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DataContext.ModelParam.CalibBoardType, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="Charuco">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource TplCharuco}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding DataContext.ModelParam.CalibBoardType, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="像素比">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource TplPixelRatio}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </StackPanel>
                                    </Grid>
                                </TabControl>
                            </Border>
                        </Grid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="标定结果" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource LightBackgroundBrush}" Padding="10" Margin="0,0,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="导出" Style="{StaticResource GeneralButtonStyle}" Margin="0,0,10,0" ToolTip="将标定结果导出到指定目录"
                                        Command="{Binding GeneralCommand}" CommandParameter="导出标定文件"/>
                                <TextBlock Text="导出目录:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Text="{Binding ModelParam.CalibFileOutputDir}" Width="420" Margin="0,0,5,0"
                                         VerticalAlignment="Center" IsReadOnly="True" FontSize="15"/>
                                <Button Content="&#xe7b9;" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30"
                                        Command="{Binding GeneralCommand}" CommandParameter="选择标定文件导出目录"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Background="{DynamicResource LightBackgroundBrush}" Padding="10" Margin="0,0,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="导入" Style="{StaticResource GeneralButtonStyle}" Margin="0,0,10,0" ToolTip="从文件导入标定结果"
                                        Command="{Binding GeneralCommand}" CommandParameter="导入标定文件"/>
                                <TextBlock Text="标定文件:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBox Text="{Binding ModelParam.CalibrationFilePath}" Width="420" Margin="0,0,5,0"
                                         VerticalAlignment="Center" IsReadOnly="True" FontSize="15"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="相机数:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ModelParam.ReportCameraCount}" Margin="0" FontSize="15"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="位姿数:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModelParam.ReportCaptureCount}" Margin="0" FontSize="15"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="观测数:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ModelParam.ReportObservationCount}" Margin="0" FontSize="15"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="残差数:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ModelParam.ReportResidualCount}" Margin="0" FontSize="15"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="初始RMS:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ModelParam.ReportInitialRmsError, StringFormat={}{0:F6}}" Margin="0" FontSize="15"/>

                                <TextBlock Grid.Row="5" Grid.Column="0" Text="最终RMS:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ModelParam.ReportFinalRmsError, StringFormat={}{0:F6}}" Margin="0" FontSize="15"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="最大重投影:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ModelParam.ReportMaxReprojectionError, StringFormat={}{0:F6}}" Margin="0" FontSize="15"/>

                                <TextBlock Grid.Row="7" Grid.Column="0" Text="连通分量:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ModelParam.ReportConnectedComponentCount}" Margin="0" FontSize="15"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="已收敛:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ModelParam.ReportConvergedText}" Margin="0" FontSize="15"/>

                                <TextBlock Grid.Row="9" Grid.Column="0" Text="相机结果:" Margin="0" FontSize="15" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="9" Grid.Column="1" Width="220" HorizontalAlignment="Left"
                                          ItemsSource="{Binding ModelParam.CameraResults}"
                                          SelectedItem="{Binding ModelParam.SelectedCameraResult, Mode=TwoWay}"
                                          DisplayMemberPath="CameraId"
                                          BorderThickness="0 0 0 1"/>

                                <TextBlock Grid.Row="10" Grid.Column="0" Text="相机RMS:" Margin="0" FontSize="15"/>
                                <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding ModelParam.SelectedCameraResult.RmsError, StringFormat={}{0:F6}}" Margin="0" FontSize="15"/>

                                <Expander Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Header="内参矩阵" Margin="5" IsExpanded="False">
                                    <ItemsControl ItemsSource="{Binding ModelParam.IntrinsicMatrix}" FontSize="12">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="3" Columns="3"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat={}{0:F6}}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <Expander Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" Header="畸变系数" Margin="5" IsExpanded="False">
                                    <ItemsControl ItemsSource="{Binding ModelParam.DistortionCoefficients}" FontSize="12">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="8" Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat={}{0:F6}}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <Expander Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2" Header="旋转向量 CommonFromCamera" Margin="5" IsExpanded="False">
                                    <ItemsControl ItemsSource="{Binding ModelParam.RotationVector}" FontSize="12">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3" Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat={}{0:F6}}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <Expander Grid.Row="14" Grid.Column="0" Grid.ColumnSpan="2" Header="平移向量 CommonFromCamera" Margin="5" IsExpanded="False">
                                    <ItemsControl ItemsSource="{Binding ModelParam.TranslationVector}" FontSize="12">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="3" Rows="1"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat={}{0:F6}}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <Expander Grid.Row="15" Grid.Column="0" Grid.ColumnSpan="2" Header="外参矩阵 CommonFromCamera" Margin="5" IsExpanded="False">
                                    <ItemsControl ItemsSource="{Binding ModelParam.ExtrinsicMatrix}" FontSize="12">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Rows="4" Columns="4"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StringFormat={}{0:F6}}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Margin="2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <Controls:ImageEditView Image="{Binding ModelParam.Image, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="300" Background="{StaticResource BackgroudBrush}"/>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{StaticResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5,2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName, Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5,0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}" Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White"
                                        ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}" Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5,0"
                                        ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid AutoGenerateColumns="False"
                                      Style="{StaticResource DefaultDataGridStyle}"
                                      ItemsSource="{Binding ModelParam.OutputParams}"
                                      SelectedItem="{Binding CurrentOutputParam}"
                                      FontSize="12"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      Height="160"
                                      RowHeaderWidth="20"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      IsReadOnly="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5,0" Background="Transparent" SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical" WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Command="{Binding GeneralCommand}" CommandParameter="执行"
                            Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80" Content="执行" Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                            Command="{Binding GeneralCommand}" CommandParameter="取消"
                            Height="35" Width="80" Style="{StaticResource GeneralButtonStyle}" Content="取消" Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                            Command="{Binding GeneralCommand}" CommandParameter="确认"
                            Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80" Content="确认" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

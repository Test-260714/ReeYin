<UserControl x:Class="ALGO.RegionProcessing.Views.RegionProcessingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:local="clr-namespace:ALGO.RegionProcessing.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:vm="clr-namespace:ALGO.RegionProcessing.ViewModels"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">

    <UserControl.Resources>
        <local:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>

        <Style x:Key="AddMethodContextMenuStyle" TargetType="{x:Type ContextMenu}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                                                  Opacity="0.18"
                                                  ShadowDepth="2"
                                                  Color="#40000000"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"
                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddMethodMenuItemStyle" TargetType="{x:Type MenuItem}">
            <Setter Property="Header" Value="{Binding Header}"/>
            <Setter Property="Command" Value="{Binding Command}"/>
            <Setter Property="CommandParameter" Value="{Binding CommandParameter}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SelectedBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectedBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#80000000"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!-- 数字输入 -->
        <DataTemplate x:Key="NumberTemplate">
            <WxNumericUpDown:WxNumericUpDown Margin="0 5 0 5" FontSize="12" HorizontalContentAlignment="Center" Minimum="{Binding MinValue}" Maximum="{Binding MaxValue}" SmallChange="{Binding SmallChange}"  
                                             Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </DataTemplate>

        <!-- 文本输入 -->
        <DataTemplate x:Key="TextTemplate">
            <TextBox FontSize="12" Margin="0 5 0 5" HorizontalContentAlignment="Center" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </DataTemplate>

        <!-- 下拉选择 -->
        <DataTemplate x:Key="ComboBoxTemplate">
            <ComboBox FontSize="12" Margin="0 5 0 5" HorizontalContentAlignment="Center" ItemsSource="{Binding Options}" SelectedItem="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </DataTemplate>

        <!-- 选择器 -->
        <local:ParamTemplateSelector x:Key="ParamTemplateSelector" NumberTemplate="{StaticResource NumberTemplate}" TextTemplate="{StaticResource TextTemplate}" 
                                     ComboBoxTemplate="{StaticResource ComboBoxTemplate}" />

    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.6*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.4*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}" x:Name="MyTabControl" SelectedIndex="{Binding ModelParam.SelectedTabIndex, Mode=TwoWay}" >
                        <TabItem Header="单个方法" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid x:Name="gd">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="78*"/>
                                    <ColumnDefinition Width="235*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="270"/>
                                    <RowDefinition Height="120"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                    <GroupBox Header="区域链接">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Width="500" HorizontalAlignment="Center">
                                                <TextBlock Width="150" Text="输入图像:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                                               OutputParam="{Binding ModelParam.InputImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 15" Text="{Binding ModelParam.InputImage.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Width="500" HorizontalAlignment="Center">
                                                <TextBlock Width="150" Text="输入区域1:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                                               OutputParam="{Binding ModelParam.InputRegion1,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 15" Text="{Binding ModelParam.InputRegion1.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Width="500" HorizontalAlignment="Center" Visibility="{Binding ModelParam.ProcessingMode, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=2}">
                                                <TextBlock Width="150" Text="输入区域2:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                                               OutputParam="{Binding ModelParam.InputRegion2,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 15" Text="{Binding ModelParam.InputRegion2.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                <Border Grid.Row="1" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                    <GroupBox Header="处理类型">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500" Margin="0 0 0 0" >
                                                <TextBlock Width="150" Text="处理方法:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <ComboBox Width="350" HorizontalContentAlignment="Center" HorizontalAlignment="Center" ItemsSource="{Binding ProcessingModes}" 
                                                      SelectedItem="{Binding ModelParam.ProcessingMode, Mode=TwoWay}" 
                                                      Margin="0 15">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>

                                <Border Grid.Row="2" Margin="0 5 0 0" Grid.ColumnSpan="2">
                                    <GroupBox Header="处理参数">
                                        <DockPanel MinHeight="260" LastChildFill="True">
                                            <CheckBox DockPanel.Dock="Bottom"
                                                      Content="急速模式"
                                                      IsChecked="{Binding ModelParam.IsFastModeEnabled, Mode=TwoWay}"
                                                      VerticalContentAlignment="Center"
                                                      Margin="12,0,0,32" Height="35"/>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding ModelParam.ProcessingParamDefinitions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <!-- 参数名称 -->
                                                                <TextBlock Text="{Binding Name}"  FontSize="12"
                                                                           Foreground="Black"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0 5 0 5"
                                                                           Width="150"/>

                                                                <!-- 根据 UIType 自动切换不同控件 -->
                                                                <ContentControl Content="{Binding}" FontSize="12"
                                                                                ContentTemplateSelector="{StaticResource ParamTemplateSelector}"
                                                                                Width="350" Margin="0 5 0 5"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </DockPanel>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem Header="方法串联" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid x:Name="nc">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80*"/>
                                    <ColumnDefinition Width="233*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="100"/>
                                    <RowDefinition Height="300"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                    <GroupBox Header="处理步骤配置">
                                        <StackPanel>
                                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 10 0 10">
                                                <Button Style="{StaticResource GeneralButtonStyle}"
                                                        Width="30"
                                                        Height="30"
                                                        Margin="5"
                                                        PreviewMouseLeftButtonUp="AddButton_PreviewMouseLeftButtonUp"
                                                        ContextMenuService.IsEnabled="False">
                                                    <Button.Content>
                                                        <TextBlock Text="&#xe630;" FontFamily="{StaticResource Iconfont}" FontSize="19"/>
                                                    </Button.Content>
                                                    <Button.ContextMenu>
                                                        <ContextMenu ItemsSource="{Binding DynamicMenuItems}"
                                                                     HorizontalContentAlignment="Center"
                                                                     Style="{StaticResource AddMethodContextMenuStyle}">
                                                            <ContextMenu.ItemContainerStyle>
                                                                <Style TargetType="MenuItem" BasedOn="{StaticResource AddMethodMenuItemStyle}"/>
                                                            </ContextMenu.ItemContainerStyle>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                                <Button Content="&#xe74b;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                Command="{Binding GeneralCommand}" CommandParameter="remove"/>
                                                <Button Content="&#xe6dd;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                Command="{Binding GeneralCommand}" CommandParameter="up"/>
                                                <Button Content="&#xe693;" Style="{StaticResource GeneralButtonStyle}" Margin="5" FontFamily="{StaticResource Iconfont}" Height="30"
                                                Command="{Binding GeneralCommand}" CommandParameter="down"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>

                                <Border Grid.Row="1" Margin="0,5,0,0" Grid.ColumnSpan="2">
                                    <!-- 处理步骤表格 -->
                                    <DataGrid Grid.Row="1" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                                      EnableColumnVirtualization="True"
                                                      EnableRowVirtualization="True"
                                                      VirtualizingPanel.IsVirtualizing="True"
                                                      ItemsSource="{Binding ModelParam.ProcessingSteps}" 
                                                      SelectedItem="{Binding ModelParam.CurrentStep}"
                                                      FontSize="12" 
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                      ScrollViewer.CanContentScroll="True"
                                                      RowHeaderWidth="20"
                                                      SelectionUnit="FullRow"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="All"
                                                      IsReadOnly="False" CanUserAddRows="False" >
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="启用" IsReadOnly="False" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsEnabled}"  HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="方法" IsReadOnly="False" Width="150">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="输入区域个数" IsReadOnly="True" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Input, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="输出区域个数" IsReadOnly="True" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Output, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                        </DataGrid.Columns>
                                    </DataGrid>

                                </Border>

                                <Border Grid.Row="2" Margin="0 5 0 0" Grid.ColumnSpan="2">
                                    <GroupBox Header="处理参数">
                                        <DockPanel MinHeight="260" LastChildFill="True">
                                            <CheckBox DockPanel.Dock="Bottom"
                                                      Content="急速模式"
                                                      IsChecked="{Binding ModelParam.IsFastModeEnabled, Mode=TwoWay}"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      VerticalContentAlignment="Center"
                                                      Margin="12,0,0,32"/>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding ModelParam.ListProcessingParamDefinitions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <!-- 参数名称 -->
                                                                <TextBlock Text="{Binding Name}"  FontSize="12"
                                                                           Foreground="Black"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0 5 0 5"
                                                                           Width="150"/>

                                                                <!-- 根据 UIType 自动切换不同控件 -->
                                                                <ContentControl Content="{Binding}" FontSize="12"
                                                                                ContentTemplateSelector="{StaticResource ParamTemplateSelector}"
                                                                                Width="350" Margin="0 5 0 5"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </DockPanel>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <local:RegionProcessingPreviewControl Model="{Binding ModelParam}"/>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="380" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                         FontFamily="{StaticResource Iconfont}"
                                                 ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                         FontFamily="{StaticResource Iconfont}" Margin="5 0"
                                             ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                      EnableColumnVirtualization="True"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      ItemsSource="{Binding ModelParam.OutputParams}" 
                                      SelectedItem="{Binding CurrentOutputParam}"
                                      FontSize="12" 
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      Height="160"
                                      RowHeaderWidth="20"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
                                                          SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                <!--<TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>-->
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>

        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="执行"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                    Height="auto" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="auto" Width="80"
                                                    Content="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

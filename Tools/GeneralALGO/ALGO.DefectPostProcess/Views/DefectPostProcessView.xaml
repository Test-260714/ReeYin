<UserControl x:Class="ALGO.DefectPostProcess.Views.DefectPostProcessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:local="clr-namespace:ALGO.DefectPostProcess.Views"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             FontSize="12"
             Height="960"
             Width="1560"
             Loaded="UserControl_Loaded"
             Unloaded="UserControl_Unloaded"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="960"
             d:DesignWidth="1560">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Button.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/CheckBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/ComboBox.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/DataGrid.xaml" />
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/ListBox.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="SelectedBrush" Color="{DynamicResource PrimaryColor}" />
            <SolidColorBrush x:Key="BtnOverColor" Color="{DynamicResource PrimaryColor}" />

        <sys:Double x:Key="PageFontSize">12</sys:Double>
        <sys:Double x:Key="PageTitleFontSize">14</sys:Double>

        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource PageFontSize}" />
        </Style>
        <Style x:Key="SchemeActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource GeneralButtonStyle}">
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="{StaticResource PageFontSize}" />
            <Setter Property="Padding" Value="10,3" />
        </Style>
        <Style x:Key="InlineFileIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2,0,0,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#666666" />
            <Setter Property="FontFamily" Value="{StaticResource Iconfont}" />
            <Setter Property="FontSize" Value="{StaticResource PageFontSize}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="InlineInputLinkStyle" TargetType="{x:Type WxLink:WxLink}">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontSize" Value="{StaticResource PageFontSize}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type WxLink:WxLink}">
                        <Border MinWidth="{TemplateBinding MinWidth}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Padding="5,2"
                                           VerticalAlignment="Center"
                                           FontSize="{TemplateBinding FontSize}"
                                           Foreground="{TemplateBinding Foreground}"
                                           Text="{TemplateBinding Text}"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{TemplateBinding Text}" />
                                <Button x:Name="PART_ButtonLink"
                                        Grid.Column="1"
                                        Content="&#xe60e;"
                                        Style="{StaticResource InlineFileIconButtonStyle}"
                                        ToolTip="链接参数" />
                                <Button x:Name="PART_ButtonCancel"
                                        Grid.Column="2"
                                        Content="&#xeaf2;"
                                        Foreground="#999999"
                                        Style="{StaticResource InlineFileIconButtonStyle}"
                                        ToolTip="取消链接" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ContentTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource PageFontSize}" />
        </Style>
        <Style x:Key="ContentTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="FontSize" Value="{StaticResource PageFontSize}" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Padding" Value="3,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" />
            <Setter Property="BorderBrush" Value="{StaticResource TextBox.Static.Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.56" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextBox.MouseOver.Border}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource TextBox.Focus.Border}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ReadOnlyRelationTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource PageFontSize}" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#7A8599" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding CanEditRelation}" Value="False">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="FeatureThresholdCellTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource ContentTextStyle}">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style x:Key="FeatureThresholdEditingTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource ContentTextBoxStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,37,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.78*"
                                  MinWidth="320" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="1.22*"
                                  MinWidth="720" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="0.92*"
                                  MinWidth="460" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="5">
                <Grid>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Margin="0,0,0,8">
                            <GroupBox Header="方案管理">
                                <Grid Margin="12,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="64" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="当前方案:" />
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              Margin="5,5,8,8"
                                              DisplayMemberPath="Name"
                                              FontSize="{StaticResource PageFontSize}"
                                              Height="25"
                                              BorderThickness="0,0,0,1"
                                              ItemsSource="{Binding ModelParam.SchemeConfigs}"
                                              SelectedItem="{Binding ModelParam.SelectedScheme,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Row="0"
                                            Grid.Column="2"
                                            Height="28"
                                            Margin="0,5,0,8"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="方案应用"
                                            Content="应用"
                                            FontSize="{StaticResource PageFontSize}"
                                            IsEnabled="{Binding ModelParam.HasSchemeConfigs}"
                                            Style="{StaticResource GeneralButtonStyle}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="方案名称:" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="1"
                                             Grid.ColumnSpan="2"
                                             Margin="4,5,0,8"
                                             Style="{StaticResource ContentTextBoxStyle}"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding ModelParam.SchemeName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />

                                    <UniformGrid Grid.Row="2"
                                                 Grid.Column="0"
                                                 Grid.ColumnSpan="3"
                                                 Columns="1"
                                                 Margin="0,6,0,6">
                                        <CheckBox Content="急速模式"
                                                  IsChecked="{Binding ModelParam.IsFastModeEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                  FontSize="{StaticResource PageFontSize}"
                                                  VerticalAlignment="Center" />
                                    </UniformGrid>

                                    <UniformGrid Grid.Row="3"
                                                 Grid.Column="0"
                                                 Grid.ColumnSpan="3"
                                                 Columns="4"
                                                 Margin="0,8,0,0">
                                        <Button Margin="0,0,8,0"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="方案新建"
                                                Content="新建"
                                                Style="{StaticResource SchemeActionButtonStyle}" />
                                        <Button Margin="0,0,8,0"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="方案保存"
                                                Content="保存"
                                                Style="{StaticResource SchemeActionButtonStyle}" />
                                        <Button Margin="0,0,8,0"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="方案导出"
                                                Content="导出"
                                                Style="{StaticResource SchemeActionButtonStyle}" />
                                        <Button Command="{Binding GeneralCommand}"
                                                CommandParameter="方案删除"
                                                Content="删除"
                                                IsEnabled="{Binding ModelParam.HasSchemeConfigs}"
                                                Style="{StaticResource SchemeActionButtonStyle}" />
                                    </UniformGrid>

                                </Grid>
                            </GroupBox>
                        </Border>

                        <Border Grid.Row="1">
                            <GroupBox Header="缺陷名称">
                                <Grid Margin="8,6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="20" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                MinWidth="62"
                                                Height="26"
                                                Margin="0,0,10,0"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="导入缺陷类别"
                                                Content="导入类别"
                                                FontSize="{StaticResource PageFontSize}"
                                                Style="{StaticResource GeneralButtonStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource ContentTextStyle}"
                                                   Text="ID:" />
                                        <TextBox Grid.Column="2"
                                                 Height="26"
                                                 Margin="0,0,6,0"
                                                 Style="{StaticResource ContentTextBoxStyle}"
                                                 Text="{Binding ModelParam.ManualDefectClassIdText,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center" />
                                        <TextBox Grid.Column="3"
                                                 Height="26"
                                                 Margin="0,0,6,0"
                                                 Style="{StaticResource ContentTextBoxStyle}"
                                                 Text="{Binding ModelParam.ManualDefectClassName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="输入缺陷类别名称"
                                                 VerticalContentAlignment="Center" />
                                        <Button Grid.Column="4"
                                                MinWidth="52"
                                                Height="26"
                                                Margin="0,0,6,0"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="新增缺陷类别"
                                                Content="新增"
                                                FontSize="{StaticResource PageFontSize}"
                                                Style="{StaticResource GeneralButtonStyle}" />
                                        <Button Grid.Column="5"
                                                MinWidth="52"
                                                Height="26"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="删除缺陷类别"
                                                Content="删除"
                                                FontSize="{StaticResource PageFontSize}"
                                                IsEnabled="{Binding ModelParam.HasCurrentDefect}"
                                                Style="{StaticResource GeneralButtonStyle}" />
                                    </Grid>

                                    <ListBox Grid.Row="1"
                                             FontSize="{StaticResource PageFontSize}"
                                             ItemsSource="{Binding ModelParam.DefectItems}"
                                             SelectedItem="{Binding ModelParam.CurrentDefect,Mode=TwoWay}">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Margin" Value="0,0,0,8" />
                                                <Setter Property="Padding" Value="0" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="ItemBorder"
                                                        Padding="8,6"
                                                        BorderThickness="0,0,0,1"
                                                        BorderBrush="#D6DCE5"
                                                        Background="White">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="34" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Index}" />

                                                        <StackPanel Grid.Column="1"
                                                                    Margin="8,0,0,0"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock FontSize="{StaticResource PageFontSize}"
                                                                       Text="{Binding DisplayName}" />
                                                            <TextBlock Margin="0,4,0,0"
                                                                       FontSize="{StaticResource PageFontSize}"
                                                                       Foreground="#7A8599"
                                                                       Text="{Binding DisplayDetail}" />
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="2"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="{StaticResource PageFontSize}"
                                                                   Foreground="#7A8599"
                                                                   Text="{Binding Count,StringFormat={}x{0}}" />
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource SelectedBrush}" />
                                                        <Setter TargetName="ItemBorder" Property="Background" Value="#F5FFF9" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                            </GroupBox>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Margin="0,5"
                          Background="{DynamicResource BtnOverColor}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <Border Grid.Column="2" Padding="5">
                <Grid>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Margin="0,0,0,8">
                            <GroupBox Header="输入链接">
                                <Grid Margin="12,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="图像:" />
                                    <WxLink:WxLink Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="2,8,10,8"
                                                    Style="{StaticResource InlineInputLinkStyle}"
                                                    InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"
                                                    OutputParam="{Binding ModelParam.InputImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                    Order="OpenParam"
                                                    Text="{Binding ModelParam.InputImage.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="推理结果:" />
                                    <WxLink:WxLink Grid.Row="0"
                                                    Grid.Column="4"
                                                    Margin="2,8,0,8"
                                                    Style="{StaticResource InlineInputLinkStyle}"
                                                    InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"
                                                    OutputParam="{Binding ModelParam.InputResults,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                    Order="OpenParam"
                                                    Text="{Binding ModelParam.InputResults.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource ContentTextStyle}"
                                               Text="边缘基准X(mm):" />
                                    <WxLink:WxLink Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="2,8,8,8"
                                                    Style="{StaticResource InlineInputLinkStyle}"
                                                    InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"
                                                    OutputParam="{Binding ModelParam.InputEdgeCalibrationX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                    Order="OpenParam"
                                                    Text="{Binding ModelParam.InputEdgeCalibrationXDisplayText,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="标定文件:" />
                                    <Border Grid.Row="1"
                                            Grid.Column="4"
                                            MinWidth="120"
                                            Margin="2,8,0,8"
                                            BorderBrush="{DynamicResource PrimaryBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Padding="5,2"
                                                       VerticalAlignment="Center"
                                                       FontSize="{StaticResource PageFontSize}"
                                                       Text="{Binding ModelParam.CalibrationFilePath,Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ModelParam.CalibrationFilePath,Mode=OneWay}" />
                                            <Button Grid.Column="1"
                                                    Command="{Binding GeneralCommand}"
                                                    CommandParameter="选择标定文件"
                                                    Content="&#xe60e;"
                                                    Style="{StaticResource InlineFileIconButtonStyle}"
                                                    ToolTip="选择标定文件" />
                                            <Button Grid.Column="2"
                                                    Command="{Binding GeneralCommand}"
                                                    CommandParameter="删除标定文件"
                                                    Content="&#xeaf2;"
                                                    Foreground="#999999"
                                                    Style="{StaticResource InlineFileIconButtonStyle}"
                                                    ToolTip="清空标定文件" />
                                        </Grid>
                                    </Border>

                                </Grid>
                            </GroupBox>
                        </Border>

                        <Border Grid.Row="1" Margin="0,0,0,8">
                            <GroupBox Header="当前缺陷规则">
                                <Grid Margin="12,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="源类别名:" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Margin="6,6,12,6" IsReadOnly="True" Style="{StaticResource ContentTextBoxStyle}" Text="{Binding ModelParam.SourceClassName}" />
                                    <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="输出类别名:" />
                                    <TextBox Grid.Row="0" Grid.Column="4" Margin="6,6,0,6" IsReadOnly="True" Style="{StaticResource ContentTextBoxStyle}" Text="{Binding ModelParam.OutputClassName}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="最小置信度阈值:" />
                                    <Grid Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="6,6,12,6"
                                          IsEnabled="{Binding ModelParam.HasCurrentDefect}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="54" />
                                        </Grid.ColumnDefinitions>

                                        <Slider Grid.Column="0"
                                                Minimum="0"
                                                Maximum="1"
                                                SmallChange="0.001"
                                                LargeChange="0.01"
                                                TickFrequency="0.05"
                                                AutoToolTipPlacement="TopLeft"
                                                AutoToolTipPrecision="4"
                                                IsMoveToPointEnabled="True"
                                                ToolTip="拖动滑块调整阈值，值越低越敏感，值越高越严格"
                                                Value="{Binding ModelParam.MinimumConfidence,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Margin="12,0,0,0"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource ContentTextStyle}"
                                                   Text="{Binding ModelParam.MinimumConfidence,StringFormat=F4}"
                                                   ToolTip="值越低越敏感，值越高越严格" />
                                    </Grid>

                                    <TextBlock Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="NMS合并:" />
                                    <Grid Grid.Row="1"
                                          Grid.Column="4"
                                          Margin="6,6,0,6"
                                          IsEnabled="{Binding ModelParam.HasCurrentDefect}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="46" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  Margin="0,0,12,0"
                                                  Content="启用"
                                                  IsChecked="{Binding ModelParam.IsNmsEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                  FontSize="{StaticResource PageFontSize}"
                                                  VerticalAlignment="Center" />
                                        <Slider Grid.Column="1"
                                                Minimum="0"
                                                Maximum="1"
                                                SmallChange="0.01"
                                                LargeChange="0.05"
                                                TickFrequency="0.05"
                                                AutoToolTipPlacement="TopLeft"
                                                AutoToolTipPrecision="2"
                                                IsEnabled="{Binding ModelParam.IsNmsEnabled}"
                                                IsMoveToPointEnabled="True"
                                                ToolTip="IoU 越大越容易保留相邻实例，越小越容易合并重叠实例"
                                                Value="{Binding ModelParam.NmsIoUThreshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2"
                                                   Margin="12,0,0,0"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource ContentTextStyle}"
                                                   Text="{Binding ModelParam.NmsIoUThreshold,StringFormat=F2}" />
                                    </Grid>
                                </Grid>
                            </GroupBox>
                        </Border>

                        <Border Grid.Row="2">
                            <GroupBox Header="特征阈值">
                                <Grid Margin="12,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Margin="0,0,0,10"
                                          IsEnabled="{Binding ModelParam.HasCurrentDefect}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Foreground="#7A8599"
                                                   Style="{StaticResource ContentTextStyle}"
                                                   Text="{Binding ModelParam.PreviewSummary}" />
                                        <Button Grid.Column="1"
                                                Width="96"
                                                Height="30"
                                                Margin="12,0,0,0"
                                                Command="{Binding ShowFeatureValuesCommand}"
                                                Content="实例特征"
                                                FontSize="{StaticResource PageFontSize}"
                                                Style="{StaticResource GeneralButtonStyle}" />
                                    </Grid>

                                    <DataGrid Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserResizeRows="False"
                                              FontSize="{StaticResource PageFontSize}"
                                              IsReadOnly="False"
                                              IsEnabled="{Binding ModelParam.HasCurrentDefect}"
                                              ItemsSource="{Binding ModelParam.FeatureThresholds}"
                                              Style="{StaticResource DefaultDataGridStyle}">
                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Width="80" Header="启用">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding IsEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Width="*"
                                                                Binding="{Binding FeatureName}"
                                                                ElementStyle="{StaticResource FeatureThresholdCellTextStyle}"
                                                                Header="特征"
                                                                IsReadOnly="True" />
                                            <DataGridTemplateColumn Width="90" Header="关系">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Grid>
                                                            <ComboBox DisplayMemberPath="."
                                                                      HorizontalAlignment="Stretch"
                                                                      FontSize="{StaticResource PageFontSize}"
                                                                      Height="25"
                                                                      BorderThickness="0,0,0,1"
                                                                      ItemsSource="{Binding RelationOptions}"
                                                                      SelectedItem="{Binding RelationOperator,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                      Visibility="{Binding CanEditRelation,Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    <TextBlock Style="{StaticResource ReadOnlyRelationTextStyle}"
                                                                       Text="—" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Width="*"
                                                                Binding="{Binding MinimumValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                EditingElementStyle="{StaticResource FeatureThresholdEditingTextBoxStyle}"
                                                                ElementStyle="{StaticResource FeatureThresholdCellTextStyle}"
                                                                Header="下限" />
                                            <DataGridTextColumn Width="*"
                                                                Binding="{Binding MaximumValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                EditingElementStyle="{StaticResource FeatureThresholdEditingTextBoxStyle}"
                                                                ElementStyle="{StaticResource FeatureThresholdCellTextStyle}"
                                                                Header="上限" />
                                            <DataGridTextColumn Width="*"
                                                                Binding="{Binding Unit}"
                                                                ElementStyle="{StaticResource FeatureThresholdCellTextStyle}"
                                                                Header="单位"
                                                                IsReadOnly="True" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </GroupBox>
                        </Border>

                        <Border Grid.Row="3" Margin="0,8,0,0">
                            <GroupBox Header="定制算法处理">
                                <Grid Margin="12,8">
                                    <ListBox x:Name="CustomAlgorithmListBox"
                                             Width="190"
                                             HorizontalAlignment="Left"
                                             FontSize="{StaticResource PageFontSize}"
                                             ItemsSource="{Binding ModelParam.CustomAlgorithmItems}"
                                             SelectedValue="{Binding ModelParam.SelectedCustomAlgorithmKey,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                             SelectedValuePath="AlgorithmKey">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Margin" Value="0,0,0,0" />
                                                <Setter Property="Padding" Value="0" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="AlgorithmItemBorder"
                                                        Padding="8,6"
                                                        BorderThickness="1,1,1,2"
                                                        BorderBrush="#D6DCE5"
                                                        Background="#FBFEFC">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="MouseLeftButtonUp">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.OpenCustomAlgorithmCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding AlgorithmKey}" />
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox Grid.Column="0"
                                                                  VerticalAlignment="Center"
                                                                  IsChecked="{Binding IsEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                                                        <TextBlock Grid.Column="1"
                                                                   Margin="8,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Style="{StaticResource ContentTextStyle}"
                                                                   Text="{Binding DisplayName}" />
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                        <Setter TargetName="AlgorithmItemBorder" Property="BorderBrush" Value="{DynamicResource SelectedBrush}" />
                                                        <Setter TargetName="AlgorithmItemBorder" Property="Background" Value="#FBFEFC" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Popup x:Name="CustomAlgorithmPopup"
                                           PlacementTarget="{Binding ElementName=CustomAlgorithmListBox}"
                                           Placement="Right"
                                           HorizontalOffset="12"
                                           VerticalOffset="0"
                                           StaysOpen="True"
                                           AllowsTransparency="True"
                                           DataContext="{Binding PlacementTarget.DataContext,RelativeSource={RelativeSource Self}}"
                                           IsOpen="{Binding ModelParam.IsCustomAlgorithmPopupOpen,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                        <Border x:Name="CustomAlgorithmPopupRoot"
                                                Width="620"
                                                Padding="12"
                                                Background="White"
                                                BorderBrush="#D6DCE5"
                                                BorderThickness="1"
                                                PreviewMouseLeftButtonDown="CustomAlgorithmPopupRoot_PreviewMouseLeftButtonDown"
                                                PreviewMouseLeftButtonUp="CustomAlgorithmPopupRoot_PreviewMouseLeftButtonUp"
                                                PreviewMouseMove="CustomAlgorithmPopupRoot_PreviewMouseMove"
                                                LostMouseCapture="CustomAlgorithmPopupRoot_LostMouseCapture">
                                            <Grid Visibility="{Binding ModelParam.IsSheetSizeJudgeSelected,Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               VerticalAlignment="Center"
                                                               FontWeight="SemiBold"
                                                               Style="{StaticResource ContentTextStyle}"
                                                               Text="片材尺寸判定" />
                                                    <Button Grid.Column="1"
                                                            Width="28"
                                                            Height="24"
                                                            Command="{Binding GeneralCommand}"
                                                            CommandParameter="关闭定制算法子页面"
                                                            Content="×"
                                                            FontSize="{StaticResource PageTitleFontSize}"
                                                            Style="{StaticResource GeneralButtonStyle}" />
                                                </Grid>

                                                <GroupBox Grid.Row="1" Header="参数设置">
                                                    <Grid Margin="10,8">
                                                        <Grid.Resources>
                                                            <Style TargetType="{x:Type TextBox}">
                                                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="{x:Type TextBox}">
                                                                            <Border Background="{TemplateBinding Background}"
                                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                                    SnapsToDevicePixels="True">
                                                                                <ScrollViewer x:Name="PART_ContentHost"
                                                                                              Margin="{TemplateBinding Padding}"
                                                                                              Focusable="False"
                                                                                              HorizontalScrollBarVisibility="Hidden"
                                                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                                              VerticalScrollBarVisibility="Hidden" />
                                                                            </Border>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </Grid.Resources>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="92" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="20" />
                                                            <ColumnDefinition Width="92" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="分割阈值:" />
                                                        <WxNumericUpDown:WxNumericUpDown Grid.Row="0"
                                                                                         Grid.Column="1"
                                                                                         Margin="6,5,0,5"
                                                                                         Minimum="0"
                                                                                         Maximum="255"
                                                                                         SmallChange="1"
                                                                                         FontSize="{StaticResource PageFontSize}"
                                                                                         HorizontalContentAlignment="Center"
                                                                                         VerticalContentAlignment="Center"
                                                                                         Value="{Binding ModelParam.SheetSizeJudge.Threshold,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Grid.Row="0" Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="矩形度:" />
                                                        <WxNumericUpDown:WxNumericUpDown Grid.Row="0"
                                                                                         Grid.Column="4"
                                                                                         Margin="6,5,0,5"
                                                                                         Minimum="0"
                                                                                         Maximum="1"
                                                                                         SmallChange="0.01"
                                                                                         Precision="4"
                                                                                         FontSize="{StaticResource PageFontSize}"
                                                                                         HorizontalContentAlignment="Center"
                                                                                         Value="{Binding ModelParam.SheetSizeJudge.RectangularityMinimum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="开操作半径:" />
                                                        <WxNumericUpDown:WxNumericUpDown Grid.Row="1"
                                                                                         Grid.Column="1"
                                                                                         Margin="6,5,0,5"
                                                                                         Minimum="0"
                                                                                         Maximum="99999999"
                                                                                         SmallChange="0.1"
                                                                                         Precision="4"
                                                                                         FontSize="{StaticResource PageFontSize}"
                                                                                         HorizontalContentAlignment="Center"
                                                                                         Value="{Binding ModelParam.SheetSizeJudge.OpeningRadius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="标准长:" />
                                                        <WxNumericUpDown:WxNumericUpDown Grid.Row="2"
                                                                                         Grid.Column="1"
                                                                                         Margin="6,5,0,5"
                                                                                         Minimum="0"
                                                                                         Maximum="99999999"
                                                                                         SmallChange="0.1"
                                                                                         Precision="4"
                                                                                         FontSize="{StaticResource PageFontSize}"
                                                                                         HorizontalContentAlignment="Center"
                                                                                         Value="{Binding ModelParam.SheetSizeJudge.StandardLength,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Grid.Row="2" Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="长公差:" />
                                                        <WxNumericUpDown:WxNumericUpDown Grid.Row="2"
                                                                                         Grid.Column="4"
                                                                                         Margin="6,5,0,5"
                                                                                         Minimum="0"
                                                                                         Maximum="99999999"
                                                                                         SmallChange="0.1"
                                                                                         Precision="4"
                                                                                         FontSize="{StaticResource PageFontSize}"
                                                                                         HorizontalContentAlignment="Center"
                                                                                         Value="{Binding ModelParam.SheetSizeJudge.LengthTolerance,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="标准宽:" />
                                                        <WxNumericUpDown:WxNumericUpDown Grid.Row="3"
                                                                                         Grid.Column="1"
                                                                                         Margin="6,5,0,5"
                                                                                         Minimum="0"
                                                                                         Maximum="99999999"
                                                                                         SmallChange="0.1"
                                                                                         Precision="4"
                                                                                         FontSize="{StaticResource PageFontSize}"
                                                                                         HorizontalContentAlignment="Center"
                                                                                         Value="{Binding ModelParam.SheetSizeJudge.StandardWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Grid.Row="3" Grid.Column="3" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="宽公差:" />
                                                        <WxNumericUpDown:WxNumericUpDown Grid.Row="3"
                                                                                         Grid.Column="4"
                                                                                         Margin="6,5,0,5"
                                                                                         Minimum="0"
                                                                                         Maximum="99999999"
                                                                                         SmallChange="0.1"
                                                                                         Precision="4"
                                                                                         FontSize="{StaticResource PageFontSize}"
                                                                                         HorizontalContentAlignment="Center"
                                                                                         Value="{Binding ModelParam.SheetSizeJudge.WidthTolerance,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                                                    </Grid>
                                                </GroupBox>

                                                <GroupBox Grid.Row="2" Header="算法执行结果" Margin="0,8,0,0">
                                                    <Border MinHeight="82"
                                                            Padding="10,8"
                                                            BorderBrush="#D6DCE5"
                                                            BorderThickness="1"
                                                            Background="#FBFEFC">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="84" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="84" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="判定结果:" />
                                                            <TextBlock Grid.Row="0"
                                                                       Grid.Column="1"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold"
                                                                       Style="{StaticResource ContentTextStyle}"
                                                                       Text="{Binding ModelParam.SheetSizeJudgePreviewStatusText}" />
                                                            <TextBlock Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="矩形度:" />
                                                            <TextBlock Grid.Row="0"
                                                                       Grid.Column="3"
                                                                       VerticalAlignment="Center"
                                                                       Style="{StaticResource ContentTextStyle}"
                                                                       Text="{Binding ModelParam.SheetSizeJudgePreviewRectangularityText}" />

                                                            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="实际长:" />
                                                            <TextBlock Grid.Row="1"
                                                                       Grid.Column="1"
                                                                       Margin="0,8,0,0"
                                                                       VerticalAlignment="Center"
                                                                       Style="{StaticResource ContentTextStyle}"
                                                                       Text="{Binding ModelParam.SheetSizeJudgePreviewLengthText}" />
                                                            <TextBlock Grid.Row="1" Grid.Column="2" Margin="0,8,0,0" VerticalAlignment="Center" Style="{StaticResource ContentTextStyle}" Text="实际宽:" />
                                                            <TextBlock Grid.Row="1"
                                                                       Grid.Column="3"
                                                                       Margin="0,8,0,0"
                                                                       VerticalAlignment="Center"
                                                                       Style="{StaticResource ContentTextStyle}"
                                                                       Text="{Binding ModelParam.SheetSizeJudgePreviewWidthText}" />
                                                        </Grid>
                                                    </Border>
                                                </GroupBox>
                                                <Button Grid.Row="3"
                                                        Width="120"
                                                        Height="30"
                                                        Margin="0,8,0,0"
                                                        HorizontalAlignment="Right"
                                                        Command="{Binding GeneralCommand}"
                                                        CommandParameter="执行片材尺寸判定"
                                                        Content="执行"
                                                        FontSize="{StaticResource PageFontSize}"
                                                        Style="{StaticResource GeneralButtonStyle}" />
                                            </Grid>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </GroupBox>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="3"
                          Margin="0,5"
                          Background="{DynamicResource BtnOverColor}"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" />

            <Border Grid.Column="4" Padding="5">
                <Grid>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Margin="0,0,0,8">
                            <Expander Header="图像预览"
                                      ExpandDirection="Down"
                                      IsExpanded="True"
                                      SnapsToDevicePixels="True"
                                      Style="{DynamicResource ExpanderStyle}"
                                      VerticalAlignment="Stretch">
                                <Grid Margin="5">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0"
                                                Width="28"
                                                Height="24"
                                                Margin="0,0,0,0"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="上一张图"
                                                Content="&lt;"
                                                FontSize="{StaticResource PageTitleFontSize}"
                                                IsEnabled="{Binding ModelParam.CanMovePreviousPreviewImage}"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                ToolTip="上一张图" />
                                        <TextBlock Grid.Column="1"
                                                   MinWidth="46"
                                                   Margin="6,0"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding ModelParam.CurrentPreviewImageDisplayText}" />
                                        <Button Grid.Column="3"
                                                Width="28"
                                                Height="24"
                                                Command="{Binding GeneralCommand}"
                                                CommandParameter="下一张图"
                                                Content="&gt;"
                                                FontSize="{StaticResource PageTitleFontSize}"
                                                IsEnabled="{Binding ModelParam.CanMoveNextPreviewImage}"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                ToolTip="下一张图" />
                                    </Grid>

                                    <local:DefectPostProcessPreviewControl Grid.Row="1"
                                                                           Model="{Binding ModelParam}" />
                                </Grid>
                            </Expander>
                        </Border>

                        <Border Grid.Row="1">
                            <Expander Header="输出信息"
                                      ExpandDirection="Down"
                                      IsExpanded="True"
                                      MaxHeight="260"
                                      SnapsToDevicePixels="True"
                                      Style="{DynamicResource ExpanderStyle}"
                                      VerticalAlignment="Top">
                                <StackPanel>
                                    <Grid Margin="5,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="数据:"
                                                   VerticalAlignment="Center" />
                                        <ComboBox x:Name="OutputParamComboBox"
                                                  Grid.Column="1"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding ModelParam.OutputParamNames}"
                                                  SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}"
                                                  Height="25"
                                                  BorderThickness="0 0 0 1"
                                                  Margin="5 0"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock MaxWidth="{Binding ActualWidth, ElementName=OutputParamComboBox}"
                                                               Text="{Binding}"
                                                               TextTrimming="CharacterEllipsis"
                                                               ToolTip="{Binding}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Content="&#xe630;"
                                                Grid.Column="2"
                                                Width="30"
                                                Height="26"
                                                FontSize="{StaticResource PageFontSize}"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                FontFamily="{StaticResource Iconfont}"
                                                ToolTip="添加"
                                                Command="{Binding DataOperateCommand}"
                                                CommandParameter="Add" />
                                        <Button Content="&#xe74b;"
                                                Grid.Column="3"
                                                Width="30"
                                                Height="26"
                                                Margin="5,0,0,0"
                                                FontSize="{StaticResource PageFontSize}"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                FontFamily="{StaticResource Iconfont}"
                                                ToolTip="删除"
                                                Command="{Binding DataOperateCommand}"
                                                CommandParameter="Delete" />
                                    </Grid>

                                    <DataGrid AutoGenerateColumns="False"
                                              Style="{StaticResource DefaultDataGridStyle}"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              ItemsSource="{Binding ModelParam.OutputParams}"
                                              SelectedItem="{Binding CurrentOutputParam}"
                                              FontSize="{StaticResource PageFontSize}"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              Height="160"
                                              RowHeaderWidth="20"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="All"
                                              IsReadOnly="False"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="参数名称" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}"
                                                                 HorizontalAlignment="Stretch"
                                                                 BorderThickness="0"
                                                                 Background="Transparent" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="数据类型" Width="Auto">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Width="130"
                                                                  Height="25"
                                                                  Margin="5,0"
                                                                  Background="Transparent"
                                                                  BorderThickness="0,0,0,1"
                                                                  helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                                  SelectedItem="{Binding Type,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="值" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}"
                                                                 HorizontalAlignment="Stretch"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 IsReadOnly="True" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="备注" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="{Binding Describe}"
                                                                 HorizontalAlignment="Stretch"
                                                                 BorderThickness="0"
                                                                 Background="Transparent" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="全局" Width="80">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}"
                                                                  HorizontalAlignment="Center" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Expander>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                BorderThickness="0,2,0,0"
                BorderBrush="{DynamicResource SelectedBrush}"
                CornerRadius="5"
                Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Margin="10,0,15,0">
                        <Run Text="耗时:" />
                        <Run Text="{Binding ModelParam.Output.RunTime}" />
                        <Run Text="ms" />
                    </TextBlock>
                    <TextBlock>
                        <Run Text="执行状态:" />
                        <Run Text="{Binding ModelParam.Output.RunStatus}" />
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Width="80"
                            Height="35"
                            Margin="0,0,15,0"
                            Content="执行"
                            FontSize="{StaticResource PageFontSize}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="执行"
                            Cursor="Hand"
                            Style="{StaticResource GeneralButtonStyle}" />
                    <Button Width="80"
                            Height="35"
                            Margin="0,0,15,0"
                            Content="取消"
                            FontSize="{StaticResource PageFontSize}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="取消"
                            Cursor="Hand"
                            Style="{StaticResource GeneralButtonStyle}" />
                    <Button Width="80"
                            Height="35"
                            Content="确认"
                            FontSize="{StaticResource PageFontSize}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="确认"
                            Cursor="Hand"
                            Style="{StaticResource GeneralButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

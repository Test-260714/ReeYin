<UserControl x:Class="HardwareTool.Motion.Views.LineOperationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="420"
             d:DesignWidth="850">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F8F9FA"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20 12"
                Margin="0 0 0 15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="直线线段"
                           FontWeight="SemiBold"
                           Foreground="#555555"
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <TextBlock Text=" - 先移动到起点，再从起点直线运行到终点。"
                           Foreground="#888888"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Margin="5 0 0 0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="6 6 0 0"
                            Padding="12 8">
                        <TextBlock Text="起点坐标"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="13"/>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="15">
                        <TextBlock Text="X 坐标 (mm)"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Maximum="1000"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 15"
                                          Value="{Binding ModelParam.SltMovementLocus.OriginX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Y 坐标 (mm)"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Maximum="1000"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Value="{Binding ModelParam.SltMovementLocus.OriginY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="6 6 0 0"
                            Padding="12 8">
                        <TextBlock Text="终点坐标"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="13"/>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="15">
                        <TextBlock Text="X 坐标 (mm)"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Maximum="1000"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 15"
                                          Value="{Binding ModelParam.SltMovementLocus.DestinationX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Y 坐标 (mm)"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Maximum="1000"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 15"
                                          Value="{Binding ModelParam.SltMovementLocus.DestinationY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <ToggleButton Style="{StaticResource ToggleButtonSwitch}"
                                      HorizontalAlignment="Left"
                                      Content="在线段开始时启用位置比较"
                                      FontSize="12"
                                      IsChecked="{Binding ModelParam.SltMovementLocus.IsUsingValid, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Margin="0 15 0 0">
            <Button Cursor="Hand"
                    Style="{StaticResource GeneralButtonStyle}"
                    Height="36"
                    Width="170"
                    FontSize="12"
                    Background="#4CAF50"
                    BorderBrush="#4CAF50"
                    Foreground="White"
                    Command="{Binding ExecuteCommand}"
                    Content="执行直线段运动"/>
        </StackPanel>
    </Grid>
</UserControl>


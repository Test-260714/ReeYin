<UserControl x:Class="HardwareTool.Motion.Views.PosCompareOperationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="620"
             d:DesignWidth="850">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F8F9FA"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="20 12"
                Margin="0 0 0 15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="位置比较"
                           FontWeight="SemiBold"
                           Foreground="#555555"
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <TextBlock Text=" - 先配置比较输出参数，再维护触发点列表。"
                           Foreground="#888888"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Margin="5 0 0 0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="0 0 0 15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="6 6 0 0"
                            Padding="12 8">
                        <TextBlock Text="基础参数"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="13"/>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="15">
                        <TextBlock Text="索引 [1-8]"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="1"
                                          Maximum="8"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 12"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.psoIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="输出轴号 X"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="1"
                                          Maximum="8"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 12"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compare_X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="输出轴号 Y"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="1"
                                          Maximum="8"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 12"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compare_Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="输出脉冲宽度 (us)"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="0"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 12"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.comparePulseWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="比较源"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="0"
                                          Maximum="1"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 12"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.sourceMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="等间距触发间隔 (Pulse)"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="1"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.syncPos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="6 6 0 0"
                            Padding="12 8">
                        <TextBlock Text="输出策略"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="13"/>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Margin="15">
                        <TextBlock Text="输出模式"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="0"
                                          Maximum="3"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 12"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compareMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="输出维数"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="1"
                                          Maximum="2"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 12"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compareDimension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="输出信号模式"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="0"
                                          Maximum="2"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Margin="0 0 0 12"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compareOutputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="误差带 (Pulse)"
                                   Foreground="#555555"
                                   FontWeight="Medium"
                                   Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="0"
                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                          Increment="1"
                                          Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compareErrBand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource PrimaryBrush}"
                        CornerRadius="6 6 0 0"
                        Padding="12 8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="比较点列表"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal">
                            <Button Style="{StaticResource GeneralButtonStyle}"
                                    Width="80"
                                    Height="28"
                                    Margin="0 0 8 0"
                                    Background="White"
                                    BorderBrush="White"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    Command="{Binding AddCommand}"
                                    Content="新增"/>
                            <Button Style="{StaticResource GeneralButtonStyle}"
                                    Width="80"
                                    Height="28"
                                    Background="White"
                                    BorderBrush="White"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    Command="{Binding RemoveCommand}"
                                    Content="删除"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1"
                          Margin="12"
                          AutoGenerateColumns="False"
                          Style="{StaticResource DefaultDataGridStyle}"
                          ItemsSource="{Binding ModelParam.SltMovementLocus.PosComparisonParam.PosCompareDatas, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          SelectedItem="{Binding ModelParam.SltMovementLocus.PosComparisonParam.SltPosCompareData, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          RowHeaderWidth="0"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="X 位置点"
                                            Width="*"
                                            Binding="{Binding PosX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="Y 位置点"
                                            Width="*"
                                            Binding="{Binding PosY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="位置比较 IO"
                                            Width="*"
                                            Binding="{Binding Hso, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn Header="通用 IO"
                                            Width="*"
                                            Binding="{Binding Gpo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal"
                    Margin="0 15 0 0">
            <ToggleButton Style="{StaticResource ToggleButtonSwitch}"
                          Content="开启位置比较"
                          Margin="0 0 10 0"
                          HorizontalAlignment="Center"
                          IsChecked="{Binding ModelParam.SltMovementLocus.Switch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Cursor="Hand"
                    Style="{StaticResource GeneralButtonStyle}"
                    Height="36"
                    Width="150"
                    FontSize="12"
                    Margin="0 0 10 0"
                    Background="White"
                    BorderBrush="#CCCCCC"
                    Foreground="#666666"
                    Command="{Binding ExecuteCommand}"
                    Content="执行当前轨迹"/>
            <Button Cursor="Hand"
                    Style="{StaticResource GeneralButtonStyle}"
                    Height="36"
                    Width="150"
                    FontSize="12"
                    Background="#4CAF50"
                    BorderBrush="#4CAF50"
                    Foreground="White"
                    Command="{Binding ApplyCommand}"
                    Content="应用位置比较"/>
        </StackPanel>
    </Grid>
</UserControl>


<UserControl x:Class="HardwareTool.Motion.Views.MotionShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:behaviors="clr-namespace:ReeYin_V.UI.Helper;assembly=ReeYin_V.UI"
             xmlns:controlEx="clr-namespace:ReeYin_V.UI.ControlExtend;assembly=ReeYin_V.UI"
             xmlns:motionModels="clr-namespace:HardwareTool.Motion.Models"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             FontSize="14"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Height="880"
             Width="1280"
             d:DesignHeight="880"
             d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F8F9FA"
                BorderBrush="#E0E0E0"
                BorderThickness="0 0 0 1"
                Padding="15 12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="运动轨迹列表"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#222222"/>
                    <TextBlock Text="/"
                               Margin="10 0"
                               Foreground="#CCCCCC"
                               FontSize="16"/>
                    <TextBlock Text="轨迹参数配置"
                               FontSize="16"
                               Foreground="#666666"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="控制卡:"
                               VerticalAlignment="Center"
                               Margin="0 0 10 0"
                               Foreground="#666666"
                               FontWeight="Medium"/>
                    <ComboBox Width="220"
                              Margin="0 0 12 0"
                              Style="{StaticResource ComboBoxExtend}"
                              ItemsSource="{Binding ModelParam.Models}"
                              DisplayMemberPath="NickName"
                              SelectedItem="{Binding ModelParam.ControlCard, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding GeneralCommand}"
                                                       CommandParameter="切换模块"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </ComboBox>

                    <Button Content="&#xe630;"
                            Width="36"
                            Height="32"
                            FontSize="16"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="#4CAF50"
                            Foreground="White"
                            FontFamily="{StaticResource Iconfont}"
                            BorderBrush="#4CAF50"
                            ToolTip="添加轨迹"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="添加新项"
                            Margin="0 0 8 0"/>
                    <Button Content="&#xe74b;"
                            Width="36"
                            Height="32"
                            FontSize="16"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="#F44336"
                            Foreground="White"
                            FontFamily="{StaticResource Iconfont}"
                            BorderBrush="#F44336"
                            ToolTip="删除选中轨迹"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="删除选中项"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.38*"
                                  MinWidth="320"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="0.62*"
                                  MinWidth="460"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Popup x:Name="popup1"
                           AllowsTransparency="True"
                           IsHitTestVisible="False"
                           Placement="RelativePoint"
                           PlacementTarget="{Binding ElementName=MotionGrid}">
                        <TextBlock Margin="8 0 0 0"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Text="释放移动到此位置..."
                                   Foreground="Black"/>
                    </Popup>

                    <DataGrid x:Name="MotionGrid"
                              AutoGenerateColumns="False"
                              Style="{StaticResource DefaultDataGridStyle}"
                              controlEx:DragDropRowBehavior.Enabled="True"
                              controlEx:DragDropRowBehavior.PopupControl="{Binding ElementName=popup1}"
                              EnableColumnVirtualization="True"
                              EnableRowVirtualization="False"
                              VirtualizingPanel.IsVirtualizing="True"
                              behaviors:DataGridRowNumberBehavior.Enable="True"
                              behaviors:DataGridRowNumberBehavior.Header="序号"
                              behaviors:DataGridRowNumberBehavior.Width="55"
                              behaviors:DataGridRowNumberBehavior.StartIndex="1"
                              behaviors:DataGridRowNumberBehavior.Format="{}{0}"
                              behaviors:DataGridRowNumberBehavior.Freeze="True"
                              ItemsSource="{Binding ModelParam.MovementLocuss, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedItem="{Binding ModelParam.SltMovementLocus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              FontSize="12"
                              RowHeaderWidth="0"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              IsReadOnly="False"
                              CanUserAddRows="False"
                              ScrollViewer.VerticalScrollBarVisibility="Visible">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectionChanged">
                                <i:InvokeCommandAction Command="{Binding GeneralCommand}"
                                                       CommandParameter="选中轨迹"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>

                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="操作方式"
                                                    Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Width="Auto"
                                                  Style="{StaticResource ComboBoxExtend}"
                                                  BorderThickness="0 0 0 1"
                                                  Foreground="Black"
                                                  HorizontalContentAlignment="Center"
                                                  FontSize="14"
                                                  helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                  helper:ItemsControlHelper.EnumType="{x:Type motionModels:CardOperaion}"
                                                  SelectedItem="{Binding MovingMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="SelectionChanged">
                                                    <i:InvokeCommandAction Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                                           CommandParameter="轨迹类型变更"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="备注"
                                                    Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox BorderThickness="0"
                                                 Background="Transparent"
                                                 HorizontalContentAlignment="Center"
                                                 Padding="5 0"
                                                 Text="{Binding Describe, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{Binding Describe}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="启用"
                                                    Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource ToggleButtonSwitch}"
                                                      HorizontalAlignment="Center"
                                                      IsChecked="{Binding IsUsing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          Background="#E0E0E0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Cursor="SizeWE"/>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#F8F9FA"
                            BorderBrush="#EEEEEE"
                            BorderThickness="0 0 0 1"
                            Padding="16 12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="轨迹详情"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#333333"/>
                                <TextBlock Text=" / "
                                           Foreground="#CCCCCC"
                                           Margin="6 0"/>
                                <TextBlock Text="{Binding ModelParam.SltMovementLocus.MovingMode, TargetNullValue=未选择轨迹}"
                                           Foreground="#666666"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Foreground="#666666">
                                <Run Text="当前控制卡: "/>
                                <Run Text="{Binding ModelParam.ControlCard.NickName, TargetNullValue=未选择}"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="White">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility"
                                        Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ModelParam.SltMovementLocus}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#xe65a;"
                                       FontFamily="{StaticResource Iconfont}"
                                       FontSize="52"
                                       HorizontalAlignment="Center"
                                       Foreground="#DDDDDD"
                                       Margin="0 0 0 16"/>
                            <TextBlock Text="请选择左侧轨迹查看和编辑参数"
                                       FontSize="15"
                                       Foreground="#AAAAAA"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <ContentControl Grid.Row="1"
                                    prism:RegionManager.RegionName="MotionOperationRegion"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <Setter Property="Visibility"
                                        Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ModelParam.SltMovementLocus}"
                                                 Value="{x:Null}">
                                        <Setter Property="Visibility"
                                                Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="#F8F9FA"
                BorderBrush="#E0E0E0"
                BorderThickness="0 1 0 0"
                Padding="15 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock Text="就绪"
                               Foreground="#666666"
                               FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="  |  "
                               Foreground="#CCCCCC"
                               Margin="10 0"/>
                    <TextBlock Foreground="#666666"
                               FontSize="13"
                               VerticalAlignment="Center">
                        <Run Text="轨迹数量: "/>
                        <Run Text="{Binding ModelParam.MovementLocuss.Count, Mode=OneWay}"
                             FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock Text="  |  "
                               Foreground="#CCCCCC"
                               Margin="10 0"/>
                    <TextBlock Foreground="#666666"
                               FontSize="13"
                               VerticalAlignment="Center">
                        <Run Text="当前模块: "/>
                        <Run Text="{Binding ModelParam.ControlCard.NickName, TargetNullValue=未选择}"
                             FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Command="{Binding GeneralCommand}"
                            Height="36"
                            Width="100"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="取消"
                            CommandParameter="取消"
                            Background="White"
                            BorderBrush="#CCCCCC"
                            Foreground="#666666"
                            Cursor="Hand"
                            Margin="0 0 10 0"/>
                    <Button Command="{Binding GeneralCommand}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="36"
                            Width="100"
                            Content="确认"
                            CommandParameter="确认"
                            Background="#2196F3"
                            BorderBrush="#2196F3"
                            Foreground="White"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

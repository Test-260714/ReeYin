<UserControl x:Class="HardwareTool.Motion.Views.MotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HardwareTool.Motion.Views"
            xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
            xmlns:hc="https://handyorg.github.io/handycontrol"
            xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
            xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
            xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:controlEx="clr-namespace:ReeYin_V.UI.ControlExtend;assembly=ReeYin_V.UI"

            xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
            xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
            xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
            xmlns:prism="http://prismlibrary.com/"
            mc:Ignorable="d" FontSize="14"
            Height="780" Width="1080"
            prism:ViewModelLocator.AutoWireViewModel="True"
            d:DesignHeight="780" d:DesignWidth="1080">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Border CornerRadius="0" Padding="0" VerticalAlignment="Stretch" HorizontalAlignment="Center">
            <TabControl Width="1080" Height="700" Style="{DynamicResource TabControlStyle}" SelectedIndex="{Binding ModelParam.SltMovingMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" FontSize="20">
                <TabItem Header="自定义组" Style="{DynamicResource SingleTabItemStyle}" Width="160">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="520"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <WxGroupBox:WxGroupBox Grid.Row="0" Header="自定义轨迹" >
                            <StackPanel >
                                <Popup x:Name="popup1" AllowsTransparency="True" IsHitTestVisible="False" Placement="RelativePoint" PlacementTarget="{Binding ElementName=dataGrid1}" >
                                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Text="释放移动到此位置..." Foreground="Black"/>
                                </Popup>
                                <DataGrid AutoGenerateColumns="False" x:Name="dg2" Style="{StaticResource DefaultDataGridStyle}"
                                  controlEx:DragDropRowBehavior.Enabled="True" controlEx:DragDropRowBehavior.PopupControl="{Binding ElementName=popup1}"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="False"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ItemsSource="{Binding ModelParam.MovementLocuss,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                  SelectedItem="{Binding ModelParam.SltMovementLocus,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Height="500"
                                  FontSize="12" 
                                  RowHeaderWidth="20"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  IsReadOnly="False" CanUserAddRows="False">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="编辑自定义参数"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>

                                    <DataGrid.ContextMenu>
                                        <ContextMenu IsEnabled="True">
                                            <MenuItem Header="执行移动" Command="{Binding GeneralCommand}" CommandParameter="自定义执行移动" />
                                            <Separator/>
                                            <!-- 分隔线 -->
                                            <MenuItem Header="添加新项" Command="{Binding GeneralCommand}" CommandParameter="自定义添加新项" />
                                            <MenuItem Header="删除选中项" Command="{Binding GeneralCommand}" CommandParameter="自定义删除选中项" />
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="序号" IsReadOnly="True" Width="100" >
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"
                                                    Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}">

                                                    </TextBlock>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="操作方式" IsReadOnly="True" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox BorderThickness="0 0 0 1" Background="Transparent" Width="300" HorizontalContentAlignment="Center" IsReadOnly="True"
                                                         Text="{Binding MovingMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" />
                                                    <!--<ComboBox IsEditable="False" Width="240" Style="{StaticResource ComboBoxExtend}" HorizontalAlignment="Center" HorizontalContentAlignment="Center" BorderThickness="0 0 0 1" 
                                                              helper:ItemsControlHelper.EnumValuesToItemsSource="True" SelectedItem="{Binding MovingMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>-->
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox BorderThickness="0 0 0 1" Background="Transparent" Width="300" HorizontalContentAlignment="Center"
                                                         Text="{Binding Describe,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="启用" IsReadOnly="true" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ToggleButton Style="{StaticResource ToggleButtonSwitch}" HorizontalAlignment="Center"
                                                               IsChecked="{Binding IsUsing,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </WxGroupBox:WxGroupBox>

                    </Grid>
                </TabItem>

                <TabItem Header="其他" Style="{DynamicResource SingleTabItemStyle}" Width="160">
                    <WxGroupBox:WxGroupBox Header="操作" Grid.Row="2">
                        <StackPanel HorizontalAlignment="Left">
                            <ComboBox IsEditable="True" Width="300" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="轴卡选择" Style="{StaticResource ComboBoxExtend}" hc:InfoElement.TitleWidth="140"
                                                        ItemsSource="{Binding ModelParam.Models}" DisplayMemberPath="NickName" SelectedItem="{Binding ModelParam.ControlCard,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="SelectionChanged">
                                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换模块"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </ComboBox>
                        </StackPanel>
                    </WxGroupBox:WxGroupBox>

                </TabItem>
            </TabControl>
        </Border>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" Background="{DynamicResource TitleForegroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                                                    <!--<Run Text="耗时:"/>
                                                    <Run Text="{Binding ModuleParam.ElapsedTime}"/>
                                                    <Run Text="ms"/>-->
                    </TextBlock>

                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                                                    <!--<Run Text="执行状态:"/>
                                                    <Run Text="{Binding ModuleParam.Status}"/>-->
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Height="35" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    CommandParameter="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="确认"
                                                    CommandParameter="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
        <hc:DrawerContainer >
            <!--打开参数页面-->
            <hc:Drawer Name="DrawerRight" MaskCanClose="True" IsOpen="{Binding EditScanningParam,Mode=TwoWay}" Margin="10 10 10 10 ">
                <Border Background="{DynamicResource RegionBrush}" Width="auto" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" Margin="10 10 10 10 ">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Margin="10,0,0,0" Style="{StaticResource TextBlockTitle}" HorizontalAlignment="Left">
                            <Run Text="晶圆参数设置"/>
                        </TextBlock>

                        <hc:PropertyGrid Grid.Row="1" Width="600" Height="auto" SelectedObject="{Binding ModelParam.SltScanningTracks}" PreviewMouseWheel="PropertyGrid_PreviewMouseWheel" />

                    </Grid>
                </Border>
            </hc:Drawer>
        </hc:DrawerContainer>

        <hc:DrawerContainer >
            <!--打开参数页面-->
            <hc:Drawer MaskCanClose="True" IsOpen="{Binding EditCustomParam,Mode=TwoWay}" Margin="10 10 10 10 ">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Closed">
                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="自定义参数关闭"/>
                    </i:EventTrigger>
                    <i:EventTrigger EventName="Opened">
                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="自定义参数打开"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>

                <Border Background="{DynamicResource RegionBrush}" Width="auto" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" Margin="10 10 10 10 ">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="650"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Margin="10,10,0,0" Style="{StaticResource TextBlockTitle}" HorizontalAlignment="Center">
                            <Run Text="自定义参数设置"/>
                        </TextBlock>
                        <StackPanel Grid.Row="1">
                            <TabControl Width="880" Height="650" Style="{DynamicResource TabControlStyle}" 
                                        SelectedIndex="{Binding ModelParam.SltMovementLocus.SltTab,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" FontSize="20">
                                <TabItem Header="点" Style="{DynamicResource SingleTabItemStyle}" Width="80">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="100"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="100"/>
                                        </Grid.RowDefinitions>

                                        <WxGroupBox:WxGroupBox Header="设置目标位置" >
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Grid.Column="0" Grid.Row="1" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black">
                                                    <Run Text="目标位置[X/Y/Z/...]:"/>
                                                </TextBlock>
                                                <WxLink:WxLink Width="350" Order="OpenPosParam" OutputParam="{Binding ModelParam.SltMovementLocus.AssignPosInfo,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  
                                                    Text="{Binding ModelParam.SltMovementLocus.AssignPosInfo.Describe,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <Button Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Background="Transparent" Height="35"
                                                    Command="{Binding GeneralCommand}" CommandParameter="开始移动" >
                                                    <Button.ContentTemplate>
                                                        <DataTemplate >
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="开始移动" TextWrapping="NoWrap" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>
                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>

                                        <WxGroupBox:WxGroupBox Header="操作" Grid.Row="3">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Button Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Background="Transparent" Height="35"
                                                    Command="{Binding GeneralCommand}" CommandParameter="移动至目标位置" >
                                                    <Button.ContentTemplate>
                                                        <DataTemplate >
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="移动至目标位置" TextWrapping="NoWrap" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>
                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="IO" Style="{DynamicResource SingleTabItemStyle}" Width="80">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="100"/>
                                        </Grid.RowDefinitions>
                                        <WxGroupBox:WxGroupBox Header="设置IO输出" >
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                <!--<CheckBox Margin="0 5 10 0 " Content="启用" BorderBrush="{DynamicResource PrimaryBrush}" IsChecked="{Binding ModelParam.IsUsingOutputIO,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>-->
                                                <ComboBox Width="240" hc:InfoElement.TitleWidth="110" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="指定输出IO：" Style="{StaticResource ComboBoxExtend}" Height="20"
                                       HorizontalAlignment="Left" HorizontalContentAlignment="Center" IsEditable="False" Margin="0 0 0 10"
                                      SelectedIndex="{Binding ModelParam.SltMovementLocus.OutputIO,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                    <ComboBoxItem Content="1" />
                                                    <ComboBoxItem Content="2" />
                                                    <ComboBoxItem Content="3" />
                                                    <ComboBoxItem Content="4" />
                                                    <ComboBoxItem Content="5" />
                                                    <ComboBoxItem Content="6" />
                                                    <ComboBoxItem Content="7" />
                                                    <ComboBoxItem Content="8" />
                                                    <ComboBoxItem Content="9" />
                                                    <ComboBoxItem Content="10" />
                                                    <ComboBoxItem Content="11" />
                                                    <ComboBoxItem Content="12" />
                                                </ComboBox>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Margin="0,0,0,0" Style="{StaticResource TextBlockTitle}" HorizontalAlignment="Left" FontSize="16">
                                                        <Run Text="开关状态："/>
                                                    </TextBlock>
                                                    <ToggleButton Style="{StaticResource ToggleButtonSwitch}" HorizontalAlignment="Center"
                                                               IsChecked="{Binding ModelParam.SltMovementLocus.OutputIOStatus,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>

                                                <hc:NumericUpDown Minimum="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="300" hc:InfoElement.Title="延时(ms)[为0时,默认持续触发]:" Style="{StaticResource NumericUpDownPlus}" Width="400" Increment="1" Height="20"
                                                        BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                        Value="{Binding ModelParam.SltMovementLocus.OutputIODelay,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>

                                        <WxGroupBox:WxGroupBox Header="操作" Grid.Row="2">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Button Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Background="Transparent" Height="35"
                                                    Command="{Binding GeneralCommand}" CommandParameter="触发IO" >
                                                    <Button.ContentTemplate>
                                                        <DataTemplate >
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="触发IO" TextWrapping="NoWrap" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>
                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="直线线段" Style="{DynamicResource SingleTabItemStyle}" Width="120">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="200"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="100"/>
                                        </Grid.RowDefinitions>
                                        <WxGroupBox:WxGroupBox Header="位置信息（运动时，会先移动到起点，从起点移动至终点）" >
                                            <UniformGrid Columns="2" HorizontalAlignment="Center" VerticalAlignment="Top">
                                                <hc:NumericUpDown Maximum="550" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="起点X(mm):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.OriginX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <hc:NumericUpDown Maximum="550" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="起点Y(mm):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.OriginY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown Maximum="550" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="终点X(mm):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.DestinationX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <hc:NumericUpDown Maximum="550" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="终点Y(mm):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.DestinationY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            </UniformGrid>
                                        </WxGroupBox:WxGroupBox>

                                        <WxGroupBox:WxGroupBox Header="操作" Grid.Row="2">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Button Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Background="Transparent" Height="35"
                                                    Command="{Binding GeneralCommand}" CommandParameter="从起点运动至终点" >
                                                    <Button.ContentTemplate>
                                                        <DataTemplate >
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="从起点运动至终点" TextWrapping="NoWrap" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>

                                                <ToggleButton Style="{StaticResource ToggleButtonSwitch}" Content="启用有效线段开启位置比较" Width="auto" Margin="0 0 0 10" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding ModelParam.SltMovementLocus.IsUsingValid,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="圆弧线段" Style="{DynamicResource SingleTabItemStyle}" Width="120">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="220"/>
                                            <RowDefinition Height="100"/>
                                        </Grid.RowDefinitions>

                                        <WxGroupBox:WxGroupBox Grid.Row="0" Header="位置信息" >
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top">
                                                <hc:NumericUpDown Maximum="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="终点X(mm):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.DestinationX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <hc:NumericUpDown Maximum="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="终点Y(mm):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.DestinationY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 0 0">
                                                    <TextBlock Margin="0,0,0,0" Style="{StaticResource TextBlockTitle}" HorizontalAlignment="Left" FontSize="16">
                                                    <Run Text="旋转方向(选中表示顺时针)："/>
                                                    </TextBlock>
                                                    <ToggleButton Style="{StaticResource ToggleButtonSwitch}" HorizontalAlignment="Center" 
                                                            IsChecked="{Binding ModelParam.SltMovementLocus.Rotation,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>
                                        <WxGroupBox:WxGroupBox Grid.Row="1" Header="绘制圆弧方式（只能单独选择圆心或半径）" >
                                            <TabControl TabStripPlacement="Left" Margin="16" Style="{StaticResource TabControlCapsule}"
                                                        SelectedIndex="{Binding ModelParam.SltMovementLocus.SltDrawingMethod,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                <TabItem Header="以圆心绘制">
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <hc:NumericUpDown Maximum="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="圆心X(mm):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                    BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.CenterX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                        <hc:NumericUpDown Maximum="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="圆心Y(mm):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                    BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.CenterY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                </TabItem>
                                                <TabItem IsSelected="True" Header="以半绘制径" >
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <hc:NumericUpDown Maximum="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="半径(mm):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                    BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.Radius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                    </StackPanel>
                                                </TabItem>

                                            </TabControl>

                                        </WxGroupBox:WxGroupBox>

                                        <WxGroupBox:WxGroupBox Header="操作" Grid.Row="2">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Button Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Background="Transparent" Height="35"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行圆弧运动" >
                                                    <Button.ContentTemplate>
                                                        <DataTemplate >
                                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock Text="从起点运动至终点" TextWrapping="NoWrap" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </Button.ContentTemplate>
                                                </Button>
                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="位置比较" Style="{DynamicResource SingleTabItemStyle}" Width="120">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="400"/>
                                            <RowDefinition Height="100"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel>
                                            <Expander Margin="5,5,5,0" Grid.Row="0" Header="必要参数设置(启用位置比较，需要在移动前设置)" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}" Foreground="White">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition/>
                                                            <RowDefinition/>
                                                        </Grid.RowDefinitions>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition/>
                                                                <ColumnDefinition/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <hc:NumericUpDown Maximum="8" Minimum="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0" FontSize="12"
                                                                hc:InfoElement.Title="索引[1-8]:" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.psoIndex,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <hc:NumericUpDown Maximum="8" Minimum="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0" FontSize="12"
                                                                hc:InfoElement.Title="输出轴号X:" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compare_X,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <hc:NumericUpDown Maximum="8" Minimum="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0" FontSize="12"
                                                                hc:InfoElement.Title="输出轴号Y:" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compare_Y,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                                <hc:NumericUpDown  Minimum="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="200" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="350" Height="20" Margin="0 5 5 0" FontSize="12"
                                                                hc:InfoElement.Title="输出脉冲宽度(us):" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.comparePulseWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <hc:NumericUpDown Maximum="1" Minimum="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="200" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="350" Height="20" Margin="0 5 5 0" FontSize="12"
                                                                hc:InfoElement.Title="比较源[0：编码器/1：脉冲计数器]:" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.sourceMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <hc:NumericUpDown Minimum="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="250"  Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="350" Height="20" Margin="0 5 5 0" FontSize="12"
                                                                hc:InfoElement.Title="等间距触发间隔，XY轴合成间隔（Pulse）:" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.syncPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                            </StackPanel>

                                                        </Grid>
                                                        <Grid Grid.Row="1">
                                                            <StackPanel>
                                                                <hc:NumericUpDown Maximum="3" Minimum="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="400" Style="{StaticResource NumericUpDownPlus}" FontSize="12" Increment="1" Width="500" Height="20" Margin="0 5 5 0"
                                                                    hc:InfoElement.Title="输出模式[0:FIFO/1:Liner/2:PSO立即模式/3:PSO等待到位模式]:" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                                              Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compareMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <hc:NumericUpDown Minimum="1" Maximum="2" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="400" Style="{StaticResource NumericUpDownPlus}" FontSize="12" Increment="1" Width="500" Height="20" Margin="0 5 5 0"
                                                                    hc:InfoElement.Title="输出维数[1：一维位置比较/2：二维位置比较]:" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                                              Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compareDimension,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <hc:NumericUpDown Maximum="2" Minimum="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="400" Style="{StaticResource NumericUpDownPlus}" FontSize="12" Increment="1" Width="500" Height="20" Margin="0 5 5 0"
                                                                    hc:InfoElement.Title="输出信号模式[0：脉冲/1：电平/2:电平自动翻转]:" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalAlignment="Left"
                                                                              Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compareOutputMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="400" Style="{StaticResource NumericUpDownPlus}" FontSize="12" Increment="1" Width="500" Height="20" Margin="0 5 5 0"
                                                                    hc:InfoElement.Title="误差带设置[二维位置比较输出误差带，单位Pulse]:" BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                                              Value="{Binding ModelParam.SltMovementLocus.PosComparisonParam.compareErrBand,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>

                                                </StackPanel>
                                            </Expander>
                                            <Expander Margin="5,5,5,0" Grid.Row="0" Header="比较点（使用一维时，以“轴1位置点”为有效数据）" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}" Foreground="White">
                                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                                    <StackPanel >
                                                        <Popup x:Name="popup2" AllowsTransparency="True" IsHitTestVisible="False" Placement="RelativePoint" PlacementTarget="{Binding ElementName=dataGrid1}" >
                                                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Text="释放移动到此位置..." />
                                                        </Popup>
                                                        <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                                          controlEx:DragDropRowBehavior.Enabled="True" controlEx:DragDropRowBehavior.PopupControl="{Binding ElementName=popup1}"
                                                          EnableColumnVirtualization="True"
                                                          EnableRowVirtualization="False"
                                                          VirtualizingPanel.IsVirtualizing="True"
                                                          ItemsSource="{Binding ModelParam.SltMovementLocus.PosComparisonParam.PosCompareDatas,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                                          SelectedItem="{Binding ModelParam.SltMovementLocus.PosComparisonParam.SltPosCompareData,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                          MaxHeight="300"
                                                          Height="300"
                                                          FontSize="12" 
                                                          RowHeaderWidth="20"
                                                          SelectionUnit="FullRow"
                                                          HeadersVisibility="Column"
                                                          GridLinesVisibility="All"
                                                          IsReadOnly="False" CanUserAddRows="False">
                                                            <DataGrid.ContextMenu>
                                                                <ContextMenu IsEnabled="True">
                                                                    <MenuItem Header="执行移动" Command="{Binding GeneralCommand}" CommandParameter="位置比较执行移动" />
                                                                    <Separator/>
                                                                    <!-- 分隔线 -->
                                                                    <MenuItem Header="添加新项" Command="{Binding GeneralCommand}" CommandParameter="位置比较添加新项" />
                                                                    <MenuItem Header="删除选中项" Command="{Binding GeneralCommand}" CommandParameter="位置比较删除选中项" />
                                                                </ContextMenu>
                                                            </DataGrid.ContextMenu>
                                                            <DataGrid.Columns>
                                                                <DataGridTemplateColumn Header="序号" IsReadOnly="True" Width="100" >
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <TextBlock  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"
                                                    Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}">

                                                                            </TextBlock>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>

                                                                <DataGridTemplateColumn Header="轴号X位置点(mm)" IsReadOnly="True" Width="*">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <hc:NumericUpDown  Style="{StaticResource NumericUpDownPlus}" Increment="1" Height="20" Margin="0 5 5 0"
                                                                    BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                              Value="{Binding PosX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>

                                                                <DataGridTemplateColumn Header="轴号Y位置点(mm)" IsReadOnly="False" Width="*">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <hc:NumericUpDown  Style="{StaticResource NumericUpDownPlus}" Increment="1" Height="20" Margin="0 5 5 0"
                                                                    BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                              Value="{Binding PosY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>

                                                                <DataGridTemplateColumn Header="位置比较IO" IsReadOnly="False" Width="*">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <hc:NumericUpDown  Style="{StaticResource NumericUpDownPlus}" Increment="1" Height="20" Margin="0 5 5 0"
                                                                    BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                              Value="{Binding Hso,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>

                                                                <DataGridTemplateColumn Header="通用IO" IsReadOnly="False" Width="*">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <hc:NumericUpDown  Style="{StaticResource NumericUpDownPlus}" Increment="1" Height="20" Margin="0 5 5 0"
                                                                    BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" HorizontalContentAlignment="Center"
                                                                              Value="{Binding Gpo,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>

                                                                <!--<DataGridTemplateColumn Header="启用" IsReadOnly="true" Width="100">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ToggleButton Style="{StaticResource ToggleButtonSwitch}" HorizontalAlignment="Center"
                                                               IsChecked="{Binding IsUsing,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>-->
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </StackPanel>

                                                </StackPanel>
                                            </Expander>

                                        </StackPanel>

                                        <WxGroupBox:WxGroupBox Grid.Row="1" Header="触发点" >
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>

                                        <WxGroupBox:WxGroupBox Header="操作" Grid.Row="2">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <ToggleButton Style="{StaticResource ToggleButtonSwitch}" Content="开启" Width="auto" Margin="0 0 0 10" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding ModelParam.SltMovementLocus.Switch,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>
                                    </Grid>
                                </TabItem>

                                <TabItem Header="延时" Style="{DynamicResource SingleTabItemStyle}" Width="120">
                                    <Grid>
                                        <WxGroupBox:WxGroupBox Header="设置延时事件" Grid.Row="2">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <hc:NumericUpDown Maximum="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="100" hc:InfoElement.Title="延时时间(S):" Style="{StaticResource NumericUpDownPlus}" Increment="1" Width="200" Height="20" Margin="0 5 5 0"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding ModelParam.SltMovementLocus.OutputIODelay,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </WxGroupBox:WxGroupBox>
                                    </Grid>
                                </TabItem>
                                
                                <TabItem Header="触发事件" Style="{DynamicResource SingleTabItemStyle}" Width="120">
                                    <WxGroupBox:WxGroupBox Header="设置触发事件" Grid.Row="2">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="事件名称：" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="100" Width="300" VerticalAlignment="Center"
                                                     Text="{Binding ModelParam.SltMovementLocus.EventName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </WxGroupBox:WxGroupBox>
                                </TabItem>
                                
                                <TabItem Header="自定义" Style="{DynamicResource SingleTabItemStyle}" Width="120">
                                    <Grid>

                                    </Grid>
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                        <!--<hc:PropertyGrid Grid.Row="1" Width="600" Height="600" SelectedObject="{Binding ModelParam.SltMovementLocus}" PreviewMouseWheel="PropertyGrid_PreviewMouseWheel" />-->

                    </Grid>
                </Border>
            </hc:Drawer>
        </hc:DrawerContainer>

    </Grid>
</UserControl>

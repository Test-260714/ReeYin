<UserControl x:Class="HardwareTool.ZMotionOutput.Views.ZMotionNgOutputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             FontSize="14"
             Height="820"
             Width="1180"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="820"
             d:DesignWidth="1180">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="12">
            <TabItem Header="配置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="2">
                <WxGroupBox:WxGroupBox Header="控制卡">
                    <Border Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="控制卡选择" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <ComboBox Grid.Column="1"
                                      Height="30"
                                      hc:InfoElement.TitlePlacement="Left"
                                      ItemsSource="{Binding ModelParam.Models}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedItem="{Binding ModelParam.ControlCard, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="SelectionChanged">
                                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换模块"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </ComboBox>
                            <Button Grid.Column="2"
                                    Margin="10,0,0,0"
                                    Content="刷新"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Command="{Binding GeneralCommand}"
                                    CommandParameter="刷新控制卡"/>
                        </Grid>
                    </Border>
                </WxGroupBox:WxGroupBox>

                <WxGroupBox:WxGroupBox Header="输入源(兼容)" Margin="0,12,0,0" Visibility="Collapsed">
                    <Border Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="220"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="默认左/右/检测包兼容旧流程；新增自定义源后，可在输出规则里绑定任意OUT点。"
                                           Foreground="#64748B"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="添加源"
                                            Width="86"
                                            Height="30"
                                            Margin="8,0,8,0"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="添加输入源"/>
                                    <Button Content="删除源"
                                            Width="86"
                                            Height="30"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="删除输入源"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,8"
                                       Text="解析器像翻译官：Bool看开关，OK/NG看文本，缺陷列表有内容即NG，数值>0即NG。"
                                       Foreground="#64748B"
                                       TextWrapping="Wrap"/>

                            <DataGrid Grid.Row="2"
                                      ItemsSource="{Binding ModelParam.InputSourceConfigs}"
                                      SelectedItem="{Binding ModelParam.SelectedInputSource, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                    <DataGridTextColumn Header="源名" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                                    <DataGridTemplateColumn Header="角色" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="28"
                                                          ItemsSource="{Binding DataContext.ModelParam.SourceRoleOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          DisplayMemberPath="RoleName"
                                                          SelectedValuePath="RoleKey"
                                                          SelectedValue="{Binding RoleKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="解析" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="28"
                                                          ItemsSource="{Binding DataContext.ModelParam.SourceResolverOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          DisplayMemberPath="ResolverName"
                                                          SelectedValuePath="ResolverKey"
                                                          SelectedValue="{Binding ResolverKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="绑定参数" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <WxLink:WxLink InputParams="{Binding DataContext.ModelParam.InputParams, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               OutputParam="{Binding BindingParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Order="OpenParam"
                                                               Text="{Binding BindingParam.Name, Mode=OneWay, TargetNullValue=未绑定}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridCheckBoxColumn Header="手动值" Binding="{Binding ManualValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </WxGroupBox:WxGroupBox>

                <WxGroupBox:WxGroupBox Header="IO输出配置" Margin="0,12,0,0">
                    <Border Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="360"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="一行就是一个输出：自定义名称，绑定前方节点输出，选择解析方式和OUT口；绑定值成立时写有效电平，不成立时按复位策略处理。"
                                           Foreground="#64748B"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox Content="启用输出"
                                              IsChecked="{Binding ModelParam.EnableOutput, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,14,0"/>
                                    <Button Content="添加输出"
                                            Width="86"
                                            Height="30"
                                            Margin="8,0,8,0"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="添加输出规则"/>
                                    <Button Content="删除输出"
                                            Width="86"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="删除输出规则"/>
                                    <Button Content="测试输出"
                                            Width="90"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="测试输出"/>
                                    <Button Content="全部复位"
                                            Width="90"
                                            Height="30"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="全部复位"/>
                                </StackPanel>
                            </Grid>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding ModelParam.OutputRuleConfigs}"
                                      SelectedItem="{Binding ModelParam.SelectedOutputRule, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                                    <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                                    <DataGridTemplateColumn Header="条件" Width="130" Visibility="Collapsed">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="28"
                                                          ItemsSource="{Binding DataContext.ModelParam.RuleConditionOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          DisplayMemberPath="ConditionName"
                                                          SelectedValuePath="ConditionKey"
                                                          SelectedValue="{Binding ConditionKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="绑定前方输出" Width="260">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <WxLink:WxLink InputParams="{Binding DataContext.ModelParam.InputParams, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                               OutputParam="{Binding BindingParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               Order="OpenParam"
                                                               Text="{Binding BindingParam.Name, Mode=OneWay, TargetNullValue=未绑定}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="解析" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="28"
                                                          ItemsSource="{Binding DataContext.ModelParam.SourceResolverOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          DisplayMemberPath="ResolverName"
                                                          SelectedValuePath="ResolverKey"
                                                          SelectedValue="{Binding ResolverKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridCheckBoxColumn Header="直配IO" Binding="{Binding UseDirectPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70" Visibility="Collapsed"/>
                                    <DataGridTemplateColumn Header="OUT口" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="28"
                                                          ItemsSource="{Binding DataContext.ModelParam.AvailableOutputPorts, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          SelectedItem="{Binding DirectPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="输出点(兼容)" Width="140" Visibility="Collapsed">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="28"
                                                          ItemsSource="{Binding DataContext.ModelParam.OutputPointConfigs, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding TargetPointId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="有效电平" Width="110">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="28"
                                                          ItemsSource="{Binding DataContext.ModelParam.ActiveLevelOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Value"
                                                          SelectedValue="{Binding ActiveLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="复位" Width="105">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="28"
                                                          ItemsSource="{Binding DataContext.ModelParam.ResetPolicyOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          DisplayMemberPath="PolicyName"
                                                          SelectedValuePath="PolicyKey"
                                                          SelectedValue="{Binding ResetPolicyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridCheckBoxColumn Header="手动值" Binding="{Binding ManualValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" Visibility="Collapsed"/>
                                    <DataGridTemplateColumn Header="动作" Width="110" Visibility="Collapsed">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Height="28"
                                                          ItemsSource="{Binding DataContext.ModelParam.RuleActionOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          DisplayMemberPath="ActionName"
                                                          SelectedValuePath="ActionKey"
                                                          SelectedValue="{Binding ActionKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="优先级" Binding="{Binding Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80" Visibility="Collapsed"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </WxGroupBox:WxGroupBox>

                <WxGroupBox:WxGroupBox Header="OUT参数(兼容)" Margin="0,12,0,0" Visibility="Collapsed">
                    <Border Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <WrapPanel VerticalAlignment="Center">
                                    <CheckBox Content="启用输出" IsChecked="{Binding ModelParam.EnableOutput, Mode=TwoWay}" Margin="0,0,22,6"/>
                                </WrapPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                    <Button Content="添加点"
                                            Width="86"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="添加OUT点"/>
                                    <Button Content="删除点"
                                            Width="86"
                                            Margin="0,0,8,0"
                                            Height="30"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="删除OUT点"/>
                                    <Button Content="测试输出"
                                            Width="90"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="测试输出"/>
                                    <Button Content="全部复位"
                                            Width="90"
                                            Height="30"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}"
                                            CommandParameter="全部复位"/>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="2">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="320"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="OUT点表" FontWeight="SemiBold" Foreground="#334155" Margin="0,0,0,8"/>
                                    <DataGrid Grid.Row="1"
                                              ItemsSource="{Binding ModelParam.OutputPointConfigs}"
                                              SelectedItem="{Binding ModelParam.SelectedOutputPoint, Mode=TwoWay}"
                                              AutoGenerateColumns="False"
                                              HeadersVisibility="Column"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              CanUserResizeRows="False"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <DataGrid.Columns>
                                            <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                            <DataGridTextColumn Header="点名" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                            <DataGridTemplateColumn Header="职责分类" Width="170">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Height="28"
                                                                  ItemsSource="{Binding DataContext.ModelParam.OutputRoleOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  DisplayMemberPath="RoleName"
                                                                  SelectedValuePath="RoleKey"
                                                                  SelectedValue="{Binding RoleKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="OUT口" Width="130">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Height="28"
                                                                  ItemsSource="{Binding DataContext.ModelParam.AvailableOutputPorts, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  SelectedItem="{Binding Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="有效电平" Width="130">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Height="28"
                                                                  ItemsSource="{Binding DataContext.ModelParam.ActiveLevelOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  DisplayMemberPath="Name"
                                                                  SelectedValuePath="Value"
                                                                  SelectedValue="{Binding ActiveLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="复位策略" Width="130">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Height="28"
                                                                  ItemsSource="{Binding DataContext.ModelParam.ResetPolicyOptions, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                  DisplayMemberPath="PolicyName"
                                                                  SelectedValuePath="PolicyKey"
                                                                  SelectedValue="{Binding ResetPolicyKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridCheckBoxColumn Header="当前状态" Binding="{Binding CurrentState, Mode=OneWay}" IsReadOnly="True" Width="90"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock Grid.Row="2"
                                               Margin="0,10,0,0"
                                               Text="{Binding ModelParam.LastMessage}"
                                               Foreground="#334155"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </WxGroupBox:WxGroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="IO状态">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="读取正运动IN/OUT当前状态；选中OUT点后可手动置ON/OFF，IN点只读。"
                                   Foreground="#64748B"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="刷新IO"
                                    Width="86"
                                    Height="30"
                                    Margin="8,0,8,0"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Command="{Binding GeneralCommand}"
                                    CommandParameter="刷新IO状态"/>
                            <Button Content="OUT置ON"
                                    Width="90"
                                    Height="30"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Command="{Binding GeneralCommand}"
                                    CommandParameter="IO置ON"/>
                            <Button Content="OUT置OFF"
                                    Width="90"
                                    Height="30"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Command="{Binding GeneralCommand}"
                                    CommandParameter="IO置OFF"/>
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ModelParam.IoStatusItems}"
                              SelectedItem="{Binding ModelParam.SelectedIoStatusItem, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              IsReadOnly="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="方向" Binding="{Binding DirectionName}" Width="90"/>
                            <DataGridTextColumn Header="点位" Binding="{Binding Port}" Width="90"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                            <DataGridCheckBoxColumn Header="状态" Binding="{Binding State}" Width="90"/>
                            <DataGridCheckBoxColumn Header="读取成功" Binding="{Binding IsReadOk}" Width="100"/>
                            <DataGridTextColumn Header="刷新时间/状态" Binding="{Binding LastRefreshText}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2"
                               Margin="0,8,0,0"
                               Text="{Binding ModelParam.LastMessage}"
                               Foreground="#334155"
                               TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
            <TabItem Header="日志">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                        <Button Content="清空日志"
                                Width="88"
                                Height="30"
                                Style="{StaticResource GeneralButtonStyle}"
                                Command="{Binding GeneralCommand}"
                                CommandParameter="清空日志"/>
                    </StackPanel>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding ModelParam.LogMessages}"
                             BorderBrush="#E0E0E0"
                             BorderThickness="1"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#334155" TextWrapping="Wrap" Margin="6,3"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="1" Background="{DynamicResource TitleForegroundBrush}">
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                <Button Margin="0,0,15,0"
                        FontSize="18"
                        Command="{Binding GeneralCommand}"
                        Height="35"
                        Width="80"
                        Style="{StaticResource GeneralButtonStyle}"
                        Content="取消"
                        CommandParameter="取消"/>
                <Button Margin="0,0,15,0"
                        FontSize="18"
                        Command="{Binding GeneralCommand}"
                        Height="35"
                        Width="80"
                        Style="{StaticResource GeneralButtonStyle}"
                        Content="确认"
                        CommandParameter="确认"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

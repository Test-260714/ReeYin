<UserControl x:Class="HardWareTool.PLC.Views.PLCMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HardWareTool.PLC.Views"
             mc:Ignorable="d" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:plcModels="clr-namespace:ReeYin_V.Hardware.PLC.Models;assembly=ReeYin_V.Hardware.PLC"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:controlEx="clr-namespace:ReeYin_V.UI.ControlExtend;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             FontSize="14"
             Height="580" Width="780"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="580" d:DesignWidth="780">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>

            <WxGroupBox:WxGroupBox Header="设置地址和值" >
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0 0 0 5">
                        <TextBox Width="250" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="地址:" hc:InfoElement.TitleWidth="100" HorizontalContentAlignment="Center" Height="30" Style="{StaticResource TextBoxExtend}"
                                                         Text="{Binding ModelParam.Param.Addr,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" />

                        <ComboBox Width="250" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="数据类型:" hc:InfoElement.TitleWidth="100" Style="{StaticResource ComboBoxExtend}" BorderThickness="0 0 0 1" Foreground="Black"  HorizontalContentAlignment="Center" helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                    helper:ItemsControlHelper.EnumType="{x:Type plcModels:EnumParaInfoModelParaType}"
                                                    SelectedItem="{Binding ModelParam.Param.ParamType}">

                        </ComboBox>
                    </StackPanel>
                    <TextBlock Margin="0,0,0,0" Style="{StaticResource TextBlockTitle}" HorizontalAlignment="Left" FontSize="16">
                                                    <Run Text="读取到的值为："/>
                                                    <Run Text="{Binding ModelParam.SltPLCOrder.Value}"/>
                    </TextBlock>
                </StackPanel>
            </WxGroupBox:WxGroupBox>

            <WxGroupBox:WxGroupBox Header="判定" Grid.Row="1">
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0 0 0 5">

                        <TextBox Width="250" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="等待值为:" hc:InfoElement.TitleWidth="100" HorizontalContentAlignment="Center" Height="30" Style="{StaticResource TextBoxExtend}"
                                                         Text="{Binding ModelParam.Param.JudgeValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" />
                    </StackPanel>
                </StackPanel>

            </WxGroupBox:WxGroupBox>

            <WxGroupBox:WxGroupBox Header="操作" Grid.Row="3">

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Height="35" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    CommandParameter="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="确认"
                                                    CommandParameter="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </WxGroupBox:WxGroupBox>
        </Grid>
    </Grid>
</UserControl>

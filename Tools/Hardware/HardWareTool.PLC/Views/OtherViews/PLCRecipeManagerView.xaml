<UserControl x:Class="HardWareTool.PLC.Views.PLCRecipeManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HardWareTool.PLC.Views"
             mc:Ignorable="d" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:behaviors="clr-namespace:ReeYin_V.UI.Helper;assembly=ReeYin_V.UI"
             xmlns:plcModels="clr-namespace:ReeYin_V.Hardware.PLC.Models;assembly=ReeYin_V.Hardware.PLC"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:controlEx="clr-namespace:ReeYin_V.UI.ControlExtend;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             FontSize="24" Width="1000" Height="700"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        
        <WxGroupBox:WxGroupBox Grid.Row="0" Header="PLC配方列表" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid>
                <Popup x:Name="popup1" AllowsTransparency="True" IsHitTestVisible="False" Placement="RelativePoint" PlacementTarget="{Binding ElementName=dataGrid1}" >
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Text="释放移动到此位置..." Foreground="Black"/>
                </Popup>
                <DataGrid AutoGenerateColumns="False" x:Name="dg2" Style="{StaticResource DefaultDataGridStyle}"
                                  controlEx:DragDropRowBehavior.Enabled="True" controlEx:DragDropRowBehavior.PopupControl="{Binding ElementName=popup1}"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="False"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  behaviors:DataGridRowNumberBehavior.Enable="True"
                                  behaviors:DataGridRowNumberBehavior.Header="序号"
                                  behaviors:DataGridRowNumberBehavior.Width="55"
                                  behaviors:DataGridRowNumberBehavior.StartIndex="1"
                                  behaviors:DataGridRowNumberBehavior.Format="{}{0}"
                                  behaviors:DataGridRowNumberBehavior.Freeze="True"
                                  ItemsSource="{Binding ModelParam.Recipes,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                  SelectedItem="{Binding ModelParam.SltRecipe,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  FontSize="12" 
                                  RowHeaderWidth="0"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  IsReadOnly="False" CanUserAddRows="False" VerticalAlignment="Stretch" >
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDoubleClick">
                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="编辑配方参数"/>
                        </i:EventTrigger>
                        <i:EventTrigger EventName="SelectionChanged">
                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换配方"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                    <DataGrid.ContextMenu>
                        <ContextMenu IsEnabled="True">
                            <MenuItem Header="触发指令" Command="{Binding GeneralCommand}" CommandParameter="触发指令" />
                            <Separator/>
                             <!--分隔线--> 
                            <MenuItem Header="添加新项" Command="{Binding GeneralCommand}" CommandParameter="添加新项" />
                            <MenuItem Header="删除选中项" Command="{Binding GeneralCommand}" CommandParameter="删除选中项" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="操作方式" IsReadOnly="True" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox BorderThickness="0 0 0 1" Background="Transparent" Width="300" HorizontalContentAlignment="Center" IsReadOnly="True"
                                                         Text="{Binding OperationType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox BorderThickness="0 0 0 1" Background="Transparent" Width="300" HorizontalContentAlignment="Center"
                                                         Text="{Binding Describe,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="启用" IsReadOnly="true" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ToggleButton Style="{StaticResource ToggleButtonSwitch}" HorizontalAlignment="Center" IsEnabled="False"
                                                               IsChecked="{Binding IsUsing,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                    </ToggleButton>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </WxGroupBox:WxGroupBox>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" Background="{DynamicResource TitleForegroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Height="35" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    CommandParameter="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="确认"
                                                    CommandParameter="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <hc:DrawerContainer >
            <!--打开参数页面-->
            <hc:Drawer MaskCanClose="True" IsOpen="{Binding EditCustomParam,Mode=TwoWay}" Margin="10 10 10 10 ">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Closed">
                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="配方参数关闭"/>
                    </i:EventTrigger>
                    <i:EventTrigger EventName="Opened">
                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="配方参数打开"/>
                    </i:EventTrigger>
                </i:Interaction.Triggers>

                <Border Background="{DynamicResource RegionBrush}" Width="auto" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" Margin="10 10 10 10 ">
                    <Grid Margin="24,18,24,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Style="{StaticResource TextBlockTitle}" HorizontalAlignment="Center">
                                <Run Text="配方参数设置"/>
                            </TextBlock>
                            <TextBlock Margin="0,6,0,0" FontSize="13" Foreground="#666666" HorizontalAlignment="Center" Text="配置当前 PLC 配方写入参数"/>
                        </StackPanel>

                        <TabControl Grid.Row="2" Style="{DynamicResource TabControlStyle}" FontSize="16" VerticalAlignment="Top">
                            <TabItem Header="写单个地址" Style="{DynamicResource SingleTabItemStyle}" Width="120">
                                <Grid Margin="24,18,24,18">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <WxGroupBox:WxGroupBox Header="设置地址和值">
                                        <Grid Margin="18,14,18,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="14"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBox Grid.Row="0" Grid.Column="0" Height="34" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="地址:" hc:InfoElement.TitleWidth="90" HorizontalContentAlignment="Center" Style="{StaticResource TextBoxExtend}"
                                                     Text="{Binding ModelParam.SltRecipe.Addr,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" />

                                            <ComboBox Grid.Row="0" Grid.Column="2" Height="34" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="数据类型:" hc:InfoElement.TitleWidth="90" Style="{StaticResource ComboBoxExtend}" BorderThickness="0 0 0 1" Foreground="Black" HorizontalContentAlignment="Center" helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                      helper:ItemsControlHelper.EnumType="{x:Type plcModels:EnumParaInfoModelParaType}"
                                                      SelectedItem="{Binding ModelParam.SltRecipe.ParamType}">
                                            </ComboBox>

                                            <TextBox Grid.Row="2" Grid.Column="0" Height="34" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="写入值:" hc:InfoElement.TitleWidth="90" HorizontalContentAlignment="Center" Style="{StaticResource TextBoxExtend}"
                                                     Text="{Binding ModelParam.SltRecipe.Value,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" />
                                        </Grid>
                                    </WxGroupBox:WxGroupBox>

                                    <WxGroupBox:WxGroupBox Header="操作" Grid.Row="2" Margin="0,18,0,0">
                                        <DockPanel Margin="18,12,18,16" LastChildFill="False">
                                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="13" Foreground="#666666" Text="确认参数无误后，可手动执行当前配方操作。"/>
                                            <Button DockPanel.Dock="Right" Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Width="120" Height="36" Content="执行操作"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行操作" />
                                        </DockPanel>
                                    </WxGroupBox:WxGroupBox>
                                </Grid>
                            </TabItem>
                        </TabControl>
                        <!--<hc:PropertyGrid Grid.Row="1" Width="600" Height="600" SelectedObject="{Binding ModelParam.SltMovementLocus}" PreviewMouseWheel="PropertyGrid_PreviewMouseWheel" />-->
                    </Grid>
                </Border>
            </hc:Drawer>
        </hc:DrawerContainer>
    </Grid>
</UserControl>

<UserControl x:Class="HardWareTool.PLC.Views.AxisOperationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="400" d:DesignWidth="850">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 说明卡片 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="20 12" Margin="0 0 0 15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="轴操作" FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock Text=" — 调用PLC配置中的已有轴，写入目标位置并触发跑位" Foreground="#888888" VerticalAlignment="Center" FontSize="12" Margin="5 0 0 0"/>
            </StackPanel>
        </Border>

        <!-- 轴走位设置 -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6 6 0 0" Padding="12 8">
                    <TextBlock Text="已有轴走位配置" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                </Border>

                <Grid Grid.Row="1" Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PLC设备" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                        <ComboBox Style="{StaticResource ComboBoxExtend}"
                                  ItemsSource="{Binding PlcDevices}"
                                  SelectedItem="{Binding SelectedPlc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="Config.DisplayName"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="轴组" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                        <ComboBox Style="{StaticResource ComboBoxExtend}"
                                  ItemsSource="{Binding AxisGroups}"
                                  SelectedItem="{Binding SelectedAxisGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="GroupName"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom" Orientation="Horizontal">
                        <CheckBox Content="等待到位" VerticalAlignment="Center"
                                  IsChecked="{Binding ModelParam.SltPLCOrder.WaitMoveDone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="6">
                        <TextBlock Text="超时(ms)" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                        <hc:NumericUpDown Minimum="100" Maximum="600000" Increment="1000" Style="{StaticResource NumericUpDownExtend}"
                                          Value="{Binding ModelParam.SltPLCOrder.MoveTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <DataGrid Grid.Row="2" Margin="15 0 15 15"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          Style="{StaticResource DefaultDataGridStyle}"
                          ItemsSource="{Binding ModelParam.SltPLCOrder.AxisMoveItems, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="启用" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ToggleButton Style="{StaticResource ToggleButtonSwitch}"
                                                  HorizontalAlignment="Center"
                                                  IsChecked="{Binding IsUsing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="轴名称" Width="*" IsReadOnly="True" Binding="{Binding AxisName}"/>
                        <DataGridTextColumn Header="轴类型" Width="*" IsReadOnly="True" Binding="{Binding AxisType}"/>
                        <DataGridTemplateColumn Header="目标位置" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <hc:NumericUpDown Style="{StaticResource NumericUpDownExtend}" Increment="1"
                                                      Value="{Binding TargetPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="运行速度" ToolTip="填0或小于0时不写入PLC，使用PLC当前参数值"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <hc:NumericUpDown Style="{StaticResource NumericUpDownExtend}" Increment="1"
                                                      Value="{Binding RunSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="加速度" ToolTip="填0或小于0时不写入PLC，使用PLC当前参数值"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <hc:NumericUpDown Style="{StaticResource NumericUpDownExtend}" Increment="1"
                                                      Value="{Binding Acc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Width="*">
                            <DataGridTemplateColumn.Header>
                                <TextBlock Text="减速度" ToolTip="填0或小于0时不写入PLC，使用PLC当前参数值"/>
                            </DataGridTemplateColumn.Header>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <hc:NumericUpDown Style="{StaticResource NumericUpDownExtend}" Increment="1"
                                                      Value="{Binding Dec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 底部操作区 -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0 15 0 0">
            <Button Cursor="Hand" Style="{StaticResource GeneralButtonStyle}"
                    Height="36" Width="150" FontSize="12"
                    Background="White" BorderBrush="#CCCCCC" Foreground="#666666"
                    Command="{Binding OpenLineScanGenerateCommand}" Content="打开线扫生成"
                    Margin="0 0 10 0"/>
            <Button Cursor="Hand" Style="{StaticResource GeneralButtonStyle}"
                    Height="36" Width="150" FontSize="12"
                    Background="#4CAF50" BorderBrush="#4CAF50" Foreground="White"
                    Command="{Binding ExecuteCommand}" Content="执行轴走位"/>
        </StackPanel>
    </Grid>
</UserControl>

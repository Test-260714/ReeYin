<UserControl x:Class="HardWareTool.PLC.Views.LineScanGenerateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="720"
             MinWidth="720"
             d:DesignHeight="720" d:DesignWidth="980">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="20 12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="线扫轨迹生成" FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock Text=" — 自动生成开始采集/扫描/延时/停止采集/偏移指令" Foreground="#888888" VerticalAlignment="Center" FontSize="12" Margin="5 0 0 0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0 0 0 10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6 6 0 0" Padding="12 8">
                            <TextBlock Text="基础选择" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        </Border>

                        <Grid Grid.Row="1" Margin="15 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PLC设备" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <ComboBox Width="126" Style="{StaticResource ComboBoxExtend}"
                                          ItemsSource="{Binding PlcDevices}"
                                          SelectedItem="{Binding SelectedPlc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="Config.DisplayName"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="轴组" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <ComboBox Width="126" Style="{StaticResource ComboBoxExtend}"
                                          ItemsSource="{Binding AxisGroups}"
                                          SelectedItem="{Binding SelectedAxisGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="GroupName"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0 0 0 10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6 6 0 0" Padding="12 8">
                            <TextBlock Text="区域参数" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        </Border>

                        <Grid Grid.Row="1" Margin="15 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="左上角 X" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="126" Style="{StaticResource NumericUpDownExtend}" Increment="1"
                                                  Minimum="-1000000000" Maximum="1000000000"
                                                  Value="{Binding LineScan.LeftTopX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="左上角 Y" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="126" Style="{StaticResource NumericUpDownExtend}" Increment="1"
                                                  Minimum="-1000000000" Maximum="1000000000"
                                                  Value="{Binding LineScan.LeftTopY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="右下角 X" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="126" Style="{StaticResource NumericUpDownExtend}" Increment="1"
                                                  Minimum="-1000000000" Maximum="1000000000"
                                                  Value="{Binding LineScan.RightBottomX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="右下角 Y" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="126" Style="{StaticResource NumericUpDownExtend}" Increment="1"
                                                  Minimum="-1000000000" Maximum="1000000000"
                                                  Value="{Binding LineScan.RightBottomY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource GeneralButtonStyle}"
                                        Height="32" Width="130"
                                        Background="White" Foreground="#555555" BorderBrush="#CCCCCC"
                                        Content="取当前点为左上角"
                                        Command="{Binding ReadLeftTopCommand}"
                                        Margin="0 0 10 0"/>
                                <Button Style="{StaticResource GeneralButtonStyle}"
                                        Height="32" Width="130"
                                        Background="White" Foreground="#555555" BorderBrush="#CCCCCC"
                                        Content="取当前点为右下角"
                                        Command="{Binding ReadRightBottomCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0 0 0 10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6 6 0 0" Padding="12 8">
                            <TextBlock Text="扫描参数" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        </Border>

                        <Grid Grid.Row="1" Margin="15 12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="Y步距" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="146" Style="{StaticResource NumericUpDownExtend}" Minimum="0.001" Increment="1"
                                                  Value="{Binding LineScan.StepY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="扫描速度" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="146" Style="{StaticResource NumericUpDownExtend}" Minimum="0" Increment="1"
                                                  Value="{Binding LineScan.ScanSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0">
                                <TextBlock Text="偏移速度" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="146" Style="{StaticResource NumericUpDownExtend}" Minimum="0" Increment="1"
                                                  Value="{Binding LineScan.OffsetSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="超时(ms)" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="146" Style="{StaticResource NumericUpDownExtend}" Minimum="100" Maximum="600000" Increment="1000"
                                                  Value="{Binding LineScan.MoveTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="0">
                                <TextBlock Text="加速度" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="146" Style="{StaticResource NumericUpDownExtend}" Minimum="0" Increment="1"
                                                  Value="{Binding LineScan.Acc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.Column="2">
                                <TextBlock Text="减速度" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="146" Style="{StaticResource NumericUpDownExtend}" Minimum="0" Increment="1"
                                                  Value="{Binding LineScan.Dec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <CheckBox Grid.Row="6" Grid.ColumnSpan="3"
                                      Content="轴操作等待到位"
                                      IsChecked="{Binding LineScan.WaitMoveDone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Margin="0 0 0 10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6 6 0 0" Padding="12 8">
                            <TextBlock Text="采集流程参数" Foreground="White" FontWeight="SemiBold" FontSize="13"/>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="15 12">
                            <StackPanel Margin="0 0 0 10">
                                <TextBlock Text="开始采集事件名" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <TextBox Width="260" Height="30" Text="{Binding LineScan.StartCollectEventName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Margin="0 0 0 10">
                                <TextBlock Text="停止采集事件名" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <TextBox Width="260" Height="30" Text="{Binding LineScan.StopCollectEventName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Margin="0 0 0 10">
                                <TextBlock Text="定位/偏移后延时(ms)" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="146" Style="{StaticResource NumericUpDownExtend}" Minimum="0" Maximum="600000" Increment="100"
                                                  Value="{Binding LineScan.OffsetStableDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="停止采集前延时(ms)" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                                <hc:NumericUpDown Width="146" Style="{StaticResource NumericUpDownExtend}" Minimum="0" Maximum="600000" Increment="100"
                                                  Value="{Binding LineScan.StopCollectDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="15 12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Foreground="#555555" FontWeight="Medium" VerticalAlignment="Center"
                                   Text="预估扫描行数："/>
                        <TextBlock Grid.Column="1" Foreground="#555555" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Text="{Binding LineScan.PreviewLineCount, StringFormat={}{0:N0}}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="3" Foreground="#555555" FontWeight="Medium" VerticalAlignment="Center"
                                   Text="预估生成指令数："/>
                        <TextBlock Grid.Column="4" Foreground="#555555" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Text="{Binding LineScan.PreviewOrderCount, StringFormat={}{0:N0}}"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0 15 0 0">
            <Button Style="{StaticResource GeneralButtonStyle}"
                    Height="36" Width="120"
                    Background="White" Foreground="#666666" BorderBrush="#CCCCCC"
                    Content="取消"
                    Command="{Binding CancelCommand}"
                    Margin="0 0 10 0"/>
            <Button Style="{StaticResource GeneralButtonStyle}"
                    Height="36" Width="140"
                    Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                    Content="追加到指令列表"
                    Command="{Binding AppendCommand}"
                    Margin="0 0 10 0"/>
            <Button Style="{StaticResource GeneralButtonStyle}"
                    Height="36" Width="140"
                    Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                    Content="替换当前指令列表"
                    Command="{Binding ReplaceCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>

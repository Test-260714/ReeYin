<UserControl x:Class="HardWareTool.PLC.Views.WriteSingleAddrView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:plcModels="clr-namespace:ReeYin_V.Hardware.PLC.Models;assembly=ReeYin_V.Hardware.PLC"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="400" d:DesignWidth="850">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 说明卡片 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="20 12" Margin="0 0 0 15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="写单地址" FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center" FontSize="14"/>
                <TextBlock Text=" — 向指定PLC地址写入数据值" Foreground="#888888" VerticalAlignment="Center" FontSize="12" Margin="5 0 0 0"/>
            </StackPanel>
        </Border>

        <!-- 设置卡片 -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6 6 0 0" Padding="12 8">
                    <TextBlock Text="地址与数值设置" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                </Border>

                <Grid Grid.Row="1" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0 0 0 15">
                        <TextBlock Text="目标地址" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                        <TextBox Style="{StaticResource TextBoxExtend}"
                                 Text="{Binding ModelParam.SltPLCOrder.Addr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0 0 0 15">
                        <TextBlock Text="数据类型" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                        <ComboBox Style="{StaticResource ComboBoxExtend}" BorderThickness="0,0,0,1"
                                  helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                  helper:ItemsControlHelper.EnumType="{x:Type plcModels:EnumParaInfoModelParaType}"
                                  SelectedItem="{Binding ModelParam.SltPLCOrder.ParamType}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3">
                        <TextBlock Text="写入值" Foreground="#555555" FontWeight="Medium" Margin="0 0 0 5"/>
                        <TextBox Style="{StaticResource TextBoxExtend}"
                                 Text="{Binding ModelParam.SltPLCOrder.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="链接值:" Foreground="#555555" VerticalAlignment="Center" Margin="0 0 0 0" />
                            <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="400" InputParams="{Binding ModelParam.InputParams,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                                             OutputParam="{Binding ModelParam.SltPLCOrder.LinkValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 15" Text="{Binding ModelParam.SltPLCOrder.LinkValue.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>

                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- 底部操作区 -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0 15 0 0">
            <Button Cursor="Hand" Style="{StaticResource GeneralButtonStyle}"
                    Height="36" Width="110" FontSize="12"
                    Background="#4CAF50" BorderBrush="#4CAF50" Foreground="White"
                    Command="{Binding ExecuteCommand}" Content="执行操作"/>
        </StackPanel>
    </Grid>
</UserControl>

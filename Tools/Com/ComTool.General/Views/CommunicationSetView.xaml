<UserControl x:Class="ComTool.General.Views.CommunicationSetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:enum="clr-namespace:ReeYin_V.Core.Enums;assembly=ReeYin_V.Core"
             xmlns:local="clr-namespace:ComTool.General.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="800" Width="1200"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid Margin="0 1">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid x:Name="gd">
                <Border x:Name="bd">
                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="通讯列表>>" Height="{Binding ElementName=bd,Path=ActualHeight}"
                              Width="{Binding ElementName=bd,Path=ActualWidth}"
                              VerticalAlignment="Top" HorizontalAlignment="Left" Margin="2 0 0 0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="AUTO"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="通讯类型:" VerticalAlignment="Center"/>
                                <ComboBox Width="130" Height="25" BorderThickness="0 0 0 1" Margin="5 0" SelectedIndex="0" Foreground="Black" Background="White"
                                          ItemsSource="{Binding CommunicationTypes}" SelectedItem="{Binding CommunicationType}"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                         Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                                                 ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                             Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                                                 ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" x:Name="dg" Style="{StaticResource DefaultDataGridStyle}"
                                                  EnableColumnVirtualization="True"
                                                  EnableRowVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  ItemsSource="{Binding ModelParam.CommunicationModels}" 
                                                  SelectedItem="{Binding CurrentCommunication}"
                                                  SelectedIndex="{Binding Communication_SelectedIndex}"
                                                  FontSize="12" 
                                                  RowHeaderWidth="20"
                                                  SelectionUnit="FullRow"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="All"
                                                  IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="通讯名称" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Key}" HorizontalAlignment="Left" BorderThickness="0" Foreground="Black" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Remarks,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="连接/断开" IsReadOnly="True" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ToggleButton Style="{StaticResource ToggleButtonSwitch}"
                                                    IsChecked="{Binding IsConnected,Mode=OneWay}" Command="{Binding ConnectCommand}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </WxGroupBox:WxGroupBox>
                </Border>
            </Grid>
            <GridSplitter Grid.Column="1"/>
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <WxGroupBox:WxGroupBox BorderThickness="0 0 0 0" Header="调试>>">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding CurrentCommunication.Key}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="Lime"/>
                        <Grid Grid.Row="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="AUTO"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="AUTO"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="发送数据" VerticalAlignment="Center" FontSize="25"/>
                                    <CheckBox Content="16进制发送" Margin="10 0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                              IsChecked="{Binding CurrentCommunication.IsSendByHex}"/>
                                </StackPanel>
                                <Border Grid.Row="1" x:Name="bd1">
                                    <TextBox Grid.Row="1" 
                                             Text="{Binding CurrentCommunication.SendText}" HorizontalContentAlignment="Left" VerticalContentAlignment="Top"
                                             TextWrapping="Wrap"
                                             BorderThickness="1" HorizontalAlignment="Stretch" 
                                             Height="{Binding ElementName=bd1,Path=ActualHeight}"/>
                                </Border>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Button Content="发送" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding CurrentCommunication.SendCommand}"/>
                                    <Button Content="清空" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding CurrentCommunication.ClearSendTextCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                        <Grid Grid.Row="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="AUTO"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="AUTO"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="接收数据" VerticalAlignment="Center" FontSize="25"/>
                                    <CheckBox Content="16进制发送" Margin="10 0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                              IsChecked="{Binding CurrentCommunication.IsReceivedByHex}"/>
                                </StackPanel>
                                <Border Grid.Row="1" x:Name="bd2">
                                    <TextBox Grid.Row="1" HorizontalContentAlignment="Left" VerticalContentAlignment="Top" IsReadOnly="True"
                                             Text="{Binding CurrentCommunication.ReceiveText}" 
                                             BorderThickness="1" HorizontalAlignment="Stretch" 
                                             Height="{Binding ElementName=bd2,Path=ActualHeight}"/>
                                </Border>
                                <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Button Content="清空" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding CurrentCommunication.ClearReceiveTextCommand}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </WxGroupBox:WxGroupBox>
                <WxGroupBox:WxGroupBox Grid.Row="1" BorderThickness="0 5 0 0" Header="参数设定>>">
                    <Grid>
                        <Grid.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Width" Value="80"/>
                            </Style>
                        </Grid.Resources>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Visibility="{Binding CurrentCommunication.CommunicationType,Converter={StaticResource EnumToVisibilityConverter},ConverterParameter={x:Static enum:eCommunicationType.TCP服务器}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="本地端口:"/>
                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="180" Margin="5 0" SmallChange="1" BorderThickness="0 0 0 1"
                                 Value="{Binding CurrentCommunication.LocalPort}"/>

                            </StackPanel>
                        </StackPanel>
                        <StackPanel Visibility="{Binding CurrentCommunication.CommunicationType,Converter={StaticResource EnumToVisibilityConverter},ConverterParameter={x:Static enum:eCommunicationType.TCP客户端}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="目标IP:"/>
                                <TextBox Text="{Binding CurrentCommunication.RemoteIP}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="目标端口:"/>
                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="180" Margin="5 0" SmallChange="1" BorderThickness="0 0 0 1"
                                    Value="{Binding CurrentCommunication.RemotePort}"/>

                            </StackPanel>
                        </StackPanel>
                        <StackPanel Visibility="{Binding CurrentCommunication.CommunicationType,Converter={StaticResource EnumToVisibilityConverter},ConverterParameter={x:Static enum:eCommunicationType.UDP通讯}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="本地端口:"/>
                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="180" Margin="5 0" SmallChange="1" BorderThickness="0 0 0 1"
                                    Value="{Binding CurrentCommunication.LocalPort}"/>

                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="目标IP:"/>
                                <TextBox Text="{Binding CurrentCommunication.RemoteIP}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="目标端口:"/>
                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="180" Margin="5 0" SmallChange="1" BorderThickness="0 0 0 1"
                                    Value="{Binding CurrentCommunication.RemotePort}"/>
                                <!--<mah:NumericUpDown Value="{Binding CurrentCommunication.RemotePort}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"/>-->
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Visibility="{Binding CurrentCommunication.CommunicationType,Converter={StaticResource EnumToVisibilityConverter},ConverterParameter={x:Static enum:eCommunicationType.串口通讯}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="串口号:"/>
                                <ComboBox ItemsSource="{Binding CurrentCommunication.PortNames}" SelectedItem="{Binding CurrentCommunication.PortName}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="波特率:"/>
                                <ComboBox ItemsSource="{Binding CurrentCommunication.BaudRates}" SelectedItem="{Binding CurrentCommunication.BaudRate}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="校验位:"/>
                                <ComboBox ItemsSource="{Binding CurrentCommunication.Paritys}" SelectedItem="{Binding CurrentCommunication.Parity}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="数据位:"/>
                                <ComboBox ItemsSource="{Binding CurrentCommunication.DataBitsList}" SelectedItem="{Binding CurrentCommunication.DataBits}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="停止位:"/>
                                <ComboBox ItemsSource="{Binding CurrentCommunication.StopBitsList}" SelectedItem="{Binding CurrentCommunication.StopBits}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"/>
                            </StackPanel>

                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="备注:"/>
                                <TextBox Text="{Binding CurrentCommunication.Remarks,UpdateSourceTrigger=PropertyChanged}" Width="120" Margin="5 0" BorderThickness="0 0 0 1"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </WxGroupBox:WxGroupBox>
            </Grid>
        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" Background="{DynamicResource TitleForegroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock
                                                Margin="10,0,0,0"
                                                HorizontalAlignment="Left"
                                                FontSize="14">
                                                    <!--<Run Text="耗时:"/>
                                                    <Run Text="{Binding ModuleParam.ElapsedTime}"/>
                                                    <Run Text="ms"/>-->
                    </TextBlock>
                    <TextBlock
                                                Margin="10,0,0,0"
                                                HorizontalAlignment="Left"
                                                FontSize="14" >
                                                    <!--<Run Text="执行状态:"/>
                                                    <Run Text="{Binding ModuleParam.Status}"/>-->
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                    Height="35" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>

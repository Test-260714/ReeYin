<Window x:Class="FileTool.BRJReportOutput.Views.BrjDiameterGroupSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="直径分组参数"
        Width="760"
        Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F5F6F8">
    <Window.Resources>
        <SolidColorBrush x:Key="DialogAccentBrush" Color="#C39200"/>
        <SolidColorBrush x:Key="DialogBorderBrush" Color="#D8D8D8"/>
        <Style x:Key="DialogButtonStyle" TargetType="Button" BasedOn="{StaticResource GeneralButtonStyle}">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="{StaticResource DialogAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource DialogBorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,8">
            <TextBlock Text="设置导出报表的缺陷直径统计区间。最大直径留空表示无上限。" FontSize="14"/>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource DialogBorderBrush}" BorderThickness="1">
            <DataGrid ItemsSource="{Binding Settings}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="True"
                      CanUserDeleteRows="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="排序" Binding="{Binding SortIndex}" Width="70"/>
                    <DataGridTextColumn Header="最小直径/mm" Binding="{Binding MinDiameterMm}" Width="120"/>
                    <DataGridTextColumn Header="最大直径/mm" Binding="{Binding MaxDiameterMm}" Width="120"/>
                    <DataGridTextColumn Header="颜色" Binding="{Binding ColorHex}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="恢复默认" Click="ResetButton_Click" Style="{StaticResource DialogButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="保存" Click="SaveButton_Click" Style="{StaticResource DialogButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="取消" IsCancel="True" Style="{StaticResource DialogButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>

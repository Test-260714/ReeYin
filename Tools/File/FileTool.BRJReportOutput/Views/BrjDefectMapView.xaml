<UserControl x:Class="FileTool.BRJReportOutput.Views.BrjDefectMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="680"
             Background="Transparent">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="20"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="ChartHost"
              Grid.Column="0"
              Background="Transparent"/>

        <ScrollBar x:Name="ViewportScrollBar"
                   Grid.Column="1"
                   Width="12"
                   Margin="3,2,0,2"
                   HorizontalAlignment="Center"
                   Minimum="0"
                   Orientation="Vertical"
                   ToolTip="可拖动滚动条，也可滚动鼠标滚轮查看当前批次缺陷"
                   ValueChanged="OnViewportScrollBarValueChanged"/>

        <TextBlock Grid.Column="2"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center"
                   Text="累计米数 (m)"
                   Foreground="#475569"
                   FontSize="10">
            <TextBlock.LayoutTransform>
                <RotateTransform Angle="90"/>
            </TextBlock.LayoutTransform>
        </TextBlock>

        <TextBlock x:Name="EmptyChartHint"
                   Grid.ColumnSpan="3"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Padding="14,8"
                   Background="#EAF0F6"
                   Foreground="#475569"
                   FontSize="12"
                   Text="当前批次暂无缺陷点"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>

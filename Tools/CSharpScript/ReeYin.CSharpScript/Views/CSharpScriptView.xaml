<UserControl x:Class="ReeYin.CSharpScript.Views.CSharpScriptView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin.CSharpScript.Views"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/" FontSize="14"
             Loaded="UserControl_Loaded"
             mc:Ignorable="d" Height="920" Width="1400"
             d:DesignHeight="920" d:DesignWidth="1400"
             Background="#F8FAFC">
    <UserControl.Resources>
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#6B7280"/>
        <SolidColorBrush x:Key="TitleTextBrush" Color="#374151"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D6A126"/>
        <SolidColorBrush x:Key="EditorBorderBrush" Color="#D1D5DB"/>

        <Style x:Key="PanelSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>

        <Style x:Key="SectionHintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PanelContainerBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>

        <Style x:Key="ReadonlyGridTextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0 0 0 1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="2"/>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GeneralButtonStyle}">
            <Setter Property="Width" Value="88"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="190" MinHeight="150"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.68*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="0.32*"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Margin="2,0,0,8"
                        Padding="12,10"
                        Background="#FFF7E6"
                        BorderBrush="#E3B341"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="编写提示" FontWeight="SemiBold" Foreground="#8A5A00"/>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap"
                                       Text="Ctrl+Space 可查看脚本 API、常用片段和当前参数补全；输入 pub/prop 后按 Tab 可直接展开；输入 Console./Math. 可查看常用成员；双击右侧变量可直接插入到当前光标位置。"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Margin="12,0,0,0"
                                Padding="10,6"
                                Background="#1F2937"
                                CornerRadius="6"
                                VerticalAlignment="Center">
                            <TextBlock Text="C# Script"
                                       Foreground="White"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>
                </Border>

                <WxGroupBox:WxGroupBox Grid.Row="1" Grid.Column="0" BorderThickness="0 5 0 0" Header="脚本编辑器" VerticalAlignment="Top" Margin="2 0 0 0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="12,8,12,6" LastChildFill="False">
                            <TextBlock DockPanel.Dock="Left"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TitleTextBrush}"
                                       Text="支持实时语法检查和轻量补全"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Style="{StaticResource SectionHintTextStyle}"
                                       Text="快捷键: Ctrl+Space / Tab"/>
                        </DockPanel>

                        <Border Grid.Row="1"
                                Margin="8,0,8,8"
                                Style="{StaticResource PanelContainerBorderStyle}"
                                BorderBrush="{StaticResource EditorBorderBrush}">
                            <avalonEdit:TextEditor
                                x:Name="ScriptEditor"
                                FontFamily="Consolas"
                                FontSize="14"
                                Padding="8"
                                Background="#FCFCFD"
                                LostFocus="ScriptEditor_LostFocus"
                                ShowLineNumbers="True"
                                SyntaxHighlighting="C#"
                                WordWrap="False"/>
                        </Border>
                    </Grid>
                </WxGroupBox:WxGroupBox>
            </Grid>

            <GridSplitter Grid.Column="1" Width="4" VerticalAlignment="Stretch" Style="{StaticResource PanelSplitterStyle}"/>
            
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.42*"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="0.58*"/>
                </Grid.RowDefinitions>
                <WxGroupBox:WxGroupBox Header="输出信息（双击插入 UploadOutput）" Grid.Row="0" Margin="5,5,6,5">
                    <ListBox Grid.Row="2"
         Name="OutputParams" Style="{StaticResource DataGridListBoxStyle}"
         ItemsSource="{Binding ModelParam.OutputParams, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
         SelectedItem="{Binding ModelParam.SltOutputParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
         FontSize="12"
         Background="Transparent"
         BorderThickness="0"
         AlternationCount="100000"
         MouseDoubleClick="OutputParams_MouseDoubleClick"
         ScrollViewer.VerticalScrollBarVisibility="Auto"
         VirtualizingPanel.IsVirtualizing="True"
         VirtualizingPanel.VirtualizationMode="Recycling">

                        <!-- 虚拟化 -->
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <!-- 右键菜单 -->
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="添加新项"
                      Command="{Binding GeneralCommand}"
                      CommandParameter="输出添加新项"/>
                                <MenuItem Header="删除选中项"
                      Command="{Binding GeneralCommand}"
                      CommandParameter="输出删除选中项"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <!-- 每一行内容 -->
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 名称 -->
                                    <TextBox Grid.Column="0" Background="Transparent" BorderThickness="0 0 0 1"
                         Width="120" HorizontalContentAlignment="Center"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <!-- 数据类型 -->
                                    <ComboBox Grid.Column="1"
                          Width="130"
                          Height="25"
                          Margin="5,0"
                          Background="Transparent"
                          BorderThickness="0,0,0,2"
                          HorizontalContentAlignment="Center"
                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                          SelectedItem="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <!-- 值 -->
                                    <TextBlock Grid.Column="2"
                           Width="100"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="{Binding Value}"/>

                                    <!-- 全局 -->
                                    <ToggleButton Grid.Column="3"
                              Style="{StaticResource ToggleButtonSwitch}"
                              IsChecked="{Binding IsGlobal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </WxGroupBox:WxGroupBox>
                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch" Style="{StaticResource PanelSplitterStyle}"/>
                <WxGroupBox:WxGroupBox Header="双击插入选中变量" Grid.Row="2">
                    <TabControl TabStripPlacement="Top" Style="{StaticResource TabControlCapsuleSolid}" Background="Transparent">
                        <TabItem Header="上一节点输入">
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Background="Transparent" BorderThickness="0" Name="LastNodeInput"
                                    EnableColumnVirtualization="True" Style="{StaticResource DefaultDataGridStyle}"
                                    EnableRowVirtualization="True"
                                    VirtualizingPanel.IsVirtualizing="True"
                                    ItemsSource="{Binding ModelParam.InputParams,Mode=TwoWay}" SelectedItem="{Binding ModelParam.SltInputParam,Mode=TwoWay}"
                                    FontSize="12"
                                    RowHeaderWidth="20"
                                    SelectionUnit="FullRow"
                                    HeadersVisibility="Column"
                                    GridLinesVisibility="All"
                                    MouseDoubleClick="DataGrid_LastInputMouseDoubleClick"
                                    IsReadOnly="True" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="归属" IsReadOnly="True" Width="100" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                                                <Run Text="{Binding Serial}"/>
                                                <Run Text="-"/>
                                                <Run Text="{Binding ParentNode}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="名称" IsReadOnly="True" Width="100" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}"
                                                          Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="值" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}"
                                                          Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="类型" IsReadOnly="True" Width="150" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}" Width="100"
                                                         Text="{Binding Type,UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="描述" IsReadOnly="True" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}" Width="100"
                                                         Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="全局变量">
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Background="Transparent" Style="{StaticResource DefaultDataGridStyle}"
                                  EnableColumnVirtualization="True" x:Name="GlobalParam"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ItemsSource="{Binding ModelParam.GlobalParams,Mode=TwoWay}" SelectedItem="{Binding ModelParam.SltInputParam,Mode=TwoWay}"
                                  FontSize="12" 
                                  RowHeaderWidth="20"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  MouseDoubleClick="GlobalParam_MouseDoubleClick"
                                  IsReadOnly="True" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="归属" IsReadOnly="True" Width="100" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                                                <Run Text="{Binding Serial}"/>
                                                <Run Text="-"/>
                                                <Run Text="{Binding ParentNode}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="名称" IsReadOnly="True" Width="100" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}"
                          Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="值" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}"
                          Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="类型" IsReadOnly="True" Width="150" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}" Width="100"
                         Text="{Binding Type,UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="描述" IsReadOnly="True" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}" Width="100"
                         Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="自定义全局变量" >
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Background="Transparent" Style="{StaticResource DefaultDataGridStyle}"
                  EnableColumnVirtualization="True" x:Name="CustomGlobal"
                  EnableRowVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  ItemsSource="{Binding ModelParam.CustomGlobalParams,Mode=TwoWay}" SelectedItem="{Binding ModelParam.SltInputParam,Mode=TwoWay}"
                  FontSize="12" 
                  RowHeaderWidth="20"
                  SelectionUnit="FullRow"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  MouseDoubleClick="CustomGlobal_MouseDoubleClick"
                  IsReadOnly="True" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="归属" IsReadOnly="True" Width="100" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                                                <Run Text="{Binding Serial}"/>
                                                <Run Text="-"/>
                                                <Run Text="{Binding ParentNode}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="名称" IsReadOnly="True" Width="100" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}"
                          Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="值" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}"
                          Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="类型" IsReadOnly="True" Width="150" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}" Width="100"
                         Text="{Binding Type,UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="描述" IsReadOnly="True" Width="60">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ReadonlyGridTextBoxStyle}" Width="100"
                         Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>
                </WxGroupBox:WxGroupBox>
            </Grid>
        </Grid>

        <GridSplitter Grid.Row="1"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      Style="{StaticResource PanelSplitterStyle}"/>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="10,8,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0" LastChildFill="True">
                    <Border Background="{Binding ModelParam.CompileStatusBrush}"
                            Padding="10,4"
                            CornerRadius="0"
                            DockPanel.Dock="Left">
                        <TextBlock Text="{Binding ModelParam.CompileStatusText}"
                                   Foreground="White"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock Margin="12,0,0,0"
                               Style="{StaticResource SectionHintTextStyle}"
                               Text="实时语法检查与正式编译结果都会显示在这里，方便连续修改脚本。"/>
                </DockPanel>
            </Grid>

            <Popup x:Name="ManagedDllPopup"
                   Grid.Row="0"
                   AllowsTransparency="True"
                   DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                   HorizontalOffset="-300"
                   Placement="Bottom"
                   PlacementTarget="{Binding ElementName=ManagedDllButton}"
                   PopupAnimation="Fade"
                   StaysOpen="False"
                   VerticalOffset="6">
                <Border Width="420"
                        MaxHeight="460"
                        Background="#F8FAFC"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Background="#1F2937" MinHeight="38">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Margin="12,0"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="被加载的 DLL"/>

                            <Button Grid.Column="1"
                                    Margin="0,5,8,5"
                                    MinWidth="52"
                                    Padding="8,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="White"
                                    Content="关闭"
                                    Click="CloseManagedDllPopupButton_Click"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="12" >
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Padding="8"
                                    Style="{StaticResource PanelContainerBorderStyle}"
                                    Margin="0,0,0,10">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <hc:TagContainer ItemsSource="{Binding ModelParam.ManagedDllNames}"
                                                     HorizontalAlignment="Stretch"
                                                     VerticalAlignment="Top"
                                                     MaxHeight="140"/>
                                </ScrollViewer>

                            </Border>

                            <StackPanel Grid.Row="1" Orientation="Horizontal">
                                <TextBox Text="{Binding NewDll}"
                                         Style="{StaticResource TextBoxExtend}"
                                         Height="40" hc:TitleElement.TitlePlacement="Left"
                                         Margin="10,0,10,2" MinWidth="180"
                                         hc:TitleElement.Title="名称："/>
                                <Button Content="添加 DLL"
                                        HorizontalAlignment="Right"
                                        Style="{StaticResource PrimaryActionButtonStyle}"
                                        Command="{Binding GeneralCommand}"
                                        CommandParameter="添加DLL"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Popup>

            <Border Grid.Row="2"
                    Margin="10,0,10,8"
                    Style="{StaticResource PanelContainerBorderStyle}"
                    Background="#111827"
                    BorderBrush="#1F2937">
                <TextBox Text="{Binding ModelParam.CompileOutput,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="Transparent"
                         Foreground="#E5E7EB"
                         BorderThickness="0"
                         Padding="12"
                         FontSize="13"
                         FontFamily="Consolas"/>
            </Border>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                </TextBlock>
                <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="ManagedDllButton"
                        Grid.Column="1"
                        Content="被加载 DLL"
                        Margin="0,0,10,0"
                        Width="120"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        ToolTip="查看和添加已加载的 DLL"
                        Click="ManagedDllButton_Click"/>

                <Button Content="运行" Click="RunScript_Click" Style="{StaticResource PrimaryActionButtonStyle}" IsEnabled="{Binding ModelParam.IsEnableRun,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                    Command="{Binding GeneralCommand}" CommandParameter="执行"/>

                <Button Content="编译" Click="RunScript_Click" Style="{StaticResource PrimaryActionButtonStyle}"
                    Command="{Binding GeneralCommand}" CommandParameter="编译"/>

                <Button Content="取消" Style="{StaticResource PrimaryActionButtonStyle}"
                    Command="{Binding GeneralCommand}" CommandParameter="取消"/>

                <Button Content="确定" Margin="0" Style="{StaticResource PrimaryActionButtonStyle}"
                    Command="{Binding GeneralCommand}" CommandParameter="确认"/>
            </StackPanel>
        </Grid>


    </Grid>
</UserControl>

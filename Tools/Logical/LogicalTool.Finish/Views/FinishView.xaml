<UserControl x:Class="LogicalTool.Finish.Views.FinishView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LogicalTool.Finish.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="640" Width="440"
             prism:ViewModelLocator.AutoWireViewModel="True" 
             d:DesignHeight="640" d:DesignWidth="440">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
        <!--<i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding ConfirmCommand}"/>
        </i:EventTrigger>-->
    </i:Interaction.Triggers>
    <Grid>
            
    </Grid>
</UserControl>

<UserControl x:Class="LogicalTool.Conditional.Views.ConditionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LogicalTool.Conditional.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:behaviors="clr-namespace:ReeYin_V.UI.Helper;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="800" Width="1200"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="900" d:DesignWidth="1400">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
        <!--<i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding ConfirmCommand}"/>
        </i:EventTrigger>-->
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0 0 0 1" Padding="15 12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 标题区域 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="条件列表" FontSize="18" FontWeight="SemiBold" Foreground="#222222"/>
                    <TextBlock Text="/" Margin="10 0" Foreground="#CCCCCC" FontSize="16"/>
                    <TextBlock Text="条件设置" FontSize="16" Foreground="#666666"/>
                </StackPanel>

                <!-- 操作按钮区域 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="操作：" VerticalAlignment="Center" Margin="0 0 10 0" Foreground="#666666" FontWeight="Medium"/>
                    <Button Content="&#xe630;" Width="36" Height="32" FontSize="16"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="#4CAF50"
                            Foreground="White"
                            FontFamily="{StaticResource Iconfont}"
                            BorderBrush="#4CAF50"
                            ToolTip="添加条件"
                            Command="{Binding DataOperateCommand}"
                            CommandParameter="Add"
                            Margin="0 0 8 0"/>
                    <Button Content="&#xe74b;" Width="36" Height="32" FontSize="16"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="#F44336"
                            Foreground="White"
                            FontFamily="{StaticResource Iconfont}"
                            BorderBrush="#F44336"
                            ToolTip="删除条件"
                            Command="{Binding DataOperateCommand}"
                            CommandParameter="Delete"
                            Margin="0 0 8 0"/>
                    <Button Content="&#xe621;" Width="36" Height="32" FontSize="16"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="#2196F3"
                            Foreground="White"
                            FontFamily="{StaticResource Iconfont}"
                            BorderBrush="#2196F3"
                            ToolTip="修改条件"
                            Command="{Binding DataOperateCommand}"
                            CommandParameter="Modify"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.25*" MinWidth="300"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="0.75*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：条件列表 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 条件列表 DataGrid -->
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                    <DataGrid AutoGenerateColumns="False"
                              x:Name="dg"
                              Style="{StaticResource DefaultDataGridStyle}"
                              EnableColumnVirtualization="True"
                              EnableRowVirtualization="False"
                              behaviors:DataGridRowNumberBehavior.Enable="True"
                              behaviors:DataGridRowNumberBehavior.Header="序号"
                              behaviors:DataGridRowNumberBehavior.Width="60"
                              behaviors:DataGridRowNumberBehavior.StartIndex="1"
                              behaviors:DataGridRowNumberBehavior.Format="{}{0}"
                              behaviors:DataGridRowNumberBehavior.Freeze="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              ItemsSource="{Binding ModelParam.AllJudgeCodition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedItem="{Binding ModelParam.SltJudgeCodition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              FontSize="12"
                              RowHeaderWidth="0"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                <i:InvokeCommandAction Command="{Binding SelectedCellsChanged}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="变量" IsReadOnly="True" Width="*" MinWidth="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <WxLink:WxLink Width="Auto"
                                                       Margin="5 0"
                                                       InputParams="{Binding ModelParam.InputParams, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                       OutputParam="{Binding Variable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       Order="OpenParam"
                                                       Text="{Binding Variable.Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="启用" IsReadOnly="True" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource ToggleButtonSwitch}"
                                                      IsChecked="{Binding IsUsing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"
                                                      Command="{Binding DataContext.DataOperateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="使能"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- 左侧输出信息（可选） -->
                <Expander Grid.Row="1"
                          MaxHeight="200"
                          Margin="0 10 0 0"
                          Header="输出预览"
                          ExpandDirection="Down"
                          IsExpanded="False"
                          Style="{DynamicResource ExpanderStyle}">
                    <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0 5 0 0">
                        <TextBlock Text="选择条件后，输出信息将显示在右侧" Foreground="#888888" FontSize="11"/>
                    </Border>
                </Expander>
            </Grid>

            <!-- 分隔符 -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          Background="#E0E0E0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Cursor="SizeWE"/>

            <!-- 右侧：条件详情和输出 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 条件详情区域（动态内容） -->
                <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                    <ContentControl prism:RegionManager.RegionName="ConditionRegion"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"/>
                </Border>

                <!-- 输出信息 -->
                <Expander Grid.Row="1"
                          MaxHeight="250"
                          Margin="0 10 0 0"
                          Header="输出参数"
                          ExpandDirection="Down"
                          IsExpanded="True"
                          Style="{DynamicResource ExpanderStyle}">
                    <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0 5 0 0">
                        <DataGrid AutoGenerateColumns="False"
                                  Style="{StaticResource DefaultDataGridStyle}"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ItemsSource="{Binding ModelParam.OutputParams}"
                                  SelectedItem="{Binding CurrentOutputParam}"
                                  FontSize="12"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Height="200"
                                  RowHeaderWidth="0"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  IsReadOnly="False"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*" MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                     HorizontalAlignment="Stretch"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Padding="5 0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Width="110"
                                                      helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                      Height="28"
                                                      BorderThickness="0"
                                                      Margin="5 2"
                                                      Background="Transparent"
                                                      SelectedItem="{Binding Type}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*" MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     HorizontalAlignment="Stretch"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     IsReadOnly="True"
                                                     Padding="5 0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*" MinWidth="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Describe, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="{Binding Describe}"
                                                     HorizontalAlignment="Stretch"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     Padding="5 0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsGlobal, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Expander>
            </Grid>
        </Grid>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0 1 0 0" Padding="15 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 状态信息区域 -->
                <StackPanel HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock Text="就绪" Foreground="#666666" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  " Foreground="#CCCCCC" Margin="10 0"/>
                    <TextBlock Foreground="#666666" FontSize="13" VerticalAlignment="Center">
                        <Run Text="条件数量："/>
                        <Run Text="{Binding ModelParam.AllJudgeCodition.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <!-- 操作按钮 -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <Button Command="{Binding GeneralCommand}"
                            Height="36"
                            Width="100"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="取消"
                            CommandParameter="取消"
                            Background="White"
                            BorderBrush="#CCCCCC"
                            Foreground="#666666"
                            Cursor="Hand"
                            Margin="0 0 10 0"/>
                    <Button Command="{Binding GeneralCommand}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="36"
                            Width="100"
                            Content="确认"
                            CommandParameter="确认"
                            Background="#2196F3"
                            BorderBrush="#2196F3"
                            Foreground="White"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

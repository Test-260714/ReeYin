<UserControl x:Class="LogicalTool.Conditional.Views.ListConditionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LogicalTool.Conditional.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:behaviors="clr-namespace:ReeYin_V.UI.Helper;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="12"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600" d:DesignWidth="600">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 变量信息卡片 -->
        <WxGroupBox:WxGroupBox Grid.Row="0" Header="变量信息" Margin="0 0 0 15">
            <Grid Margin="15 10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 名称 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="名称" FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center" Margin="0 5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurCodition.Variable.Name}" Foreground="#222222" VerticalAlignment="Center" Margin="10 5" TextWrapping="Wrap"/>

                <!-- 参数类型 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="参数类型" FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center" Margin="0 5"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurCodition.Variable.Type}" Foreground="#222222" VerticalAlignment="Center" Margin="10 5" TextWrapping="Wrap"/>

                <!-- 值 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="值" FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center" Margin="0 5"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CurCodition.Variable.Value}" Foreground="#222222" VerticalAlignment="Center" Margin="10 5" TextWrapping="Wrap"/>

                <!-- 数据源 -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="数据源" FontWeight="SemiBold" Foreground="#555555" VerticalAlignment="Center" Margin="0 5"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CurCodition.Variable.ResourcePath}" Foreground="#222222" VerticalAlignment="Center" Margin="10 5" TextWrapping="Wrap"/>
            </Grid>
        </WxGroupBox:WxGroupBox>

        <!-- 集合操作区域 -->
        <WxGroupBox:WxGroupBox Grid.Row="1" Header="集合操作" Margin="0 0 0 15">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="5">
                    <!-- 输出单个数据 -->
                    <Expander Header="输出指定单个数据" IsExpanded="True" Margin="0 5" Style="{DynamicResource ExpanderStyle}">
                        <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="5 10 5 5" Padding="15">
                            <StackPanel>
                                <!-- 启用开关 -->
                                <Grid Margin="0 0 0 15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="启用单个数据输出" VerticalAlignment="Center" Foreground="#333333" FontWeight="Medium" Margin="0 0 15 0"/>
                                    <RadioButton Grid.Column="1" Style="{StaticResource ToggleButtonSwitch}" Content="启用" HorizontalAlignment="Left"
                                                 IsChecked="{Binding CurCodition.IsOutputSingle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <!-- 集合下标输入 -->
                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                  hc:InfoElement.Title="集合下标"
                                                  hc:InfoElement.TitleWidth="100"
                                                  DecimalPlaces="0"
                                                  Minimum="0"
                                                  Width="300"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource NumericUpDownExtendGlobal}"
                                                  BorderThickness="1"
                                                  BorderBrush="#CCCCCC"
                                                  Foreground="#222222"
                                                  Background="White"
                                                  Value="{Binding CurCodition.SingleIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <!-- 说明文本 -->
                                <TextBlock Text="提示：输入集合中元素的索引位置（从0开始）"
                                           Foreground="#888888"
                                           FontSize="11"
                                           Margin="0 10 0 0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- 输出范围数据 -->
                    <Expander Header="输出指定范围数据" IsExpanded="False" Margin="0 5" Style="{DynamicResource ExpanderStyle}">
                        <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="5 10 5 5" Padding="15">
                            <StackPanel>
                                <!-- 启用开关 -->
                                <Grid Margin="0 0 0 15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="启用范围数据输出" VerticalAlignment="Center" Foreground="#333333" FontWeight="Medium" Margin="0 0 15 0"/>
                                    <RadioButton Grid.Column="1" Style="{StaticResource ToggleButtonSwitch}" Content="启用" HorizontalAlignment="Left"
                                                 IsChecked="{Binding CurCodition.IsOutputRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <!-- 起始和结束索引 -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 起始索引 -->
                                    <hc:NumericUpDown Grid.Row="0"
                                                      hc:InfoElement.TitlePlacement="Left"
                                                      hc:InfoElement.Title="起始索引"
                                                      hc:InfoElement.TitleWidth="100"
                                                      DecimalPlaces="0"
                                                      Minimum="0"
                                                      Width="300"
                                                      HorizontalAlignment="Left"
                                                      Margin="0 0 0 10"
                                                      Style="{StaticResource NumericUpDownExtendGlobal}"
                                                      BorderThickness="1"
                                                      BorderBrush="#CCCCCC"
                                                      Foreground="#222222"
                                                      Background="White"
                                                      Value="{Binding CurCodition.RangeStartIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                    <!-- 结束索引 -->
                                    <hc:NumericUpDown Grid.Row="1"
                                                      hc:InfoElement.TitlePlacement="Left"
                                                      hc:InfoElement.Title="结束索引"
                                                      hc:InfoElement.TitleWidth="100"
                                                      DecimalPlaces="0"
                                                      Minimum="0"
                                                      Width="300"
                                                      HorizontalAlignment="Left"
                                                      Style="{StaticResource NumericUpDownExtendGlobal}"
                                                      BorderThickness="1"
                                                      BorderBrush="#CCCCCC"
                                                      Foreground="#222222"
                                                      Background="White"
                                                      Value="{Binding CurCodition.RangeEndIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>

                                <!-- 说明文本 -->
                                <TextBlock Text="提示：输入起始和结束索引以获取指定范围的数据（包含起始，不包含结束）"
                                           Foreground="#888888"
                                           FontSize="11"
                                           Margin="0 10 0 0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </WxGroupBox:WxGroupBox>

        <!-- 操作按钮区域 -->
        <WxGroupBox:WxGroupBox Grid.Row="2" Header="操作">
            <Grid Margin="10">
                <Button HorizontalAlignment="Right"
                        Command="{Binding GeneralCommand}"
                        Style="{StaticResource GeneralButtonStyle}"
                        Height="38"
                        Width="120"
                        Content="追加至输出"
                        CommandParameter="追加至输出"
                        Cursor="Hand"
                        FontSize="13"/>
            </Grid>
        </WxGroupBox:WxGroupBox>
    </Grid>
</UserControl>


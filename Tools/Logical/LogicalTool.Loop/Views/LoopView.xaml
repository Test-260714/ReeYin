<UserControl x:Class="LogicalTool.Loop.Views.LoopView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LogicalTool.Loop.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="640" Width="640"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="640" d:DesignWidth="640">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Border x:Name="bd" Grid.Row="0">
            <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="循环设定>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Left" Margin="2 0 0 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="AUTO"/>
                        <RowDefinition Height="AUTO"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="1" Orientation="Vertical" Margin="5 2">
                        <StackPanel Orientation="Horizontal">
                            <!--<TextBlock Text="监听类型:" VerticalAlignment="Center"/>
                            <ComboBox Width="120" Height="25" BorderThickness="0 0 0 1" Margin="5 0" helper:ItemsControlHelper.EnumValuesToItemsSource="True" HorizontalContentAlignment="Center"
                                       SelectedItem="{Binding ModelParam.SltMonitorType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="SelectionChanged">
                                        <i:InvokeCommandAction Command="{Binding DataOperateCommand}" CommandParameter="切换监听类型"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </ComboBox>-->
                        </StackPanel>
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center">
                                <RadioButton FontSize="14" Margin="0 0 0 0" Width="83" Height="32" IsChecked="True" Content="指定次数" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="指定次数"/>

                                <RadioButton FontSize="14" Margin="100 0 0 0" Width="83" Height="32" Content="链接次数" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="链接次数"/>

                            </StackPanel>

                            <Grid>
                                <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center" Visibility="{Binding ModelParam.IsAssignVisibility,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                    <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="循环次数(-1：无限循环):" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="10" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Height="30"
                                      Value="{Binding ModelParam.LoopNum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="ValueChanged">
                                                <i:InvokeCommandAction Command="{Binding ValueChanged}" CommandParameter="LoopNum"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </hc:NumericUpDown>
                                </StackPanel>

                                <StackPanel Visibility="{Binding ModelParam.IsLinkVisibility,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                    <WxLink:WxLink Width="350" InputParams="{Binding ModelParam.InputParams, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" 
                                                               OutputParam="{Binding ModelParam.LinkLoopNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  
                                                               Order="OpenParam" 
                                                               Margin="0 15 0 15"
                                                               Text="{Binding ModelParam.LinkLoopNum.Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </WxGroupBox:WxGroupBox>
        </Border>
        <Border Grid.Row="1">
            <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                <StackPanel>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                        <TextBlock Text="数据:" VerticalAlignment="Center"/>
                        <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                        <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
             Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                     ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                        <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                 Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                     ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                    </StackPanel>
                    <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      ItemsSource="{Binding ModelParam.OutputParams}" 
                      SelectedItem="{Binding CurrentOutputParam}"
                      FontSize="12" 
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Height="160"
                      RowHeaderWidth="20"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      IsReadOnly="False" CanUserAddRows="False" >
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
         SelectedItem="{Binding Type}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                        <!--<TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>-->
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Expander>
        </Border>

        <!--底部运行状态栏-->
        <Border Grid.Row="2" Background="{DynamicResource TitleForegroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width = "0.3*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                                                    <!--<Run Text="耗时:"/>
                                                    <Run Text="{Binding ModuleParam.ElapsedTime}"/>
                                                    <Run Text="ms"/>-->
                    </TextBlock>

                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                                                    <!--<Run Text="执行状态:"/>
                                                    <Run Text="{Binding ModuleParam.Status}"/>-->
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Height="35" Width="100"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="终止循环"
                                                    CommandParameter="终止循环"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Height="35" Width="100"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    CommandParameter="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="100"
                                                    Content="确认"
                                                    CommandParameter="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>


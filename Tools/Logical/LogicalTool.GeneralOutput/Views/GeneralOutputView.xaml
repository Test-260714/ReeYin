<UserControl x:Class="LogicalTool.GeneralOutput.Views.GeneralOutputView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LogicalTool.GeneralOutput.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="640" Width="800"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="640" d:DesignWidth="800">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
        <!--<i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding ConfirmCommand}"/>
        </i:EventTrigger>-->
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>
        <Border x:Name="bd" Grid.Row="0">
            <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="输出>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Left" Margin="2 0 0 0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="AUTO"/>
                        <RowDefinition Height="AUTO"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5 2">
                        <TextBlock Text="输出对象:" VerticalAlignment="Center"/>
                        <ComboBox Width="160" Height="25" BorderThickness="0 0 0 1" Margin="5 0" x:Name="cmbCameraNo" 
                                      ItemsSource="{Binding ComLists,Mode=TwoWay}" SelectedItem="{Binding ModelParam.SltCom,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                        <Button  Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                             Background="White" FontFamily="{StaticResource Iconfont}"
                                             BorderBrush="White" 
                                             ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                        <Button  Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                             Background="White" FontFamily="{StaticResource Iconfont}"
                                             BorderBrush="White" Margin="5 0" 
                                             ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                        <Button  Content="&#xe621;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                                             Background="White" FontFamily="{StaticResource Iconfont}"
                                             BorderBrush="White"
                                             ToolTip="修改" Command="{Binding DataOperateCommand}" CommandParameter="Modify"/>
                    </StackPanel>
                    <DataGrid Grid.Row="2" AutoGenerateColumns="False" x:Name="dg" Style="{StaticResource DefaultDataGridStyle}"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              ItemsSource="{Binding ModelParam.Monitors,Mode=TwoWay}" SelectedItem="{Binding SelectedMonitor,Mode=TwoWay}"
                                              FontSize="12" 
                                              RowHeaderWidth="20"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="All"
                                              IsReadOnly="True" CanUserAddRows="False">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectedCellsChanged">
                                <i:InvokeCommandAction Command="{Binding SelectedCellsChanged}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="对象" IsReadOnly="True" Width="100" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="类型" IsReadOnly="False" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Width="160" Height="25" BorderThickness="0 0 0 1" Margin="5 0" x:Name="cmbCameraNo"
                                      ItemsSource="{Binding DataContext.Condition,Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}}" SelectedItem="{Binding Condition,Mode=TwoWay}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="判定值" IsReadOnly="True" Width="150" >
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="启用" IsReadOnly="True" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ToggleButton Style="{StaticResource ToggleButtonSwitch}" IsChecked="{Binding IsUsing,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                                      Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="使能"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </WxGroupBox:WxGroupBox>
        </Border>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" Background="{DynamicResource TitleForegroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                                                    <!--<Run Text="耗时:"/>
                                                    <Run Text="{Binding ModuleParam.ElapsedTime}"/>
                                                    <Run Text="ms"/>-->
                    </TextBlock>

                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                                                    <!--<Run Text="执行状态:"/>
                                                    <Run Text="{Binding ModuleParam.Status}"/>-->
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Height="35" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    CommandParameter="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="确认"
                                                    CommandParameter="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

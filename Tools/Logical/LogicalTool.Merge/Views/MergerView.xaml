<UserControl x:Class="LogicalTool.Merge.Views.MergerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LogicalTool.Merge.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:behaviors="clr-namespace:ReeYin_V.UI.Helper;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="800" Width="1200"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="800" d:DesignWidth="1200">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0 0 0 1" Padding="15 12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="分支合并" FontSize="18" FontWeight="SemiBold" Foreground="#222222"/>
                <TextBlock Text="/" Margin="10 0" Foreground="#CCCCCC" FontSize="16"/>
                <TextBlock Text="输入参数 → 输出参数" FontSize="16" Foreground="#666666"/>
            </StackPanel>
        </Border>

        <!-- 合并配置区域 -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="0 0 0 1" Padding="15 10" Background="White">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="触发模式：" VerticalAlignment="Center" Foreground="#555555" FontWeight="SemiBold"/>
                <ComboBox Width="180" Height="28"
                          Margin="5 0 30 0"
                          BorderThickness="0 0 0 1"
                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                          SelectedItem="{Binding ModelParam.TriggerMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="超时等待：" VerticalAlignment="Center" Foreground="#555555" FontWeight="SemiBold"/>
                <TextBox Width="70" Height="28"
                         Margin="5 0 5 0"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         BorderBrush="#CCCCCC" BorderThickness="1"
                         Text="{Binding ModelParam.WaitTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="秒" VerticalAlignment="Center" Foreground="#666666"/>

                <TextBlock Margin="30 0 0 0" VerticalAlignment="Center" Foreground="#999999" FontSize="12">
                    <Run Text="AnyOne = 任意一个成功即通过  |  All = 所有节点成功才通过"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 主内容区域：输入参数 | 操作按钮 | 输出参数 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <!-- 输入参数列表 -->
                <ColumnDefinition Width="*"/>
                <!-- 中间操作区 -->
                <ColumnDefinition Width="70"/>
                <!-- 输出参数列表 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧：输入参数 ===== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 左侧标题行 -->
                <Border Grid.Row="0" Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1 1 1 0"
                        CornerRadius="4 4 0 0" Padding="10 8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xe6f2;" FontFamily="{StaticResource Iconfont}"
                                       Foreground="#2563EB" FontSize="16" Margin="0 0 8 0" VerticalAlignment="Center"/>
                            <TextBlock Text="输入参数" FontWeight="SemiBold" Foreground="#1E40AF" FontSize="14"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" Foreground="#3B82F6">
                            <Run Text="共"/>
                            <Run Text="{Binding ModelParam.InputParams.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                            <Run Text="个"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- 输入参数 DataGrid -->
                <Border Grid.Row="1" Background="White" BorderBrush="#BFDBFE" BorderThickness="1"
                        CornerRadius="0 0 4 4">
                    <DataGrid AutoGenerateColumns="False"
                              Style="{StaticResource DefaultDataGridStyle}"
                              EnableColumnVirtualization="True"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              behaviors:DataGridRowNumberBehavior.Enable="True"
                              behaviors:DataGridRowNumberBehavior.Header="序号"
                              behaviors:DataGridRowNumberBehavior.Width="50"
                              behaviors:DataGridRowNumberBehavior.StartIndex="1"
                              behaviors:DataGridRowNumberBehavior.Format="{}{0}"
                              behaviors:DataGridRowNumberBehavior.Freeze="True"
                              ItemsSource="{Binding ModelParam.InputParams, Mode=OneWay}"
                              SelectedItem="{Binding SelectedInputParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              FontSize="12"
                              RowHeaderWidth="0"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              IsReadOnly="True"
                              CanUserAddRows="False">
                        <i:Interaction.Triggers>
                            <!-- 双击直接加入输出 -->
                            <i:EventTrigger EventName="MouseDoubleClick">
                                <i:InvokeCommandAction Command="{Binding DataOperateCommand}"
                                                       CommandParameter="AddToOutput"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="参数名称" Width="*" MinWidth="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}"
                                                   Padding="5 0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="类型" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Type}" HorizontalAlignment="Center"
                                                   Padding="5 0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="值" Width="*" MinWidth="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Value}" ToolTip="{Binding Value}"
                                                   Padding="5 0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="备注" Width="*" MinWidth="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Describe}" ToolTip="{Binding Describe}"
                                                   Padding="5 0" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- 左侧底部：全部导入输出 -->
                <Button Grid.Row="2"
                        Content="全部导入输出"
                        Height="32" Margin="0 6 0 0"
                        Style="{StaticResource GeneralButtonStyle}"
                        Background="#4CAF50" BorderBrush="#4CAF50" Foreground="White"
                        ToolTip="将全部输入参数添加到输出列表"
                        Command="{Binding DataOperateCommand}"
                        CommandParameter="AddAllToOutput"/>
            </Grid>

            <!-- ===== 中间：单条操作按钮 ===== -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Orientation="Vertical">

                <!-- 添加选中行 -->
                <Button Content="&#xe630;"
                        Width="42" Height="42"
                        FontSize="20"
                        FontFamily="{StaticResource Iconfont}"
                        Style="{StaticResource GeneralButtonStyle}"
                        Background="#2196F3" BorderBrush="#2196F3" Foreground="White"
                        ToolTip="添加选中参数到输出（双击行也可快速添加）"
                        Command="{Binding DataOperateCommand}"
                        CommandParameter="AddToOutput"
                        Margin="0 0 0 16"/>

                <!-- 移除选中 -->
                <Button Content="&#xe74b;"
                        Width="42" Height="42"
                        FontSize="20"
                        FontFamily="{StaticResource Iconfont}"
                        Style="{StaticResource GeneralButtonStyle}"
                        Background="#FF9800" BorderBrush="#FF9800" Foreground="White"
                        ToolTip="从输出中移除选中参数"
                        Command="{Binding DataOperateCommand}"
                        CommandParameter="RemoveFromOutput"/>
            </StackPanel>

            <!-- ===== 右侧：输出参数 ===== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 右侧标题行 -->
                <Border Grid.Row="0" Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1 1 1 0"
                        CornerRadius="4 4 0 0" Padding="10 8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xe618;" FontFamily="{StaticResource Iconfont}"
                                       Foreground="#16A34A" FontSize="16" Margin="0 0 8 0" VerticalAlignment="Center"/>
                            <TextBlock Text="输出参数" FontWeight="SemiBold" Foreground="#15803D" FontSize="14"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="12" Foreground="#22C55E">
                            <Run Text="共"/>
                            <Run Text="{Binding ModelParam.OutputParams.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                            <Run Text="个"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- 输出参数 DataGrid（可编辑名称、备注、全局标记） -->
                <Border Grid.Row="1" Background="White" BorderBrush="#86EFAC" BorderThickness="1"
                        CornerRadius="0 0 4 4">
                    <DataGrid AutoGenerateColumns="False"
                              Style="{StaticResource DefaultDataGridStyle}"
                              EnableColumnVirtualization="True"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              behaviors:DataGridRowNumberBehavior.Enable="True"
                              behaviors:DataGridRowNumberBehavior.Header="序号"
                              behaviors:DataGridRowNumberBehavior.Width="50"
                              behaviors:DataGridRowNumberBehavior.StartIndex="1"
                              behaviors:DataGridRowNumberBehavior.Format="{}{0}"
                              behaviors:DataGridRowNumberBehavior.Freeze="True"
                              ItemsSource="{Binding ModelParam.OutputParams, Mode=TwoWay}"
                              SelectedItem="{Binding SelectedOutputParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              FontSize="12"
                              RowHeaderWidth="0"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              IsReadOnly="False"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <!-- 参数名称（可编辑改名） -->
                            <DataGridTemplateColumn Header="参数名称" Width="*" MinWidth="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{Binding Name}"
                                                 HorizontalAlignment="Stretch"
                                                 BorderThickness="0" Background="Transparent"
                                                 Padding="5 0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- 类型 -->
                            <DataGridTemplateColumn Header="类型" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox Width="90" Height="26"
                                                  BorderThickness="0"
                                                  Background="Transparent"
                                                  helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                  SelectedItem="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- 值（只读显示） -->
                            <DataGridTemplateColumn Header="值" Width="*" MinWidth="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Value}" ToolTip="{Binding Value}"
                                                   Padding="5 0" VerticalAlignment="Center"
                                                   Foreground="#444444"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- 备注（可编辑） -->
                            <DataGridTemplateColumn Header="备注" Width="*" MinWidth="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Describe, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="{Binding Describe}"
                                                 HorizontalAlignment="Stretch"
                                                 BorderThickness="0" Background="Transparent"
                                                 Padding="5 0"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <!-- 全局标记 -->
                            <DataGridTemplateColumn Header="全局" Width="55">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsGlobal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  ToolTip="勾选后作为全局参数输出"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- 右侧底部：清空输出 -->
                <Button Grid.Row="2"
                        Content="清空输出"
                        Height="32" Margin="0 6 0 0"
                        Style="{StaticResource GeneralButtonStyle}"
                        Background="#F44336" BorderBrush="#F44336" Foreground="White"
                        ToolTip="清空全部输出参数"
                        Command="{Binding DataOperateCommand}"
                        CommandParameter="ClearOutput"/>
            </Grid>
        </Grid>

        <!-- 底部操作栏 -->
        <Border Grid.Row="3" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0 1 0 0" Padding="15 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Foreground="#666666" FontSize="13" VerticalAlignment="Center">
                        <Run Text="模式："/>
                        <Run Text="{Binding ModelParam.TriggerMode, Mode=OneWay}" FontWeight="SemiBold" Foreground="#2196F3"/>
                    </TextBlock>
                    <TextBlock Text="  |  " Foreground="#CCCCCC" Margin="10 0"/>
                    <TextBlock Foreground="#666666" FontSize="13" VerticalAlignment="Center">
                        <Run Text="超时："/>
                        <Run Text="{Binding ModelParam.WaitTimeoutSeconds, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" 秒"/>
                    </TextBlock>
                    <TextBlock Text="  |  " Foreground="#CCCCCC" Margin="10 0"/>
                    <TextBlock Foreground="#666666" FontSize="13" VerticalAlignment="Center">
                        <Run Text="输入："/>
                        <Run Text="{Binding ModelParam.InputParams.Count, Mode=OneWay}" FontWeight="SemiBold" Foreground="#2563EB"/>
                        <Run Text=" 个  输出："/>
                        <Run Text="{Binding ModelParam.OutputParams.Count, Mode=OneWay}" FontWeight="SemiBold" Foreground="#16A34A"/>
                        <Run Text=" 个"/>
                    </TextBlock>
                    <TextBlock Text="  |  " Foreground="#CCCCCC" Margin="10 0"/>
                    <TextBlock Foreground="#999999" FontSize="12" VerticalAlignment="Center"
                               Text="提示：双击左侧参数行可快速加入输出"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding GeneralCommand}"
                            Height="36" Width="100"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="取消" CommandParameter="取消"
                            Background="White" BorderBrush="#CCCCCC" Foreground="#666666"
                            Cursor="Hand" Margin="0 0 10 0"/>
                    <Button Command="{Binding GeneralCommand}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="36" Width="100"
                            Content="确认" CommandParameter="确认"
                            Background="#2196F3" BorderBrush="#2196F3" Foreground="White"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

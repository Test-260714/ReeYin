<UserControl x:Class="LogicalTool.BranchRouter.Views.BranchRouterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             Height="800"
             Width="1200"
             FontSize="14"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="800"
             d:DesignWidth="1200">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题和规则操作，页面结构对齐条件分支模块。 -->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0 0 0 1" Padding="15 12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="分支路由" FontSize="18" FontWeight="SemiBold" Foreground="#222222"/>
                    <TextBlock Text="/" Margin="10 0" Foreground="#CCCCCC" FontSize="16"/>
                    <TextBlock Text="输入参数 → 自定义判断值 → 已连接节点" FontSize="16" Foreground="#666666"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="匹配模式：" VerticalAlignment="Center" Foreground="#666666" FontWeight="Medium"/>
                    <ComboBox Width="150"
                              Height="30"
                              Margin="8 0 16 0"
                              ItemsSource="{Binding MatchModes}"
                              SelectedItem="{Binding ModelParam.MatchMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="添加"
                            Width="70"
                            Height="32"
                            Margin="0 0 8 0"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="#4CAF50"
                            BorderBrush="#4CAF50"
                            Foreground="White"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="添加规则"/>
                    <Button Content="删除"
                            Width="70"
                            Height="32"
                            Margin="0 0 8 0"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="#F44336"
                            BorderBrush="#F44336"
                            Foreground="White"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="删除规则"/>
                    <Button Content="刷新节点"
                            Width="90"
                            Height="32"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="#2196F3"
                            BorderBrush="#2196F3"
                            Foreground="White"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="刷新节点"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.35*" MinWidth="360"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="0.65*" MinWidth="480"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：规则列表，变量选择复用 WxLink 的上一节点/全局/自定义全局数据选择。 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#E3F2FD" CornerRadius="4" Padding="10 8" Margin="0 0 0 10">
                    <TextBlock Text="先添加规则，再点击变量框右侧按钮选择数据；选中规则后在右侧配置判断和分支节点。"
                               Foreground="#1976D2"
                               FontSize="12"/>
                </Border>

                <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                    <DataGrid AutoGenerateColumns="False"
                              Style="{StaticResource DefaultDataGridStyle}"
                              EnableColumnVirtualization="True"
                              EnableRowVirtualization="False"
                              VirtualizingPanel.IsVirtualizing="True"
                              ItemsSource="{Binding ModelParam.Rules, Mode=TwoWay}"
                              SelectedItem="{Binding SelectedRule, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              FontSize="12"
                              RowHeaderWidth="0"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="变量" Width="*" MinWidth="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <WxLink:WxLink Width="Auto"
                                                       Margin="5 0"
                                                       InputParams="{Binding DataContext.ModelParam.InputParams, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
                                                       OutputParam="{Binding Variable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                       Order="OpenParam"
                                                       Text="{Binding Variable.Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="启用" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="节点" Width="70"
                                                Binding="{Binding TargetNodeSerial, Mode=OneWay}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0 10 0 0">
                    <TextBlock Foreground="#666666" FontSize="12">
                        <Run Text="规则数量："/>
                        <Run Text="{Binding ModelParam.Rules.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          Background="#E0E0E0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Cursor="SizeWE"/>

            <!-- 右侧：选中规则的路由操作配置。 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15 10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="操作区域" FontSize="16" FontWeight="SemiBold" Foreground="#222222"/>
                        <TextBlock Text=" / 判断当前选中数据后，只放行指定的已连接节点" Margin="8 0 0 0" Foreground="#666666"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="18" Margin="0 10 0 0"
                        DataContext="{Binding SelectedRule}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="当前变量：" VerticalAlignment="Center" Foreground="#666666"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Variable.Name}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#222222"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="数据类型：" VerticalAlignment="Center" Foreground="#666666" Margin="0 12 0 0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DataType}" VerticalAlignment="Center" Margin="0 12 0 0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="判断方式：" VerticalAlignment="Center" Foreground="#666666" Margin="0 12 0 0"/>
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  Height="30"
                                  Margin="0 12 0 0"
                                  ItemsSource="{Binding DataContext.CompareTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  SelectedItem="{Binding CompareType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="自定义判断值：" VerticalAlignment="Center" Foreground="#666666" Margin="0 12 0 0"/>
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 Height="30"
                                 Margin="0 12 0 0"
                                 Text="{Binding TargetValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="执行节点：" VerticalAlignment="Center" Foreground="#666666" Margin="0 12 0 0"/>
                        <ComboBox Grid.Row="4" Grid.Column="1"
                                  Height="30"
                                  Margin="0 12 0 0"
                                  ItemsSource="{Binding DataContext.ConnectedNodes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Serial"
                                  SelectedValue="{Binding TargetNodeSerial, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <Border Grid.Row="5" Grid.ColumnSpan="2" Background="#F5F5F5" CornerRadius="4" Padding="12" Margin="0 18 0 0" VerticalAlignment="Top">
                            <TextBlock Foreground="#666666" TextWrapping="Wrap"
                                       Text="运行时会读取当前变量实时值：命中规则则只执行选择的已连接节点；未命中任何规则时本节点返回 NotRun，后续分支会被跳过。"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="4" Padding="10" Margin="0 10 0 0">
                    <TextBlock Foreground="#666666" FontSize="12">
                        <Run Text="已连接节点："/>
                        <Run Text="{Binding ConnectedNodes.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text=" 个"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0 1 0 0" Padding="15 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock VerticalAlignment="Center" Foreground="#666666" FontSize="13"
                           Text="FirstMatch 命中第一条规则；AllMatch 命中全部符合规则的已连接节点。"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消"
                            Width="100"
                            Height="36"
                            Margin="0 0 10 0"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="White"
                            BorderBrush="#CCCCCC"
                            Foreground="#666666"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="取消"/>
                    <Button Content="确认"
                            Width="100"
                            Height="36"
                            Style="{StaticResource GeneralButtonStyle}"
                            Background="#2196F3"
                            BorderBrush="#2196F3"
                            Foreground="White"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="确认"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

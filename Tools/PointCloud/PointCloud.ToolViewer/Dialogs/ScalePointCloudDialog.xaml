<Window x:Class="PointCloud.ToolViewer.Dialogs.ScalePointCloudDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="Scale / multiply"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="130" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center" Text="Scale(x)" />
            <hc:NumericUpDown x:Name="ScaleXNumeric"
                              Grid.Column="1"
                              DecimalPlaces="8"
                              Minimum="-1000000"
                              Maximum="1000000"
                              Value="{Binding Parameters.ScaleX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ValueChanged="ScaleXNumeric_ValueChanged" />

            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Scale(y)" />
            <hc:NumericUpDown x:Name="ScaleYNumeric"
                              Grid.Column="4"
                              DecimalPlaces="8"
                              Minimum="-1000000"
                              Maximum="1000000"
                              Value="{Binding Parameters.ScaleY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Column="6" VerticalAlignment="Center" Text="Scale(z)" />
            <hc:NumericUpDown x:Name="ScaleZNumeric"
                              Grid.Column="7"
                              DecimalPlaces="8"
                              Minimum="-1000000"
                              Maximum="1000000"
                              Value="{Binding Parameters.ScaleZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <CheckBox x:Name="SameScaleCheckBox"
                  Grid.Row="1"
                  Margin="0,12,0,0"
                  Content="Same scale for all dimensions"
                  IsChecked="{Binding Parameters.SameScaleForAllDimensions, Mode=TwoWay}"
                  Checked="SameScaleCheckBox_Checked"
                  Unchecked="SameScaleCheckBox_Unchecked" />

        <CheckBox Grid.Row="2"
                  Margin="0,8,0,0"
                  Content="Keep entity in place"
                  IsChecked="{Binding Parameters.KeepEntityInPlace, Mode=TwoWay}" />

        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="90"
                    Margin="0,0,8,0"
                    Content="&#37325;&#32622;"
                    Click="ResetButton_Click" />
            <Button Width="90"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Content="OK"
                    Click="OkButton_Click" />
            <Button Width="90"
                    IsCancel="True"
                    Content="Cancel" />
        </StackPanel>
    </Grid>
</Window>

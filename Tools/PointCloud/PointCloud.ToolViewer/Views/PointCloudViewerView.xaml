<UserControl x:Class="PointCloud.ToolViewer.Views.PointCloudViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:model="clr-namespace:PointCloud.VTKWPF.Models;assembly=PointCloud.VTKWPF"
             xmlns:vm="clr-namespace:PointCloud.ToolViewer.ViewModels"
             xmlns:vtk="clr-namespace:PointCloud.VTKWPF.Controls;assembly=PointCloud.VTKWPF"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DataContext="{d:DesignInstance Type=vm:PointCloudViewerViewModel}"
             d:DesignHeight="880"
             d:DesignWidth="1400"
             FontSize="14"
             Height="880"
             Width="1400">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <FontFamily x:Key="PointCloudViewIconFont">pack://application:,,,/ReeYin_V.UI;component/Font/#iconfont</FontFamily>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource GeneralButtonStyle}">
            <Setter Property="Width" Value="110" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="ViewOrientationButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#C8C8C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF3DD" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D7A451" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE1B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C98D2C" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="#F7FFFFFF" />
            <Setter Property="BorderBrush" Value="#19000000" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource InfoCardStyle}">
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="10" />
        </Style>

        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#7A000000" />
        </Style>

        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style x:Key="PillToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{DynamicResource BtnOverColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Opacity="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BtnOverColor}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#C8C8C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF3DD" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D7A451" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE1B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C98D2C" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BtnOverColor}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BtnOverColor}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#C8C8C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF3DD" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D7A451" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE1B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C98D2C" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="8,6,8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <Button Content="&#21152;&#36733;&#28857;&#20113;"
                            Command="{Binding OpenPointCloudCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="&#28165;&#31354;&#22330;&#26223;"
                            Command="{Binding ClearCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="0" />
                </StackPanel>

                <Border Grid.Column="2"
                        HorizontalAlignment="Right"
                        Margin="0,0,12,0"
                        Padding="8,4,8,4"
                        Background="#F5F5F5"
                        BorderBrush="#1A000000"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#66000000"
                                   Text="点云操作" />

                        <Button Content="&#35774;&#32622;&#26631;&#37327;&#22330;"
                                Command="{Binding SetScalarFieldCommand}"
                                Style="{StaticResource ToolbarActionButtonStyle}" />
                        <Button Content="&#36873;&#28857;&#25805;&#20316;"
                                Command="{Binding OpenPointPickingMeasurementDialogCommand}"
                                Style="{StaticResource ToolbarActionButtonStyle}" />
                        <Button Content="&#32553;&#25918;"
                                Command="{Binding ScalePointCloudCommand}"
                                Style="{StaticResource ToolbarActionButtonStyle}" />
                        <Button Content="SF params"
                                Command="{Binding EditScalarFieldDisplayParamsCommand}"
                                Style="{StaticResource ToolbarActionButtonStyle}" />
                        <ToggleButton Content="EDL"
                                      IsChecked="{Binding EnableEdl, Mode=TwoWay}"
                                      Style="{StaticResource ToolbarToggleButtonStyle}" />
                        <ToggleButton Content="设置中枢"
                                      IsChecked="{Binding IsPivotPickingEnabled, Mode=TwoWay}"
                                      Style="{StaticResource ToolbarToggleButtonStyle}"
                                      Margin="0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        HorizontalAlignment="Right"
                        Padding="8,4,2,4"
                        Background="#F5F5F5"
                        BorderBrush="#1A000000"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#66000000"
                                   Text="&#26631;&#20934;&#35270;&#22270;" />

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Front}"
                                Content="&#xe671;"
                                FontFamily="{StaticResource PointCloudViewIconFont}"
                                FontSize="18"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#21069;&#35270;&#22270; (+Y)" />

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Back}"
                                Content="&#xe66a;"
                                FontFamily="{StaticResource PointCloudViewIconFont}"
                                FontSize="18"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#21518;&#35270;&#22270; (-Y)" />

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Left}"
                                Content="&#xe674;"
                                FontFamily="{StaticResource PointCloudViewIconFont}"
                                FontSize="18"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#24038;&#35270;&#22270; (-X)" />

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Right}"
                                Content="&#xe675;"
                                FontFamily="{StaticResource PointCloudViewIconFont}"
                                FontSize="18"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#21491;&#35270;&#22270; (+X)" />

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Top}"
                                Content="&#xe66d;"
                                FontFamily="{StaticResource PointCloudViewIconFont}"
                                FontSize="18"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#20463;&#35270;&#22270; (+Z)" />

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Bottom}"
                                Content="&#xe66b;"
                                FontFamily="{StaticResource PointCloudViewIconFont}"
                                FontSize="18"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                Margin="0"
                                ToolTip="&#20208;&#35270;&#22270; (-Z)" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="5">
                <TabControl Style="{StaticResource TabControlWithUnderLineStyle}">
                    <TabItem Header="&#22330;&#26223;&#35774;&#32622;"
                             Width="92"
                             FontSize="16"
                             Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <Border Style="{StaticResource InfoCardStyle}">
                                    <StackPanel>
                                        <TextBlock
                                                   Text="&#36873;&#20013;&#28857;"
                                                   Style="{StaticResource CardTitleStyle}" />
                                        <Border Margin="0,4,0,0"
                                                Padding="8,6"
                                                Background="#66FFFFFF"
                                                CornerRadius="8">
                                            <TextBlock FontSize="12"
                                                       Text="{Binding SelectedPointText}"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <TextBlock Margin="0,12,0,0"
                                                   Text="选点测量"
                                                   Style="{StaticResource CardTitleStyle}" />
                                        <Border Margin="0,4,0,0"
                                                Padding="8,6"
                                                Background="#66FFFFFF"
                                                CornerRadius="8">
                                            <TextBlock FontFamily="Consolas"
                                                       FontSize="11.5"
                                                       LineHeight="18"
                                                       Text="{Binding MeasurementText}"
                                                       TextWrapping="Wrap" />
                                        </Border>

                                        <TextBlock Margin="0,12,0,0"
                                                   Text="&#36793;&#30028;"
                                                   Style="{StaticResource CardTitleStyle}" />
                                        <Grid Margin="0,6,0,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="36" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="&#26368;&#23567;"
                                                       FontSize="12"
                                                       Foreground="#7A000000"
                                                       VerticalAlignment="Top" />
                                            <Border Grid.Column="1"
                                                    Padding="8,6"
                                                    Background="#66FFFFFF"
                                                    CornerRadius="8">
                                                <TextBlock FontFamily="Consolas"
                                                           FontSize="11.5"
                                                           LineHeight="18"
                                                           Text="{Binding BoundsMinText}"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <TextBlock Grid.Row="1"
                                                       Text="&#26368;&#22823;"
                                                       FontSize="12"
                                                       Foreground="#7A000000"
                                                       VerticalAlignment="Top"
                                                       Margin="0,8,0,0" />
                                            <Border Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="0,8,0,0"
                                                    Padding="8,6"
                                                    Background="#66FFFFFF"
                                                    CornerRadius="8">
                                                <TextBlock FontFamily="Consolas"
                                                           FontSize="11.5"
                                                           LineHeight="18"
                                                           Text="{Binding BoundsMaxText}"
                                                           TextWrapping="Wrap" />
                                            </Border>

                                            <TextBlock Grid.Row="2"
                                                       Text="&#23610;&#23544;"
                                                       FontSize="12"
                                                       Foreground="#7A000000"
                                                       VerticalAlignment="Top"
                                                       Margin="0,8,0,0" />
                                            <Border Grid.Row="2"
                                                    Grid.Column="1"
                                                    Margin="0,8,0,0"
                                                    Padding="8,6"
                                                    Background="#66FFFFFF"
                                                    CornerRadius="8">
                                                <TextBlock FontFamily="Consolas"
                                                           FontSize="11.5"
                                                           LineHeight="18"
                                                           Text="{Binding BoundsSizeText}"
                                                           TextWrapping="Wrap" />
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <ProgressBar Margin="0,0,0,12"
                                             Height="5"
                                             IsIndeterminate="True"
                                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <Border Style="{StaticResource InfoCardStyle}">
                                    <StackPanel>
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="&#26631;&#37327;&#22330;"
                                                       VerticalAlignment="Center"
                                                       Foreground="#7A000000" />
                                            <Border Grid.Column="1"
                                                    Padding="8,2"
                                                    Background="#66FFFFFF"
                                                    CornerRadius="10">
                                                <TextBlock Text="{Binding ScalarFieldDisplayText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="&#28857;&#22823;&#23567;"
                                                       VerticalAlignment="Center"
                                                       Foreground="#7A000000" />
                                            <Border Grid.Column="1"
                                                    Padding="8,2"
                                                    Background="#66FFFFFF"
                                                    CornerRadius="10">
                                                <TextBlock Text="{Binding PointSizeText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <Slider Margin="0,8,0,0"
                                                Minimum="1"
                                                Maximum="20"
                                                TickFrequency="0.5"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding PointSize, Mode=TwoWay}" />

                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="&#36879;&#26126;&#24230;"
                                                       VerticalAlignment="Center"
                                                       Foreground="#7A000000" />
                                            <Border Grid.Column="1"
                                                    Padding="8,2"
                                                    Background="#66FFFFFF"
                                                    CornerRadius="10">
                                                <TextBlock Text="{Binding OpacityText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>
                                        <Slider Margin="0,8,0,0"
                                                Minimum="0.15"
                                                Maximum="1"
                                                TickFrequency="0.05"
                                                IsSnapToTickEnabled="False"
                                                Value="{Binding Opacity, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource InfoCardStyle}">
                                    <StackPanel>
                                        <CheckBox Content="&#26174;&#31034;&#26041;&#21521;&#36724;"
                                                  Margin="0,0,0,10"
                                                  IsChecked="{Binding ShowOrientationAxes, Mode=TwoWay}" />
                                        <CheckBox Content="&#20351;&#29992;&#28176;&#21464;&#32972;&#26223;"
                                                  IsChecked="{Binding UseGradientBackground, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="&#25805;&#20316;&#26085;&#24535;"
                             Width="92"
                             FontSize="16"
                             Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <Grid Margin="10">
                            <Border Style="{StaticResource InfoCardStyle}" Margin="0">
                                <ListBox ItemsSource="{Binding Logs}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Margin="0,0,0,8"
                                                       TextWrapping="Wrap" />
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1"
                          Background="{DynamicResource BtnOverColor}"
                          HorizontalAlignment="Stretch" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Margin="5,5,5,0"
                        CornerRadius="8"
                        BorderBrush="#1A000000"
                        BorderThickness="1"
                        Background="White">
                    <Grid Background="#10273D">
                        <vtk:PointCloudViewportControl x:Name="Viewport"
                                                       Margin="0" />

                        <Border HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="18"
                                Padding="12,10"
                                Background="#AD0B1220"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8"
                                IsHitTestVisible="False">
                            <StackPanel>
                                <TextBlock Text="{Binding StatusText}"
                                           Foreground="White"
                                           FontWeight="SemiBold" />
                                <TextBlock Margin="0,6,0,0"
                                           Text="{Binding SelectedPointText}"
                                           Foreground="#E1E7EF" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                BorderThickness="0,2,0,0"
                BorderBrush="{DynamicResource SelectedBrush}"
                CornerRadius="5"
                Padding="8,6"
                Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="13">
                        <Run Text="&#29366;&#24577;: " />
                        <Run Text="{Binding StatusText, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock FontSize="13" Margin="0,4,0,0">
                        <Run Text="&#24403;&#21069;&#25991;&#20214;: " />
                        <Run Text="{Binding FileName, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>

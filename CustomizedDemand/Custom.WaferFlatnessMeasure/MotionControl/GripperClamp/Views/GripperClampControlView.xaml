<UserControl x:Class="Custom.WaferFlatnessMeasure.Views.GripperClampControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             Height="640"
             Width="1020"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="640"
             d:DesignWidth="1020">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Width="92" Height="30" Margin="0,0,8,0"
                        Content="刷新状态"
                        Style="{StaticResource GeneralButtonStyle}"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="Refresh"/>
                <Button Width="92" Height="30" Margin="0,0,8,0"
                        Content="刷新压力"
                        Style="{StaticResource GeneralButtonStyle}"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="RefreshPressures"/>
                <Button Width="110" Height="30" Margin="0,0,8,0"
                        Content="停止点动"
                        Style="{StaticResource GeneralButtonStyle}"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="StopJog:0"/>
                <Button Width="110" Height="30"
                        Content="复位命令"
                        Style="{StaticResource GeneralButtonStyle}"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="ResetCommands"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="PLC:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding ModelParam.PlcDisplayName}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="连接:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding ModelParam.IsPlcConnected}" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="夹爪点动控制">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="0.75*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="四个夹爪上下左右点动" Padding="10">
                        <ItemsControl ItemsSource="{Binding ModelParam.Grippers}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" Rows="2"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="8" Padding="12" BorderBrush="#D9DEE8" BorderThickness="1" CornerRadius="4" Background="#FAFBFC">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                                <CheckBox DockPanel.Dock="Right" Content="启用"
                                                          IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="（" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding PositionName}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="）" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </DockPanel>

                                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="压力" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding PressureValue, StringFormat={}{0:F3}}" VerticalAlignment="Center"/>
                                                <Button Grid.Column="2" Height="26" Content="读取"
                                                        Style="{StaticResource GeneralButtonStyle}"
                                                        Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Index, StringFormat=RefreshPressure:{0}}"/>
                                            </Grid>

                                            <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,10">
                                                <Button Height="42" Margin="0,0,6,0" Content="点动正转"
                                                        Style="{StaticResource GeneralButtonStyle}"
                                                        IsEnabled="{Binding IsEnabled}">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding Index, StringFormat=StartForwardJog:{0}}"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding Index, StringFormat=StopJog:{0}}"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="MouseLeave">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding Index, StringFormat=StopJog:{0}}"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="LostMouseCapture">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding Index, StringFormat=StopJog:{0}}"/>
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                </Button>

                                                <Button Height="42" Margin="6,0,0,0" Content="点动反转"
                                                        Style="{StaticResource GeneralButtonStyle}"
                                                        IsEnabled="{Binding IsEnabled}">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding Index, StringFormat=StartReverseJog:{0}}"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding Index, StringFormat=StopJog:{0}}"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="MouseLeave">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding Index, StringFormat=StopJog:{0}}"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="LostMouseCapture">
                                                            <i:InvokeCommandAction Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                   CommandParameter="{Binding Index, StringFormat=StopJog:{0}}"/>
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                </Button>
                                            </UniformGrid>

                                            <Grid Grid.Row="3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="24"/>
                                                    <RowDefinition Height="24"/>
                                                    <RowDefinition Height="24"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="正转地址" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding ForwardJogAddress}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="1" Text="反转地址" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ReverseJogAddress}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="2" Text="压力地址" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PressureAddress}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </GroupBox>

                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#D9DEE8"/>

                    <StackPanel Grid.Column="2">
                        <GroupBox Header="操作信息" Padding="10" Margin="0,0,0,10">
                            <TextBlock MinHeight="74" TextWrapping="Wrap" Text="{Binding ModelParam.LastOperationMessage}"/>
                        </GroupBox>

                        <GroupBox Header="汇总状态" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="任一正转命令" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ModelParam.ClampCommandValue}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Text="任一反转命令" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModelParam.ReleaseCommandValue}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Text="最近操作成功" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ModelParam.LastOperationSuccess}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Text="最近操作时间" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ModelParam.LastOperationTimeText}" VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>

                        <Expander Header="输出参数" IsExpanded="True">
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                    <ComboBox Width="240" Height="25" Margin="8,0"
                                              ItemsSource="{Binding ModelParam.OutputParamNames}"
                                              SelectedItem="{Binding SltOutputParamName, Mode=TwoWay}"/>
                                    <Button Content="添加" Width="60" Height="26" Margin="0,0,6,0"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding DataOperateCommand}"
                                            CommandParameter="Add"/>
                                    <Button Content="删除" Width="60" Height="26"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding DataOperateCommand}"
                                            CommandParameter="Delete"/>
                                </StackPanel>

                                <DataGrid AutoGenerateColumns="False"
                                          Style="{StaticResource DefaultDataGridStyle}"
                                          ItemsSource="{Binding ModelParam.OutputParams}"
                                          SelectedItem="{Binding CurrentOutputParam}"
                                          Height="150"
                                          CanUserAddRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="参数名称" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                        <DataGridTextColumn Header="值" Binding="{Binding Value}" IsReadOnly="True" Width="*"/>
                                        <DataGridTextColumn Header="备注" Binding="{Binding Describe, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="地址设置">
                <Grid Margin="8">
                    <GroupBox Header="四路夹爪PLC地址" Padding="8">
                        <DataGrid AutoGenerateColumns="False"
                                  Style="{StaticResource DefaultDataGridStyle}"
                                  ItemsSource="{Binding ModelParam.Grippers}"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="序号" Binding="{Binding Index}" IsReadOnly="True" Width="54"/>
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58"/>
                                <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="92"/>
                                <DataGridTextColumn Header="方位" Binding="{Binding PositionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                                <DataGridTextColumn Header="正转点动地址" Binding="{Binding ForwardJogAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="反转点动地址" Binding="{Binding ReverseJogAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="压力地址" Binding="{Binding PressureAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="压力值" Binding="{Binding PressureValue, StringFormat={}{0:F3}}" IsReadOnly="True" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#D9DEE8" Margin="0,10,0,0" Padding="0,10,0,0">
            <Grid>
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <TextBlock Text="耗时:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ModelParam.Output.RunTime}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="执行状态:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ModelParam.Output.RunStatus}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Width="80" Height="32" Margin="0,0,10,0"
                            Content="执行"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="执行"/>
                    <Button Width="80" Height="32" Margin="0,0,10,0"
                            Content="取消"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="取消"/>
                    <Button Width="80" Height="32"
                            Content="确认"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="确认"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

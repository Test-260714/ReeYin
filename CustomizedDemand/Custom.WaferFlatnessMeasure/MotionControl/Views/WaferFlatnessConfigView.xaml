<UserControl x:Class="Custom.WaferFlatnessMeasure.Views.WaferFlatnessConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.WaferFlatnessMeasure.Views"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:uiConverter="clr-namespace:ReeYin_V.UI.Converter;assembly=ReeYin_V.UI"
             xmlns:trajectoryControls="clr-namespace:ReeYin_V.UI.UserControls.TrajectoryDesigner.Views;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" 
             FontSize="14"
             Height="980"
             Width="1480"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="980"
             d:DesignWidth="1480">
    <UserControl.Resources>
        <uiConverter:Bool2VisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.55*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.45*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="5">
                <TabControl Style="{StaticResource TabControlWithUnderLineStyle}">
                    <TabItem Header="输入参数" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,5,0,0">
                                <WxGroupBox:WxGroupBox Header="采样高度" Margin="0,0,0,8">
                                    <StackPanel>
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="采样上Z轴高度：" hc:InfoElement.TitleWidth="140" Style="{StaticResource NumericUpDownExtend}"
                                                          Width="340" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center" Value="{Binding ModelParam.ZHight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="采样下Z轴高度：" hc:InfoElement.TitleWidth="140" Style="{StaticResource NumericUpDownExtend}"
                                                          Width="340" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center" Value="{Binding ModelParam.Z1Hight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>


                                        <StackPanel Orientation="Horizontal" Width="560" HorizontalAlignment="Center">
                                            <TextBlock Width="150" Text="圆心坐标链接:" Foreground="Black" VerticalAlignment="Center"/>
                                            <WxLink:WxLink Width="390" Margin="0,15"
                                                           InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                           OutputParam="{Binding ModelParam.CreateTrajectoryModel.CircleCenterActualXYLinkParam,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                           Order="OpenParam"
                                                           Text="{Binding ModelParam.CreateTrajectoryModel.CircleCenterActualXYLinkParam.Name}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"  hc:InfoElement.Title="手动输入圆心X/Y：" hc:InfoElement.TitleWidth="180"
                                                              Width="300" DecimalPlaces="3" Minimum="-100000" Maximum="100000" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1"
                                                              HorizontalContentAlignment="Center" Value="{Binding ModelParam.CreateTrajectoryModel.CircleCenterX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Width="100" DecimalPlaces="3" Minimum="-100000" Maximum="100000" BorderThickness="0 0 0 1"
                                                              HorizontalContentAlignment="Center" Value="{Binding ModelParam.CreateTrajectoryModel.CircleCenterY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                                        <TabItem Header="轨迹生成" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,5,0,0">
                                <WxGroupBox:WxGroupBox Header="自定义轨迹设计" Margin="0,0,0,8">
                                    <StackPanel Margin="8">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="#2E5573"
                                                   Text="SkiaSharp 自定义轨迹" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Foreground="#4C5A67"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding ModelParam.DesignedTrajectorySummaryText}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <Button Width="110"
                                                    Height="32"
                                                    Command="{Binding EditDesignedTrajectoryCommand}"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="编辑轨迹" />
                                            <TextBlock Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="#6A7480"
                                                       Text="点击编辑进入完整 XY 平面；在编辑页点击返回后会写入运行轨迹。" />
                                        </StackPanel>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="执行步骤预览" Margin="0,0,0,8">
                                    <DataGrid AutoGenerateColumns="False"
                                              Style="{StaticResource DefaultDataGridStyle}"
                                              EnableColumnVirtualization="True"
                                              EnableRowVirtualization="True"
                                              VirtualizingPanel.IsVirtualizing="True"
                                              ItemsSource="{Binding ModelParam.DesignedTrajectoryRunSteps}"
                                              FontSize="12"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              Height="360"
                                              RowHeaderWidth="20"
                                              SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="All"
                                              IsReadOnly="True"
                                              CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Width="48" Binding="{Binding Index}" />
                                            <DataGridTextColumn Header="类型" Width="70" Binding="{Binding KindText}" />
                                            <DataGridTextColumn Header="起点X" Width="90" Binding="{Binding StartX, StringFormat=F3}" />
                                            <DataGridTextColumn Header="起点Y" Width="90" Binding="{Binding StartY, StringFormat=F3}" />
                                            <DataGridTextColumn Header="终点X" Width="90" Binding="{Binding EndX, StringFormat=F3}" />
                                            <DataGridTextColumn Header="终点Y" Width="90" Binding="{Binding EndY, StringFormat=F3}" />
                                            <DataGridTextColumn Header="来源" Width="*" Binding="{Binding SourceName}" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </WxGroupBox:WxGroupBox>

                                <GroupBox Header="结构说明" Margin="0,0,0,8">
                                    <TextBlock Margin="12"
                                               Foreground="#4C5A67"
                                               TextWrapping="Wrap"
                                               Text="DesignedTrajectoryPlan 保存坐标范围、默认中心、原始图形 Shapes 和展平后的 RunSteps；SensorMotionControlModel 执行前会把 RunSteps 转换成 AllLocusInfo。" />
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

<TabItem Header="标定片位置" Width="120" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,5,0,0">
                                <WxGroupBox:WxGroupBox Header="标定片位置列表" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5,2">
                                            <TextBlock Text="操作:" VerticalAlignment="Center"/>
                                            <Button Margin="10,0,0,0" Width="80" Height="28" Command="{Binding AddCalibrationWaferPositionCommand}" Style="{StaticResource GeneralButtonStyle}" Content="新增"/>
                                            <Button Margin="8,0,0,0" Width="80" Height="28" Command="{Binding RemoveCalibrationWaferPositionCommand}" Style="{StaticResource GeneralButtonStyle}" Content="删除"/>
                                            <Button Margin="8,0,0,0" Width="80" Height="28" Command="{Binding ClearCalibrationWaferPositionCommand}" Style="{StaticResource GeneralButtonStyle}" Content="清空"/>
                                        </StackPanel>

                                        <DataGrid AutoGenerateColumns="False"
                                                  Style="{StaticResource DefaultDataGridStyle}"
                                                  EnableColumnVirtualization="True"
                                                  EnableRowVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  ItemsSource="{Binding ModelParam.CalibrationWaferPositions}"
                                                  SelectedItem="{Binding SelectedCalibrationWaferPosition,Mode=TwoWay}"
                                                  FontSize="12"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  Height="420"
                                                  RowHeaderWidth="20"
                                                  SelectionUnit="FullRow"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="All"
                                                  IsReadOnly="False"
                                                  CanUserAddRows="False">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="名称" Width="2*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                     ToolTip="{Binding Name}"
                                                                     BorderThickness="0"
                                                                     Background="Transparent"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="X 坐标" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <hc:NumericUpDown Width="150"
                                                                              DecimalPlaces="3"
                                                                              Minimum="-100000"
                                                                              Maximum="100000"
                                                                              BorderThickness="0 0 0 1"
                                                                              Style="{StaticResource NumericUpDownExtend}"
                                                                              HorizontalContentAlignment="Center"
                                                                              Value="{Binding X,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Y 坐标" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <hc:NumericUpDown Width="150"
                                                                              DecimalPlaces="3"
                                                                              Minimum="-100000"
                                                                              Maximum="100000"
                                                                              BorderThickness="0 0 0 1"
                                                                              Style="{StaticResource NumericUpDownExtend}"
                                                                              HorizontalContentAlignment="Center"
                                                                              Value="{Binding Y,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <GroupBox Header="参数说明">
                                    <TextBlock Margin="12"
                                               TextWrapping="Wrap"
                                               Foreground="#4C5A67"
                                               Text="执行标定时会使用这里配置的标定片位置列表。新增后可直接编辑名称、X 坐标和 Y 坐标，点击“确认”保存到当前模块参数。"/>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="控制卡设置" Width="auto" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,5,0,0">
                                <WxGroupBox:WxGroupBox Header="位置比较参数"
                                                       Margin="0,0,0,8"
                                                       Visibility="{Binding IsGoogolControlCardVisible,Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="比较模式："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="3"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.compareMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Margin="20,4,0,12"
                                                   Foreground="#6A7480"
                                                   Text="0:FIFO  1:Linear  2:PSO立即模式  3:PSO等待到位模式"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="输出脉冲宽度(us)："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="100000"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.comparePulseWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="输出信号模式："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="2"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.compareOutputMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Margin="20,4,0,12"
                                                   Foreground="#6A7480"
                                                   Text="0:脉冲  1:电平  2:电平自动翻转"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="比较源："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="1"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.sourceMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Margin="20,4,0,12"
                                                   Foreground="#6A7480"
                                                   Text="0:编码器  1:脉冲计数器"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="误差带(Pulse)："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="100000"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.compareErrBand,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="等间距触发间隔(Pulse)："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="1"
                                                          Maximum="1000000"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.syncPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="ACS LCI固定距离脉冲"
                                                       Margin="0,0,0,8"
                                                       Visibility="{Binding IsAcsControlCardVisible,Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <CheckBox Content="启用ACS LCI固定距离脉冲"
                                                  Margin="20,8,0,8"
                                                  IsChecked="{Binding ModelParam.AcsLciPulseParam.IsEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="Buffer编号："
                                                              hc:InfoElement.TitleWidth="130"
                                                              Width="250"
                                                              DecimalPlaces="0"
                                                              Minimum="0"
                                                              Maximum="64"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.BufferNo,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="超时(ms)："
                                                              hc:InfoElement.TitleWidth="120"
                                                              Width="250"
                                                              DecimalPlaces="0"
                                                              Minimum="1000"
                                                              Maximum="600000"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.Timeout,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="ACS轴X："
                                                              hc:InfoElement.TitleWidth="130"
                                                              Width="250"
                                                              DecimalPlaces="0"
                                                              Minimum="0"
                                                              Maximum="63"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.AxisX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="ACS轴Y："
                                                              hc:InfoElement.TitleWidth="120"
                                                              Width="250"
                                                              DecimalPlaces="0"
                                                              Minimum="0"
                                                              Maximum="63"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.AxisY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="脉冲宽度(ms)："
                                                              hc:InfoElement.TitleWidth="130"
                                                              Width="250"
                                                              DecimalPlaces="6"
                                                              Minimum="0.000001"
                                                              Maximum="100000"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.PulseWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="脉冲间距(mm)："
                                                              hc:InfoElement.TitleWidth="120"
                                                              Width="250"
                                                              DecimalPlaces="6"
                                                              Minimum="0.00001"
                                                              Maximum="100000"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.Interval,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="起始距离："
                                                              hc:InfoElement.TitleWidth="130"
                                                              Width="250"
                                                              DecimalPlaces="3"
                                                              Minimum="0"
                                                              Maximum="1000000"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.StartDistance,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="结束距离："
                                                              hc:InfoElement.TitleWidth="120"
                                                              Width="250"
                                                              DecimalPlaces="3"
                                                              Minimum="0"
                                                              Maximum="1000000"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.EndDistance,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <CheckBox Content="路由到ConfigOut"
                                                      Width="250"
                                                      Margin="20,4,0,8"
                                                      IsChecked="{Binding ModelParam.AcsLciPulseParam.RouteConfigOutput,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="输出索引："
                                                              hc:InfoElement.TitleWidth="120"
                                                              Width="250"
                                                              DecimalPlaces="0"
                                                              Minimum="0"
                                                              Maximum="10"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.ConfigOutputIndex,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="输出代码："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="65535"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.AcsLciPulseParam.ConfigOutputCode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="坐标数组触发窗口："
                                                              hc:InfoElement.TitleWidth="130"
                                                              Width="250"
                                                              DecimalPlaces="6"
                                                              Minimum="0.000001"
                                                              Maximum="1000"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.CoordinateArrayMultiAxWinSize,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="坐标数组速度："
                                                              hc:InfoElement.TitleWidth="120"
                                                              Width="250"
                                                              DecimalPlaces="3"
                                                              Minimum="0"
                                                              Maximum="1000000"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.AcsLciPulseParam.CoordinateArrayVelocity,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <TextBlock Margin="20,4,0,12"
                                                   Foreground="#6A7480"
                                                   TextWrapping="Wrap"
                                                   Text="启用后每段线轨迹会调用ACS的TryRunLciFixedDistancePulseXseg执行。结束距离小于等于起始距离时，自动使用当前线段长度。"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <GroupBox Header="参数说明">
                                    <TextBlock Margin="12"
                                               TextWrapping="Wrap"
                                               Foreground="#4C5A67"
                                               Text="这里配置的位置比较参数会在执行轨迹前传入控制卡的 ControlPosComparison。修改后点击“确认”保存，后续执行时会读取当前配置值。"/>
                                </GroupBox>

                                <WxGroupBox:WxGroupBox Header="打点参数" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Width="560" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="IO 掩码(ushort)："
                                                              hc:InfoElement.TitleWidth="160"
                                                              Width="420"
                                                              DecimalPlaces="0"
                                                              Minimum="0"
                                                              Maximum="65535"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.PointOperationIoMaskHex,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="关闭延时(ms)："
                                                          hc:InfoElement.TitleWidth="160"
                                                          Width="420"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="65535"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PointOperationCloseDelayMs,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="到位延时(ms)："
                                                          hc:InfoElement.TitleWidth="160"
                                                          Width="420"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="65535"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PointReadyDelayMs,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto"
                              Margin="5,5,5,0"
                              Header="轨迹预览"
                              ExpandDirection="Down"
                              VerticalAlignment="Top"
                              IsExpanded="True"
                              Style="{DynamicResource ExpanderStyle}">
                        <Border Background="#F7F9FB" CornerRadius="8" Padding="8" Margin="8,8,8,8">
                            <trajectoryControls:SkiaTrajectoryDesignerControl
                                Height="380"
                                IsPreviewOnly="True"
                                Shapes="{Binding DesignedTrajectoryPreviewShapes}"
                                CoordinateStartX="{Binding DesignedTrajectoryPreviewCoordinateStartX}"
                                CoordinateStartY="{Binding DesignedTrajectoryPreviewCoordinateStartY}"
                                CoordinateEndX="{Binding DesignedTrajectoryPreviewCoordinateEndX}"
                                CoordinateEndY="{Binding DesignedTrajectoryPreviewCoordinateEndY}"
                                DefaultCenterX="{Binding DesignedTrajectoryPreviewDefaultCenterX}"
                                DefaultCenterY="{Binding DesignedTrajectoryPreviewDefaultCenterY}" />
                        </Border>
                    </Expander>

                    <Expander Width="auto"
                              MaxHeight="420"
                              Margin="5,5,5,0"
                              Header="输出信息"
                              ExpandDirection="Down"
                              VerticalAlignment="Top"
                              IsExpanded="True"
                              Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="360"
                                          ItemsSource="{Binding ModelParam.OutputParamNames}"
                                          SelectedItem="{Binding SltOutputParamName,Mode=TwoWay}"
                                          Height="25"
                                          BorderThickness="0 0 0 1"
                                          Margin="5 0"/>
                                <Button Content="&#xe630;"
                                        Width="30"
                                        Height="26"
                                        FontSize="18"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Background="White"
                                        FontFamily="{StaticResource Iconfont}"
                                        BorderBrush="White"
                                        ToolTip="添加"
                                        Command="{Binding DataOperateCommand}"
                                        CommandParameter="Add"/>
                                <Button Content="&#xe74b;"
                                        Width="30"
                                        Height="26"
                                        FontSize="18"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Background="White"
                                        FontFamily="{StaticResource Iconfont}"
                                        BorderBrush="White"
                                        Margin="5 0"
                                        ToolTip="删除"
                                        Command="{Binding DataOperateCommand}"
                                        CommandParameter="Delete"/>
                            </StackPanel>

                            <DataGrid AutoGenerateColumns="False"
                                      Style="{StaticResource DefaultDataGridStyle}"
                                      EnableColumnVirtualization="True"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      ItemsSource="{Binding ModelParam.OutputParams}"
                                      SelectedItem="{Binding CurrentOutputParam}"
                                      FontSize="12"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      Height="340"
                                      RowHeaderWidth="20"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      IsReadOnly="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}"
                                                         HorizontalAlignment="Stretch"
                                                         BorderThickness="0"
                                                         Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          Height="25"
                                                          BorderThickness="0 0 0 1"
                                                          Margin="5 0"
                                                          Background="Transparent"
                                                          SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}"
                                                         HorizontalAlignment="Center"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{Binding Describe}"
                                                         HorizontalAlignment="Stretch"
                                                         BorderThickness="0"
                                                         Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Grid.RowSpan="2"
                Grid.ColumnSpan="2"

                BorderThickness="0 2 0 0"
                BorderBrush="{DynamicResource SelectedBrush}"
                CornerRadius="5"
                Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical" WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime, Mode=OneWay}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0"
                            FontSize="18"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="执行标定"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="35"
                            Width="auto"
                            Content="执行标定"
                            Cursor="Hand"/>

                    <Button Margin="0,0,15,0"
                            FontSize="18"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="执行"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="35"
                            Width="80"
                            Content="执行"
                            Cursor="Hand"/>
                    <Button Margin="0,0,15,0"
                            FontSize="18"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="取消"
                            Width="80"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="取消"
                            Cursor="Hand"/>
                    <Button Margin="0,0,15,0"
                            FontSize="18"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="确认"
                            Style="{StaticResource GeneralButtonStyle}"
                            Width="80"
                            Content="确认"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

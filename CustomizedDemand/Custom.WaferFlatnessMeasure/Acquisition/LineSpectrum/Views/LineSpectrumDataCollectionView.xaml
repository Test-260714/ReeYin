<UserControl x:Class="Custom.WaferFlatnessMeasure.Views.LineSpectrumDataCollectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:project="clr-namespace:ReeYin_V.Core.Services.Project;assembly=ReeYin_V.Core"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             Height="720"
             Width="1100"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="720"
             d:DesignWidth="1100">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="72"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="1.25*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Padding="8">
            <TabControl Style="{StaticResource TabControlWithUnderLineStyle}">
                <TabItem Header="线光谱采集" Width="120" Style="{StaticResource TabItemExWithUnderLineStyle}">
                    <StackPanel Margin="8">
                        <WxGroupBox:WxGroupBox Header="传感器设置" Margin="0,0,0,10">
                            <UniformGrid Columns="2" Margin="12">
                                <TextBlock Text="传感器选择:" Foreground="Black" VerticalAlignment="Center"/>
                                <ComboBox Width="240"
                                          Margin="5"
                                          BorderThickness="0 0 0 1"
                                          Foreground="Black"
                                          ItemsSource="{Binding ModelParam.Models}"
                                          DisplayMemberPath="NickName"
                                          SelectedItem="{Binding ModelParam.SltModel,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="SelectionChanged">
                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换模块"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ComboBox>

                                <TextBlock Text="高度缩放:" Foreground="Black" VerticalAlignment="Center"/>
                                <hc:NumericUpDown DecimalPlaces="4"
                                                  Minimum="0.0001"
                                                  Maximum="99999999"
                                                  Width="240"
                                                  Margin="5"
                                                  Style="{StaticResource NumericUpDownExtendGlobal}"
                                                  BorderThickness="0 0 0 1"
                                                  Value="{Binding ModelParam.HeightScale,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="TIFF导出路径:" Foreground="Black" VerticalAlignment="Center"/>
                                <Grid Margin="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             MinWidth="180"
                                             Margin="0,0,6,0"
                                             Style="{StaticResource TextBoxExtend}"
                                             Text="{Binding ModelParam.TiffOutputDirectory,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="1"
                                            Width="60"
                                            Height="28"
                                            Content="选择"
                                            Command="{Binding SelectTiffOutputDirectoryCommand}"
                                            Style="{StaticResource GeneralButtonStyle}"/>
                                </Grid>
                            </UniformGrid>
                        </WxGroupBox:WxGroupBox>

                        <WxGroupBox:WxGroupBox Header="触发设置" Margin="0,0,0,10">
                            <Grid Margin="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <RadioButton Grid.Row="0"
                                             Grid.Column="0"
                                             Margin="0,0,0,10"
                                             Style="{StaticResource ToggleButtonSwitch}"
                                             Content="触发开始采集"
                                             IsChecked="{Binding ModelParam.StartCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="5,0,0,10"
                                         hc:InfoElement.TitlePlacement="Left"
                                         hc:InfoElement.Title="事件名称："
                                         hc:InfoElement.TitleWidth="90"
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding ModelParam.StartEventName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                <RadioButton Grid.Row="1"
                                             Grid.Column="0"
                                             Style="{StaticResource ToggleButtonSwitch}"
                                             Content="触发停止采集"
                                             IsChecked="{Binding ModelParam.StopCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Margin="5,0,0,0"
                                         hc:InfoElement.TitlePlacement="Left"
                                         hc:InfoElement.Title="事件名称："
                                         hc:InfoElement.TitleWidth="90"
                                         Style="{StaticResource TextBoxExtend}"
                                         Text="{Binding ModelParam.StopEventName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </WxGroupBox:WxGroupBox>

                        <WxGroupBox:WxGroupBox Header="最近采集结果">
                            <StackPanel Margin="12">
                                <TextBlock Foreground="Black" Margin="0,0,0,6">
                                    <Run Text="高度行数："/>
                                    <Run Text="{Binding ModelParam.HeightRowCount, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Foreground="Black" Margin="0,0,0,6">
                                    <Run Text="灰度行数："/>
                                    <Run Text="{Binding ModelParam.GrayRowCount, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Foreground="#666666"
                                           TextWrapping="Wrap"
                                           Text="{Binding ModelParam.LastCollectSummary, Mode=OneWay}"/>
                            </StackPanel>
                        </WxGroupBox:WxGroupBox>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Border>

        <GridSplitter Grid.Row="0"
                      Grid.Column="1"
                      Background="{DynamicResource BtnOverColor}"
                      HorizontalAlignment="Stretch"/>

        <Expander Grid.Row="0"
                  Grid.Column="2"
                  Margin="8"
                  Header="输出信息"
                  ExpandDirection="Down"
                  IsExpanded="True"
                  Style="{DynamicResource ExpanderStyle}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5,2">
                    <TextBlock Text="数据:" VerticalAlignment="Center"/>
                    <ComboBox Width="260"
                              Height="25"
                              Margin="5,0"
                              ItemsSource="{Binding ModelParam.OutputParamNames}"
                              SelectedItem="{Binding SltOutputParamName,Mode=TwoWay}"/>
                    <Button Content="&#xe630;"
                            Width="30"
                            Height="26"
                            FontSize="18"
                            FontFamily="{StaticResource Iconfont}"
                            Style="{StaticResource GeneralButtonStyle}"
                            ToolTip="添加"
                            Command="{Binding DataOperateCommand}"
                            CommandParameter="Add"/>
                    <Button Content="&#xe74b;"
                            Width="30"
                            Height="26"
                            Margin="5,0"
                            FontSize="18"
                            FontFamily="{StaticResource Iconfont}"
                            Style="{StaticResource GeneralButtonStyle}"
                            ToolTip="删除"
                            Command="{Binding DataOperateCommand}"
                            CommandParameter="Delete"/>
                </StackPanel>

                <DataGrid AutoGenerateColumns="False"
                          Style="{StaticResource DefaultDataGridStyle}"
                          ItemsSource="{Binding ModelParam.OutputParams}"
                          SelectedItem="{Binding CurrentOutputParam}"
                          Height="420"
                          FontSize="12"
                          RowHeaderWidth="20"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          IsReadOnly="False"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="参数名称" Binding="{Binding Name,UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTemplateColumn Header="数据类型" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Width="120"
                                              helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                              helper:ItemsControlHelper.EnumType="{x:Type project:DataType}"
                                              SelectedItem="{Binding Type,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="值" Binding="{Binding Value}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridCheckBoxColumn Header="全局" Binding="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Expander>

        <Border Grid.Row="1"
                Grid.ColumnSpan="3"
                BorderThickness="0 2 0 0"
                BorderBrush="{DynamicResource SelectedBrush}"
                Padding="8">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock>
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button Margin="0,0,15,0"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="执行"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="35"
                            Width="80"
                            Content="执行"/>
                    <Button Margin="0,0,15,0"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="取消"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="35"
                            Width="80"
                            Content="取消"/>
                    <Button Command="{Binding GeneralCommand}"
                            CommandParameter="确认"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="35"
                            Width="80"
                            Content="确认"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="Custom.WaferRoutePlan.Views.WaferRoutePlanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:local="clr-namespace:Custom.WaferRoutePlan.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">

    <UserControl.Resources>
        <local:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter"/>

        <!-- 数字输入 -->
        <DataTemplate x:Key="NumberTemplate">
            <WxNumericUpDown:WxNumericUpDown Margin="0 5 0 5" FontSize="12" HorizontalContentAlignment="Center" Minimum="{Binding MinValue}" Maximum="{Binding MaxValue}" SmallChange="{Binding SmallChange}"  
                                             Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <!-- 文本输入 -->
        <DataTemplate x:Key="TextTemplate">
            <TextBox FontSize="12" Margin="0 5 0 5" HorizontalContentAlignment="Center" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <!-- 下拉选择 -->
        <DataTemplate x:Key="ComboBoxTemplate">
            <ComboBox FontSize="12" Margin="0 5 0 5" HorizontalContentAlignment="Center" ItemsSource="{Binding Options}" SelectedItem="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <!-- 选择器 -->
        <local:ParamTemplateSelector x:Key="ParamTemplateSelector" NumberTemplate="{StaticResource NumberTemplate}" TextTemplate="{StaticResource TextTemplate}" 
                                     ComboBoxTemplate="{StaticResource ComboBoxTemplate}" />

    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="基础参数" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid x:Name="gd">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="120"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Margin="0,5,0,0">
                                    <GroupBox Header="输入链接">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Width="500" HorizontalAlignment="Center">
                                                <TextBlock Width="150" Text="输入图像:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                                               OutputParam="{Binding ModelParam.InputImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="0 15" Text="{Binding ModelParam.InputImage.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Width="500" HorizontalAlignment="Center">
                                                <TextBlock Width="150" Text="输入轮廓:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" 
                                                               OutputParam="{Binding ModelParam.InputCircle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="0 15" Text="{Binding ModelParam.InputCircle.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                
                                <Border Grid.Row="1" Margin="0,5,0,0">
                                    <GroupBox Header="扫描配置">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500" >
                                                <TextBlock Text="扫描方式:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" Width="150"/>
                                                <ComboBox BorderThickness="0 0 0 0" Width="350" Margin="0 15 0 15" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" VerticalAlignment="Center"
                                                SelectedItem="{Binding CurrentScanType, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ItemsSource="{Binding ScanTypesArray}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                
                                <Border Grid.Row="2" Margin="0,5,0,0">
                                    <GroupBox Header="扫描参数" Visibility="{Binding CurrentScanType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter='旋转线扫,水平线扫,点扫,相切圆点扫,圆环扫描,拍摄中心自标定'}">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Height="300">
                                            <ItemsControl ItemsSource="{Binding CurrentParamDefinitions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500">
                                                            <!-- 参数名称 -->
                                                            <TextBlock Text="{Binding Name}"  FontSize="12" 
                                                               Foreground="Black" 
                                                               VerticalAlignment="Center" 
                                                               Margin="0 5 0 5" 
                                                               Width="150"/>

                                                            <!-- 根据 UIType 自动切换不同控件 -->
                                                            <ContentControl Content="{Binding}" FontSize="12"
                                                                ContentTemplateSelector="{StaticResource ParamTemplateSelector}" 
                                                                Width="350" Margin="0 5 0 5"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>
                        <TabItem Header="输入参数" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid >
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="200"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Margin="0,5,0,0">
                                    <GroupBox Header="拍摄圆心的机械坐标">
                                        <StackPanel>
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="X坐标：" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center"
                                                  Value="{Binding ModelParam.XPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="Y坐标：" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center"
                                                  Value="{Binding ModelParam.YPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="Z坐标：" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center"
                                                  Value="{Binding ModelParam.ZPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                <Border Grid.Row="1" Margin="0,5,0,0">
                                    <GroupBox Header="激光中心图像坐标">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500">
                                                <TextBlock Width="150" Text="列坐标I:" Foreground="Black"  VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" Margin="0 15 0 15" 
                                                        InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  
                                                        Order="OpenParam" Text="{Binding ModelParam.LaserIPos,Mode=TwoWay,UpdateSourceTrigger=LostFocus,StringFormat=F4}"/>
                                            </StackPanel>
                                            <!--<hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="J坐标：" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center"
                                                  Value="{Binding ModelParam.JPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>-->
                                            <!--<hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="Z坐标：" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center"
                                                  Value="{Binding ModelParam.ZPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>-->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Width="500">
                                                <TextBlock Width="150" Text="行坐标J:" Foreground="Black"  VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="350" Margin="0 15 0 15" 
                                                        InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  
                                                        Order="OpenParam" Text="{Binding ModelParam.LaserJPos,Mode=TwoWay,UpdateSourceTrigger=LostFocus,StringFormat=F4}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                                <Border Grid.Row="2" Margin="0,5,0,0">
                                    <GroupBox Header="标定文件">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                <TextBlock Width="150" Text="相机标定:" Foreground="Black"  VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <TextBox Text="{Binding ModelParam.CalibrationFile,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="300" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                <Button Width="30" Height="30" Content="&#xe60e;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                 Command="{Binding GeneralCommand}" CommandParameter="标定文件"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                <TextBlock Width="150" Text="N点标定(可选):" Foreground="Black"  VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <TextBox Text="{Binding ModelParam.NPointCalibrationFile,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="300" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                <Button Width="30" Height="30" Content="&#xe60e;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                 Command="{Binding GeneralCommand}" CommandParameter="N点标定文件"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <Controls:ImageEditView Image="{Binding ModelParam.PreviewImage,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" Height="500" Margin="5"
                                                    DrawObjectList="{Binding ModelParam.PreviewDrawObjectList,Mode=OneWay}"
                                                    Background="{StaticResource BackgroudBrush}"/>
                        </StackPanel>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
             Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                     ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                 Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                     ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      ItemsSource="{Binding ModelParam.OutputParams}" 
                      SelectedItem="{Binding CurrentOutputParam}"
                      FontSize="12" 
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Height="160"
                      RowHeaderWidth="20"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
         SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                <!--<TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>-->
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>

        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="执行"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                    Height="auto" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="auto" Width="80"
                                                    Content="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</UserControl>


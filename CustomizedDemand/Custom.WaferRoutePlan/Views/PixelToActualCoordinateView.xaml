<UserControl x:Class="Custom.WaferRoutePlan.Views.PixelToActualCoordinateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             FontSize="14"
             Height="880"
             Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880"
             d:DesignWidth="1280">

    <UserControl.Resources>
        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="ResultCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F0F4F8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="0,37,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.55*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.45*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="5" Background="#FAFBFC">
                <TabControl Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                    <TabItem Header="输入参数" Width="110" FontSize="18" FontWeight="Medium" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,8,0,0">
                                <WxGroupBox:WxGroupBox Header="拍照实际坐标" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionBorderStyle}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="X/Y 坐标：" hc:InfoElement.TitleWidth="100" Width="200" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#3498DB" HorizontalContentAlignment="Center" Value="{Binding ModelParam.CaptureXPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Width="100" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#3498DB" HorizontalContentAlignment="Center" Value="{Binding ModelParam.CaptureYPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Border>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="图像尺寸" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionBorderStyle}">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="宽/高：" hc:InfoElement.TitleWidth="80" Width="200" Minimum="1" Style="{StaticResource NumericUpDownExtendGlobal}" DecimalPlaces="0" BorderThickness="0 0 0 2" BorderBrush="#2ECC71" HorizontalContentAlignment="Center" Value="{Binding ModelParam.ImageWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Width="100" Style="{StaticResource NumericUpDownExtendGlobal}" Minimum="1" DecimalPlaces="0" BorderThickness="0 0 0 2" BorderBrush="#2ECC71" HorizontalContentAlignment="Center" Value="{Binding ModelParam.ImageHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Border>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="两点像素坐标" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="P1 I/J：" hc:InfoElement.TitleWidth="100" Width="200" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#9B59B6" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistancePoint1PixelI,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <hc:NumericUpDown Width="100" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#9B59B6" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistancePoint1PixelJ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="P2 I/J：" hc:InfoElement.TitleWidth="100" Width="200" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#E74C3C" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistancePoint2PixelI,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <hc:NumericUpDown Width="100" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#E74C3C" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistancePoint2PixelJ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="像素坐标（外部链接）" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Width="140" Text="X 像素坐标：" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                <WxLink:WxLink Width="340" InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" OutputParam="{Binding ModelParam.CircleCenterI,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Order="OpenParam" Margin="0,10" Text="{Binding ModelParam.CircleCenterI.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <TextBlock Width="140" Text="Y 像素坐标：" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                <WxLink:WxLink Width="340" InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" OutputParam="{Binding ModelParam.CircleCenterJ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Order="OpenParam" Margin="0,10" Text="{Binding ModelParam.CircleCenterJ.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="标定文件" Margin="0,0,0,8">
                                    <Border Style="{StaticResource SectionBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8" HorizontalAlignment="Center">
                                                <TextBlock Width="160" Text="相机标定：" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                <TextBox Text="{Binding ModelParam.CalibrationFile,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="300" Foreground="#2C3E50" VerticalAlignment="Center" BorderThickness="0 0 0 2" BorderBrush="#3498DB" Background="#F8FAFC"/>
                                                <Button Width="32" Height="32" Content="..." FontSize="16" BorderThickness="0" Background="#EBF5FB" Command="{Binding GeneralCommand}" CommandParameter="标定文件" ToolTip="选择标定文件"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4" HorizontalAlignment="Center">
                                                <TextBlock Width="160" Text="N 点标定（可选）：" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                                <TextBox Text="{Binding ModelParam.NPointCalibrationFile,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="300" Foreground="#2C3E50" VerticalAlignment="Center" BorderThickness="0 0 0 2" BorderBrush="#2ECC71" Background="#F8FAFC"/>
                                                <Button Width="32" Height="32" Content="..." FontSize="16" BorderThickness="0" Background="#EBF5FB" Command="{Binding GeneralCommand}" CommandParameter="NPointCalibrationFile" ToolTip="选择 N 点标定文件"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="标定" Width="110" FontSize="18" FontWeight="Medium" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,8,0,0">
                                <WxGroupBox:WxGroupBox Header="相机中心位置" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="X/Y 坐标：" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Grid.Column="1" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#3498DB" HorizontalContentAlignment="Center" Value="{Binding ModelParam.CameraCenterPosX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Column="3" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#3498DB" HorizontalContentAlignment="Center" Value="{Binding ModelParam.CameraCenterPosY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Column="5" Height="32" Content="获取当前坐标" Command="{Binding GeneralCommand}" CommandParameter="GetCurrentPositionToCameraCenter" Style="{StaticResource GeneralButtonStyle}" Background="#3498DB" Foreground="White" FontSize="13"/>
                                        </Grid>
                                    </Border>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="点光谱光点位置" Margin="0,0,0,10">
                                    <Border Style="{StaticResource SectionBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="X/Y 坐标：" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Grid.Column="1" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#9B59B6" HorizontalContentAlignment="Center" Value="{Binding ModelParam.PointSpectrumPosX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Column="3" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#9B59B6" HorizontalContentAlignment="Center" Value="{Binding ModelParam.PointSpectrumPosY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Column="5" Height="32" Content="获取当前坐标" Command="{Binding GeneralCommand}" CommandParameter="GetCurrentPositionToPointSpectrum" Style="{StaticResource GeneralButtonStyle}" Background="#9B59B6" Foreground="White" FontSize="13"/>
                                        </Grid>
                                    </Border>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="点光谱补偿">
                                    <Border Style="{StaticResource SectionBorderStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="150"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="光点-相机：" Foreground="#2C3E50" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Grid.Column="1" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#E67E22" HorizontalContentAlignment="Center" Value="{Binding ModelParam.OutputCompensationX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Column="3" Style="{StaticResource NumericUpDownExtendGlobal}" BorderThickness="0 0 0 2" BorderBrush="#E67E22" HorizontalContentAlignment="Center" Value="{Binding ModelParam.OutputCompensationY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Column="5" Height="32" Content="计算偏差" Command="{Binding GeneralCommand}" CommandParameter="CalculateCalibrationOffset" Style="{StaticResource GeneralButtonStyle}" Background="#E67E22" Foreground="White" FontSize="13"/>
                                        </Grid>
                                    </Border>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="计算结果" Width="110" FontSize="18" FontWeight="Medium" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,8,0,0">
                                <GroupBox Header="结果摘要" Margin="0,0,0,10" FontWeight="Medium">
                                    <StackPanel>
                                        <Border Background="#FFF8E1" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                                            <TextBlock TextWrapping="Wrap" Foreground="#856404" Text="{Binding ModelParam.ResultMessage,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </Border>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#E8F4FD" CornerRadius="4" Padding="6" Margin="0,0,0,4">
                                                <TextBlock Text="图像中心像素坐标" FontWeight="SemiBold" Foreground="#2980B9"/>
                                            </Border>
                                            <hc:NumericUpDown Grid.Row="1" Grid.Column="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="中心 I：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.ImageCenterPixelI,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="中心 J：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.ImageCenterPixelJ,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#E8F8F0" CornerRadius="4" Padding="6" Margin="0,6,0,4">
                                                <TextBlock Text="实际偏移（含点光谱补偿）" FontWeight="SemiBold" Foreground="#27AE60"/>
                                            </Border>
                                            <hc:NumericUpDown Grid.Row="3" Grid.Column="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="偏移 X：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.ActualOffsetX,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="3" Grid.Column="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="偏移 Y：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.ActualOffsetY,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <Border Grid.Row="4" Grid.ColumnSpan="2" Background="#F0E6F6" CornerRadius="4" Padding="6" Margin="0,6,0,4">
                                                <TextBlock Text="圆心实际坐标（点光谱光点）" FontWeight="SemiBold" Foreground="#8E44AD"/>
                                            </Border>
                                            <hc:NumericUpDown Grid.Row="5" Grid.Column="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="圆心 X：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.CircleCenterActualX,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="5" Grid.Column="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="圆心 Y：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.CircleCenterActualY,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <Border Grid.Row="6" Grid.ColumnSpan="2" Background="#FEF5E7" CornerRadius="4" Padding="6" Margin="0,6,0,4">
                                                <TextBlock Text="点光谱补偿" FontWeight="SemiBold" Foreground="#D35400"/>
                                            </Border>
                                            <hc:NumericUpDown Grid.Row="7" Grid.Column="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="补偿 X：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.OutputCompensationX,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="7" Grid.Column="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="补偿 Y：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.OutputCompensationY,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <Border Grid.Row="8" Grid.ColumnSpan="2" Background="#E8F4FD" CornerRadius="4" Padding="6" Margin="0,6,0,4">
                                                <TextBlock Text="两点距离计算结果" FontWeight="SemiBold" Foreground="#2980B9"/>
                                            </Border>
                                            <hc:NumericUpDown Grid.Row="9" Grid.Column="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="P1 X：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistancePoint1ActualX,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="9" Grid.Column="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="P1 Y：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistancePoint1ActualY,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="10" Grid.Column="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="P2 X：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistancePoint2ActualX,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="10" Grid.Column="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="P2 Y：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistancePoint2ActualY,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="11" Grid.Column="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="位移 X：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistanceActualOffsetX,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="11" Grid.Column="1" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="位移 Y：" hc:InfoElement.TitleWidth="70" Width="150" IsEnabled="False" BorderThickness="0 0 0 1" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistanceActualOffsetY,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="物理距离：" hc:InfoElement.TitleWidth="70" Width="300" IsEnabled="False" BorderThickness="0 0 0 2" BorderBrush="#E74C3C" FontWeight="Bold" HorizontalContentAlignment="Center" Value="{Binding ModelParam.DistanceActualValue,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Header="计算逻辑说明" FontWeight="Medium">
                                    <Border Background="#FFF8E1" CornerRadius="6" Padding="12">
                                        <TextBlock TextWrapping="Wrap" Foreground="#856404" FontSize="13" LineHeight="22">
                                            <Run Text="圆心实际坐标(点光谱光点) = 相机中心计算出的实际圆心 + 点光谱补偿(光点-相机)"/>
                                            <LineBreak/>
                                            <Run Text="P1/P2 先映射到标定实际平面，再按 sqrt((P2X-P1X)² + (P2Y-P1Y)²) 计算物理距离，该距离不叠加点光谱补偿。"/>
                                        </TextBlock>
                                    </Border>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1" Height="730" Background="#E2E8F0" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2" Background="#FAFBFC">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="结果总览" ExpandDirection="Down" VerticalAlignment="Top" IsExpanded="True" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel Margin="8">
                            <Border Style="{StaticResource ResultCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="圆心实际 X" Foreground="#7F8C8D" FontSize="12"/>
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#2C3E50" Text="{Binding ModelParam.CircleCenterActualX,StringFormat=F6}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="圆心实际 Y" Foreground="#7F8C8D" FontSize="12"/>
                                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#2C3E50" Text="{Binding ModelParam.CircleCenterActualY,StringFormat=F6}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource ResultCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="当前状态" Foreground="#7F8C8D" FontSize="12"/>
                                    <TextBlock Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#2C3E50" FontSize="13" Text="{Binding ModelParam.ResultMessage,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ResultCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="物理距离" Foreground="#7F8C8D" FontSize="12"/>
                                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#E74C3C" Text="{Binding ModelParam.DistanceActualValue,StringFormat=F6}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="补偿 X/Y" Foreground="#7F8C8D" FontSize="12"/>
                                        <TextBlock FontSize="16" Foreground="#D35400" Text="{Binding ModelParam.OutputCompensationX,StringFormat='F4'}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Expander>

                    <Expander Width="auto" MaxHeight="420" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" VerticalAlignment="Top" IsExpanded="True" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5,4">
                                <TextBlock Text="数据：" VerticalAlignment="Center" Foreground="#2C3E50"/>
                                <ComboBox Width="340" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName,Mode=TwoWay}" Height="28" BorderThickness="0 0 0 2" BorderBrush="#3498DB" Margin="5,0"/>
                                <Button Content="+" Width="30" Height="28" FontSize="16" Style="{StaticResource GeneralButtonStyle}" Background="#27AE60" Foreground="White" BorderThickness="0" ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="-" Width="30" Height="28" FontSize="16" Style="{StaticResource GeneralButtonStyle}" Background="#E74C3C" Foreground="White" BorderThickness="0" Margin="4,0" ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>

                            <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}" EnableColumnVirtualization="True" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" ItemsSource="{Binding ModelParam.OutputParams}" SelectedItem="{Binding CurrentOutputParam}" FontSize="12" ScrollViewer.HorizontalScrollBarVisibility="Auto" Height="340" RowHeaderWidth="20" SelectionUnit="FullRow" HeadersVisibility="Column" GridLinesVisibility="All" IsReadOnly="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent" SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="0,748,0,0" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical" WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding GeneralCommand}" CommandParameter="执行" Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80" Content="执行" Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="取消" Width="80" Style="{StaticResource GeneralButtonStyle}" Content="取消" Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="确认" Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80" Content="确认" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

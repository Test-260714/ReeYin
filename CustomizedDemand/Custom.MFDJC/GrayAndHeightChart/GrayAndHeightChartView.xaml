<UserControl x:Class="Custom.MFDJC.GrayAndHeightChart.GrayAndHeightChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lcu="http://schemas.arction.com/charting/ultimate/"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:local="clr-namespace:Custom.MFDJC.GrayAndHeightChart"
             xmlns:drawingCanvasViewer="clr-namespace:Custom.MFDJC"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="2000">
    <UserControl.Resources>
        <Style TargetType="{x:Type drawingCanvasViewer:DrawingCanvasViewer}">
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ScrollViewer.VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type drawingCanvasViewer:DrawingCanvasViewer}">
                        <Grid>
                            <Label
                            x:Name="Part_Label"
                            Height="20"
                            Padding="5,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="9999"
                            Visibility="Hidden" />

                            <Border x:Name="Part_ImageBorder" ClipToBounds="True">
                                <Grid>
                                    <Image
                                    x:Name="Part_Image"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    RenderOptions.EdgeMode="Aliased"
                                    Stretch="Uniform" />
                                    <Viewbox>
                                        <Viewbox.ContextMenu>
                                            <ContextMenu Visibility="Hidden" />
                                        </Viewbox.ContextMenu>
                                        <ContentPresenter x:Name="Part_ContentPresenter" Content="{TemplateBinding DrawingCanvas}" />
                                    </Viewbox>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Page.Styles.Button.Base" TargetType="{x:Type ButtonBase}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style
			x:Key="Page.Styles.Button.Color"
			BasedOn="{StaticResource Page.Styles.Button.Base}"
			TargetType="{x:Type ToggleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <StackPanel>
                                <Border
									Width="24"
									Height="24"
									Padding="1"
									Background="Transparent"
									BorderBrush="Transparent"
									BorderThickness="1"
									CornerRadius="2">
                                    <Rectangle
										Fill="{TemplateBinding Foreground}"
										RadiusX="2"
										RadiusY="2" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style BasedOn="{StaticResource ButtonPrimary}" TargetType="{x:Type Button}" />
        <Style
			x:Key="toolButtonStyle"
			BasedOn="{StaticResource ButtonPrimary}"
			TargetType="{x:Type Button}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <!--<Setter Property="FontFamily" Value="{StaticResource IconFont}" />-->
            <Setter Property="FontSize" Value="22" />
        </Style>
        <Style BasedOn="{StaticResource RadioButtonIconBaseStyle}" TargetType="RadioButton">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Content" Value="&#xe637;" />
            <!--<Setter Property="FontFamily" Value="{StaticResource IconFont}" />-->
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource MainPrimaryTextBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid Width="1800" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="3"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Height="50">
            <DockPanel Margin="10,0,0,0" VerticalAlignment="Center">
                <Rectangle
					Width="5"
					Height="20"
					Fill="White" />

                <TextBlock
					Margin="10,0"
					VerticalAlignment="Center"
					FontSize="15"
					FontWeight="Bold"
					Foreground="{DynamicResource MainPrimaryTextBrush}"
					Text="灰度/高度图" />
            </DockPanel>
        </Border>
        
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>

            <hc:SimplePanel Grid.Row="0" x:Name="HCSimplePanel" MinWidth="700" MinHeight="700">
                <!--主要内容-->
                <lcu:LightningChart x:Name="LightningChart" MinHeight="700" Margin="5" MinWidth="700" />

                <!--瑕疵信息显示覆盖层-->
                <Expander x:Name="DefectInfoExpander"
				          Width="320" MaxHeight="750"
				          HorizontalAlignment="Right"
				          VerticalAlignment="Top"
				          Margin="0,15,20,0"
				          IsExpanded="True"
				          Header="瑕疵信息"
				          Foreground="White"
				          Background="#96000000"
				          BorderBrush="Transparent"
				          BorderThickness="0">

                    <Border 
						Background="#96000000"
						BorderBrush="Gray"
						BorderThickness="1,0,1,1"
						CornerRadius="0,0,3,3"
						Padding="10,5,10,10">
                        <!--瑕疵列表滚动区域-->
                        <ScrollViewer
							x:Name="sv_DefectList"
							Height="{Binding ActualHeight,RelativeSource={RelativeSource AncestorType=hc:SimplePanel}}"
							VerticalScrollBarVisibility="Auto"
							HorizontalScrollBarVisibility="Hidden">
                            <StackPanel x:Name="sp_DefectList" Margin="0,0,0,60">
                                <TextBlock
									Text="暂无瑕疵数据"
									FontSize="10"
									Foreground="LightGray"
									HorizontalAlignment="Center"
									Margin="0,20" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                </Expander>

                <!--操作-->
                <Expander Header="点击此处显示或隐藏" Background="Gray" BorderThickness="0" HorizontalContentAlignment="Center"
                  IsExpanded="True" Margin="10" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                    <Border  MaxHeight="200"  CornerRadius="3">
                        <Border.Background>
                            <SolidColorBrush Color="Gray" Opacity="0.7" />
                        </Border.Background>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" Height="200" Width="400" >
                            <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" Margin="10">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!--参数设置按钮 - 改为ToggleButton-->
                                    <ToggleButton Content="参数设置"  Height="30" IsChecked="{Binding IsOpen, ElementName=DrawerLeft}" />

                                    <!--质量设置下拉菜单-->
                                    <hc:ComboBox Width="100" Height="30" Margin="5,0" VerticalAlignment="Center" x:Name="cb_QualityMode"
									IsEnabled="{Binding Model.IsEnabeld}" SelectedIndex="4" ToolTip="选择图表质量模式">
                                        <ComboBoxItem Content="极速" Tag="UltraFast" />
                                        <ComboBoxItem Content="快速" Tag="Fast" />
                                        <ComboBoxItem Content="平衡" Tag="Balanced" />
                                        <ComboBoxItem Content="高质量" Tag="HighQuality" />
                                        <ComboBoxItem Content="超高质量" Tag="UltraHighQuality" />
                                    </hc:ComboBox>

                                    <!--调色板选择器-->
                                    <hc:ComboBox Width="80" Height="30" Margin="5,0" VerticalAlignment="Center" SelectedIndex="0" ToolTip="选择调色板" x:Name="cb_ColorPalette"
										IsEnabled="{Binding Model.IsEnabeld}">
                                        <ComboBoxItem Content="经典" Tag="Classic" />
                                        <ComboBoxItem Content="热图" Tag="Heatmap" />
                                    </hc:ComboBox>
                                </StackPanel>

                                <!-- 色域范围设置 -->
                                <CheckBox Margin="0 5 0 0" Content="自定义色域" Foreground="{DynamicResource MainPrimaryTextBrush}" IsChecked="False" VerticalAlignment="Center" HorizontalAlignment="Left" x:Name="chk_CustomColorRange" 
						  FontSize="10" Checked="OnCustomColorRangeChecked" Unchecked="OnCustomColorRangeUnchecked" ToolTip="启用自定义色域范围"/>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0 5 0 0" IsEnabled="{Binding IsChecked, ElementName=chk_CustomColorRange}">
                                    <TextBlock Text="范围:"  Foreground="{DynamicResource MainPrimaryTextBrush}"  VerticalAlignment="Center" Margin="0,0,5,0" FontSize="10"/>

                                    <hc:NumericUpDown Value="-1.0" DecimalPlaces="2" Increment="0.1"  Width="100" Height="20" ToolTip="最小值" x:Name="nud_MinValue"  FontSize="10"
                                                      ValueChanged="OnMinValueChanged" />

                                    <TextBlock Text="~" Foreground="{DynamicResource MainPrimaryTextBrush}" VerticalAlignment="Center" Margin="3,0"/>

                                    <hc:NumericUpDown Value="1.0" DecimalPlaces="2" Increment="0.1"  Width="100" Height="20" ToolTip="最大值"  FontSize="10"
									  ValueChanged="OnMaxValueChanged" x:Name="nud_MaxValue" />

                                    <Button Content="数据范围" Height="25" Width="60" FontSize="9" Background="Transparent" BorderBrush="{DynamicResource BorderBrush}" Foreground="{DynamicResource MainPrimaryTextBrush}"
							Click="OnApplyDataRangeClick" Margin="5,0,0,0" ToolTip="应用当前数据范围" x:Name="btn_ApplyDataRange"/>
                                </StackPanel>

                                <!--视距控制-->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0 5 0 0">
                                    <TextBlock
										Text="视距:"
										VerticalAlignment="Center"
										Margin="0,0,5,0"
										Foreground="{DynamicResource MainPrimaryTextBrush}"
										FontSize="10" />
                                    <Slider Width="100" Height="20" Minimum="50" Maximum="500" Value="180" VerticalAlignment="Center" TickPlacement="None"
											ToolTip="调整视距 (50-500) &#x0A;+/- 键快速调整" IsEnabled="{Binding Model.IsEnabeld}" x:Name="slider_ViewDistance"/>
                                    <TextBlock Text="180" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="{DynamicResource MainPrimaryTextBrush}"
										FontSize="10" Width="30" x:Name="tb_ViewDistance"/>
                                </StackPanel>

                                <!-- 3D高度维度控制 -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0 5 0 0">
                                    <TextBlock
										Text="高度缩放:"
										VerticalAlignment="Center"
										Margin="0,0,5,0"
										Foreground="{DynamicResource MainPrimaryTextBrush}"
										FontSize="10" />
                                    <hc:NumericUpDown
										Width="80"
										Value="1.0"
										Minimum="0.1"
										Maximum="100.0"
										Increment="0.1"
										DecimalPlaces="1"
										ToolTip="调整3D视图的Y轴缩放 (0.1 - 5.0)"
										IsEnabled="{Binding Model.IsEnabeld}"
										KeyDown="Nud_3DHeight_KeyDown" x:Name="nud_3DHeight"
										LostFocus="Nud_3DHeight_LostFocus" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0 5 0 0">
                                    <!--视图控制按钮-->
                                    <Button Content="&#xe62f;" Width="30" Height="30" Margin="5,0" Background="Transparent" BorderBrush="Transparent" FontSize="16" FontFamily="{StaticResource Iconfont}"
									Foreground="{DynamicResource MainPrimaryTextBrush}" ToolTip="还原初始视图 (Home键)" IsEnabled="{Binding Model.IsEnabeld}" Cursor="Hand" x:Name="btn_ResetView" Style="{DynamicResource toolButtonStyle}"/>

                                    <!--适配视图按钮-->
                                    <Button Content="&#xe654;" Width="35" Height="30" Margin="2,0" Background="Transparent" BorderBrush="Transparent" FontSize="16" FontFamily="{StaticResource Iconfont}"
					Foreground="{DynamicResource MainPrimaryTextBrush}" ToolTip="适配数据视图" IsEnabled="{Binding Model.IsEnabeld}" Cursor="Hand" x:Name="btn_FitView" Style="{DynamicResource toolButtonStyle}"/>

                                    <!--深度范围信息-->
                                    <!--<TextBlock
					x:Name="tb_DepthRange"
					Margin="10,0"
					VerticalAlignment="Center"
					FontSize="10"
					Foreground="{DynamicResource MainPrimaryTextBrush}"
					Text="深度范围: 加载中..."
					ToolTip="当前有效深度范围" />-->

                                    <!--圆形信息显示-->
                                    <TextBlock
										x:Name="tb_CircleInfo"
										Margin="10,0"
										VerticalAlignment="Center"
										FontSize="10"
										Foreground="{DynamicResource MainPrimaryTextBrush}"
										Text="圆形: 未绘制"
										ToolTip="当前绘制圆形的信息"
										Visibility="Collapsed" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Expander>

                <hc:DrawerContainer>
                    <hc:Drawer Name="DrawerLeft" Dock="Left" ShowMode="Push" IsOpen="False">
                        <Border Background="#96000000" 
								Width="420" 
								BorderThickness="1" 
								BorderBrush="Gray"
								CornerRadius="3">
                            <Grid Margin="15">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!--标题栏-->
                                <DockPanel Grid.Row="0" Margin="0,0,0,15">
                                    <TextBlock Text="缺陷检测参数设置" 
											   FontSize="14" 
											   FontWeight="Bold" 
											   Foreground="White" 
											   DockPanel.Dock="Left"/>
                                    <Button Command="hc:ControlCommands.Close" 
											HorizontalAlignment="Right" 
											Foreground="White" 
											Style="{StaticResource ButtonIcon}" 
											hc:IconElement.Geometry="{StaticResource DeleteFillCircleGeometry}"
											Background="Transparent"
											BorderBrush="Transparent"/>
                                </DockPanel>

                                <!--动态内容容器-->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="DynamicConfigContainer" Margin="0,0,0,20">
                                        <!--这里将动态生成配置控件-->
                                    </StackPanel>
                                </ScrollViewer>

                                <!--底部按钮区域-->
                                <StackPanel Grid.Row="2" 
											Orientation="Horizontal" 
											HorizontalAlignment="Right" 
											Margin="0,15,0,0">
                                    <Button Content="重置" 
											Width="60" 
											Height="30"
											Background="Transparent"
											BorderBrush="Gray"
											Foreground="White"
											Margin="0,0,10,0"
											Click="btn_Reset_Click"/>
                                    <Button Content="应用" 
											Width="60" 
											Height="30"
											Style="{StaticResource ButtonPrimary}"
											Margin="0,0,10,0"
											Click="btn_Apply_Click"/>
                                    <Button Content="保存" 
											Width="60" 
											x:Name="btn_Save"
											Height="30"
											Style="{StaticResource ButtonSuccess}"
											Click="btn_Save_Click"/>
                                </StackPanel>

                            </Grid>
                        </Border>
                    </hc:Drawer>
                </hc:DrawerContainer>
            </hc:SimplePanel>
        </Grid>

        <GridSplitter Grid.Column="1" Grid.Row="1" Height="800" Background="{DynamicResource BtnOverColor}" ResizeBehavior="PreviousAndNext"  HorizontalAlignment="Stretch" Cursor=""/>

        <!--绘制形状-->
        <Grid Grid.Column="2" Grid.Row="1" HorizontalAlignment="Left" Margin="10 0 0 0">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <drawingCanvasViewer:DrawingCanvasViewer x:Name="drawViewer">
                <drawingCanvasViewer:DrawingCanvas x:Name="drawCanvas" Background="Transparent" />
            </drawingCanvasViewer:DrawingCanvasViewer>
            <ToolBarTray
				Grid.Row="1"
				HorizontalAlignment="Center"
				Orientation="Horizontal">
                <ToolBar
					x:Name="toolbar"
					Background="Transparent"
					ToolBarTray.IsLocked="True">
                    <Button FontFamily="{StaticResource Iconfont}"
						x:Name="btn_SaveImage"
						Content="&#xe641;"
						IsEnabled="{Binding Model.IsEnabeld}"
						Click="btn_SaveImage_Click"
						Style="{DynamicResource toolButtonStyle}" />
                    <Button FontFamily="{StaticResource Iconfont}"
						x:Name="btn_OriginalScale"
						Content="&#xe611;"
						IsEnabled="{Binding Model.IsEnabeld}"
						Style="{DynamicResource toolButtonStyle}" />
                    <!--<Button FontFamily="{StaticResource Iconfont}"
						x:Name="btn_Ellipse"
						Content="&#xe61d;"
						IsEnabled="{Binding Model.IsEnabeld}"
						Style="{DynamicResource toolButtonStyle}" />-->

                    <Button FontFamily="{StaticResource Iconfont}"
						x:Name="btn_ClearTools"
						Content="&#xeaf2;"
						IsEnabled="{Binding Model.IsEnabeld}"
						Style="{DynamicResource toolButtonStyle}" />

                    <Popup
						IsOpen="{Binding IsChecked, ElementName=btn_color}"
						Placement="Bottom"
						PlacementTarget="{Binding ElementName=btn_color}">
                        <hc:ColorPicker x:Name="color_picker" />
                    </Popup>
                </ToolBar>
            </ToolBarTray>
        </Grid>

    </Grid>
</UserControl>

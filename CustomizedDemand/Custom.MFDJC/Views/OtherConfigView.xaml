<UserControl x:Class="Custom.MFDJC.Views.OtherConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.MFDJC.Views"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" FontSize="12"
             d:DesignHeight="450" d:DesignWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        
        <WxGroupBox:WxGroupBox Header="其他配置" >
            <!-- 日志显示区域：带滚动条的TextBlock -->
            <ScrollViewer Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel>
                    <hc:PropertyGrid SelectedObject="{Binding Model}" FontSize="12" Background="Transparent"/>

                    <StackPanel Orientation="Vertical">

                        <DockPanel Margin="10 " HorizontalAlignment="Left">
                            <TextBlock Text="存图路径:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                            <WxLink:WxLink MinWidth="150" MaxWidth="200" Margin="5 0" Order="OpenFile" Text="{Binding Model.SavePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                           hc:TitleElement.Title="asdasdas" hc:TitleElement.TitleWidth="100"/>
                        </DockPanel>

                        <DockPanel  Margin="10 ">
                            <TextBlock  Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" MaxWidth="200">
                                <Run Text="从文件中加载图片:"/>
                                <Run Text="{Binding FilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </TextBlock>
                            <Button Margin="0,0,0,0" FontSize="18" HorizontalAlignment="Right"
                                                    Command="{Binding GeneralCommand}" CommandParameter="打开"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="60"
                                                    Content="打开"
                                                    Cursor="Hand"/>
                        </DockPanel>

                    </StackPanel>
                </StackPanel>

            </ScrollViewer>
            
        </WxGroupBox:WxGroupBox>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
            <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="保存"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="100"
                                                    Content="保存"
                                                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>

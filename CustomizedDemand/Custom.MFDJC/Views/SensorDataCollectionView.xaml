<UserControl x:Class="Custom.MFDJC.Views.SensorDataCollectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.MFDJC.Views"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:project="clr-namespace:ReeYin_V.Core.Services.Project;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280" Loaded="UserControl_Loaded"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <Button Name="btnLogin" Margin="5 0 5 0" IsEnabled="{Binding IsEnabled}" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ImportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe645;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导入配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button IsEnabled="{Binding IsEnabled}" Margin="5 0 5 0" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ExportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe646;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导出配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <!--主体-->
        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="基础配置" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="采集模式" Margin="5 5 5 10">
                                    <Grid >
                                        <Border CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TabControl Width="600" Height="550" SelectedIndex="{Binding ModelParam.SltTriggerPicIndex,Mode=TwoWay}" Style="{DynamicResource TabControlStyle}">
                                                <TabItem Header="指定图像"  Style="{DynamicResource SingleTabItemStyle}" >
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center">
                                                                <RadioButton FontSize="14" Margin="0 0 0 0" Width="83" Height="32" IsChecked="True" Content="选择文件" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="选择文件"/>

                                                                <RadioButton FontSize="14" Margin="100 0 0 0" Width="83" Height="32" Content="链接路径" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="链接路径"/>

                                                            </StackPanel>

                                                            <Grid>
                                                                <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center">
                                                                    <TextBox Text="{Binding ModelParam.SltFile,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                    <Button Width="30" Height="30" Content="&#xe7b9;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="打开文件"/>
                                                                </StackPanel>

                                                                <StackPanel Visibility="{Binding ModelParam.IsLinkVisibility,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                                    <TextBox Text="{Binding ModelParam.LinkPath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                    <Button Width="30" Height="30" Content="&#xe60e;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="链接图片"/>
                                                                    <Button Width="30" Height="30" Content="&#xeaf2;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="取消链接"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="文件目录" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBox Text="{Binding ModelParam.FilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                <Button Content="&#xe7b9;" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="获取路径"/>
                                                            </StackPanel>
                                                            <TextBlock Text="选择文件夹，文件夹中应包含两份灰度/高度图" Foreground="Black" VerticalAlignment="Center"/>
                                                            <StackPanel/>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="指定采集" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                                            <UniformGrid Columns="2" Margin="0,0,0,8" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                                <TextBlock Text="传感器选择:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center"
                                                                          ItemsSource="{Binding ModelParam.Models}" DisplayMemberPath="NickName" SelectedItem="{Binding ModelParam.SltModel,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                                    <i:Interaction.Triggers>
                                                                        <i:EventTrigger EventName="SelectionChanged">
                                                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换模块"/>
                                                                        </i:EventTrigger>
                                                                    </i:Interaction.Triggers>
                                                                </ComboBox>

                                                                <!--<TextBlock Text="相机旋转:" Foreground="Black" VerticalAlignment="Center" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Margin="5"
                                                                          ItemsSource="{Binding }" SelectedItem="{Binding ModelParam.CamSltRotate }"/>-->

                                                                <!--<TextBlock Text="采集模式:" Foreground="Black" VerticalAlignment="Center" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Margin="5"
                                                                          ItemsSource="{Binding ModelParam.SelectedCameraModel.TrigModes}" SelectedItem="{Binding ModelParam.SelectedCameraModel.TrigMode}"/>-->

                                                                <TextBlock Text="传感器备注:" Foreground="Black" VerticalAlignment="Center"/>
                                                                <TextBox Width="200"  Height="25" BorderThickness="0 0 0 1" Margin="5 0" Text="{Binding ModelParam.SelectedCameraModel.Remarks,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>

                                                                <TextBlock Text="曝光时间:" Foreground="Black" VerticalAlignment="Center" />
                                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="0 0" SmallChange="1" BorderThickness="0 0 0 1"
                                                                    Value="{Binding ModelParam.SelectedCameraModel.ExposeTime,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                                <!--<TextBlock Text="增益:" Foreground="Black" VerticalAlignment="Center" />
                                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="0 0" SmallChange="0.1"  BorderThickness="0 0 0 1"
                                                                    Value="{Binding ModelParam.SelectedCameraModel.Gain,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>-->

                                                            </UniformGrid>

                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发开始采集" Width="auto" Margin="0 0 0 10" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding ModelParam.StartCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发停止采集" Width="auto" HorizontalAlignment="Left" FontSize="16" Margin="0 0 0 10"
                                                               IsChecked="{Binding ModelParam.StopCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发停止采集并处理数据" Width="auto" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding ModelParam.StopAndDispose,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>


                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                            </TabControl>
                                        </Border>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="图像参数" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="文件设置>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                                        <StackPanel Orientation="Vertical">
                                            <CheckBox Content="启用存图" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding ModelParam.IsSaveImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                <TextBlock Text="存图路径:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="500" Margin="5 0" Order="OpenFile" Text="{Binding ModelParam.OtherConfig.SavePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <UniformGrid Columns="2" Margin="0,0,0,8" HorizontalAlignment="Center" VerticalAlignment="Top">
                                                <TextBlock Text="保存天数:" Foreground="Black" VerticalAlignment="Center" />
                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="5 0" SmallChange="1"
                                                                 Value="{Binding ModelParam.SaveDays}"/>
                                            </UniformGrid>

                                        </StackPanel>
                                    </WxGroupBox:WxGroupBox>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="其他配置" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}" Height="45" VerticalAlignment="Top">
                            <Grid>
                                <WxGroupBox:WxGroupBox Header="传感器配置参数" >
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="X像素当量：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.Algorithm.IntervalX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="Y像素当量：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.Algorithm.IntervalY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="Z像素当量：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.Algorithm.IntervalZ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="深度值下限：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.Algorithm.MinDepth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="深度值上限：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.Algorithm.MaxDepth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="图片拼接X偏移(um)：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.Algorithm.OffsetX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="图片拼接Y偏移(um)：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.Algorithm.OffsetY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="手动图片拼接X偏移(um)：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.OtherConfig.ManualOffsetX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="手动图片拼接Y偏移(um)：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.OtherConfig.ManualOffsetY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" Minimum="0" Maximum="1" DecimalPlaces="0" hc:InfoElement.Title="流程选择(填0或1)：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.SelectFlow,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>


                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </Grid>
                        </TabItem>

                        <TabItem Header="输出信息" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>

                            </Grid>
                        </TabItem>

                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
             Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                     ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                 Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                     ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      ItemsSource="{Binding ModelParam.OutputParams}" 
                      SelectedItem="{Binding CurrentOutputParam}"
                      FontSize="12" 
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Height="160"
                      RowHeaderWidth="20"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" 
                                                                        helper:ItemsControlHelper.EnumType="{x:Type project:DataType}"
                                                          Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
         SelectedItem="{Binding Type,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                <!--<TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>-->
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="打开图像预览"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="auto"
                                                    Content="预览3D图"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="执行"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                    Height="auto" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="auto" Width="80"
                                                    Content="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>


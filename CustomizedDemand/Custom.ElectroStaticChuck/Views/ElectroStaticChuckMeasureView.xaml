<UserControl x:Class="Custom.ElectroStaticChuckMeasure.Views.ElectroStaticChuckMeasureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:WinFormHost="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Loaded="UserControl_Loaded"
             FontFamily="Microsoft YaHei UI"
             FontSize="13"
             MaxWidth="1280"
             MaxHeight="820"
             d:DesignHeight="820"
             d:DesignWidth="1280">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Background="{DynamicResource RegionBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Row="0"
                      Grid.Column="0"
                      Margin="14"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Text="ElectroStaticChuck" />

                <Expander Margin="0,14,0,0"
                          Header="标定"
                          IsExpanded="True"
                          Style="{DynamicResource ExpanderStyle}">
                    <StackPanel Margin="10">
                        <TextBlock Margin="0,0,0,6" Text="Calibration frame directory" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="42" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ModelParam.CalibrationFrameDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Command="{Binding BrowseCalibrationFrameDirectoryCommand}"
                                    Content="..."
                                    Style="{StaticResource GeneralButtonStyle}" />
                        </Grid>

                        <TextBlock Margin="0,0,0,6" Text="Output directory" />
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="42" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding ModelParam.OutputDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Command="{Binding BrowseOutputDirectoryCommand}"
                                    Content="..."
                                    Style="{StaticResource GeneralButtonStyle}" />
                        </Grid>

                        <CheckBox Margin="0,0,0,8"
                                  Content="UsePitchCorrection"
                                  IsChecked="{Binding ModelParam.UsePitchCorrection, Mode=TwoWay}" />
                        <CheckBox Margin="0,0,0,8"
                                  Content="UseYawCorrection"
                                  IsChecked="{Binding ModelParam.UseYawCorrection, Mode=TwoWay}" />
                        <Button Height="34"
                                Command="{Binding RunCalibrationCommand}"
                                Content="执行姿态标定"
                                Style="{StaticResource GeneralButtonStyle}" />
                    </StackPanel>
                </Expander>

                <Expander Margin="0,12,0,0"
                          Header="Sensor"
                          IsExpanded="True"
                          Style="{DynamicResource ExpanderStyle}">
                    <UniformGrid Margin="10" Columns="2">
                        <TextBlock VerticalAlignment="Center" Text="IntervalX" />
                        <TextBox Text="{Binding ModelParam.SensorIntervalX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="IntervalY" />
                        <TextBox Text="{Binding ModelParam.SensorIntervalY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="IntervalZ" />
                        <TextBox Text="{Binding ModelParam.SensorIntervalZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="MinDepth" />
                        <TextBox Text="{Binding ModelParam.SensorMinDepth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="MaxDepth" />
                        <TextBox Text="{Binding ModelParam.SensorMaxDepth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock VerticalAlignment="Center" Text="InvalidValue" />
                        <TextBox Text="{Binding ModelParam.SensorInvalidValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="IsFlip"
                                  IsChecked="{Binding ModelParam.SensorIsFlip, Mode=TwoWay}" />
                    </UniformGrid>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="0"
              Grid.Column="1"
              Margin="0,14,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Expander Header="测量输入"
                      IsExpanded="True"
                      Style="{DynamicResource ExpanderStyle}">
                <StackPanel Margin="10">
                    <TextBlock Margin="0,0,0,6" Text="Measurement frame directory" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="42" />
                        </Grid.ColumnDefinitions>
                        <TextBox Text="{Binding ModelParam.MeasurementFrameDirectory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Margin="6,0,0,0"
                                Command="{Binding BrowseMeasurementFrameDirectoryCommand}"
                                Content="..."
                                Style="{StaticResource GeneralButtonStyle}" />
                    </Grid>
                </StackPanel>
            </Expander>

            <TabControl Grid.Row="1"
                        Margin="0,12,0,0"
                        Style="{StaticResource TabControlWithUnderLineStyle}">
                <TabItem Header="Registration"
                         Style="{StaticResource TabItemExWithUnderLineStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <UniformGrid Margin="12" Columns="2">
                            <TextBlock Text="Fine Mode" />
                            <ComboBox ItemsSource="{Binding FineRegistrationModes}"
                                      SelectedItem="{Binding ModelParam.FineRegistrationMode, Mode=TwoWay}" />
                            <TextBlock Text="SearchWindowX" />
                            <TextBox Text="{Binding ModelParam.CoarseSearchWindowX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="SearchWindowY" />
                            <TextBox Text="{Binding ModelParam.CoarseSearchWindowY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="SearchSpeedFactor" />
                            <TextBox Text="{Binding ModelParam.CoarseSearchSpeedFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="HeightWeight" />
                            <TextBox Text="{Binding ModelParam.CoarseHeightWeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="GrayWeight" />
                            <TextBox Text="{Binding ModelParam.CoarseGrayWeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="MaskWeight" />
                            <TextBox Text="{Binding ModelParam.CoarseMaskWeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="ZSampleStepPixel" />
                            <TextBox Text="{Binding ModelParam.NoRegistrationZSampleStepPixel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="MinZSampleCount" />
                            <TextBox Text="{Binding ModelParam.NoRegistrationMinZSampleCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="IcpLeafSizeMultiplier" />
                            <TextBox Text="{Binding ModelParam.IcpLeafSizeMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="IcpMaxIterations" />
                            <TextBox Text="{Binding ModelParam.IcpMaxIterations, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="IcpMaxDistanceMultiplier" />
                            <TextBox Text="{Binding ModelParam.IcpMaxCorrespondenceDistanceMultiplier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="IcpMinDistance" />
                            <TextBox Text="{Binding ModelParam.IcpMinMaxCorrespondenceDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="TransformationEpsilon" />
                            <TextBox Text="{Binding ModelParam.IcpTransformationEpsilon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="FitnessEpsilon" />
                            <TextBox Text="{Binding ModelParam.IcpFitnessEpsilon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="MinInlierRatio" />
                            <TextBox Text="{Binding ModelParam.IcpMinInlierRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Content="NoRegistrationUseZCorrection"
                                      IsChecked="{Binding ModelParam.NoRegistrationUseZCorrection, Mode=TwoWay}" />
                            <CheckBox Content="OptimizeX"
                                      IsChecked="{Binding ModelParam.OptimizeX, Mode=TwoWay}" />
                            <CheckBox Content="OptimizeY"
                                      IsChecked="{Binding ModelParam.OptimizeY, Mode=TwoWay}" />
                            <CheckBox Content="OptimizeZ"
                                      IsChecked="{Binding ModelParam.OptimizeZ, Mode=TwoWay}" />
                            <CheckBox Content="OptimizeYawDeg"
                                      IsChecked="{Binding ModelParam.OptimizeYawDeg, Mode=TwoWay}" />
                        </UniformGrid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Measurement"
                         Style="{StaticResource TabItemExWithUnderLineStyle}">
                    <UniformGrid Margin="12" Columns="2">
                        <TextBlock Text="MeasurementMode" />
                        <ComboBox ItemsSource="{Binding MeasurementModes}"
                                  SelectedItem="{Binding ModelParam.MeasurementMode, Mode=TwoWay}" />
                        <TextBlock Text="ConvexStandardDiameter" />
                        <TextBox Text="{Binding ModelParam.ConvexStandardDiameter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="ConvexStandardHeight" />
                        <TextBox Text="{Binding ModelParam.ConvexStandardHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="TileCoreWidthPixel" />
                        <TextBox Text="{Binding ModelParam.StreamingTileCoreWidthPixel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="TileCoreHeightPixel" />
                        <TextBox Text="{Binding ModelParam.StreamingTileCoreHeightPixel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="TileHaloPixel" />
                        <TextBox Text="{Binding ModelParam.StreamingTileHaloPixel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="EnableStitching"
                                  IsChecked="{Binding ModelParam.EnableStitching, Mode=TwoWay}" />
                    </UniformGrid>
                </TabItem>

                <TabItem Header="Export"
                         Style="{StaticResource TabItemExWithUnderLineStyle}">
                    <UniformGrid Margin="12" Columns="2">
                        <TextBlock Text="ImageDownsampleFactor" />
                        <TextBox Text="{Binding ModelParam.ImageDownsampleFactor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="PointCloudStride" />
                        <TextBox Text="{Binding ModelParam.StitchingPointCloudStride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="DrawLabels"
                                  IsChecked="{Binding ModelParam.DrawLabels, Mode=TwoWay}" />
                        <CheckBox Content="DrawOverlay"
                                  IsChecked="{Binding ModelParam.DrawOverlay, Mode=TwoWay}" />
                        <CheckBox Content="SavePreviewImages"
                                  IsChecked="{Binding ModelParam.SavePreviewImages, Mode=TwoWay}" />
                        <CheckBox Content="SavePointCloud"
                                  IsChecked="{Binding ModelParam.SavePointCloud, Mode=TwoWay}" />
                        <CheckBox Content="RenderOverlay"
                                  IsChecked="{Binding ModelParam.RenderOverlay, Mode=TwoWay}" />
                        <CheckBox Content="ExportResults"
                                  IsChecked="{Binding ModelParam.ExportResults, Mode=TwoWay}" />
                    </UniformGrid>
                </TabItem>
            </TabControl>
        </Grid>

        <ScrollViewer Grid.Row="0"
                      Grid.Column="2"
                      Margin="14"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Expander Header="结果"
                          IsExpanded="True"
                          Style="{DynamicResource ExpanderStyle}">
                    <StackPanel Margin="10">
                        <UniformGrid Columns="2">
                            <TextBlock Text="RunStatus" />
                            <TextBlock FontWeight="SemiBold" Text="{Binding RunStatusText}" />
                            <TextBlock Text="RunTime" />
                            <TextBlock FontWeight="SemiBold" Text="{Binding RunTimeText}" />
                            <TextBlock Text="Calibration" />
                            <TextBlock FontWeight="SemiBold" Text="{Binding CalibrationStateText}" />
                            <TextBlock Text="ConvexsFlatness" />
                            <TextBlock FontWeight="SemiBold" Text="{Binding ModelParam.ConvexsFlatness}" />
                            <TextBlock Text="OverallFlatness" />
                            <TextBlock FontWeight="SemiBold" Text="{Binding ModelParam.OverallFlatness}" />
                            <TextBlock Text="LastErrorStage" />
                            <TextBlock FontWeight="SemiBold" Text="{Binding ModelParam.LastErrorStage}" />
                        </UniformGrid>
                        <TextBlock Margin="0,12,0,6" Text="CalibrationMessage" />
                        <TextBox MinHeight="46"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 Text="{Binding ModelParam.CalibrationMessage, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                        <TextBlock Margin="0,12,0,6" Text="MeasurementMessage" />
                        <TextBox MinHeight="58"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 Text="{Binding ModelParam.MeasurementMessage, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                        <TextBlock Margin="0,12,0,6" Text="ExportOutputPaths" />
                        <TextBox MinHeight="58"
                                 AcceptsReturn="True"
                                 IsReadOnly="True"
                                 Text="{Binding ModelParam.ExportOutputPathsText, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Expander>

                <Expander Margin="0,12,0,0"
                          Header="图像预览"
                          IsExpanded="False"
                          Style="{DynamicResource ExpanderStyle}">
                    <WinFormHost:WindowsFormsHost x:Name="winFormHost"
                                                  Height="240"
                                                  Margin="6" />
                </Expander>

                <Expander Margin="0,12,0,0"
                          Header="输出参数"
                          IsExpanded="True"
                          Style="{DynamicResource ExpanderStyle}">
                    <StackPanel Margin="10">
                        <DockPanel Margin="0,0,0,8">
                            <Button DockPanel.Dock="Right"
                                    Width="30"
                                    Height="26"
                                    Command="{Binding DataOperateCommand}"
                                    CommandParameter="Add"
                                    Content="&#xe630;"
                                    FontFamily="{StaticResource Iconfont}"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    ToolTip="添加" />
                            <Button DockPanel.Dock="Right"
                                    Width="30"
                                    Height="26"
                                    Margin="6,0,0,0"
                                    Command="{Binding DataOperateCommand}"
                                    CommandParameter="Delete"
                                    Content="&#xe74b;"
                                    FontFamily="{StaticResource Iconfont}"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    ToolTip="删除" />
                            <ComboBox ItemsSource="{Binding ModelParam.OutputParamNames}"
                                      SelectedItem="{Binding SltOutputParamName, Mode=TwoWay}" />
                        </DockPanel>
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  Height="220"
                                  ItemsSource="{Binding ModelParam.OutputParams}"
                                  SelectedItem="{Binding CurrentOutputParam}"
                                  Style="{StaticResource DefaultDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Width="*" Binding="{Binding Name, Mode=TwoWay}" Header="参数名称" />
                                <DataGridTextColumn Width="*" Binding="{Binding Value}" Header="值" IsReadOnly="True" />
                                <DataGridCheckBoxColumn Width="70" Binding="{Binding IsGlobal, Mode=TwoWay}" Header="全局" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <GroupBox Grid.Row="1"
                  Grid.ColumnSpan="3"
                  Margin="14,0,14,10"
                  Header="运行日志">
            <ListBox ItemsSource="{Binding OperationLogs}" />
        </GroupBox>

        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                BorderBrush="{DynamicResource SelectedBrush}"
                BorderThickness="0,2,0,0"
                Padding="8">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Width="100"
                        Margin="0,0,12,0"
                        Command="{Binding ExecuteMeasurementCommand}"
                        Content="执行测量"
                        Style="{StaticResource GeneralButtonStyle}" />
                <Button Width="80"
                        Margin="0,0,12,0"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="取消"
                        Content="取消"
                        Style="{StaticResource GeneralButtonStyle}" />
                <Button Width="80"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="确认"
                        Content="确认"
                        Style="{StaticResource GeneralButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

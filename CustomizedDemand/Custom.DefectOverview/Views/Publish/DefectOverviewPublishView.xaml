<UserControl x:Class="Custom.DefectOverview.Views.DefectOverviewPublishView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="1380"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             d:DesignHeight="720"
             d:DesignWidth="1380">

    <UserControl.Resources>
        <DataTemplate x:Key="TransmitParamComboTemplate">
            <TextBlock TextTrimming="CharacterEllipsis">
                <Run Text="{Binding Serial, StringFormat={}{0:000}}"/>
                <Run Text=" "/>
                <Run Text="{Binding Name}"/>
                <Run Text=" / "/>
                <Run Text="{Binding ParamName}"/>
            </TextBlock>
        </DataTemplate>
        <Style x:Key="PublishSchemeTabItemStyle" TargetType="{x:Type TabItem}">
            <Setter Property="MinWidth" Value="118"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="#FFF7F7F7"
                                BorderBrush="#FFD6D6D6"
                                BorderThickness="1"
                                CornerRadius="5,5,0,0"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                TextElement.FontWeight="{TemplateBinding FontWeight}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="#FFFFFCF2"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#FFE3C55B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#7C5A00"/>
                                <Setter TargetName="TabBorder" Property="Background" Value="#FFFFFFFF"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#FFC69200"/>
                                <Setter TargetName="TabBorder" Property="BorderThickness" Value="1,1,1,0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#999999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Padding="8"
                Background="#FFF7F3D6"
                BorderBrush="#FFE3C55B"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Width="120"
                        Margin="12,0,0,0"
                        Padding="10,4"
                        Content="刷新输入"
                        Command="{Binding RefreshInputParamsCommand}"/>
                <TextBlock Foreground="#7C5A00"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Text="用途：发布当前流程缺陷结果到缺陷总览、缺陷墙和地图；路径图像用于裁剪预览图。方案C按连续采集相机输出生成多相机通道。"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="0,12,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="0"/>
                    <ColumnDefinition Width="0"/>
                </Grid.ColumnDefinitions>

                <GroupBox Header="发布方案" Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Margin="0,0,0,8"
                                Padding="8"
                                Background="#FFF9F9F9"
                                BorderBrush="#FFE0E0E0"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock VerticalAlignment="Center"
                                           Foreground="#666666"
                                           Text="选择 A/B/C 发布接线方案；页面不再靠勾选隐藏，切换页签就是切换当前模式。"/>
                                <CheckBox Grid.Column="1"
                                          Margin="12,0,0,0"
                                          VerticalAlignment="Center"
                                          Content="保存缺陷缩略图到本地"
                                          IsChecked="{Binding ModelParam.SaveLocalDefectImages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <Grid Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock VerticalAlignment="Center"
                                               Text="路径名称"/>
                                    <TextBox Grid.Column="1"
                                             Height="28"
                                             Text="{Binding ModelParam.PathName, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Column="3"
                                               VerticalAlignment="Center"
                                               Text="结果模式"/>
                                    <ComboBox Grid.Column="4"
                                              Height="28"
                                              ItemsSource="{Binding ResultModes}"
                                              SelectedItem="{Binding ModelParam.ResultMode, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Column="5"
                                               Margin="12,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="#888888"
                                               Text="布局和左右角色由当前方案自动决定。"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <TabControl Grid.Row="1"
                                    MinHeight="470"
                                    Padding="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderBrush="#FFE0E0E0"
                                    BorderThickness="0"
                                    ItemContainerStyle="{StaticResource PublishSchemeTabItemStyle}"
                                    SelectedIndex="{Binding SelectedPublishSchemeIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                            <TabItem Header="方案A 单路">
                                <Grid Margin="12,10,12,8" MinHeight="420">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="#666666"
                                                   TextWrapping="Wrap"
                                                   Text="单路：一路路径图像 + 一路缺陷结果，适合普通发布节点。"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       VerticalAlignment="Center"
                                                       Text="路径图像"/>
                                            <ComboBox Grid.Row="0"
                                                      Grid.Column="1"
                                                      Margin="6"
                                                      ItemTemplate="{StaticResource TransmitParamComboTemplate}"
                                                      ItemsSource="{Binding ImageCandidates}"
                                                      SelectedItem="{Binding ModelParam.InputImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Row="0"
                                                    Grid.Column="2"
                                                    Margin="6"
                                                    Padding="10,4"
                                                    Command="{Binding ClearSelectedInputCommand}"
                                                    CommandParameter="Image"
                                                    Content="清空"/>

                                            <TextBlock Grid.Row="1"
                                                       VerticalAlignment="Center"
                                                       Text="缺陷结果"/>
                                            <ComboBox Grid.Row="1"
                                                      Grid.Column="1"
                                                      Margin="6"
                                                      ItemTemplate="{StaticResource TransmitParamComboTemplate}"
                                                      ItemsSource="{Binding ResultCandidates}"
                                                      SelectedItem="{Binding ModelParam.InputResults, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Row="1"
                                                    Grid.Column="2"
                                                    Margin="6"
                                                    Padding="10,4"
                                                    Command="{Binding ClearSelectedInputCommand}"
                                                    CommandParameter="Results"
                                                    Content="清空"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="方案B 双路">
                                <Grid Margin="12,10,12,8" MinHeight="420">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="#666666"
                                                   TextWrapping="Wrap"
                                                   Text="双路：左路图像/结果 + 右路图像/结果，同帧键发布到缺陷墙。"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       VerticalAlignment="Center"
                                                       Text="左路图像"/>
                                            <ComboBox Grid.Row="0"
                                                      Grid.Column="1"
                                                      Margin="6"
                                                      ItemTemplate="{StaticResource TransmitParamComboTemplate}"
                                                      ItemsSource="{Binding ImageCandidates}"
                                                      SelectedItem="{Binding ModelParam.LeftInputImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Row="0"
                                                    Grid.Column="2"
                                                    Margin="6"
                                                    Padding="10,4"
                                                    Command="{Binding ClearSelectedInputCommand}"
                                                    CommandParameter="LeftImage"
                                                    Content="清空"/>

                                            <TextBlock Grid.Row="1"
                                                       VerticalAlignment="Center"
                                                       Text="左路结果"/>
                                            <ComboBox Grid.Row="1"
                                                      Grid.Column="1"
                                                      Margin="6"
                                                      ItemTemplate="{StaticResource TransmitParamComboTemplate}"
                                                      ItemsSource="{Binding ResultCandidates}"
                                                      SelectedItem="{Binding ModelParam.LeftInputResults, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Row="1"
                                                    Grid.Column="2"
                                                    Margin="6"
                                                    Padding="10,4"
                                                    Command="{Binding ClearSelectedInputCommand}"
                                                    CommandParameter="LeftResults"
                                                    Content="清空"/>

                                            <TextBlock Grid.Row="2"
                                                       VerticalAlignment="Center"
                                                       Text="右路图像"/>
                                            <ComboBox Grid.Row="2"
                                                      Grid.Column="1"
                                                      Margin="6"
                                                      ItemTemplate="{StaticResource TransmitParamComboTemplate}"
                                                      ItemsSource="{Binding ImageCandidates}"
                                                      SelectedItem="{Binding ModelParam.RightInputImage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Row="2"
                                                    Grid.Column="2"
                                                    Margin="6"
                                                    Padding="10,4"
                                                    Command="{Binding ClearSelectedInputCommand}"
                                                    CommandParameter="RightImage"
                                                    Content="清空"/>

                                            <TextBlock Grid.Row="3"
                                                       VerticalAlignment="Center"
                                                       Text="右路结果"/>
                                            <ComboBox Grid.Row="3"
                                                      Grid.Column="1"
                                                      Margin="6"
                                                      ItemTemplate="{StaticResource TransmitParamComboTemplate}"
                                                      ItemsSource="{Binding ResultCandidates}"
                                                      SelectedItem="{Binding ModelParam.RightInputResults, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Row="3"
                                                    Grid.Column="2"
                                                    Margin="6"
                                                    Padding="10,4"
                                                    Command="{Binding ClearSelectedInputCommand}"
                                                    CommandParameter="RightResults"
                                                    Content="清空"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </TabItem>

                            <TabItem Header="方案C 多相机">
                                <Grid Margin="12,10,12,8" MinHeight="420">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <DockPanel Margin="0,0,0,8" LastChildFill="True">
                                        <Button DockPanel.Dock="Right"
                                                MinWidth="96"
                                                Margin="12,0,0,0"
                                                Padding="10,4"
                                                Content="按相机刷新"
                                                Command="{Binding ResetGroupedDualCameraBindingsCommand}"/>
                                        <TextBlock VerticalAlignment="Center"
                                                   Foreground="#666666"
                                                   TextWrapping="Wrap"
                                                   Text="按前方连续采集相机发图生成行；相机数量跟随上游输出，只选组号和 L/R。"/>
                                    </DockPanel>

                                    <DataGrid Grid.Row="1"
                                              MinHeight="300"
                                              MinWidth="900"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserReorderColumns="False"
                                              EnableColumnVirtualization="False"
                                              FrozenColumnCount="6"
                                              HorizontalScrollBarVisibility="Disabled"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              HeadersVisibility="Column"
                                              ItemsSource="{Binding ModelParam.GroupedDualCameraBindings}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="#" Width="44" Binding="{Binding SortIndex}"/>
                                            <DataGridTextColumn Header="前方相机" Width="140" IsReadOnly="True" Binding="{Binding SourceCameraName}"/>
                                            <DataGridTextColumn Header="输出" Width="100" IsReadOnly="True" Binding="{Binding SourceOutputName}"/>
                                            <DataGridTemplateColumn Header="组号" Width="90">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Margin="2"
                                                                  Height="28"
                                                                  ItemsSource="{Binding DataContext.GroupedDualCameraGroupOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding GroupKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="侧别" Width="92">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Margin="2"
                                                                  Height="28"
                                                                  DisplayMemberPath="DisplayName"
                                                                  SelectedValuePath="Value"
                                                                  ItemsSource="{Binding DataContext.WidthSideOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedValue="{Binding Side, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTextColumn Header="索引" Width="90" IsReadOnly="True" Binding="{Binding DisplayName}"/>
                                            <DataGridTemplateColumn Header="后处理结果源" Width="*" MinWidth="220">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Margin="2"
                                                                  ItemTemplate="{StaticResource TransmitParamComboTemplate}"
                                                                  ItemsSource="{Binding DataContext.ResultCandidates, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  SelectedItem="{Binding ResultInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="路径图像" Width="*" MinWidth="220">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ContentControl Margin="2"
                                                                        Content="{Binding ImageInput}"
                                                                        ContentTemplate="{StaticResource TransmitParamComboTemplate}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridCheckBoxColumn Header="必填" Width="60" Binding="{Binding IsRequired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </GroupBox>
                <GroupBox Grid.Column="2"
                          Header="基础配置"
                          Padding="8"
                          Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Margin="6,0,6,8"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"
                                   Text="这里配置发布行为本身。一般只需要关心路径名称、结果模式，以及当前是单路、双路还是多相机。多相机的路径名称会作为左右聚合通道前缀。"/>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       VerticalAlignment="Center"
                                       Text="路径名称"/>
                            <TextBox Grid.Row="0"
                                     Grid.Column="1"
                                     Margin="6"
                                     Text="{Binding ModelParam.PathName, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1"
                                       VerticalAlignment="Center"
                                       Text="结果模式"/>
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      Margin="6"
                                      ItemsSource="{Binding ResultModes}"
                                      SelectedItem="{Binding ModelParam.ResultMode, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2"
                                       VerticalAlignment="Center"
                                       Text="布局模式"/>
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      Margin="6"
                                      ItemsSource="{Binding FrameLayouts}"
                                      SelectedItem="{Binding ModelParam.FrameLayout, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="3"
                                       VerticalAlignment="Center"
                                       Text="路径角色"/>
                            <ComboBox Grid.Row="3"
                                      Grid.Column="1"
                                      Margin="6"
                                      ItemsSource="{Binding PathRoles}"
                                      SelectedItem="{Binding ModelParam.PathRole, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <GroupBox Grid.Row="1"
                          Grid.ColumnSpan="3"
                          Margin="0,12,0,0"
                          Header="输出设置"
                          Padding="8"
                          Visibility="Collapsed">
                    <DataGrid MinHeight="180"
                              MaxHeight="220"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              IsReadOnly="True"
                              ItemsSource="{Binding ModelParam.OutputParams}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="输出口" Width="180" Binding="{Binding ParamName}"/>
                            <DataGridTextColumn Header="类型" Width="110" Binding="{Binding Type}"/>
                            <DataGridTextColumn Header="来源" Width="90" Binding="{Binding Resourece}"/>
                            <DataGridTextColumn Header="绑定属性" Width="*" Binding="{Binding ResourcePath}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
            </Grid>
        </ScrollViewer>

        <DockPanel Grid.Row="2"
                   Margin="0,12,0,0"
                   LastChildFill="True">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal">
                <Button MinWidth="88"
                        Margin="6,0,0,0"
                        Padding="18,6"
                        Command="{Binding ExecuteCommand}"
                        Content="执行"/>
                <Button MinWidth="88"
                        Margin="6,0,0,0"
                        Padding="18,6"
                        Command="{Binding CancelCommand}"
                        Content="取消"/>
                <Button MinWidth="88"
                        Margin="6,0,0,0"
                        Padding="18,6"
                        Command="{Binding ConfirmCommand}"
                        Content="确认"/>
            </StackPanel>

            <TextBlock VerticalAlignment="Center"
                       Foreground="#666666"
                       Text="{Binding ModelParam.PublishStatusText}"/>
        </DockPanel>
    </Grid>
</UserControl>

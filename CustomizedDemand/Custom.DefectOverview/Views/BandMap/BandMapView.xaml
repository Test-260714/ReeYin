<UserControl x:Class="Custom.DefectOverview.Views.BandMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:local="clr-namespace:Custom.DefectOverview.Views"
             xmlns:models="clr-namespace:Custom.DefectOverview.Models"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             FontSize="13"
             Background="#EEF3F7"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display">
    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D8E1EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="GroupContentCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="CornerRadius" Value="0,0,10,10"/>
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="StateDotStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#9CA3AF"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding StreamState}" Value="Live">
                    <Setter Property="Fill" Value="#16A34A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StreamState}" Value="Warn">
                    <Setter Property="Fill" Value="#F59E0B"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StreamState}" Value="Stale">
                    <Setter Property="Fill" Value="#DC2626"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModuleButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#C69300"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#B88300"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="27"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Padding" Value="9,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#B88300"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#9D7000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#9D7000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModuleButtonStyle}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#8A6100"/>
            <Setter Property="BorderBrush" Value="#D4A938"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#FFF7D6"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#C69300"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#F7E6B2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PointModeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="25"/>
            <Setter Property="Width" Value="86"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="MapToolbarStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D7E2EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="7,4"/>
        </Style>

        <Style x:Key="PointModePanelStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="7,2"/>
        </Style>

        <Style x:Key="MapToolbarLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="10.8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BatchTagStyle" TargetType="Border">
            <Setter Property="Background" Value="#DBEAFE"/>
            <Setter Property="BorderBrush" Value="#BFDBFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,5"/>
        </Style>

        <Style x:Key="HeaderMetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D7E2EC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="MinHeight" Value="92"/>
        </Style>

        <Style x:Key="HeaderStatusCardStyle" TargetType="Border" BasedOn="{StaticResource HeaderMetricCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStatusCode}" Value="OK">
                    <Setter Property="Background" Value="#F0FDF4"/>
                    <Setter Property="BorderBrush" Value="#86EFAC"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStatusCode}" Value="NG">
                    <Setter Property="Background" Value="#FFF1F2"/>
                    <Setter Property="BorderBrush" Value="#FDA4AF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderDataCardStyle" TargetType="Border" BasedOn="{StaticResource HeaderMetricCardStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding StreamState}" Value="Warn">
                    <Setter Property="Background" Value="#FFFBEB"/>
                    <Setter Property="BorderBrush" Value="#FDE68A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StreamState}" Value="Stale">
                    <Setter Property="Background" Value="#FEF2F2"/>
                    <Setter Property="BorderBrush" Value="#FCA5A5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderWidthCardStyle" TargetType="Border" BasedOn="{StaticResource HeaderMetricCardStyle}">
            <Setter Property="Background" Value="#EFF6FF"/>
            <Setter Property="BorderBrush" Value="#93C5FD"/>
        </Style>

        <Style x:Key="HeaderMetricLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="10.8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="HeaderMetricValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="HeaderMetricHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="10.2"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="HeaderMetricStrongHintStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderMetricHintStyle}">
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="10.8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="HeaderMetricUnitStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="10.8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="5,0,0,3"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>

        <Style x:Key="HeaderBatchValueStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderMetricValueStyle}">
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="HeaderWidthValueStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderMetricValueStyle}">
            <Setter Property="Foreground" Value="#0369A1"/>
            <Setter Property="FontSize" Value="26"/>
        </Style>

        <Style x:Key="HeaderStatusValueStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderMetricValueStyle}">
            <Setter Property="FontSize" Value="36"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStatusCode}" Value="OK">
                    <Setter Property="Foreground" Value="#16A34A"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStatusCode}" Value="NG">
                    <Setter Property="Foreground" Value="#E11D48"/>
                    <Setter Property="FontSize" Value="40"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStatusCode}" Value="Idle">
                    <Setter Property="Foreground" Value="#334155"/>
                    <Setter Property="FontSize" Value="30"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderDataValueStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderMetricValueStyle}">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding StreamState}" Value="Warn">
                    <Setter Property="Foreground" Value="#B45309"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding StreamState}" Value="Stale">
                    <Setter Property="Foreground" Value="#DC2626"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderOkInlineTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#15803D"/>
            <Setter Property="FontSize" Value="13.2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HeaderOkStatLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#15803D"/>
            <Setter Property="FontSize" Value="11.6"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HeaderNgStatLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderOkStatLabelStyle}">
            <Setter Property="Foreground" Value="#E11D48"/>
        </Style>

        <Style x:Key="HeaderOkStatValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#15803D"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="34"/>
            <Setter Property="LineHeight" Value="27"/>
        </Style>

        <Style x:Key="HeaderNgStatValueStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderOkStatValueStyle}">
            <Setter Property="Foreground" Value="#E11D48"/>
        </Style>

        <Style x:Key="HeaderNgInlineTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderOkInlineTextStyle}">
            <Setter Property="Foreground" Value="#E11D48"/>
        </Style>

        <Style x:Key="HeaderOkNgValueTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="13.2"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HeaderTotalFrameTextStyle" TargetType="TextBlock" BasedOn="{StaticResource HeaderMetricHintStyle}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="HeaderProductionMetersTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="HeaderStatusAccentBarStyle" TargetType="Border">
            <Setter Property="Width" Value="4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#94A3B8"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding CurrentStatusCode}" Value="OK">
                    <Setter Property="Background" Value="#22C55E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding CurrentStatusCode}" Value="NG">
                    <Setter Property="Background" Value="#E11D48"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeaderWidthAccentBarStyle" TargetType="Border">
            <Setter Property="Width" Value="4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#0284C7"/>
        </Style>

        <Style x:Key="MapGridLineStyle" TargetType="Line">
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="StrokeStartLineCap" Value="Square"/>
            <Setter Property="StrokeEndLineCap" Value="Square"/>
            <Setter Property="Opacity" Value="0.92"/>
            <Setter Property="RenderOptions.EdgeMode" Value="Aliased"/>
        </Style>

        <Style x:Key="PopupToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#8A6100"/>
            <Setter Property="BorderBrush" Value="#D4A938"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="27"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Padding" Value="9,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#FFF7D6"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#C69300"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#F7E6B2"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#F7E6B2"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#B88300"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MapPlotBorderStyle" TargetType="Rectangle">
            <Setter Property="SnapsToDevicePixels" Value="False"/>
            <Setter Property="StrokeThickness" Value="1.7"/>
        </Style>

        <Style x:Key="MapPointButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="MarkerHost"
                              Width="{TemplateBinding Width}"
                              Height="{TemplateBinding Height}"
                              SnapsToDevicePixels="True"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>

                            <Viewbox Stretch="Fill">
                                <Grid Width="28" Height="28">
                                    <Path x:Name="TriangleMarker"
                                          Data="M14,5 L21,21 L7,21 Z"
                                          Fill="{Binding Fill}"
                                          Stroke="{Binding Stroke}"
                                          StrokeThickness="1.6"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed"/>

                                    <Grid x:Name="CircleMarker" Visibility="Collapsed">
                                        <Ellipse Width="17"
                                                 Height="17"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding Fill}"
                                                 Stroke="{Binding Stroke}"
                                                 StrokeThickness="1.6"/>
                                    </Grid>

                                    <Grid x:Name="CrossMarker" Visibility="Collapsed">
                                        <Path Data="M6,6 L22,22"
                                              Stroke="{Binding Stroke}"
                                              StrokeThickness="5.2"
                                              Opacity="0.28"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                        <Path Data="M22,6 L6,22"
                                              Stroke="{Binding Stroke}"
                                              StrokeThickness="5.2"
                                              Opacity="0.28"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                        <Path Data="M6,6 L22,22"
                                              Stroke="{Binding Fill}"
                                              StrokeThickness="3.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                        <Path Data="M22,6 L6,22"
                                              Stroke="{Binding Fill}"
                                              StrokeThickness="3.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"/>
                                    </Grid>
                                </Grid>
                            </Viewbox>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding MarkerKind}" Value="Triangle">
                                <Setter TargetName="TriangleMarker" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding MarkerKind}" Value="Circle">
                                <Setter TargetName="CircleMarker" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding MarkerKind}" Value="Cross">
                                <Setter TargetName="CrossMarker" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MarkerHost" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.1" ScaleY="1.1"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="MarkerHost" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.22" ScaleY="1.22"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LegendCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="7,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="10.4"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Background" Value="#F4F7FA"/>
            <Setter Property="BorderBrush" Value="#C4D0DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="CheckBadge"
                                        Width="12"
                                        Height="12"
                                        CornerRadius="6"
                                        Background="White"
                                        BorderBrush="#94A3B8"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <Path x:Name="CheckGlyph"
                                          Data="M3,7 L6,10 L11,4"
                                          Stroke="White"
                                          StrokeThickness="1.9"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="6,0,0,0"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#94A3B8"/>
                                <Setter TargetName="CheckBadge" Property="Background" Value="#1F2937"/>
                                <Setter TargetName="CheckBadge" Property="BorderBrush" Value="#1F2937"/>
                                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.74"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#7C8EA1"/>
                                <Setter TargetName="RootBorder" Property="Background" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="RootBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
        <i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding UnLoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="6,6,6,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="10,7" MinHeight="118">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource ModuleButtonStyle}"
                            MinWidth="76"
                            Content="开始检测"
                            Command="{Binding StartDetectionCommand}"/>
                    <Button Margin="6,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="76"
                            Content="结束检测"
                            Command="{Binding EndDetectionCommand}"/>
                    <Button Margin="6,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="64"
                            Content="记录"
                            Click="OnOpenBrjReportPageClick"/>
                    <Button Margin="6,0,0,0"
                            Style="{StaticResource ModuleButtonStyle}"
                            MinWidth="64"
                            Content="换卷"
                            Command="{Binding ChangeBatchCommand}"/>
                    <ToggleButton x:Name="SlittingPopupToggleButton"
                                  Margin="6,0,0,0"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource PopupToggleButtonStyle}"
                                  Content="切刀设置"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Style="{StaticResource HeaderMetricCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="生产节拍" Style="{StaticResource HeaderMetricLabelStyle}"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrentSpeedDisplayText}" Style="{StaticResource HeaderMetricValueStyle}"/>
                            <TextBlock Text="m/min" Style="{StaticResource HeaderMetricUnitStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding CumulativeMeters, StringFormat=累计 {0:F2} m}"
                                   Style="{StaticResource HeaderProductionMetersTextStyle}"/>
                    </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource HeaderStatusCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="当前判定" Style="{StaticResource HeaderMetricLabelStyle}"/>
                        <Grid Grid.Row="1" Margin="0,5,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="26"/>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="64"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding CurrentStatusText, FallbackValue=未运行}"
                                       Style="{StaticResource HeaderStatusValueStyle}"/>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="OK" Style="{StaticResource HeaderOkStatLabelStyle}"/>
                                <TextBlock Text="{Binding OkFrames}" Style="{StaticResource HeaderOkStatValueStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                <TextBlock Text="NG" Style="{StaticResource HeaderNgStatLabelStyle}"/>
                                <TextBlock Text="{Binding NgFrames}" Style="{StaticResource HeaderNgStatValueStyle}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="6"
                                       Text="{Binding TotalFrames, StringFormat=总 {0}}"
                                       Style="{StaticResource HeaderTotalFrameTextStyle}"/>
                        </Grid>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding QualityRiskText}"
                                   Style="{StaticResource HeaderMetricHintStyle}"/>
                    </Grid>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource HeaderDataCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="数据链路" Style="{StaticResource HeaderMetricLabelStyle}"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,1">
                            <Ellipse Width="11"
                                     Height="11"
                                     Margin="0,0,7,0"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource StateDotStyle}"/>
                            <TextBlock Text="{Binding DataPrimaryText}" Style="{StaticResource HeaderDataValueStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding DataSummaryText}"
                                   Style="{StaticResource HeaderMetricStrongHintStyle}"/>
                    </Grid>
                    </Border>

                    <Border Grid.Column="6" Style="{StaticResource HeaderWidthCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="实时幅宽" Style="{StaticResource HeaderMetricLabelStyle}"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding RealtimeWidthDisplayText}" Style="{StaticResource HeaderWidthValueStyle}"/>
                            <TextBlock Text="mm" Style="{StaticResource HeaderMetricUnitStyle}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding LineDistanceSummaryText}"
                                   Style="{StaticResource HeaderMetricStrongHintStyle}"/>
                    </Grid>
                    </Border>

                    <Border Grid.Column="8" Style="{StaticResource HeaderMetricCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="卷号 / 路别" Style="{StaticResource HeaderMetricLabelStyle}"/>
                        <TextBlock Grid.Row="1" Margin="0,4,0,0" Text="{Binding BatchNumberText}" Style="{StaticResource HeaderBatchValueStyle}"/>
                        <TextBlock Grid.Row="2"
                                   Text="{Binding RouteSummaryText}"
                                   Style="{StaticResource HeaderMetricStrongHintStyle}"/>
                        <TextBlock Grid.Row="3"
                                   Text="{Binding RollTraceSummaryText}"
                                   Style="{StaticResource HeaderMetricHintStyle}"/>
                    </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3.1*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="2.7*"/>
            </Grid.ColumnDefinitions>

            <WxGroupBox:WxGroupBox Header="带材地图">
                <Border Style="{StaticResource GroupContentCardStyle}" Padding="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource MapToolbarStyle}" Margin="0,0,0,4">
                            <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Style="{StaticResource PointModePanelStyle}"
                                        HorizontalAlignment="Left">
                                <StackPanel
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            ToolTip="{Binding PointDisplayModeHintText}">
                                    <TextBlock Text="点位"
                                               Style="{StaticResource MapToolbarLabelStyle}"
                                               Margin="0,0,6,0"/>
                                    <ComboBox Style="{StaticResource PointModeComboBoxStyle}"
                                              SelectedValue="{Binding PointDisplayMode, Mode=TwoWay}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Content="精确"
                                                      Tag="{x:Static models:BandMapPointDisplayMode.Precise}"/>
                                        <ComboBoxItem Content="聚合"
                                                      Tag="{x:Static models:BandMapPointDisplayMode.Aggregate}"/>
                                    </ComboBox>
                                </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Padding="8,2"
                                        CornerRadius="10"
                                        Background="#ECFDF5"
                                        BorderBrush="#A7F3D0"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowPathStatusBadges}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Path1Header, FallbackValue=左路}"
                                                   Foreground="#166534"
                                                   FontSize="10.3"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text=" " Foreground="#166534" FontSize="10.3" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Path1Result, FallbackValue=-}"
                                                   Foreground="#166534"
                                                   FontSize="10.3"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Margin="6,0,0,0"
                                        Padding="8,2"
                                        CornerRadius="10"
                                        Background="#FFF7ED"
                                        BorderBrush="#FDBA74"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowPathStatusBadges}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Path2Header, FallbackValue=右路}"
                                                   Foreground="#C2410C"
                                                   FontSize="10.3"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text=" " Foreground="#C2410C" FontSize="10.3" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Path2Result, FallbackValue=-}"
                                                   Foreground="#C2410C"
                                                   FontSize="10.3"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <Popup PlacementTarget="{Binding ElementName=SlittingPopupToggleButton}"
                                       Placement="Bottom"
                                       VerticalOffset="6"
                                       AllowsTransparency="True"
                                       PopupAnimation="Fade"
                                       StaysOpen="False"
                                       IsOpen="{Binding IsChecked, ElementName=SlittingPopupToggleButton, Mode=TwoWay}">
                                    <Border Background="#FFFFFF"
                                            BorderBrush="#D4A938"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12"
                                            MinWidth="430"
                                            MaxWidth="430">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Background="#F8FAFC"
                                                    BorderBrush="#D7E2EC"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="8,6">
                                                <TextBlock Text="{Binding SlittingSummaryText}"
                                                           Foreground="#475569"
                                                           FontSize="10.4"
                                                           TextWrapping="Wrap"/>
                                            </Border>

                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="单帧走料 (mm)" Foreground="#6B7280" FontSize="11"/>
                                                    <TextBox Height="28"
                                                             Margin="0,3,0,0"
                                                             VerticalContentAlignment="Center"
                                                             Text="{Binding FrameSpanMillimeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="显示窗口 (m)" Foreground="#6B7280" FontSize="11"/>
                                                    <TextBox Height="28"
                                                             Margin="0,3,0,0"
                                                             VerticalContentAlignment="Center"
                                                             Text="{Binding WindowMeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Grid>

                                            <Grid Grid.Row="4">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="6"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="6"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <CheckBox Content="启用切刀分切"
                                                          IsChecked="{Binding IsSlittingEnabled, Mode=TwoWay}"/>

                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="切刀间距 (mm)" Foreground="#6B7280" FontSize="11"/>
                                                        <TextBox Height="28"
                                                                 Margin="0,3,0,0"
                                                                 VerticalContentAlignment="Center"
                                                                 Text="{Binding KnifeSpacingMillimeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="第一切距边 (mm)" Foreground="#6B7280" FontSize="11"/>
                                                        <TextBox Height="28"
                                                                 Margin="0,3,0,0"
                                                                 VerticalContentAlignment="Center"
                                                                 Text="{Binding FirstCutOffsetMillimeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Grid.Row="4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <TextBlock Text="横向幅宽 (mm)" Foreground="#6B7280" FontSize="11"/>
                                                        <TextBox Height="28"
                                                                 Margin="0,3,0,0"
                                                                 VerticalContentAlignment="Center"
                                                                 Text="{Binding StripWidthMillimeters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="切刀数量" Foreground="#6B7280" FontSize="11"/>
                                                        <TextBox Height="28"
                                                                 Margin="0,3,0,0"
                                                                 VerticalContentAlignment="Center"
                                                                 Text="{Binding SlitCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>

                                            <TextBlock Grid.Row="6"
                                                       Text="{Binding BrjSyncStatusText}"
                                                       Foreground="#64748B"
                                                       FontSize="10.5"
                                                       TextWrapping="Wrap"/>

                                            <StackPanel Grid.Row="8"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="{Binding BrjSyncButtonText}"
                                                        Click="OnSlittingPopupActionClick"
                                                        Command="{Binding SyncBrjReportCommand}"/>
                                                <Button Margin="6,0,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Content="重置视图"
                                                        Click="OnSlittingPopupActionClick"
                                                        Command="{Binding ResetCommand}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Popup>
                            </Grid>

                            <ItemsControl Grid.Row="1"
                                          Margin="0,5,0,0"
                                          ItemsSource="{Binding LegendItems}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasLegendItems}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Style="{StaticResource LegendCheckBoxStyle}"
                                                  IsChecked="{Binding IsChecked, Mode=OneWay}"
                                                  Command="{Binding DataContext.ToggleLegendCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Viewbox Width="14" Height="14" Margin="0,0,5,0">
                                                    <Grid Width="24" Height="24">
                                                        <Path x:Name="LegendTriangle"
                                                              Data="M12,4 L18.8,19 L5.2,19 Z"
                                                              Fill="{Binding Fill}"
                                                              Stroke="{Binding Stroke}"
                                                              StrokeThickness="1.4"
                                                              StrokeLineJoin="Round"
                                                              Visibility="Collapsed">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding MarkerKind}" Value="Triangle">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                        <Ellipse x:Name="LegendCircle"
                                                                 Width="15"
                                                                 Height="15"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Fill="{Binding Fill}"
                                                                 Stroke="{Binding Stroke}"
                                                                 StrokeThickness="1.4"
                                                                 Visibility="Collapsed">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding MarkerKind}" Value="Circle">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <Grid x:Name="LegendCross" Visibility="Collapsed">
                                                            <Grid.Style>
                                                                <Style TargetType="Grid">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding MarkerKind}" Value="Cross">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Grid.Style>
                                                            <Path Data="M5,5 L19,19"
                                                                  Stroke="{Binding Stroke}"
                                                                  StrokeThickness="4.8"
                                                                  Opacity="0.28"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"/>
                                                            <Path Data="M19,5 L5,19"
                                                                  Stroke="{Binding Stroke}"
                                                                  StrokeThickness="4.8"
                                                                  Opacity="0.28"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"/>
                                                            <Path Data="M5,5 L19,19"
                                                                  Stroke="{Binding Fill}"
                                                                  StrokeThickness="3.1"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"/>
                                                            <Path Data="M19,5 L5,19"
                                                                  Stroke="{Binding Fill}"
                                                                  StrokeThickness="3.1"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"/>
                                                        </Grid>
                                                    </Grid>
                                                </Viewbox>
                                                <TextBlock Text="{Binding SummaryText}"
                                                           VerticalAlignment="Center"
                                                           Foreground="#1F2937"
                                                           FontSize="10.2"/>
                                            </StackPanel>
                                        </CheckBox>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              Background="Transparent"
                              PreviewMouseWheel="OnMapViewportMouseWheel"
                              PreviewMouseDown="OnMapViewportPreviewMouseDown"
                              PreviewMouseMove="OnMapViewportPreviewMouseMove"
                              PreviewMouseUp="OnMapViewportPreviewMouseUp"
                              LostMouseCapture="OnMapViewportLostMouseCapture">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    x:Name="MapCanvasHost"
                                    Background="Transparent"
                                    ClipToBounds="False"
                                    Loaded="OnMapCanvasHostLoaded"
                                    SizeChanged="OnMapCanvasHostSizeChanged">
                                <local:LightningBandMapView PointSelected="OnLightningMapPointSelected"/>
                            </Border>

                            <Popup PlacementTarget="{Binding ElementName=MapCanvasHost}"
                                   Placement="Relative"
                                   AllowsTransparency="True"
                                   IsHitTestVisible="False"
                                   PopupAnimation="Fade"
                                   StaysOpen="True"
                                   IsOpen="{Binding IsSelectedMapPointPopupOpen}"
                                   HorizontalOffset="{Binding SelectedMapPointPopupOffsetX}"
                                   VerticalOffset="{Binding SelectedMapPointPopupOffsetY}">
                                <Border Background="#F8FAFC"
                                        BorderBrush="#C69300"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,7"
                                        MaxWidth="320">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedMapPointPopupTitle}"
                                                   Foreground="#0F172A"
                                                   FontSize="12.5"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,3,0,0"
                                                   Text="{Binding SelectedMapPointPopupDetail}"
                                                   Foreground="#475569"
                                                   FontSize="10.6"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <ScrollBar Grid.Column="1"
                                       Width="12"
                                       Margin="3,2,0,2"
                                       HorizontalAlignment="Center"
                                       Minimum="0"
                                       Maximum="{Binding ViewportMaxStartMeters}"
                                       Value="{Binding ViewportScrollOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                       ViewportSize="{Binding ViewportScrollViewportSize}"
                                       Orientation="Vertical"
                                       SmallChange="{Binding ViewportScrollSmallChange}"
                                       LargeChange="{Binding ViewportScrollLargeChange}"
                                       ToolTip="可拖动滚动条，也可按住鼠标中键上下拖动查看历史缺陷"
                                       IsEnabled="{Binding CanScrollViewport}"/>

                            <TextBlock Grid.Column="2"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Text="累计米数 (m)"
                                       Foreground="#475569"
                                       FontSize="10">
                                <TextBlock.LayoutTransform>
                                    <RotateTransform Angle="90"/>
                                </TextBlock.LayoutTransform>
                            </TextBlock>
                        </Grid>

                    </Grid>
                </Border>
            </WxGroupBox:WxGroupBox>

            <local:SharedDefectWallView Grid.Column="2"/>
        </Grid>
    </Grid>
</UserControl>

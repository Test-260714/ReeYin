<UserControl x:Class="Custom.WaferFlatnessMeasure.Views.ResultDisposeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.WaferFlatnessMeasure.Views"
             xmlns:PointCloudDisplay="clr-namespace:ReeYin_V.UI.UserControls.PointCloudDisplay;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#F4F7FB">
        <Border Margin="20" Padding="24" Background="White" BorderBrush="#D9E1EA" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="结果" FontSize="26" FontWeight="SemiBold" Foreground="#1F2937"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="页面显示最近一次数据分析输出的算法、数据源、结果值、最小值、最大值、点数和状态，并保留厚度点云预览。"
                               FontSize="14"
                               Foreground="#667085"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="14" Foreground="#667085">
                        <Run Text="分析结果数量: "/>
                        <Run Text="{Binding ModelParam.DataAnalysisResultCount, Mode=OneWay}"/>
                        <Run Text="  PreDatas 点数: "/>
                        <Run Text="{Binding ModelParam.PreDataCount, Mode=OneWay}"/>
                    </TextBlock>

                    <TextBlock Grid.Row="1" Margin="0,6,0,0" FontSize="14" Foreground="#667085" TextWrapping="Wrap">
                        <Run Text="厚度公式: "/>
                        <Run Text="{Binding ModelParam.ChannelCalibrationFormulaDisplay, Mode=OneWay}"/>
                    </TextBlock>

                    <TextBlock Grid.Row="2" Margin="0,6,0,0" FontSize="14" Foreground="#667085" TextWrapping="Wrap">
                        <Run Text="当前点云: "/>
                        <Run Text="{Binding ModelParam.ResultPointCloudTitle, Mode=OneWay}"/>
                        <Run Text="  点数: "/>
                        <Run Text="{Binding ModelParam.ResultPointCloudCount, Mode=OneWay}"/>
                    </TextBlock>

                    <TextBlock Grid.Row="3" Margin="0,6,0,0" FontSize="14" Foreground="#667085" TextWrapping="Wrap">
                        <Run Text="GrayAndHeightChart 高度图目录: "/>
                        <Run Text="{Binding ModelParam.LastPointCloudImageDirectory, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>

                <Border Grid.Row="2" Margin="0,18,0,0" Padding="12" Background="#F8FAFC" BorderBrush="#D9E1EA" BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="分析结果" FontSize="15" FontWeight="SemiBold" Foreground="#4B5563"/>

                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  ItemsSource="{Binding ModelParam.DataAnalysisResults}"
                                  Height="230"
                                  Margin="0,10,0,0"
                                  RowHeaderWidth="20"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="算法" Binding="{Binding AlgorithmName}" Width="100"/>
                                <DataGridTextColumn Header="数据源" Binding="{Binding DataSourceName}" Width="*"/>
                                <DataGridTextColumn Header="结果值" Binding="{Binding Value, StringFormat={}{0:F8}}" Width="110"/>
                                <DataGridTextColumn Header="最小值" Binding="{Binding MinValue, StringFormat={}{0:F8}}" Width="110"/>
                                <DataGridTextColumn Header="最大值" Binding="{Binding MaxValue, StringFormat={}{0:F8}}" Width="110"/>
                                <DataGridTextColumn Header="点数" Binding="{Binding PointCount}" Width="70"/>
                                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Margin="0,24,0,0" Padding="16" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="厚度点云" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Margin="14,3,0,0" Foreground="#CBD5E1">
                                <Run Text="{Binding ModelParam.ResultPointCloudTitle, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <PointCloudDisplay:PointCloudDisplayView x:Name="ResultPointCloudDisplay" MinHeight="360"/>
                            <TextBlock x:Name="EmptyPointCloudHint"
                                       Text="当前还没有可显示的点云结果。"
                                       Foreground="#E2E8F0"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

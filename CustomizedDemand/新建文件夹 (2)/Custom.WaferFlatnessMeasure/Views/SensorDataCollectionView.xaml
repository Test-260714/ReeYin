<UserControl x:Class="Custom.WaferFlatnessMeasure.Views.SensorDataCollectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.WaferFlatnessMeasure.Views"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <Button Name="btnLogin" Margin="5 0 5 0" IsEnabled="{Binding IsEnabled}" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ImportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe645;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导入配置" TextWrapping="Wrap" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button IsEnabled="{Binding IsEnabled}" Margin="5 0 5 0" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ExportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe646;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导出配置" TextWrapping="Wrap" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <!--主体-->
        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto"  Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="基础配置" Width="100" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="采集模式" Margin="5 5 5 10">
                                    <Grid >
                                        <Border CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TabControl Width="600" Height="550" SelectedIndex="{Binding ModelParam.SltTriggerPicIndex,Mode=TwoWay}" Style="{DynamicResource TabControlStyle}">
                                                <TabItem Header="原始数据CSV"  Style="{DynamicResource SingleTabItemStyle}" >
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="原始数据CSV:" Foreground="Black" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0"/>
                                                            <StackPanel Orientation="Horizontal" Margin="5,10,5,0" HorizontalAlignment="Center">
                                                                <TextBox Text="{Binding ModelParam.FilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="430" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                <Button Width="90" Height="30" Margin="8,0,0,0" Content="选择文件" Style="{StaticResource GeneralButtonStyle}"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="SelectRawDataCsvFile"/>
                                                            </StackPanel>
                                                            <TextBlock Width="520" Margin="5,12,5,0" Foreground="#666666" TextWrapping="Wrap"
                                                                       Text="执行时会从 CSV 加载原始数据，并按数据分析 Tab 中配置的数据源、过滤和算法计算结果。CSV 应包含 PosX、PosY 以及对应的 OriginalData 数据列。"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="传感器采集" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                                            <UniformGrid Columns="2" Margin="0,0,0,8" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                                <TextBlock Text="传感器选择:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center"
                                                                          ItemsSource="{Binding ModelParam.Models}" DisplayMemberPath="NickName" SelectedItem="{Binding ModelParam.SltModel,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                                    <i:Interaction.Triggers>
                                                                        <i:EventTrigger EventName="SelectionChanged">
                                                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换模块"/>
                                                                        </i:EventTrigger>
                                                                    </i:Interaction.Triggers>
                                                                </ComboBox>

                                                                <!--<TextBlock Text="相机旋转:" Foreground="Black" VerticalAlignment="Center" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Margin="5"
                                                                          ItemsSource="{Binding }" SelectedItem="{Binding ModelParam.CamSltRotate }"/>-->

                                                                <!--<TextBlock Text="采集模式:" Foreground="Black" VerticalAlignment="Center" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Margin="5"
                                                                          ItemsSource="{Binding ModelParam.SelectedCameraModel.TrigModes}" SelectedItem="{Binding ModelParam.SelectedCameraModel.TrigMode}"/>-->

                                                                <TextBlock Text="传感器备注:" Foreground="Black" VerticalAlignment="Center"/>
                                                                <TextBox Width="200"  Height="25" BorderThickness="0 0 0 1" Margin="5 0" Text="{Binding ModelParam.SelectedCameraModel.Remarks,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>

                                                                <TextBlock Text="曝光时间:" Foreground="Black" VerticalAlignment="Center" />
                                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="0 0" SmallChange="1" BorderThickness="0 0 0 1"
                                                                    Value="{Binding ModelParam.SelectedCameraModel.ExposeTime,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                                <!--<TextBlock Text="增益:" Foreground="Black" VerticalAlignment="Center" />
                                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="0 0" SmallChange="0.1"  BorderThickness="0 0 0 1"
                                                                    Value="{Binding ModelParam.SelectedCameraModel.Gain,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>-->

                                                            </UniformGrid>

                                                            <UniformGrid Columns="2">
                                                                <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发开始采集" Width="auto"  HorizontalAlignment="Left" 
                                                               IsChecked="{Binding ModelParam.StartCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="事件名称：" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="80" Width="250" VerticalAlignment="Center"
                                                     Text="{Binding ModelParam.StartEventName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                                <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发停止采集" Width="auto" HorizontalAlignment="Left" 
                                                               IsChecked="{Binding ModelParam.StopCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="事件名称：" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="80" Width="250" VerticalAlignment="Center"
                                                     Text="{Binding ModelParam.StopEventName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                                <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发停止采集并处理数据" Width="auto" HorizontalAlignment="Left" 
                                                               IsChecked="{Binding ModelParam.StopAndDispose,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="事件名称：" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="80" Width="250" VerticalAlignment="Center"
                                                     Text="{Binding ModelParam.StopAndDisposeEventName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                            </UniformGrid>

                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                            </TabControl>
                                        </Border>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="测量参数" Width="100" Style="{StaticResource TabItemExWithUnderLineStyle}" Height="45" VerticalAlignment="Top">
                            <Grid>
                                <WxGroupBox:WxGroupBox Header="平面度测量参数">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Margin="5">
                                        <CheckBox Content="启用点云插值" Width="auto" Margin="5 5 5 10" HorizontalAlignment="Left"
                                                  IsChecked="{Binding ModelParam.MeasureParam.Interpolate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <StackPanel Orientation="Vertical"
                                                    IsEnabled="{Binding ModelParam.MeasureParam.Interpolate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" Minimum="1" Maximum="5000"
                                                              hc:InfoElement.Title="插值分辨率：" Width="400" Style="{StaticResource NumericUpDownExtendGlobal}"
                                                              hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" Foreground="Black" Margin="5"
                                                              HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                              Value="{Binding ModelParam.MeasureParam.Resolution,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <ComboBox Width="400" Height="30" Margin="5" BorderThickness="0 0 0 1" Foreground="Black"
                                                      hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="径向基核函数："
                                                      hc:InfoElement.TitleWidth="140"
                                                      helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                      SelectedItem="{Binding ModelParam.MeasureParam.Function,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" Minimum="0" Maximum="999999"
                                                              hc:InfoElement.Title="核函数参数 Epsilon：" Width="400" Style="{StaticResource NumericUpDownExtendGlobal}"
                                                              hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" Foreground="Black" Margin="5"
                                                              HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                              Value="{Binding ModelParam.MeasureParam.Epsilon,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" Minimum="0" Maximum="999999"
                                                              hc:InfoElement.Title="平滑系数 Smooth：" Width="400" Style="{StaticResource NumericUpDownExtendGlobal}"
                                                              hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1" Foreground="Black" Margin="5"
                                                              HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                              Value="{Binding ModelParam.MeasureParam.Smooth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="插值外半径："
                                                     Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140" Width="400"
                                                     VerticalAlignment="Center" Margin="5"
                                                     Text="{Binding ModelParam.MeasureParam.OuterRadius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="插值内半径："
                                                     Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140" Width="400"
                                                     VerticalAlignment="Center" Margin="5"
                                                     Text="{Binding ModelParam.MeasureParam.InnerRadius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Margin="5,10,5,0" Foreground="#666666" TextWrapping="Wrap"
                                                       Text="外半径留空时自动按点云范围计算；内半径留空时按整圆区域插值。"/>
                                        </StackPanel>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </Grid>
                        </TabItem>

                        <TabItem Header="存储参数" Width="100" Height="45" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="存储设置>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                                        <StackPanel Orientation="Vertical">
                                            <CheckBox Content="启用" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" 
                                                               IsChecked="{Binding ModelParam.OtherConfig.IsSaveImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                <TextBlock Text="存储路径:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="500" Margin="5 0" Order="OpenFile" Text="{Binding ModelParam.OtherConfig.SavePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <CheckBox Content="导出 PreDatas 到 CSV" Width="auto" Margin="10 5 0 10" HorizontalAlignment="Left"
                                                      IsChecked="{Binding ModelParam.IsSavePreDatasToCsv,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10" HorizontalAlignment="Center">
                                                <TextBlock Text="PreDatas CSV路径:" Foreground="Black" VerticalAlignment="Center"/>
                                                <TextBox Width="500" Margin="5,0" BorderThickness="0 0 0 1"
                                                         Text="{Binding ModelParam.PreDatasCsvDirectory,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10" HorizontalAlignment="Center">
                                                <TextBlock Text="点云导出路径:" Foreground="Black" VerticalAlignment="Center"/>
                                                <TextBox Width="420" Margin="5,0" BorderThickness="0 0 0 1"
                                                         Text="{Binding ModelParam.PointCloudOutputDirectory,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <Button Width="100" Height="30" Margin="5,0" Style="{StaticResource GeneralButtonStyle}"
                                                        Content="选择文件夹" Command="{Binding GeneralCommand}" CommandParameter="SelectPointCloudOutputDirectory"/>
                                            </StackPanel>

                                            <CheckBox Content="导出 GrayAndHeightChart 高度图" Width="auto" Margin="10 0 0 10" HorizontalAlignment="Left"
                                                      IsChecked="{Binding ModelParam.IsSaveRunAlgoPointCloudImages,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <StackPanel Orientation="Horizontal" Margin="10,0,10,10" HorizontalAlignment="Center"
                                                        IsEnabled="{Binding ModelParam.IsSaveRunAlgoPointCloudImages,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                <TextBlock Text="高度图分辨率:" Foreground="Black" VerticalAlignment="Center"/>
                                                <hc:NumericUpDown DecimalPlaces="0" Minimum="16" Maximum="5480" Width="500" Margin="5,0"
                                                                  Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Foreground="Black"
                                                                  HorizontalContentAlignment="Center"
                                                                  Value="{Binding ModelParam.RunAlgoPointCloudImageResolution,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <TextBlock Margin="15,0,15,6" Foreground="#666666" TextWrapping="Wrap"
                                                       Text="RunALGO 会按变量名导出 PLY 文件，并在 GrayAndHeightChart\depth 子目录导出可加载的 real TIFF 高度图；未设置点云导出路径时将跳过导出。"/>

                                            <TextBlock Margin="15,0,15,10" Foreground="#666666" TextWrapping="Wrap"
                                                       Text="{Binding ModelParam.LastPointCloudImageDirectory, StringFormat=最近高度图目录：{0}}"/>

                                        </StackPanel>
                                    </WxGroupBox:WxGroupBox>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="数据分析" Width="100" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="5">
                                    <WxGroupBox:WxGroupBox Header="数据源">
                                        <StackPanel Margin="10,5">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                <Button Width="80" Height="28" Margin="0,0,6,0" Style="{StaticResource GeneralButtonStyle}"
                                                        Content="添加" Command="{Binding GeneralCommand}" CommandParameter="AddDataAnalysisDataSource"/>
                                                <Button Width="80" Height="28" Margin="0,0,6,0" Style="{StaticResource GeneralButtonStyle}"
                                                        Content="删除" Command="{Binding GeneralCommand}" CommandParameter="DeleteDataAnalysisDataSource"/>
                                                <Button Width="80" Height="28" Style="{StaticResource GeneralButtonStyle}"
                                                        Content="重置" Command="{Binding GeneralCommand}" CommandParameter="ResetDataAnalysisDataSource"/>
                                            </StackPanel>

                                            <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                                      ItemsSource="{Binding ModelParam.DataAnalysisDataSources}"
                                                      SelectedItem="{Binding CurrentDataAnalysisDataSource,Mode=TwoWay}"
                                                      Height="195"
                                                      RowHeaderWidth="20"
                                                      CanUserAddRows="False"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="All">
                                                <DataGrid.Columns>
                                                    <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="58"/>
                                                    <DataGridTextColumn Header="名称" Binding="{Binding Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="92"/>
                                                    <DataGridTemplateColumn Header="OriginalData 数据源" Width="150">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <ComboBox Height="25" BorderThickness="0 0 0 1" Background="Transparent"
                                                                          IsEditable="True"
                                                                          IsTextSearchEnabled="True"
                                                                          ItemsSource="{Binding DataContext.ModelParam.OriginalDataValueNames, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                          Text="{Binding OriginalDataValueName,Mode=TwoWay,UpdateSourceTrigger=LostFocus}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>
                                                    <DataGridCheckBoxColumn Header="过滤" Binding="{Binding IsFilterEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="58"/>
                                                    <DataGridCheckBoxColumn Header="原始过滤" Binding="{Binding IsRawDataFilter,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="78"/>
                                                    <DataGridTextColumn Header="下限" Binding="{Binding FilterMin,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged,StringFormat={}{0:G17}}" Width="95"/>
                                                    <DataGridTextColumn Header="上限" Binding="{Binding FilterMax,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged,StringFormat={}{0:G17}}" Width="95"/>
                                                </DataGrid.Columns>
                                            </DataGrid>

                                            <TextBlock Margin="0,6,0,0" Foreground="#666666" TextWrapping="Wrap"
                                                       Text="{Binding ModelParam.SurfaceChannelSummary}"/>
                                            <TextBlock Margin="0,4,0,0" Foreground="#666666" TextWrapping="Wrap"
                                                       Text="勾选“原始过滤”时，传感器采集数据会先按轨迹点等分，在每组原始数据内过滤后再平均；未勾选时按平均后的数据过滤。"/>
                                        </StackPanel>
                                    </WxGroupBox:WxGroupBox>

                                    <WxGroupBox:WxGroupBox Header="采集数据滤波" Margin="0,8,0,0">
                                        <StackPanel Margin="10,5">
                                            <WrapPanel Margin="0,0,0,8">
                                                <CheckBox Content="中值滤波" Margin="0,0,8,0" VerticalAlignment="Center"
                                                          IsChecked="{Binding ModelParam.IsMedianFilterEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="窗口:" Foreground="Black" VerticalAlignment="Center"/>
                                                <hc:NumericUpDown DecimalPlaces="0" Minimum="3" Maximum="999" Width="80" Margin="5,0,20,0"
                                                                  Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Foreground="Black"
                                                                  HorizontalContentAlignment="Center"
                                                                  Value="{Binding ModelParam.MedianFilterWindowSize,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <CheckBox Content="平滑滤波" Margin="0,0,8,0" VerticalAlignment="Center"
                                                          IsChecked="{Binding ModelParam.IsSmoothFilterEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Text="窗口:" Foreground="Black" VerticalAlignment="Center"/>
                                                <hc:NumericUpDown DecimalPlaces="0" Minimum="3" Maximum="999" Width="80" Margin="5,0,20,0"
                                                                  Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Foreground="Black"
                                                                  HorizontalContentAlignment="Center"
                                                                  Value="{Binding ModelParam.SmoothFilterWindowSize,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <CheckBox Content="扩展 OriginalDataValues 同步滤波" Margin="0,0,8,0" VerticalAlignment="Center"
                                                          IsChecked="{Binding ModelParam.IsFilterOriginalDataValues,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </WrapPanel>

                                            <TextBlock Foreground="#666666" TextWrapping="Wrap"
                                                       Text="滤波会在采集数据生成 PreDatas 后、保存预处理 CSV 和 RunALGO 前执行；上表面、下表面、厚度默认参与滤波，并同步核心 OriginalDataValues 字段。"/>
                                        </StackPanel>
                                    </WxGroupBox:WxGroupBox>

                                    <WxGroupBox:WxGroupBox Header="算法选择" Margin="0,8,0,0">
                                        <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                                  ItemsSource="{Binding ModelParam.DataAnalysisAlgorithms}"
                                                  Height="170"
                                                  Margin="10,5"
                                                  RowHeaderWidth="20"
                                                  CanUserAddRows="False"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="All">
                                            <DataGrid.Columns>
                                                <DataGridCheckBoxColumn Header="执行" Binding="{Binding IsEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="58"/>
                                                <DataGridTextColumn Header="算法" Binding="{Binding DisplayName}" IsReadOnly="True" Width="95"/>
                                                <DataGridTextColumn Header="数据源要求" Binding="{Binding RequiredDataSourceText}" IsReadOnly="True" Width="90"/>
                                                <DataGridTemplateColumn Header="数据源A" Width="125">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ComboBox Height="25" BorderThickness="0 0 0 1" Background="Transparent"
                                                                      IsEnabled="{Binding RequiresPairSource}"
                                                                      ItemsSource="{Binding DataContext.ModelParam.DataAnalysisDataSources, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      DisplayMemberPath="Name"
                                                                      SelectedValuePath="DataSourceId"
                                                                      SelectedValue="{Binding SourceADataSourceId,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="数据源B" Width="125">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ComboBox Height="25" BorderThickness="0 0 0 1" Background="Transparent"
                                                                      IsEnabled="{Binding RequiresPairSource}"
                                                                      ItemsSource="{Binding DataContext.ModelParam.DataAnalysisDataSources, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      DisplayMemberPath="Name"
                                                                      SelectedValuePath="DataSourceId"
                                                                      SelectedValue="{Binding SourceBDataSourceId,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="说明" Binding="{Binding Description}" IsReadOnly="True" Width="*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </WxGroupBox:WxGroupBox>

                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="通道标定" Width="100" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid Height="680">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <WxGroupBox:WxGroupBox Header="标定采集" Margin="5,5,5,8">
                                    <StackPanel Margin="5,0,5,5">
                                        <UniformGrid Columns="2" Margin="0,0,0,8">
                                            <TextBlock Text="传感器选择:" Foreground="Black" VerticalAlignment="Center"/>
                                            <ComboBox Width="220" BorderThickness="0 0 0 1" Foreground="Black" Margin="5"
                                                      HorizontalContentAlignment="Center"
                                                      ItemsSource="{Binding ModelParam.Models}"
                                                      DisplayMemberPath="NickName"
                                                      SelectedItem="{Binding ModelParam.SltModel,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="SwitchModule"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>

                                            <TextBlock Text="采集状态:" Foreground="Black" VerticalAlignment="Center"/>
                                            <CheckBox Content="采集中" Margin="5,0" VerticalAlignment="Center"
                                                      IsChecked="{Binding ModelParam.IsChannelCalibrationCollecting,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="False"/>

                                            <TextBlock Text="启用通道标定:" Foreground="Black" VerticalAlignment="Center"/>
                                            <CheckBox Content="启用" Margin="5,0" VerticalAlignment="Center"
                                                      IsChecked="{Binding ModelParam.IsUsingChannelCalibration,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Text="当前标准值:" Foreground="Black" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Width="220" Margin="5,0" BorderThickness="0 0 0 1"
                                                              DecimalPlaces="6" Minimum="-99999999" Maximum="99999999"
                                                              HorizontalContentAlignment="Center"
                                                              IsEnabled="{Binding ModelParam.IsUsingChannelCalibration,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                              Value="{Binding ModelParam.CurrentCalibrationStandardValue,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Text="系数 A(手动输入):" Foreground="Black" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Width="220" Margin="5,0" BorderThickness="0 0 0 1"
                                                              DecimalPlaces="8" Minimum="-99999999" Maximum="99999999"
                                                              HorizontalContentAlignment="Center"
                                                              IsEnabled="{Binding ModelParam.IsUsingChannelCalibration,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                              Value="{Binding ModelParam.ChannelCalibrationA,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Text="系数 B(手动输入):" Foreground="Black" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Width="220" Margin="5,0" BorderThickness="0 0 0 1"
                                                              DecimalPlaces="8" Minimum="-99999999" Maximum="99999999"
                                                              HorizontalContentAlignment="Center"
                                                              IsEnabled="{Binding ModelParam.IsUsingChannelCalibration,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                              Value="{Binding ModelParam.ChannelCalibrationB,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            <TextBlock Text="原始点数:" Foreground="Black" VerticalAlignment="Center"/>
                                            <TextBox Width="220" Height="28" BorderThickness="0 0 0 1" Margin="5,0"
                                                     Text="{Binding ModelParam.ChannelCalibrationRawPointCount}"
                                                     IsReadOnly="True"
                                                     HorizontalContentAlignment="Center"/>

                                            <TextBlock Text="系数 C:" Foreground="Black" VerticalAlignment="Center"/>
                                            <TextBox Margin="5,0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding ModelParam.ChannelCalibrationC, StringFormat={}{0:F8}}"/>

                                            <TextBlock Text="RMSE:" Foreground="Black" VerticalAlignment="Center"/>
                                            <TextBox Margin="5,0" BorderThickness="0 0 0 1" IsReadOnly="True"
                                                     Text="{Binding ModelParam.ChannelCalibrationRmse, StringFormat={}{0:F8}}"/>
                                        </UniformGrid>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,4,0,0">
                                            <Button Width="110" Height="30" Margin="5,0" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="开始采集" Command="{Binding GeneralCommand}" CommandParameter="StartCollect"
                                                    IsEnabled="{Binding ModelParam.IsUsingChannelCalibration,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Width="110" Height="30" Margin="5,0" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="停止采集" Command="{Binding GeneralCommand}" CommandParameter="StopCollect"
                                                    IsEnabled="{Binding ModelParam.IsUsingChannelCalibration,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Width="110" Height="30" Margin="5,0" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="计算C" Command="{Binding GeneralCommand}" CommandParameter="CalculateC"
                                                    IsEnabled="{Binding ModelParam.IsUsingChannelCalibration,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Width="110" Height="30" Margin="5,0" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="清空原始点" Command="{Binding GeneralCommand}" CommandParameter="ClearRawPoints"/>
                                        </StackPanel>

                                        <TextBlock Margin="5,10,5,0" Foreground="#666666" TextWrapping="Wrap"
                                                   Text="启用通道标定时按 A*UpSurface + B*DownSurface + C 计算厚度；未启用时按 Abs(UpSurface - DownSurface) 直接由原始数据计算厚度。"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Grid.Row="1" Header="原始数据" Margin="5,0,5,8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal" Margin="5,5,5,8" VerticalAlignment="Center">
                                            <TextBlock VerticalAlignment="Center" Margin="5,0,10,0">
                                                <Run Text="原始点数: "/>
                                                <Run Text="{Binding ModelParam.ChannelCalibrationRawPointCount, Mode=OneWay}"/>
                                            </TextBlock>
                                            <Button Width="100" Height="30" Margin="0,0,8,0" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="清空原始点" Command="{Binding GeneralCommand}" CommandParameter="ClearRawPoints"/>
                                            <Button Width="100" Height="30" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="计算C" Command="{Binding GeneralCommand}" CommandParameter="CalculateC"
                                                    IsEnabled="{Binding ModelParam.IsUsingChannelCalibration,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <DataGrid Grid.Row="1" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                                  EnableColumnVirtualization="True"
                                                  EnableRowVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  ItemsSource="{Binding ModelParam.ChannelCalibrationRawPoints}"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  RowHeaderWidth="20"
                                                  SelectionUnit="FullRow"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="All"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="序号" Width="80" Binding="{Binding Index}"/>
                                                <DataGridTextColumn Header="标准值" Width="*" Binding="{Binding StandardValue, StringFormat={}{0:F6}}"/>
                                                <DataGridTextColumn Header="UpSurface" Width="*" Binding="{Binding UpSurface, StringFormat={}{0:F8}}"/>
                                                <DataGridTextColumn Header="DownSurface" Width="*" Binding="{Binding DownSurface, StringFormat={}{0:F8}}"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Grid.Row="2" Header="结果总览" Margin="5,0,5,5">
                                    <StackPanel Margin="10,6">
                                        <TextBlock Margin="0,2" TextWrapping="Wrap"
                                                   Text="{Binding ModelParam.ChannelCalibrationFormulaDisplay}"/>
                                        <TextBlock Margin="0,2">
                                            <Run Text="原始点总数: "/>
                                            <Run Text="{Binding ModelParam.ChannelCalibrationRawPointCount, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,2">
                                            <Run Text="当前 RMSE: "/>
                                            <Run Text="{Binding ModelParam.ChannelCalibrationRmse, Mode=OneWay, StringFormat={}{0:F8}}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,2" Foreground="#666666" TextWrapping="Wrap"
                                                   Text="建议采集多组不同标准值后再计算 C，可更稳定地评估 A/B 设置是否合理。"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </Grid>
                        </TabItem>

                        <TabItem Header="文件标定" Width="100" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>
                                <WxGroupBox:WxGroupBox Header="标定模型生成" Margin="5">
                                    <StackPanel Margin="10,6">
                                        <CheckBox Content="启用三维补偿" Width="auto" Margin="0,5,0,10" HorizontalAlignment="Left"
                                                IsChecked="{Binding ModelParam.IsUsingCalib,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <TextBlock Width="110" Text="标定数据文件:" Foreground="Black" VerticalAlignment="Center"/>
                                            <TextBox Width="320" Margin="5,0" BorderThickness="0 0 0 1" 
                                                     Text="{Binding ModelParam.CalibrationSourceFilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Width="100" Height="30" Margin="5,0" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="选择文件" Command="{Binding GeneralCommand}" CommandParameter="SelectCalibrationSourceFile"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <TextBlock Width="110" Text="原始点云PLY:" Foreground="Black" VerticalAlignment="Center"/>
                                            <TextBox Width="320" Margin="5,0" BorderThickness="0 0 0 1"
                                                     Text="{Binding ModelParam.RawPointCloudPlyPath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Width="100" Height="30" Margin="5,0" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="选择路径" Command="{Binding GeneralCommand}" CommandParameter="SelectRawPointCloudPlyPath"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <TextBlock Width="110" Text="残差点云PLY:" Foreground="Black" VerticalAlignment="Center"/>
                                            <TextBox Width="320" Margin="5,0" BorderThickness="0 0 0 1"
                                                     Text="{Binding ModelParam.ResidualPointCloudPlyPath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Width="100" Height="30" Margin="5,0" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="选择路径" Command="{Binding GeneralCommand}" CommandParameter="SelectResidualPointCloudPlyPath"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <Button Width="110" Height="30" Margin="5,0" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="文件标定" Command="{Binding GeneralCommand}" CommandParameter="CalibFromFile"/>
                                        </StackPanel>

                                        <TextBlock Margin="5,4,5,0">
                                            <Run Text="当前 PreDatas 点数: "/>
                                            <Run Text="{Binding ModelParam.PreDataCount, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Margin="5,4,5,0">
                                            <Run Text="当前文件路径: "/>
                                            <Run Text="{Binding ModelParam.CalibrationSourceFilePath, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Margin="5,4,5,0" TextWrapping="Wrap">
                                            <Run Text="原始点云输出: "/>
                                            <Run Text="{Binding ModelParam.RawPointCloudPlyPath, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Margin="5,4,5,0" TextWrapping="Wrap">
                                            <Run Text="残差点云输出: "/>
                                            <Run Text="{Binding ModelParam.ResidualPointCloudPlyPath, Mode=OneWay}"/>
                                        </TextBlock>
                                        <TextBlock Margin="5,10,5,0" Foreground="#666666" TextWrapping="Wrap"
                                                   Text="该页面用于从 CSV 文件读取预处理点云后直接执行标定模型生成；文件需包含 PosX、PosY、UpSurface、DownSurface 列。PLY 输出路径留空时只在内存中生成标定模型，不导出文件。"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </Grid>
                        </TabItem>

                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" MaxHeight="260" Margin="5,5,5,0" Header="分析结果" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel Margin="10,5">
                            <TextBlock Margin="0,2">
                                <Run Text="分析结果数量 = "/>
                                <Run Text="{Binding ModelParam.DataAnalysisResultCount, Mode=OneWay}"/>
                            </TextBlock>
                            <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                      ItemsSource="{Binding ModelParam.DataAnalysisResults}"
                                      Height="210"
                                      RowHeaderWidth="20"
                                      IsReadOnly="True"
                                      CanUserAddRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="算法" Binding="{Binding AlgorithmName}" Width="80"/>
                                    <DataGridTextColumn Header="数据源" Binding="{Binding DataSourceName}" Width="120"/>
                                    <DataGridTextColumn Header="结果值" Binding="{Binding Value, StringFormat={}{0:F8}}" Width="90"/>
                                    <DataGridTextColumn Header="最小值" Binding="{Binding MinValue, StringFormat={}{0:F8}}" Width="85"/>
                                    <DataGridTextColumn Header="最大值" Binding="{Binding MaxValue, StringFormat={}{0:F8}}" Width="85"/>
                                    <DataGridTextColumn Header="点数" Binding="{Binding PointCount}" Width="55"/>
                                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="65"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>

                    <Expander Width="auto" MaxHeight="220" Margin="5,5,5,0" Header="通道标定结果" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel Margin="10,5">
                            <TextBlock Margin="0,2" TextWrapping="Wrap">
                                <Run Text="公式: "/>
                                <Run Text="{Binding ModelParam.ChannelCalibrationFormulaDisplay, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Run Text="启用通道标定 = "/>
                                <Run Text="{Binding ModelParam.IsUsingChannelCalibration, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Run Text="A = "/>
                                <Run Text="{Binding ModelParam.ChannelCalibrationA, Mode=OneWay, StringFormat={}{0:F8}}"/>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Run Text="B = "/>
                                <Run Text="{Binding ModelParam.ChannelCalibrationB, Mode=OneWay, StringFormat={}{0:F8}}"/>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Run Text="C = "/>
                                <Run Text="{Binding ModelParam.ChannelCalibrationC, Mode=OneWay, StringFormat={}{0:F8}}"/>
                            </TextBlock>
                            <TextBlock Margin="0,2">
                                <Run Text="RMSE = "/>
                                <Run Text="{Binding ModelParam.ChannelCalibrationRmse, Mode=OneWay, StringFormat={}{0:F8}}"/>
                            </TextBlock>
                        </StackPanel>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName ,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" Style="{StaticResource GeneralButtonStyle}"
             Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                     ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" Style="{StaticResource GeneralButtonStyle}"
                 Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                     ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      ItemsSource="{Binding ModelParam.OutputParams}" 
                      SelectedItem="{Binding CurrentOutputParam}"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Height="160"
                      RowHeaderWidth="20"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"
         SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                                <!--<TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>-->
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" >
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime, Mode=OneWay}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left">
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left">
                        <Run Text="标定原始点数:"/>
                        <Run Text="{Binding ModelParam.ChannelCalibrationRawPointCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left">
                        <Run Text="PreDatas点数:"/>
                        <Run Text="{Binding ModelParam.PreDataCount, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left">
                        <Run Text="标定采集状态:"/>
                        <Run Text="{Binding ModelParam.IsChannelCalibrationCollecting, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left">
                        <Run Text="最近TTV:"/>
                        <Run Text="{Binding ModelParam.LastTtvValue, Mode=OneWay, StringFormat={}{0:F8}}"/>
                    </TextBlock>
                </WrapPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="80"
                                                    Content="执行"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                                                    Height="auto" Width="80"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="取消"
                                                    Cursor="Hand"/>
                    <Button Margin="0,0,15,0" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="auto" Width="80"
                                                    Content="确认"
                                                    Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>


<UserControl x:Class="Custom.WaferFlatnessMeasure.Views.GripperClampControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             Height="640"
             Width="1020"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="640"
             d:DesignWidth="1020">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Width="92" Height="30" Margin="0,0,8,0"
                        Content="刷新状态"
                        Style="{StaticResource GeneralButtonStyle}"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="Refresh"/>
                <Button Width="92" Height="30" Margin="0,0,8,0"
                        Content="夹紧"
                        Style="{StaticResource GeneralButtonStyle}"
                        IsEnabled="{Binding ModelParam.IsOperationIdle}"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="Clamp"/>
                <Button Width="92" Height="30" Margin="0,0,8,0"
                        Content="松开"
                        Style="{StaticResource GeneralButtonStyle}"
                        IsEnabled="{Binding ModelParam.IsOperationIdle}"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="Release"/>
                <Button Width="110" Height="30"
                        Content="停止/复位"
                        Style="{StaticResource GeneralButtonStyle}"
                        Command="{Binding GeneralCommand}"
                        CommandParameter="Stop"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="PLC:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding ModelParam.PlcDisplayName}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Text="连接:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding ModelParam.IsPlcConnected}" VerticalAlignment="Center"/>
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="操作监控">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="0.85*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="运行参数" Grid.Column="0" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="执行模式" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Height="26" Margin="0,0,18,0"
                                      helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                      SelectedItem="{Binding ModelParam.OperationMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="0" Grid.Column="2" Text="脉冲复位(ms)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="3" Height="25" BorderThickness="0,0,0,1"
                                     Text="{Binding ModelParam.CommandPulseResetDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Text="超时(ms)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Height="25" BorderThickness="0,0,0,1" Margin="0,0,18,0"
                                     Text="{Binding ModelParam.OperationTimeoutMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="1" Grid.Column="2" Text="轮询(ms)" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="3" Height="25" BorderThickness="0,0,0,1"
                                     Text="{Binding ModelParam.PollIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Grid.Row="2" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,6,0,0">
                                <CheckBox Content="命令按脉冲写入"
                                          Margin="0,0,18,0"
                                          IsChecked="{Binding ModelParam.IsPulseCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <CheckBox Content="等待到位反馈"
                                          Margin="0,0,18,0"
                                          IsChecked="{Binding ModelParam.WaitForDoneSignal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <CheckBox Content="执行前复位反向命令"
                                          IsChecked="{Binding ModelParam.ResetOppositeCommand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <GroupBox Header="四路夹爪状态" Grid.Row="1" Grid.Column="0" Padding="8">
                        <DataGrid AutoGenerateColumns="False"
                                  Style="{StaticResource DefaultDataGridStyle}"
                                  ItemsSource="{Binding ModelParam.Grippers}"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="58"/>
                                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="90"/>
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="62"/>
                                <DataGridCheckBoxColumn Header="夹紧命令" Binding="{Binding ClampCommandValue}" Width="82"/>
                                <DataGridCheckBoxColumn Header="松开命令" Binding="{Binding ReleaseCommandValue}" Width="82"/>
                                <DataGridCheckBoxColumn Header="夹紧到位" Binding="{Binding ClampDone}" Width="82"/>
                                <DataGridCheckBoxColumn Header="松开到位" Binding="{Binding ReleaseDone}" Width="82"/>
                                <DataGridCheckBoxColumn Header="报警" Binding="{Binding AlarmSignal}" Width="62"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GridSplitter Grid.RowSpan="2" Grid.Column="1" HorizontalAlignment="Stretch" Background="#D9DEE8"/>

                    <StackPanel Grid.Column="2" Grid.RowSpan="2">
                        <GroupBox Header="汇总状态" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="任一夹紧命令" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ModelParam.ClampCommandValue}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Text="任一松开命令" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ModelParam.ReleaseCommandValue}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Text="全部夹紧到位" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ModelParam.ClampDone}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="3" Text="全部松开到位" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ModelParam.ReleaseDone}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="4" Text="任一报警" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ModelParam.AlarmSignal}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="5" Text="最近操作成功" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ModelParam.LastOperationSuccess}" VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="6" Text="最近操作时间" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ModelParam.LastOperationTimeText}" VerticalAlignment="Center"/>
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="操作信息" Padding="10" Margin="0,0,0,10">
                            <TextBlock MinHeight="72"
                                       TextWrapping="Wrap"
                                       Text="{Binding ModelParam.LastOperationMessage}"/>
                        </GroupBox>

                        <Expander Header="输出参数" IsExpanded="True">
                            <StackPanel Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                    <ComboBox Width="240" Height="25" Margin="8,0"
                                              ItemsSource="{Binding ModelParam.OutputParamNames}"
                                              SelectedItem="{Binding SltOutputParamName, Mode=TwoWay}"/>
                                    <Button Content="添加" Width="60" Height="26" Margin="0,0,6,0"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding DataOperateCommand}"
                                            CommandParameter="Add"/>
                                    <Button Content="删除" Width="60" Height="26"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding DataOperateCommand}"
                                            CommandParameter="Delete"/>
                                </StackPanel>

                                <DataGrid AutoGenerateColumns="False"
                                          Style="{StaticResource DefaultDataGridStyle}"
                                          ItemsSource="{Binding ModelParam.OutputParams}"
                                          SelectedItem="{Binding CurrentOutputParam}"
                                          Height="150"
                                          CanUserAddRows="False"
                                          IsReadOnly="False"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="参数名称" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                        <DataGridTextColumn Header="值" Binding="{Binding Value}" IsReadOnly="True" Width="*"/>
                                        <DataGridTextColumn Header="备注" Binding="{Binding Describe, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="地址设置">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Header="四路夹爪PLC地址" Padding="8">
                        <DataGrid AutoGenerateColumns="False"
                                  Style="{StaticResource DefaultDataGridStyle}"
                                  ItemsSource="{Binding ModelParam.Grippers}"
                                  CanUserAddRows="False"
                                  IsReadOnly="False"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="序号" Binding="{Binding Index}" IsReadOnly="True" Width="54"/>
                                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58"/>
                                <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="86"/>
                                <DataGridTextColumn Header="夹紧命令地址" Binding="{Binding ClampCommandAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="夹紧到位地址" Binding="{Binding ClampDoneAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="松开命令地址" Binding="{Binding ReleaseCommandAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="松开到位地址" Binding="{Binding ReleaseDoneAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                                <DataGridTextColumn Header="报警地址" Binding="{Binding AlarmAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#D9DEE8" Margin="0,10,0,0" Padding="0,10,0,0">
            <Grid>
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <TextBlock Text="耗时:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ModelParam.Output.RunTime}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="ms" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock Text="执行状态:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding ModelParam.Output.RunStatus}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Width="80" Height="32" Margin="0,0,10,0"
                            Content="执行"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="执行"/>
                    <Button Width="80" Height="32" Margin="0,0,10,0"
                            Content="取消"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="取消"/>
                    <Button Width="80" Height="32"
                            Content="确认"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="确认"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="Custom.WaferFlatnessMeasure.Views.WaferFlatnessConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.WaferFlatnessMeasure.Views"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:uiConverter="clr-namespace:ReeYin_V.UI.Converter;assembly=ReeYin_V.UI"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" 
             FontSize="14"
             Height="980"
             Width="1480"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="980"
             d:DesignWidth="1480">
    <UserControl.Resources>
        <uiConverter:Bool2VisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2" Margin="0,37,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.55*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.45*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="5">
                <TabControl Style="{StaticResource TabControlWithUnderLineStyle}">
                    <TabItem Header="输入参数" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,5,0,0">
                                <WxGroupBox:WxGroupBox Header="触发间隔" Margin="0,0,0,8">
                                    <StackPanel>
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="采样间距：" hc:InfoElement.TitleWidth="140" Style="{StaticResource NumericUpDownExtend}"
                                                          Width="340" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center" Value="{Binding ModelParam.SensorInterval,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="采样上Z轴高度：" hc:InfoElement.TitleWidth="140" Style="{StaticResource NumericUpDownExtend}"
                                                          Width="340" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center" Value="{Binding ModelParam.ZHight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="采样下Z轴高度：" hc:InfoElement.TitleWidth="140" Style="{StaticResource NumericUpDownExtend}"
                                                          Width="340" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center" Value="{Binding ModelParam.Z1Hight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>


                                        <StackPanel Orientation="Horizontal" Width="560" HorizontalAlignment="Center">
                                            <TextBlock Width="150" Text="圆心坐标链接:" Foreground="Black" VerticalAlignment="Center"/>
                                            <WxLink:WxLink Width="390" Margin="0,15"
                                                           InputParams="{Binding ModelParam.InputParams,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                           OutputParam="{Binding ModelParam.CreateTrajectoryModel.CircleCenterActualXYLinkParam,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                           Order="OpenParam"
                                                           Text="{Binding ModelParam.CreateTrajectoryModel.CircleCenterActualXYLinkParam.Name}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"  hc:InfoElement.Title="手动输入圆心X/Y：" hc:InfoElement.TitleWidth="180"
                                                              Width="300" DecimalPlaces="3" Minimum="-100000" Maximum="100000" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1"
                                                              HorizontalContentAlignment="Center" Value="{Binding ModelParam.CreateTrajectoryModel.CircleCenterX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <hc:NumericUpDown Width="100" DecimalPlaces="3" Minimum="-100000" Maximum="100000" BorderThickness="0 0 0 1"
                                                              HorizontalContentAlignment="Center" Value="{Binding ModelParam.CreateTrajectoryModel.CircleCenterY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="轨迹生成" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,5,0,0">
                                <WxGroupBox:WxGroupBox Header="圆形轨迹生成" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
                                            <TextBlock Width="110" Text="生成类型:" Foreground="Black" VerticalAlignment="Center"/>
                                            <ComboBox Width="280" Height="30" BorderThickness="0 0 0 1"
                                                       ItemsSource="{Binding CircleTrajectoryGenerateModes}"
                                                       SelectedItem="{Binding ModelParam.CreateTrajectoryModel.CircleGenerateMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Width="90" Height="30" Margin="12,0,0,0" Command="{Binding GenerateCircleTrajectoryCommand}"
                                                    Style="{StaticResource GeneralButtonStyle}" Content="生成轨迹"/>
                                            <CheckBox Content="启用最优路径" Margin="12,0,0,0" VerticalAlignment="Center"
                                                      IsChecked="{Binding ModelParam.CreateTrajectoryModel.IsOptimalPathEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="外圆半径：" hc:InfoElement.TitleWidth="110"
                                                              Width="300" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1" Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center" Value="{Binding ModelParam.CreateTrajectoryModel.CircleRadius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <Border Margin="8,10,8,0" Padding="10" CornerRadius="6" BorderBrush="#D8E2EE" BorderThickness="1"
                                                Visibility="{Binding ModelParam.CreateTrajectoryModel.IsCircleLineCountEditable,Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#2E5573" Text="线段轨迹参数"/>
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="线条数：" hc:InfoElement.TitleWidth="110"
                                                                  Width="300" DecimalPlaces="0" Minimum="1" Maximum="1000" BorderThickness="0 0 0 1" Style="{StaticResource NumericUpDownExtend}"
                                                                  HorizontalContentAlignment="Center"
                                                                  Value="{Binding ModelParam.CreateTrajectoryModel.CircleLineCount,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Margin="8,6,0,0" Foreground="#6A7480" Text="水平线、垂直线和过圆心交叉线使用该参数控制生成条数。"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="8,10,8,0" Padding="10" CornerRadius="6" BorderBrush="#D8E2EE" BorderThickness="1"
                                                Visibility="{Binding ModelParam.CreateTrajectoryModel.IsRectangleHorizontalLineEditable,Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#2E5573" Text="矩形水平线参数"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"  hc:InfoElement.Title="对角线起点X/Y：" hc:InfoElement.TitleWidth="150"
                                                                      Width="300" DecimalPlaces="3" Minimum="-100000" Maximum="100000" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1"
                                                                      HorizontalContentAlignment="Center" Value="{Binding ModelParam.CreateTrajectoryModel.RectangleStartX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                    <hc:NumericUpDown Width="100" DecimalPlaces="3" Minimum="-100000" Maximum="100000" BorderThickness="0 0 0 1"
                                                                      HorizontalContentAlignment="Center" Value="{Binding ModelParam.CreateTrajectoryModel.RectangleStartY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"  hc:InfoElement.Title="对角线终点X/Y：" hc:InfoElement.TitleWidth="150"
                                                                      Width="300" DecimalPlaces="3" Minimum="-100000" Maximum="100000" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1"
                                                                      HorizontalContentAlignment="Center" Value="{Binding ModelParam.CreateTrajectoryModel.RectangleEndX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                    <hc:NumericUpDown Width="100" DecimalPlaces="3" Minimum="-100000" Maximum="100000" BorderThickness="0 0 0 1"
                                                                      HorizontalContentAlignment="Center" Value="{Binding ModelParam.CreateTrajectoryModel.RectangleEndY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="水平线间距：" hc:InfoElement.TitleWidth="150"
                                                                  Width="300" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1" Style="{StaticResource NumericUpDownExtend}"
                                                                  HorizontalContentAlignment="Center"
                                                                  Value="{Binding ModelParam.CreateTrajectoryModel.HorizontalLineSpacing,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Margin="8,6,0,0" Foreground="#6A7480" TextWrapping="Wrap" Text="通过矩形对角线起点和终点确定范围，按水平线间距生成轨迹，并包含上下边界线。"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="8,10,8,0" Padding="10" CornerRadius="6" BorderBrush="#D8E2EE" BorderThickness="1"
                                                Visibility="{Binding ModelParam.CreateTrajectoryModel.IsInscribedCircleRadiusEditable,Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#2E5573" Text="内圆半径参数"/>
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="{Binding ModelParam.CreateTrajectoryModel.InscribedCircleRadiusTitle}" hc:InfoElement.TitleWidth="110"
                                                                  Width="300" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1" Style="{StaticResource NumericUpDownExtend}"
                                                                  HorizontalContentAlignment="Center"
                                                                  Value="{Binding ModelParam.CreateTrajectoryModel.InscribedCircleRadius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="8,10,8,0" Padding="10" CornerRadius="6" BorderBrush="#D8E2EE" BorderThickness="1"
                                                Visibility="{Binding ModelParam.CreateTrajectoryModel.IsPointSpacingEditable,Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#2E5573" Text="点位分布参数"/>
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="点间距：" hc:InfoElement.TitleWidth="110"
                                                                  Width="300" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1" Style="{StaticResource NumericUpDownExtend}"
                                                                  HorizontalContentAlignment="Center"
                                                                  Value="{Binding ModelParam.CreateTrajectoryModel.PointSpacing,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBlock Margin="8,6,0,0" Foreground="#6A7480" Text="等间距点、内切正方形点、内接同心圆点和圆环点使用该参数控制点密度。"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="8,10,8,0" Padding="10" CornerRadius="6" BorderBrush="#D8E2EE" BorderThickness="1"
                                                Visibility="{Binding ModelParam.CreateTrajectoryModel.IsCalibrationWaferMeasurementModeVisible,Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#2E5573" Text="标准片测量"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <TextBlock Width="110" Text="测量方式:" Foreground="Black" VerticalAlignment="Center"/>
                                                    <ComboBox Width="280" Height="30" BorderThickness="0 0 0 1"
                                                              ItemsSource="{Binding CalibrationWaferMeasurementModes}"
                                                              SelectedItem="{Binding ModelParam.CreateTrajectoryModel.CalibrationWaferMeasurementMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                                <TextBlock Margin="8,6,0,0"
                                                           Foreground="#6A7480"
                                                           TextWrapping="Wrap"
                                                           Text="仅在生成类型为内切正方形点时生效。启用后使用“标定片位置”页第一条有效坐标；为保持每行顺序，执行时会忽略最优路径排序。"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Margin="8,10,8,0" Padding="10" CornerRadius="6" BorderBrush="#D8E2EE" BorderThickness="1"
                                                Visibility="{Binding ModelParam.CreateTrajectoryModel.IsCustomRingAngleSpacingEditable,Converter={StaticResource BoolToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#2E5573" Text="自定义圆环参数"/>
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="角度间距：" hc:InfoElement.TitleWidth="110"
                                                                  Width="300" DecimalPlaces="3" Minimum="0.001" Maximum="360" BorderThickness="0 0 0 1" Style="{StaticResource NumericUpDownExtend}"
                                                                  HorizontalContentAlignment="Center"
                                                                  Value="{Binding ModelParam.CreateTrajectoryModel.CustomRingAngleSpacing,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                                                    <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="圆环半径：" hc:InfoElement.TitleWidth="110"
                                                                      Width="280" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1" Style="{StaticResource NumericUpDownExtend}"
                                                                      HorizontalContentAlignment="Center"
                                                                      Value="{Binding ModelParam.CreateTrajectoryModel.CustomRingRadiusInput,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                    <Button Width="80" Height="28" Margin="8,0,0,0" Command="{Binding AddCustomRingCommand}" Style="{StaticResource GeneralButtonStyle}" Content="添加"/>
                                                    <Button Width="80" Height="28" Margin="8,0,0,0" Command="{Binding RemoveCustomRingCommand}" Style="{StaticResource GeneralButtonStyle}" Content="删除"/>
                                                </StackPanel>
                                                <ListBox Height="120" Margin="8,10,8,0"
                                                         ItemsSource="{Binding ModelParam.CreateTrajectoryModel.CustomRingDefinitions}"
                                                         SelectedItem="{Binding SelectedCustomRing,Mode=TwoWay}">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" Margin="4">
                                                                <TextBlock Width="70" VerticalAlignment="Center" Text="半径"/>
                                                                <hc:NumericUpDown Width="220" Height="28" DecimalPlaces="3" Minimum="0.001" Maximum="100000" BorderThickness="0 0 0 1"
                                                                                  Value="{Binding Radius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Margin="12,10,12,0"
                                                   Foreground="#4C5A67"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding ModelParam.CreateTrajectoryModel.CircleGeneratorSummaryText}"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="轨迹编辑" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5,2">
                                            <TextBlock Text="操作:" VerticalAlignment="Center"/>
                                            <Button Margin="10,0,0,0" Width="80" Height="28" Command="{Binding AddLocusCommand}" Style="{StaticResource GeneralButtonStyle}" Content="新增"/>
                                            <Button Margin="8,0,0,0" Width="80" Height="28" Command="{Binding RemoveLocusCommand}" Style="{StaticResource GeneralButtonStyle}" Content="删除"/>
                                            <Button Margin="8,0,0,0" Width="120" Height="28" Command="{Binding MoveToSelectedLocusCommand}" Style="{StaticResource GeneralButtonStyle}" Content="移动到选中点"/>
                                            <Button Margin="8,0,0,0" Width="80" Height="28" Command="{Binding ClearLocusCommand}" Style="{StaticResource GeneralButtonStyle}" Content="清空"/>
                                        </StackPanel>

                                        <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}" EnableColumnVirtualization="True" EnableRowVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True" ItemsSource="{Binding ModelParam.AllLocusInfo}" SelectedItem="{Binding SelectedLocus,Mode=TwoWay}"
                                                  FontSize="12" ScrollViewer.HorizontalScrollBarVisibility="Auto" Height="340" RowHeaderWidth="20"
                                                  SelectionUnit="FullRow" HeadersVisibility="Column" GridLinesVisibility="All" IsReadOnly="False" CanUserAddRows="False">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="轨迹类型" Width="120">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ComboBox ItemsSource="{Binding DataContext.LocusTypeOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      SelectedValuePath="Value"
                                                                      DisplayMemberPath="DisplayName"
                                                                      SelectedValue="{Binding Type,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                      ToolTip="{Binding Type}"
                                                                      BorderThickness="0 0 0 1"
                                                                      Background="Transparent"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="起点 X" Width="Auto">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding OriginX,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding OriginX}" BorderThickness="0" Background="Transparent"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="起点 Y" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding OriginY,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding OriginY}" BorderThickness="0" Background="Transparent"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="终点 X" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding TargetX,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding TargetX}" BorderThickness="0" Background="Transparent"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="终点 Y" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding TargetY,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding TargetY}" BorderThickness="0" Background="Transparent"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="标定片位置" Width="120" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,5,0,0">
                                <WxGroupBox:WxGroupBox Header="标定片位置列表" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="5,2">
                                            <TextBlock Text="操作:" VerticalAlignment="Center"/>
                                            <Button Margin="10,0,0,0" Width="80" Height="28" Command="{Binding AddCalibrationWaferPositionCommand}" Style="{StaticResource GeneralButtonStyle}" Content="新增"/>
                                            <Button Margin="8,0,0,0" Width="80" Height="28" Command="{Binding RemoveCalibrationWaferPositionCommand}" Style="{StaticResource GeneralButtonStyle}" Content="删除"/>
                                            <Button Margin="8,0,0,0" Width="80" Height="28" Command="{Binding ClearCalibrationWaferPositionCommand}" Style="{StaticResource GeneralButtonStyle}" Content="清空"/>
                                        </StackPanel>

                                        <DataGrid AutoGenerateColumns="False"
                                                  Style="{StaticResource DefaultDataGridStyle}"
                                                  EnableColumnVirtualization="True"
                                                  EnableRowVirtualization="True"
                                                  VirtualizingPanel.IsVirtualizing="True"
                                                  ItemsSource="{Binding ModelParam.CalibrationWaferPositions}"
                                                  SelectedItem="{Binding SelectedCalibrationWaferPosition,Mode=TwoWay}"
                                                  FontSize="12"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  Height="420"
                                                  RowHeaderWidth="20"
                                                  SelectionUnit="FullRow"
                                                  HeadersVisibility="Column"
                                                  GridLinesVisibility="All"
                                                  IsReadOnly="False"
                                                  CanUserAddRows="False">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="名称" Width="2*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBox Text="{Binding Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
                                                                     ToolTip="{Binding Name}"
                                                                     BorderThickness="0"
                                                                     Background="Transparent"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="X 坐标" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <hc:NumericUpDown Width="150"
                                                                              DecimalPlaces="3"
                                                                              Minimum="-100000"
                                                                              Maximum="100000"
                                                                              BorderThickness="0 0 0 1"
                                                                              Style="{StaticResource NumericUpDownExtend}"
                                                                              HorizontalContentAlignment="Center"
                                                                              Value="{Binding X,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Header="Y 坐标" Width="*">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <hc:NumericUpDown Width="150"
                                                                              DecimalPlaces="3"
                                                                              Minimum="-100000"
                                                                              Maximum="100000"
                                                                              BorderThickness="0 0 0 1"
                                                                              Style="{StaticResource NumericUpDownExtend}"
                                                                              HorizontalContentAlignment="Center"
                                                                              Value="{Binding Y,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <GroupBox Header="参数说明">
                                    <TextBlock Margin="12"
                                               TextWrapping="Wrap"
                                               Foreground="#4C5A67"
                                               Text="执行标定时会使用这里配置的标定片位置列表。新增后可直接编辑名称、X 坐标和 Y 坐标，点击“确认”保存到当前模块参数。"/>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="控制卡设置" Width="auto" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="0,5,0,0">
                                <WxGroupBox:WxGroupBox Header="位置比较参数" Margin="0,0,0,8">
                                    <StackPanel>
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="比较模式："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="3"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.compareMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Margin="20,4,0,12"
                                                   Foreground="#6A7480"
                                                   Text="0:FIFO  1:Linear  2:PSO立即模式  3:PSO等待到位模式"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="输出脉冲宽度(us)："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="100000"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.comparePulseWidth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="输出信号模式："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="2"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.compareOutputMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Margin="20,4,0,12"
                                                   Foreground="#6A7480"
                                                   Text="0:脉冲  1:电平  2:电平自动翻转"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="比较源："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="1"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.sourceMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBlock Margin="20,4,0,12"
                                                   Foreground="#6A7480"
                                                   Text="0:编码器  1:脉冲计数器"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="误差带(Pulse)："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="100000"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.compareErrBand,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="等间距触发间隔(Pulse)："
                                                          hc:InfoElement.TitleWidth="170"
                                                          Width="380"
                                                          DecimalPlaces="0"
                                                          Minimum="1"
                                                          Maximum="1000000"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PosComparisonParam.syncPos,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <GroupBox Header="参数说明">
                                    <TextBlock Margin="12"
                                               TextWrapping="Wrap"
                                               Foreground="#4C5A67"
                                               Text="这里配置的位置比较参数会在执行轨迹前传入控制卡的 ControlPosComparison。修改后点击“确认”保存，后续执行时会读取当前配置值。"/>
                                </GroupBox>

                                <WxGroupBox:WxGroupBox Header="打点参数" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Width="560" HorizontalAlignment="Center">
                                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                              hc:InfoElement.Title="IO 掩码(ushort)："
                                                              hc:InfoElement.TitleWidth="160"
                                                              Width="420"
                                                              DecimalPlaces="0"
                                                              Minimum="0"
                                                              Maximum="65535"
                                                              BorderThickness="0 0 0 1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.PointOperationIoMaskHex,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="关闭延时(ms)："
                                                          hc:InfoElement.TitleWidth="160"
                                                          Width="420"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="65535"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PointOperationCloseDelayMs,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          hc:InfoElement.Title="到位延时(ms)："
                                                          hc:InfoElement.TitleWidth="160"
                                                          Width="420"
                                                          DecimalPlaces="0"
                                                          Minimum="0"
                                                          Maximum="65535"
                                                          BorderThickness="0 0 0 1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PointReadyDelayMs,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto"
                              Margin="5,5,5,0"
                              Header="轨迹预览"
                              ExpandDirection="Down"
                              VerticalAlignment="Top"
                              IsExpanded="True"
                              Style="{DynamicResource ExpanderStyle}">
                        <Border Background="#F7F9FB" CornerRadius="8" Padding="8" Margin="8,8,8,8">
                            <Canvas Background="White" 
                                    Width="380" 
                                    Height="380">
                                <ItemsControl ItemsSource="{Binding TrajectoryShapes}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </Canvas>
                        </Border>
                    </Expander>

                    <Expander Width="auto"
                              MaxHeight="420"
                              Margin="5,5,5,0"
                              Header="输出信息"
                              ExpandDirection="Down"
                              VerticalAlignment="Top"
                              IsExpanded="True"
                              Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="360"
                                          ItemsSource="{Binding ModelParam.OutputParamNames}"
                                          SelectedItem="{Binding SltOutputParamName,Mode=TwoWay}"
                                          Height="25"
                                          BorderThickness="0 0 0 1"
                                          Margin="5 0"/>
                                <Button Content="&#xe630;"
                                        Width="30"
                                        Height="26"
                                        FontSize="18"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Background="White"
                                        FontFamily="{StaticResource Iconfont}"
                                        BorderBrush="White"
                                        ToolTip="添加"
                                        Command="{Binding DataOperateCommand}"
                                        CommandParameter="Add"/>
                                <Button Content="&#xe74b;"
                                        Width="30"
                                        Height="26"
                                        FontSize="18"
                                        Style="{StaticResource GeneralButtonStyle}"
                                        Background="White"
                                        FontFamily="{StaticResource Iconfont}"
                                        BorderBrush="White"
                                        Margin="5 0"
                                        ToolTip="删除"
                                        Command="{Binding DataOperateCommand}"
                                        CommandParameter="Delete"/>
                            </StackPanel>

                            <DataGrid AutoGenerateColumns="False"
                                      Style="{StaticResource DefaultDataGridStyle}"
                                      EnableColumnVirtualization="True"
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      ItemsSource="{Binding ModelParam.OutputParams}"
                                      SelectedItem="{Binding CurrentOutputParam}"
                                      FontSize="12"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      Height="340"
                                      RowHeaderWidth="20"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      IsReadOnly="False"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}"
                                                         HorizontalAlignment="Stretch"
                                                         BorderThickness="0"
                                                         Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          Height="25"
                                                          BorderThickness="0 0 0 1"
                                                          Margin="5 0"
                                                          Background="Transparent"
                                                          SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}"
                                                         HorizontalAlignment="Center"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="{Binding Describe}"
                                                         HorizontalAlignment="Stretch"
                                                         BorderThickness="0"
                                                         Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Grid.RowSpan="2"
                Grid.ColumnSpan="2"

                BorderThickness="0 2 0 0"
                BorderBrush="{DynamicResource SelectedBrush}"
                CornerRadius="5"
                Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical" WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime, Mode=OneWay}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0"
                            FontSize="18"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="执行标定"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="35"
                            Width="auto"
                            Content="执行标定"
                            Cursor="Hand"/>

                    <Button Margin="0,0,15,0"
                            FontSize="18"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="执行"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="35"
                            Width="80"
                            Content="执行"
                            Cursor="Hand"/>
                    <Button Margin="0,0,15,0"
                            FontSize="18"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="取消"
                            Width="80"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="取消"
                            Cursor="Hand"/>
                    <Button Margin="0,0,15,0"
                            FontSize="18"
                            Command="{Binding GeneralCommand}"
                            CommandParameter="确认"
                            Style="{StaticResource GeneralButtonStyle}"
                            Width="80"
                            Content="确认"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

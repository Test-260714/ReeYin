<UserControl x:Class="Custom.WaferFlatnessMeasure.Views.DataAnalysisSourceFilterSettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             MinWidth="500"
             MaxWidth="640"
             MaxHeight="520"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignWidth="540"
             d:DesignHeight="395">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,14"
                   Foreground="#666666"
                   TextWrapping="Wrap"
                   Text="设置当前数据源的过滤范围和点采集首尾去除数量。启用“原始过滤”时，会在每个点位原始采样内先过滤再聚合；首尾去除数量仅在点采集聚合时作用于该数据源。"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      MaxHeight="360">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="数据源名称:"/>
                <TextBox Grid.Row="0" Grid.Column="1" Height="26" IsReadOnly="True"
                         BorderThickness="0 0 0 1"
                         Text="{Binding DataSourceName}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="OriginalData:"/>
                <TextBox Grid.Row="1" Grid.Column="1" Height="26" IsReadOnly="True"
                         BorderThickness="0 0 0 1"
                         Text="{Binding OriginalDataValueName}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="启用过滤:"/>
                <CheckBox Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"
                          IsChecked="{Binding IsFilterEnabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="原始过滤:"/>
                <CheckBox Grid.Row="3" Grid.Column="1" VerticalAlignment="Center"
                          IsChecked="{Binding IsRawDataFilter,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="下限:"/>
                <TextBox Grid.Row="4" Grid.Column="1" Height="26"
                         BorderThickness="0 0 0 1"
                         Text="{Binding FilterMin,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged,StringFormat={}{0:G17}}"/>

                <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="上限:"/>
                <TextBox Grid.Row="5" Grid.Column="1" Height="26"
                         BorderThickness="0 0 0 1"
                         Text="{Binding FilterMax,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged,StringFormat={}{0:G17}}"/>

                <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="点采集首尾去除:"/>
                <hc:NumericUpDown Grid.Row="6" Grid.Column="1"
                                  Width="120"
                                  Height="28"
                                  HorizontalAlignment="Left"
                                  DecimalPlaces="0"
                                  Minimum="0"
                                  Maximum="1000"
                                  BorderThickness="0 0 0 1"
                                  HorizontalContentAlignment="Center"
                                  Value="{Binding PointCollectionTrimCountPerSide,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Width="82" Height="30" Margin="0,0,8,0"
                    Content="确定"
                    Style="{StaticResource GeneralButtonStyle}"
                    Command="{Binding GeneralCommand}"
                    CommandParameter="OK"/>
            <Button Width="82" Height="30"
                    Content="取消"
                    Style="{StaticResource GeneralButtonStyle}"
                    Command="{Binding GeneralCommand}"
                    CommandParameter="Cancel"/>
        </StackPanel>
    </Grid>
</UserControl>

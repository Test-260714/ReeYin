<UserControl x:Class="Custom.KBTScraper.Views.SensorDataCollectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.KBTScraper.Views"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <Button Name="btnLogin" Margin="5 0 5 0" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30" Command="{Binding GeneralCommand}" CommandParameter="瀵煎叆閰嶇疆">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe645;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="瀵煎叆閰嶇疆" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button Margin="5 0 5 0" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30" Command="{Binding GeneralCommand}" CommandParameter="ExportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe646;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="瀵煎嚭閰嶇疆" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <!--涓讳綋-->
        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="鍩虹閰嶇疆" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="閲囬泦妯″紡" Margin="5 5 5 10">
                                    <Grid >
                                        <Border CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TabControl Width="600" Height="550" Style="{DynamicResource TabControlStyle}" SelectedIndex="{Binding ModelParam.SltTriggerPicIndex}">
                                                <TabItem Header="鎸囧畾鍥惧儚"  Style="{DynamicResource SingleTabItemStyle}" >
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center">
                                                                <RadioButton FontSize="14" Margin="0 0 0 0" Width="83" Height="32" IsChecked="{Binding ModelParam.IsLinkMode, Converter={StaticResource Boolean2BooleanReConverter}}" Content="閫夋嫨鏂囦欢" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"/>

                                                                <RadioButton FontSize="14" Margin="100 0 0 0" Width="83" Height="32" IsChecked="{Binding ModelParam.IsLinkMode}" Content="閾炬帴璺緞" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"/>

                                                            </StackPanel>

                                                            <Grid>
                                                                <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center" Visibility="{Binding ModelParam.IsFileVisibility}">
                                                                    <TextBox Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1" Text="{Binding ModelParam.FilePath}"/>
                                                                    <Button Width="30" Height="30" Content="&#xe7b9;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="鑾峰彇璺緞"/>
                                                                </StackPanel>

                                                                <StackPanel Visibility="{Binding ModelParam.IsLinkVisibility}" Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                                    <TextBox Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1" Text="{Binding ModelParam.LinkPath}"/>
                                                                    <Button Width="30" Height="30" Content="&#xe60e;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="杩炴帴璺緞" ToolTip="杩炴帴"/>
                                                                    <Button Width="30" Height="30" Content="&#xeaf2;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="鏂紑璺緞" ToolTip="鏂紑"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="鏂囦欢鐩綍" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center">
                                                                <TextBox Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1" Text="{Binding ModelParam.FilePath}"/>
                                                                <Button Content="&#xe7b9;" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30" Command="{Binding GeneralCommand}" CommandParameter="鑾峰彇璺緞"/>
                                                            </StackPanel>
                                                            <TextBlock Text="选择文件夹，总文件夹中应包含多份灰度和高度图" Foreground="Black" VerticalAlignment="Center"/>
                                                            <StackPanel/>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="鎸囧畾閲囬泦" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                                            <UniformGrid Columns="2" Margin="0,0,0,8" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                                <TextBlock Text="浼犳劅鍣ㄩ€夋嫨:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" ItemsSource="{Binding ModelParam.Models}" SelectedItem="{Binding ModelParam.SltModel}" DisplayMemberPath="NickName">
                                                                    <i:Interaction.Triggers>
                                                                        <i:EventTrigger EventName="SelectionChanged">
                                                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="鍒囨崲妯″潡"/>
                                                                        </i:EventTrigger>
                                                                    </i:Interaction.Triggers>
                                                                </ComboBox>

                                                                <TextBlock Text="浼犳劅鍣ㄥ娉?" Foreground="Black" VerticalAlignment="Center"/>
                                                                <TextBox Width="200"  Height="25" BorderThickness="0 0 0 1" Margin="5 0" HorizontalContentAlignment="Center" Text="{Binding ModelParam.SltModel.NickName}" IsReadOnly="True"/>

                                                                <TextBlock Text="鏇濆厜鏃堕棿:" Foreground="Black" VerticalAlignment="Center" />
                                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="0 0" SmallChange="1" BorderThickness="0 0 0 1" Value="{Binding ModelParam.SltModel.ExposureTime}"/>

                                                            </UniformGrid>

                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发开始采集" Width="auto" Margin="0 0 0 10" HorizontalAlignment="Left" FontSize="16" IsChecked="{Binding ModelParam.StartCollect}"/>

                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发停止采集并处理数据" Width="auto" HorizontalAlignment="Left" FontSize="16" IsChecked="{Binding ModelParam.StopAndDispose}"/>


                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                            </TabControl>
                                        </Border>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="閲囬泦閰嶇疆" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}" Height="45" VerticalAlignment="Top">
                            <Grid>
                                <WxGroupBox:WxGroupBox Header="绠楁硶閰嶇疆鍙傛暟">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="X像素当量(um)：" Width="400" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Minimum="0.001" Maximum="1000" Value="{Binding ModelParam.SensorIntervalX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="Y像素当量(um)：" Width="400" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Minimum="0.001" Maximum="1000" Value="{Binding ModelParam.SensorIntervalY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="Z像素当量(um)：" Width="400" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Minimum="0.001" Maximum="1000" Value="{Binding ModelParam.SensorIntervalZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="深度值下限(um*10)：" Width="400" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Value="{Binding ModelParam.MeasureParam.MinDepth}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="深度值上限(um*10)：" Width="400" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Value="{Binding ModelParam.MeasureParam.MaxDepth}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="最小缺陷深度(um)：" Width="400" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Value="{Binding ModelParam.MeasureParam.MinDefectDepth}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          DecimalPlaces="4"
                                                          hc:InfoElement.Title="最小缺陷直径(um)："
                                                          Width="400"
                                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                                          hc:InfoElement.TitleWidth="auto"
                                                          BorderThickness="0 0 0 1"
                                                          Foreground="Black"
                                                          Margin="5"
                                                          HorizontalContentAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          Value="{Binding ModelParam.MeasureParam.MinDefectRadius}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left"
                                                          DecimalPlaces="2"
                                                          hc:InfoElement.Title="走带距离(mm)："
                                                          Width="400"
                                                          Style="{StaticResource NumericUpDownExtendGlobal}"
                                                          hc:InfoElement.TitleWidth="auto"
                                                          BorderThickness="0 0 0 1"
                                                          Foreground="Black"
                                                          Margin="5"
                                                          HorizontalContentAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          Minimum="0.1"
                                                          Maximum="1000"
                                                          Value="{Binding ModelParam.TravelDistanceMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Left">
                                            <TextBlock Text="缂洪櫡妫€娴婸LC寮€鍏筹細" Foreground="Black" VerticalAlignment="Center" />
                                            <ComboBox Width="120" BorderThickness="0 0 0 1" Margin="10 0 0 0"
                                                      SelectedValuePath="Tag"
                                                      SelectedValue="{Binding ModelParam.EnablePlcDefectSignal, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                                <ComboBoxItem Content="开启" Tag="True"/>
                                                <ComboBoxItem Content="鍏抽棴" Tag="False"/>
                                            </ComboBox>
                                        </StackPanel>

                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </Grid>
                        </TabItem>

                        <TabItem Header="瀛樺偍鍙傛暟" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="瀛樺浘璁剧疆>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                                        <StackPanel Orientation="Vertical">
                                            <CheckBox Content="鍚敤瀛樺浘" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16" IsChecked="{Binding ModelParam.OtherConfig.IsSaveImage}"/>

                                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                <TextBlock Text="瀛樺浘璺緞:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="500" Margin="5 0" Order="OpenFile" Text="{Binding ModelParam.OtherConfig.SavePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </WxGroupBox:WxGroupBox>
                                    
                                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="瀛樼己闄蜂俊鎭瓑璁剧疆>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                                        <StackPanel Orientation="Vertical">
                                            <CheckBox Content="鍚敤瀛樺偍缂洪櫡鏁版嵁" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16" IsChecked="{Binding ModelParam.OtherConfig.IsSaveCSV}"/>

                                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                <TextBlock Text="瀛樺偍璺緞:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                <WxLink:WxLink Width="500" Margin="5 0" Order="OpenFile" Text="{Binding ModelParam.OtherConfig.SaveCSVPath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                        </StackPanel>
                                    </WxGroupBox:WxGroupBox>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="鍏朵粬" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>

                            </Grid>
                        </TabItem>

                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="鍥惧儚棰勮" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <!--<Controls:ImageEditView Height="300" Background="{StaticResource BackgroudBrush}"/>-->
                        </StackPanel>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="杈撳嚭淇℃伅" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="鏁版嵁:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" Height="25" BorderThickness="0 0 0 1" Margin="5 0" ItemsSource="{Binding ModelParam.OutputParamResource}" SelectedValue="{Binding SltOutputParamName}" DisplayMemberPath="Key"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
             Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                     ToolTip="娣诲姞" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                 Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                     ToolTip="鍒犻櫎" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}" ItemsSource="{Binding ModelParam.OutputParams}" SelectedItem="{Binding CurrentOutputParam}"
                      EnableColumnVirtualization="True"
                      EnableRowVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      FontSize="12" 
                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                      Height="160"
                      RowHeaderWidth="20"
                      SelectionUnit="FullRow"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      IsReadOnly="False" CanUserAddRows="False" >
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="鍙傛暟鍚嶇О" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="鏁版嵁绫诲瀷" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="澶囨敞" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="鍏ㄥ眬" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <!--搴曢儴杩愯鐘舵€佹爮-->
        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="鑰楁椂:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <Run Text="鎵ц鐘舵€?"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="auto"
                                                    Content="鎵撳紑鍥惧儚棰勮"
                                                    Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="鎵撳紑鍥惧儚棰勮"/>
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Style="{StaticResource GeneralButtonStyle}"
                                Height="35" Width="80"
                                Content="鎵ц"
                                Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="鎵ц"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                Height="auto" Width="80"
                                Style="{StaticResource GeneralButtonStyle}"
                                Content="鍙栨秷"
                                Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="鍙栨秷"/>
                    <Button Margin="0,0,15,0" FontSize="18"
                                Style="{StaticResource GeneralButtonStyle}"
                                Height="auto" Width="80"
                                Content="纭"
                                Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="纭"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>


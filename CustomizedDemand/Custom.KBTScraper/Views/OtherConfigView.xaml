<UserControl x:Class="Custom.KBTScraper.Views.OtherConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.KBTScraper.Views"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             d:DesignHeight="950" d:DesignWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <WxGroupBox:WxGroupBox Header="鍏朵粬閰嶇疆">
            <!-- 鏃ュ織鏄剧ず鍖哄煙锛氬甫婊氬姩鏉＄殑TextBlock -->
            <ScrollViewer Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel>
                    <StackPanel>
                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="最小缺陷深度(um)：" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="10" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Value="{Binding Algorithm.MinDefectDepth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        
                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="最小缺陷直径(um)：" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="10" HorizontalContentAlignment="Center" HorizontalAlignment="Left" Value="{Binding Algorithm.MinDefectRadius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Left">
                            <TextBlock Text="型号：" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                            <TextBox Width="200" Margin="5 0" Text="{Binding Model.ProductNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Left">
                            <TextBlock Text="批号：" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                            <TextBox Width="200" Margin="5 0" Text="{Binding Model.BatchNum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                    </StackPanel>

                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="瀛樺浘璁剧疆>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                        <StackPanel Orientation="Vertical">
                            <CheckBox Content="鍚敤瀛樺浘" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16" IsChecked="{Binding Model.IsSaveImage}"/>

                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Left">
                                <TextBlock Text="瀛樺浘璺緞:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                <WxLink:WxLink Width="auto" MinWidth="200" Margin="5 0" Order="OpenFile" Text="{Binding Model.SavePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <DockPanel  Margin="10 ">
                                <TextBlock  Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" MaxWidth="200">
                                <Run Text="浠庢枃浠朵腑鍔犺浇鍥剧墖(棰勮):"/>
                                </TextBlock>
                                <Button Margin="0,0,0,0" FontSize="18" HorizontalAlignment="Right"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="60"
                                                    Content="鎵撳紑"
                                                    Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="鎵撳紑"/>
                            </DockPanel>
                        </StackPanel>


                    </WxGroupBox:WxGroupBox>

                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="瀛樼己闄蜂俊鎭瓑璁剧疆>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                        <StackPanel Orientation="Vertical">
                            <CheckBox Content="鍚敤瀛樺偍缂洪櫡鏁版嵁" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16" IsChecked="{Binding Model.IsSaveCSV}"/>

                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Left">
                                <TextBlock Text="瀛樺偍璺緞:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                <WxLink:WxLink Width="auto" MinWidth="200" Margin="5 0" Order="OpenFile" Text="{Binding Model.SaveCSVPath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                        </StackPanel>
                    </WxGroupBox:WxGroupBox>
                </StackPanel>


            </ScrollViewer>

        </WxGroupBox:WxGroupBox>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
            <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="100"
                                                    Content="淇濆瓨"
                                                    Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="淇濆瓨"/>
        </StackPanel>
    </Grid>
</UserControl>


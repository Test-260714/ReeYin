<UserControl x:Class="Custom.KBTScraper.Views.AutoProcessView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.KBTScraper.Views"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="500">
    <Grid>
        <WxGroupBox:WxGroupBox Header="运行操作按钮" >
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" Margin="10 0 0 0">
                    <Button Content="&#xe61b;" Style="{StaticResource NavOperateButtonStyle}" ToolTip="开始" 
                            Command="{Binding GeneralCommand}" CommandParameter="开始" Cursor="Hand"/>
                    <Button Content="&#xe7a3;" Style="{StaticResource NavOperateButtonStyle}" ToolTip="继续" 
                            Command="{Binding GeneralCommand}" CommandParameter="继续"/>
                    <Button Content="&#xea76;" Style="{StaticResource NavOperateButtonStyle}" ToolTip="停止" 
                            Command="{Binding GeneralCommand}" CommandParameter="停止"/>
                    <Button Content="&#xe64c;" Style="{StaticResource NavOperateButtonStyle}" ToolTip="重置" 
                            Command="{Binding GeneralCommand}" CommandParameter="重置"/>
                </StackPanel>
                
                <!-- 传感器状态和采集段数 -->
                <StackPanel Orientation="Vertical" Margin="20 5 0 0">
                    <!-- 传感器状态 -->
                    <TextBlock Foreground="Black" VerticalAlignment="Center">
                        <Run Text="传感器状态: "/>
                        <Run Text="{Binding Model.SensorStatus}"/>
                    </TextBlock>

                    <!-- 运行次数 -->
                    <TextBlock Foreground="Black" VerticalAlignment="Center" Margin="0 5 0 0">
                        <Run Text="采集段数: "/>
                        <Run Text="{Binding Model.RunNum}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </WxGroupBox:WxGroupBox>
    </Grid>
</UserControl>

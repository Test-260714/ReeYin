<UserControl x:Class="Custom.KBTScraper.Views.GrayShowView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.KBTScraper.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600" d:DesignWidth="500">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 左侧：上一段结果 -->
        <WxGroupBox:WxGroupBox Grid.Column="0" Header="上一段结果" Margin="0">
            <DockPanel>
                <Controls:ImageEditView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" Image="{Binding PreviousImage}"/>
            </DockPanel>
        </WxGroupBox:WxGroupBox>
        
        <!-- 右侧：当前段结果 -->
        <WxGroupBox:WxGroupBox Grid.Column="1" Header="当前段结果" Margin="0">
            <DockPanel>
                <Controls:ImageEditView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" Image="{Binding Image}"/>
            </DockPanel>
        </WxGroupBox:WxGroupBox>
        
        <!--操作-->
        <!-- 左侧：上一段缺陷信息 -->
        <Expander Grid.Column="0" Header="上一段缺陷信息" Background="#80FFFFFF" BorderThickness="0" HorizontalContentAlignment="Center" FontWeight="Bold"
                  IsExpanded="False" Margin="10 45 10 0" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Border MaxHeight="300" CornerRadius="3">
                <Border.Background>
                    <SolidColorBrush Color="#80FFFFFF" Opacity="0.7" />
                </Border.Background>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" MaxHeight="500" MinHeight="200" MinWidth="300">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="10">
                        <TextBlock Foreground="White">
                            <Run Text="缺陷深度："/>
                            <LineBreak/>
                            <Run Text="     最小值："/> <Run Text="{Binding PrevMinDefectDepth, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                            <Run Text="     最大值："/> <Run Text="{Binding PrevMaxDefectDepth, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                            <LineBreak/>
                            <Run Text="     平均值："/> <Run Text="{Binding PrevAvgDefectDepth, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                        </TextBlock>
                        
                        <TextBlock Foreground="White">
                            <Run Text="缺陷直径："/>
                            <LineBreak/>
                            <Run Text="     最小值："/> <Run Text="{Binding PrevMinDefectRadius, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                            <Run Text="     最大值："/> <Run Text="{Binding PrevMaxDefectRadius, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                            <LineBreak/>
                            <Run Text="     平均值："/> <Run Text="{Binding PrevAvgDefectRadius, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                        </TextBlock>

                        <TextBlock Foreground="White">
                            <Run Text="缺陷数量："/>
                            <Run Text="{Binding PrevDefectCount}"/>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Expander>
        
        <!-- 右侧：当前段缺陷信息 -->
        <Expander Grid.Column="1" Header="当前段缺陷信息" Background="#80FFFFFF" BorderThickness="0" HorizontalContentAlignment="Center" FontWeight="Bold"
                  IsExpanded="False" Margin="10 45 10 0" HorizontalAlignment="Right" VerticalAlignment="Top">
            <Border MaxHeight="300" CornerRadius="3">
                <Border.Background>
                    <SolidColorBrush Color="#80FFFFFF" Opacity="0.7" />
                </Border.Background>
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" MaxHeight="500" MinHeight="200" MinWidth="300">
                    <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Left" Margin="10">
                        <TextBlock Foreground="White">
                            <Run Text="缺陷深度："/>
                            <LineBreak/>
                            <Run Text="     最小值："/> <Run Text="{Binding MinDefectDepth, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                            <Run Text="     最大值："/> <Run Text="{Binding MaxDefectDepth, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                            <LineBreak/>
                            <Run Text="     平均值："/> <Run Text="{Binding AvgDefectDepth, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                        </TextBlock>
                        
                        <TextBlock Foreground="White">
                            <Run Text="缺陷直径："/>
                            <LineBreak/>
                            <Run Text="     最小值："/> <Run Text="{Binding MinDefectRadius, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                            <Run Text="     最大值："/> <Run Text="{Binding MaxDefectRadius, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                            <LineBreak/>
                            <Run Text="     平均值："/> <Run Text="{Binding AvgDefectRadius, StringFormat={}{0:F2}}"/> <Run Text="um;"/>
                        </TextBlock>

                        <TextBlock Foreground="White">
                            <Run Text="缺陷数量："/>
                            <Run Text="{Binding DefectCount}"/>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Expander>
    </Grid>
</UserControl>

<UserControl x:Class="Custom.KBTScraper.Views.ChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.KBTScraper.Views"
             mc:Ignorable="d" 
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             prism:ViewModelLocator.AutoWireViewModel="True"
             FontSize="14"
             x:Name="window" Height="880" Width="1500">
    <Grid>
        <WxGroupBox:WxGroupBox Header="图表视图">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <WxGroupBox:WxGroupBox Grid.Column="0" Header="灰度图" Margin="5">
                    <Controls:ImageEditView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" Image="{Binding GrayImage}"/>
                </WxGroupBox:WxGroupBox>
                
                <WxGroupBox:WxGroupBox Grid.Column="1" Header="高度图" Margin="5">
                    <Controls:ImageEditView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" Image="{Binding HeightImage}"/>
                </WxGroupBox:WxGroupBox>
            </Grid>
        </WxGroupBox:WxGroupBox>
    </Grid>
</UserControl>

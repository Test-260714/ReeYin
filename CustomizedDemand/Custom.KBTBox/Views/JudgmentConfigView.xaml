<UserControl x:Class="Custom.KBTBox.Views.JudgmentConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Custom.KBTBox.Views"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="550">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <WxGroupBox:WxGroupBox Header="判定参数配置">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel>

                    <!-- 胶面参数判定 -->
                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="胶面参数判定(每条边)>>"
                                           VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                        <StackPanel>
                            <!-- 表头 -->
                            <Grid Margin="10,8,10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="参数名称" FontWeight="Bold" Foreground="Gray"/>
                                <TextBlock Grid.Column="1" Text="最小值" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="最大值" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center"/>
                            </Grid>

                            <!-- 胶平面度 -->
                            <Grid Margin="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="胶平面度" FontSize="14" VerticalAlignment="Center"
                                          IsChecked="{Binding Config.GlueFlatness.Enabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="1" DecimalPlaces="2" Margin="5,0" Minimum="-99999" Maximum="99999"
                                                  IsEnabled="{Binding Config.GlueFlatness.Enabled}"
                                                  Value="{Binding Config.GlueFlatness.Min,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="2" DecimalPlaces="2" Margin="5,0" Minimum="-99999" Maximum="99999"
                                                  IsEnabled="{Binding Config.GlueFlatness.Enabled}"
                                                  Value="{Binding Config.GlueFlatness.Max,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <!-- 胶宽 -->
                            <Grid Margin="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="胶宽" FontSize="14" VerticalAlignment="Center"
                                          IsChecked="{Binding Config.GlueWidth.Enabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="1" DecimalPlaces="2" Margin="5,0"
                                                  IsEnabled="{Binding Config.GlueWidth.Enabled}"
                                                  Value="{Binding Config.GlueWidth.Min,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="2" DecimalPlaces="2" Margin="5,0"
                                                  IsEnabled="{Binding Config.GlueWidth.Enabled}"
                                                  Value="{Binding Config.GlueWidth.Max,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <!-- 胶厚 -->
                            <Grid Margin="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="胶厚" FontSize="14" VerticalAlignment="Center"
                                          IsChecked="{Binding Config.GlueThickness.Enabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="1" DecimalPlaces="2" Margin="5,0"
                                                  IsEnabled="{Binding Config.GlueThickness.Enabled}"
                                                  Value="{Binding Config.GlueThickness.Min,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="2" DecimalPlaces="2" Margin="5,0"
                                                  IsEnabled="{Binding Config.GlueThickness.Enabled}"
                                                  Value="{Binding Config.GlueThickness.Max,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <!-- 胶路偏转角度(取绝对值) -->
                            <Grid Margin="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="胶路偏转角度" FontSize="14" VerticalAlignment="Center"
                                          IsChecked="{Binding Config.GluePathTiltAngle.Enabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="1" DecimalPlaces="2" Margin="5,0" Minimum="0" Maximum="99999"
                                                  IsEnabled="{Binding Config.GluePathTiltAngle.Enabled}"
                                                  Value="{Binding Config.GluePathTiltAngle.Min,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="2" DecimalPlaces="2" Margin="5,0" Minimum="0" Maximum="99999"
                                                  IsEnabled="{Binding Config.GluePathTiltAngle.Enabled}"
                                                  Value="{Binding Config.GluePathTiltAngle.Max,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </WxGroupBox:WxGroupBox>

                    <!-- 缺陷参数判定 -->
                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="缺陷参数判定(每条边)>>"
                                           VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                        <StackPanel>
                            <!-- 表头 -->
                            <Grid Margin="10,8,10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="参数名称" FontWeight="Bold" Foreground="Gray"/>
                                <TextBlock Grid.Column="1" Text="最小值" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="最大值" FontWeight="Bold" Foreground="Gray" HorizontalAlignment="Center"/>
                            </Grid>

                            <!-- 缺陷面积 -->
                            <Grid Margin="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="缺陷面积" FontSize="14" VerticalAlignment="Center"
                                          IsChecked="{Binding Config.DefectArea.Enabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="1" DecimalPlaces="2" Margin="5,0" Minimum="-99999" Maximum="99999"
                                                  IsEnabled="{Binding Config.DefectArea.Enabled}"
                                                  Value="{Binding Config.DefectArea.Min,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="2" DecimalPlaces="2" Margin="5,0" Minimum="-99999" Maximum="99999"
                                                  IsEnabled="{Binding Config.DefectArea.Enabled}"
                                                  Value="{Binding Config.DefectArea.Max,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <!-- 缺陷直径 -->
                            <Grid Margin="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="缺陷直径" FontSize="14" VerticalAlignment="Center"
                                          IsChecked="{Binding Config.DefectDiameter.Enabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="1" DecimalPlaces="2" Margin="5,0" Minimum="-99999" Maximum="99999"
                                                  IsEnabled="{Binding Config.DefectDiameter.Enabled}"
                                                  Value="{Binding Config.DefectDiameter.Min,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="2" DecimalPlaces="2" Margin="5,0" Minimum="-99999" Maximum="99999"
                                                  IsEnabled="{Binding Config.DefectDiameter.Enabled}"
                                                  Value="{Binding Config.DefectDiameter.Max,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>

                            <!-- 缺陷深度 -->
                            <Grid Margin="10,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="缺陷深度" FontSize="14" VerticalAlignment="Center"
                                          IsChecked="{Binding Config.DefectDepth.Enabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="1" DecimalPlaces="2" Margin="5,0" Minimum="-99999" Maximum="99999"
                                                  IsEnabled="{Binding Config.DefectDepth.Enabled}"
                                                  Value="{Binding Config.DefectDepth.Min,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                <hc:NumericUpDown Grid.Column="2" DecimalPlaces="2" Margin="5,0" Minimum="-99999" Maximum="99999"
                                                  IsEnabled="{Binding Config.DefectDepth.Enabled}"
                                                  Value="{Binding Config.DefectDepth.Max,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </StackPanel>
                    </WxGroupBox:WxGroupBox>

                </StackPanel>
            </ScrollViewer>
        </WxGroupBox:WxGroupBox>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
            <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Command="{Binding GeneralCommand}" CommandParameter="保存"
                    Style="{StaticResource GeneralButtonStyle}"
                    Height="35" Width="100"
                    Content="保存"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>

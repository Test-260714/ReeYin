<UserControl x:Class="Custom.KBTBox.Views.OtherConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.KBTBox.Views"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"
             d:DesignHeight="950" d:DesignWidth="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <WxGroupBox:WxGroupBox Header="其他配置">
            <!-- 日志显示区域：带滚动条的TextBlock -->
            <ScrollViewer Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Background="Transparent">
                <StackPanel>
                    <StackPanel>
                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="折射率：" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="10" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                      Value="{Binding Algorithm.RefractiveIndex,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="胶高/宽采样点间隔(um)：" IsEnabled="False" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="10" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                      Value="{Binding Algorithm.SamplingInterval,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="采样点可视化间隔(个)：" Width="300" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="10" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                      Value="{Binding Algorithm.SamplingViewInterval,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                    </StackPanel>

                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="存图设置>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                        <StackPanel Orientation="Vertical">
                            <CheckBox Content="启用存图" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding Model.IsSaveImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Left">
                                <TextBlock Text="存图路径:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                <WxLink:WxLink Width="auto" MinWidth="200" Margin="5 0" Order="OpenFile" Text="{Binding Model.SavePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <DockPanel  Margin="10 ">
                                <TextBlock  Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" MaxWidth="200">
                                <Run Text="从文件中加载图片(预览):"/>
                                <Run Text="{Binding FilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                </TextBlock>
                                <Button Margin="0,0,0,0" FontSize="18" HorizontalAlignment="Right"
                                                    Command="{Binding GeneralCommand}" CommandParameter="打开"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="60"
                                                    Content="打开"
                                                    Cursor="Hand"/>
                            </DockPanel>
                        </StackPanel>


                    </WxGroupBox:WxGroupBox>

                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="判定设置>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                        <StackPanel Orientation="Vertical">
                            <CheckBox Content="启用数据判定" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding Model.IsEnableJudgment,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </WxGroupBox:WxGroupBox>

                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="自动流程设置>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                        <StackPanel Orientation="Vertical">
                            <CheckBox Content="软件启动后自动运行流程" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding Model.IsAutoStart,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </WxGroupBox:WxGroupBox>

                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="存缺陷信息等设置>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                        <StackPanel Orientation="Vertical">
                            <CheckBox Content="启用存储倍数（100um）的胶宽/高数据" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding Model.IsSaveCSV,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                            <StackPanel Orientation="Horizontal" Margin="10 " HorizontalAlignment="Left">
                                <TextBlock Text="存储路径:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                <WxLink:WxLink Width="auto" MinWidth="200" Margin="5 0" Order="OpenFile" Text="{Binding Model.SaveCSVPath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                        </StackPanel>
                    </WxGroupBox:WxGroupBox>
                </StackPanel>


            </ScrollViewer>

        </WxGroupBox:WxGroupBox>

        <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
            <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                                    Command="{Binding GeneralCommand}" CommandParameter="保存"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Height="35" Width="100"
                                                    Content="保存"
                                                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>


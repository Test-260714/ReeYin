<UserControl x:Class="Custom.CalibrationPlateMeasure.Views.CalibrationPlatePointCloudViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:model="clr-namespace:PointCloud.VTKWPF.Models;assembly=PointCloud.VTKWPF"
             xmlns:vtk="clr-namespace:PointCloud.VTKWPF.Controls;assembly=PointCloud.VTKWPF"
             mc:Ignorable="d"
             d:DesignHeight="780"
             d:DesignWidth="1100"
             FontFamily="Microsoft YaHei UI"
             FontSize="13">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource GeneralButtonStyle}">
            <Setter Property="Width" Value="110" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style x:Key="ViewOrientationButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#C8C8C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF3DD" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D7A451" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE1B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C98D2C" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#C8C8C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF3DD" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D7A451" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE1B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C98D2C" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BtnOverColor}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource BtnOverColor}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#C8C8C8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFF3DD" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D7A451" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFE1B8" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#C98D2C" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SceneCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D8E0E8" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SceneLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#0F172A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="8,6,8,6" Margin="5 2 5 0"
                Background="#F8FAFC"
                BorderBrush="#D8E0E8"
                BorderThickness="0,0,0,1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <Button Content="&#21152;&#36733;&#28857;&#20113;"
                            Command="{Binding OpenPointCloudCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" />
                    <Button Content="&#28165;&#31354;&#22330;&#26223;"
                            Command="{Binding ClearCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Margin="0" />
                </StackPanel>

                <Border Grid.Column="2"
                        HorizontalAlignment="Right"
                        Margin="0,0,12,0"
                        Padding="8,4,8,4"
                        Background="#F5F5F5"
                        BorderBrush="#1A000000"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#66000000"
                                   Text="&#28857;&#20113;&#25805;&#20316;" />

                        <Button Content="&#35774;&#32622;&#26631;&#37327;&#22330;"
                                Command="{Binding SetScalarFieldCommand}"
                                Style="{StaticResource ToolbarActionButtonStyle}" />
                        <Button Content="&#32553;&#25918;"
                                Command="{Binding ScalePointCloudCommand}"
                                Style="{StaticResource ToolbarActionButtonStyle}" />
                        <Button Content="SF params"
                                Command="{Binding EditScalarFieldDisplayParamsCommand}"
                                Style="{StaticResource ToolbarActionButtonStyle}" />
                        <ToggleButton Content="EDL"
                                      IsChecked="{Binding EnableEdl, Mode=TwoWay}"
                                      Style="{StaticResource ToolbarToggleButtonStyle}" />
                        <ToggleButton Content="&#35774;&#32622;&#20013;&#26530;"
                                      IsChecked="{Binding IsPivotPickingEnabled, Mode=TwoWay}"
                                      Style="{StaticResource ToolbarToggleButtonStyle}"
                                      Margin="0" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                        HorizontalAlignment="Right"
                        Padding="8,4,2,4"
                        Background="#F5F5F5"
                        BorderBrush="#1A000000"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#66000000"
                                   Text="&#26631;&#20934;&#35270;&#22270;" />

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Front}"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#21069;&#35270;&#22270; (+Y)">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="18" Height="18">
                                    <Polygon Points="3,6 9,3 15,6 9,9" Fill="#FFFDF9" Stroke="#5B5B5B" StrokeThickness="1" />
                                    <Polygon Points="3,6 9,9 9,15 3,12" Fill="#F0A74D" Stroke="#5B5B5B" StrokeThickness="1" />
                                    <Polygon Points="9,9 15,6 15,12 9,15" Fill="#F4F4F4" Stroke="#5B5B5B" StrokeThickness="1" />
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Back}"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#21518;&#35270;&#22270; (-Y)">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="18" Height="18" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform ScaleX="-1" />
                                    </Grid.RenderTransform>
                                    <Canvas Width="18" Height="18">
                                        <Polygon Points="3,6 9,3 15,6 9,9" Fill="#FFFDF9" Stroke="#5B5B5B" StrokeThickness="1" />
                                        <Polygon Points="3,6 9,9 9,15 3,12" Fill="#F0A74D" Stroke="#5B5B5B" StrokeThickness="1" />
                                        <Polygon Points="9,9 15,6 15,12 9,15" Fill="#F4F4F4" Stroke="#5B5B5B" StrokeThickness="1" />
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                        </Button>

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Left}"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#24038;&#35270;&#22270; (-X)">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="18" Height="18" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform ScaleX="-1" />
                                    </Grid.RenderTransform>
                                    <Canvas Width="18" Height="18">
                                        <Polygon Points="3,6 9,3 15,6 9,9" Fill="#FFFDF9" Stroke="#5B5B5B" StrokeThickness="1" />
                                        <Polygon Points="3,6 9,9 9,15 3,12" Fill="#F7F7F7" Stroke="#5B5B5B" StrokeThickness="1" />
                                        <Polygon Points="9,9 15,6 15,12 9,15" Fill="#F0A74D" Stroke="#5B5B5B" StrokeThickness="1" />
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                        </Button>

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Right}"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#21491;&#35270;&#22270; (+X)">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="18" Height="18">
                                    <Polygon Points="3,6 9,3 15,6 9,9" Fill="#FFFDF9" Stroke="#5B5B5B" StrokeThickness="1" />
                                    <Polygon Points="3,6 9,9 9,15 3,12" Fill="#F7F7F7" Stroke="#5B5B5B" StrokeThickness="1" />
                                    <Polygon Points="9,9 15,6 15,12 9,15" Fill="#F0A74D" Stroke="#5B5B5B" StrokeThickness="1" />
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Top}"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                ToolTip="&#20463;&#35270;&#22270; (+Z)">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="18" Height="18">
                                    <Polygon Points="3,6 9,3 15,6 9,9" Fill="#F0A74D" Stroke="#5B5B5B" StrokeThickness="1" />
                                    <Polygon Points="3,6 9,9 9,15 3,12" Fill="#F7F7F7" Stroke="#5B5B5B" StrokeThickness="1" />
                                    <Polygon Points="9,9 15,6 15,12 9,15" Fill="#F4F4F4" Stroke="#5B5B5B" StrokeThickness="1" />
                                </Canvas>
                            </Viewbox>
                        </Button>

                        <Button Command="{Binding SetViewOrientationCommand}"
                                CommandParameter="{x:Static model:PointCloudViewOrientation.Bottom}"
                                Style="{StaticResource ViewOrientationButtonStyle}"
                                Margin="0"
                                ToolTip="&#20208;&#35270;&#22270; (-Z)">
                            <Viewbox Width="18" Height="18">
                                <Grid Width="18" Height="18" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform ScaleY="-1" />
                                    </Grid.RenderTransform>
                                    <Canvas Width="18" Height="18">
                                        <Polygon Points="3,6 9,3 15,6 9,9" Fill="#F0A74D" Stroke="#5B5B5B" StrokeThickness="1" />
                                        <Polygon Points="3,6 9,9 9,15 3,12" Fill="#F7F7F7" Stroke="#5B5B5B" StrokeThickness="1" />
                                        <Polygon Points="9,9 15,6 15,12 9,15" Fill="#F4F4F4" Stroke="#5B5B5B" StrokeThickness="1" />
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="5 5 1 5"
                    Padding="12"
                    Background="#F8FAFC"
                    BorderBrush="#D8E0E8"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="&#22330;&#26223;&#35774;&#32622;"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#1F2933" />

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,12,0,0"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Style="{StaticResource SceneCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Margin="0,0,8,0"
                                                 VerticalAlignment="Center"
                                                 Fill="{Binding Tag.PointCloudLoadStateBrush, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Tag.PointCloudLoadStateText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1F2933"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SceneCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="&#36873;&#20013;&#28857;"
                                               Style="{StaticResource SceneLabelStyle}" />
                                    <TextBlock Margin="0,6,0,12"
                                               Text="{Binding SelectedPointText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />

                                    <TextBlock Text="&#36793;&#30028;"
                                               Style="{StaticResource SceneLabelStyle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="&#26368;&#23567;"
                                               Style="{StaticResource SceneLabelStyle}" />
                                    <TextBlock Text="{Binding BoundsMinText}"
                                               FontFamily="Consolas"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="&#26368;&#22823;"
                                               Style="{StaticResource SceneLabelStyle}" />
                                    <TextBlock Text="{Binding BoundsMaxText}"
                                               FontFamily="Consolas"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,10,0,0"
                                               Text="&#23610;&#23544;"
                                               Style="{StaticResource SceneLabelStyle}" />
                                    <TextBlock Text="{Binding BoundsSizeText}"
                                               FontFamily="Consolas"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SceneCardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#26631;&#37327;&#22330;"
                                                   Style="{StaticResource SceneLabelStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ScalarFieldDisplayText}"
                                                   FontWeight="SemiBold" />
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#28857;&#22823;&#23567;"
                                                   Style="{StaticResource SceneLabelStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PointSizeText}"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                    <Slider Margin="0,8,0,0"
                                            Minimum="1"
                                            Maximum="20"
                                            Value="{Binding PointSize, Mode=TwoWay}" />

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#36879;&#26126;&#24230;"
                                                   Style="{StaticResource SceneLabelStyle}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding OpacityText}"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                    <Slider Margin="0,8,0,0"
                                            Minimum="0.15"
                                            Maximum="1"
                                            Value="{Binding Opacity, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SceneCardStyle}">
                                <StackPanel>
                                    <CheckBox Content="&#26174;&#31034;&#26041;&#21521;&#36724;"
                                              Margin="0,0,0,8"
                                              IsChecked="{Binding ShowOrientationAxes, Mode=TwoWay}" />
                                    <CheckBox Content="&#20351;&#29992;&#28176;&#21464;&#32972;&#26223;"
                                              IsChecked="{Binding UseGradientBackground, Mode=TwoWay}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!--<gridsplitter grid.column="1"
                          background="#eab308"
                          horizontalalignment="stretch" margin="0,5,0,0" />-->

            <Border Grid.Column="2"
                    Margin="1 5 5 5"
                    CornerRadius="6"
                    BorderBrush="#D8E0E8"
                    BorderThickness="1"
                    Background="White">
                <Grid Background="#10273D">
                    <vtk:PointCloudViewportControl x:Name="Viewport" />

                    <Border HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="18"
                            Padding="12,10"
                            Background="#AD0B1220"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            CornerRadius="6"
                            IsHitTestVisible="False">
                        <StackPanel>
                            <TextBlock Text="{Binding Tag.PointCloudLoadStateText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Foreground="White"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding SelectedPointText}"
                                       Foreground="#E1E7EF" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="Custom.KCJC.Views.SensorDataCollectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.KCJC.Views"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition />
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <Button Name="btnLogin" Margin="5 0 5 0" IsEnabled="{Binding IsEnabled}" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ImportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe645;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导入配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button IsEnabled="{Binding IsEnabled}" Margin="5 0 5 0" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ExportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe646;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导出配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <!--主体-->
        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="基础配置" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="采集模式" Margin="5 5 5 10">
                                    <Grid >
                                        <Border CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TabControl Width="600" Height="550" SelectedIndex="{Binding ModelParam.SltTriggerPicIndex,Mode=TwoWay}" Style="{DynamicResource TabControlStyle}">
                                                <TabItem Header="指定图像"  Style="{DynamicResource SingleTabItemStyle}" >
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center">
                                                                <RadioButton FontSize="14" Margin="0 0 0 0" Width="83" Height="32" IsChecked="True" Content="选择文件" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="选择文件"/>

                                                                <RadioButton FontSize="14" Margin="100 0 0 0" Width="83" Height="32" Content="链接路径" Foreground="Black" FontFamily="{StaticResource Iconfont}"
                             Style="{StaticResource ImgHomeBtn}"  Command="{Binding GeneralCommand}" CommandParameter="链接路径"/>

                                                            </StackPanel>

                                                            <Grid>
                                                                <StackPanel Orientation="Horizontal" Margin="5 0" HorizontalAlignment="Center">
                                                                    <TextBox Text="{Binding ModelParam.FilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                    <Button Width="30" Height="30" Content="&#xe7b9;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="打开文件"/>
                                                                </StackPanel>

                                                                <StackPanel Visibility="{Binding ModelParam.IsLinkVisibility,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Orientation="Horizontal" Margin="10 " HorizontalAlignment="Center">
                                                                    <TextBox Text="{Binding ModelParam.LinkPath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                    <Button Width="30" Height="30" Content="&#xe60e;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="链接图片"/>
                                                                    <Button Width="30" Height="30" Content="&#xeaf2;" FontFamily="{StaticResource Iconfont}" BorderThickness="0 0 0 1"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="取消链接"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="文件目录" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top" HorizontalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBox Text="{Binding ModelParam.FilePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Width="400" Foreground="Black" VerticalAlignment="Center" BorderThickness="0 0 0 1"/>
                                                                <Button Content="&#xe7b9;" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="获取路径"/>
                                                            </StackPanel>
                                                            <TextBlock Text="选择文件夹，文件夹中应包含两份灰度/高度图" Foreground="Black" VerticalAlignment="Center"/>
                                                            <StackPanel/>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="指定采集" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                                            <UniformGrid Columns="2" Margin="0,0,0,8" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                                <TextBlock Text="传感器选择:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                                                                <hc:ComboBox Width="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center"
                                                                          ItemsSource="{Binding ModelParam.Models}" DisplayMemberPath="NickName" SelectedItem="{Binding ModelParam.SltModel,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                                    <i:Interaction.Triggers>
                                                                        <i:EventTrigger EventName="SelectionChanged">
                                                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换模块"/>
                                                                        </i:EventTrigger>
                                                                    </i:Interaction.Triggers>
                                                                </hc:ComboBox>

                                                                <!--<TextBlock Text="相机旋转:" Foreground="Black" VerticalAlignment="Center" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Margin="5"
                                                                          ItemsSource="{Binding }" SelectedItem="{Binding ModelParam.CamSltRotate }"/>-->

                                                                <!--<TextBlock Text="采集模式:" Foreground="Black" VerticalAlignment="Center" />
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Margin="5"
                                                                          ItemsSource="{Binding ModelParam.SelectedCameraModel.TrigModes}" SelectedItem="{Binding ModelParam.SelectedCameraModel.TrigMode}"/>-->

                                                                <TextBlock Text="传感器备注:" Foreground="Black" VerticalAlignment="Center"/>
                                                                <TextBox Width="200"  Height="25" BorderThickness="0 0 0 1" Margin="5 0" Text="{Binding ModelParam.SelectedCameraModel.Remarks,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>

                                                                <TextBlock Text="曝光时间:" Foreground="Black" VerticalAlignment="Center" />
                                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="0 0" SmallChange="1" BorderThickness="0 0 0 1"
                                                                    Value="{Binding ModelParam.SelectedCameraModel.ExposeTime,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                                <!--<TextBlock Text="增益:" Foreground="Black" VerticalAlignment="Center" />
                                                                <WxNumericUpDown:WxNumericUpDown Minimum="0" Maximum="99999999" Width="200" Margin="0 0" SmallChange="0.1"  BorderThickness="0 0 0 1"
                                                                    Value="{Binding ModelParam.SelectedCameraModel.Gain,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>-->

                                                            </UniformGrid>

                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发开始采集" Width="auto" Margin="0 0 0 10" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding ModelParam.StartCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发停止采集" Width="auto" HorizontalAlignment="Left" FontSize="16" Margin="0 0 0 10"
                                                               IsChecked="{Binding ModelParam.StopCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发停止采集并处理数据" Width="auto" HorizontalAlignment="Left" FontSize="16"
                                                               IsChecked="{Binding ModelParam.StopAndDispose,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>


                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>

                                                <TabItem Header="PLC" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top" Margin="10">
                                                            <TextBlock Text="当前页签用于执行PLC写入。" Foreground="Black" Margin="0 0 0 8"/>
                                                            <TextBlock Text="总次数 -> HD31 (Short)" Foreground="Black" Margin="0 0 0 5"/>
                                                            <TextBlock Text="复位次数 -> HD30 (Short)" Foreground="Black" Margin="0 0 0 5"/>
                                                            <TextBlock Text="材料长度 -> HD32 (Float)" Foreground="Black" Margin="0 0 0 5"/>
                                                            <TextBlock Text="检测位1 -> HD20204 (Float)" Foreground="Black" Margin="0 0 0 5"/>
                                                            <TextBlock Text="检测位2 -> HD20206 (Float)" Foreground="Black" Margin="0 0 0 5"/>
                                                            <TextBlock Text="运行速度 -> HD1218 (Float)" Foreground="Black" Margin="0 0 0 15"/>
                                                            <TextBlock Text="请使用页面底部的“执行”按钮。"
                                                                       Foreground="#666666"
                                                                       Margin="0 0 0 5"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                            </TabControl>
                                        </Border>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="采集配置" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}" Height="45" VerticalAlignment="Top">
                            <Grid>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                    <StackPanel>
                                    <WxGroupBox:WxGroupBox Header="传感器配置参数" Grid.ColumnSpan="2" Margin="5,5,5,5" MaxHeight="500">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                                                <hc:ComboBox Width="250" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="检测方式：" hc:InfoElement.TitleWidth="100"
                                                             Style="{StaticResource ComboBoxExtend}" BorderThickness="0 0 0 1" Foreground="Black" Margin="5 3 0 0"
                                                             HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                             SelectedValuePath="Tag"
                                                             SelectedValue="{Binding ModelParam.MeasureParam.AlgorithmType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                    <ComboBoxItem Content="刻槽检测" Tag="0"/>
                                                    <ComboBoxItem Content="刻点检测" Tag="1"/>
                                                    <ComboBoxItem Content="刻槽+刻点" Tag="2"/>
                                                </hc:ComboBox>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="X方向像素当量(um)：" Width="auto" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.IntervalX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="Y方向像素当量(um)：" Width="auto" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.IntervalY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="Z方向像素当量(um)：" Width="auto" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.IntervalZ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <ToggleButton  Content="是否翻转" Width="200" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Style="{StaticResource ToggleButtonSwitch}" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left" FontSize="14"
                                                  IsChecked="{Binding ModelParam.MeasureParam.IsFlip,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="刻蚀线测量分区数：" Width="300" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.SamplePointNum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="灰度图边缘梯度阈值：" Width="300" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.GrayAmplitudeThr,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="灰度图边缘平滑系数：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.GrayAmplitudeSigma,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="高度图边缘梯度阈值：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.HeightAmplitudeThr,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="高度图边缘平滑系数：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.HeightAmplitudeSigma,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="极片扫描始末边缘检测采样点数：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.PlateSEEdgeSamplingMum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="极片顶部、底部边缘检测采样点数：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.PlateTDEdgeSamplingMum,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="分区内最大刻蚀线条数：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.EtchingLineNumMax,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="极片边缘屏蔽区大小(像素)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.PlateEdgeMaskSize,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="图片边缘屏蔽区大小(像素)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.ImageEdgeMaskSize,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="极片头部去除区大小(微米)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.PlateLeftEdgeMaskSizeReal,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="极片尾部去除区大小(微米)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.PlateRightEdgeMaskSizeReal,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="深度图宽度下采样率：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.DepthMapSampleDownSizeW,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="深度图高度下采样率：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.DepthMapSampleDownSizeH,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:ComboBox Width="400" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="灰度图旋转：" hc:InfoElement.TitleWidth="auto"
                                                             Style="{StaticResource ComboBoxExtend}" BorderThickness="0 0 0 1" Foreground="Black" Margin="5"
                                                             HorizontalContentAlignment="Center" HorizontalAlignment="Left" SelectedValuePath="Tag"
                                                             SelectedValue="{Binding ModelParam.MeasureParam.GrayImageRotateAngle,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                    <ComboBoxItem Content="0" Tag="0"/>
                                                    <ComboBoxItem Content="90" Tag="90"/>
                                                    <ComboBoxItem Content="180" Tag="180"/>
                                                    <ComboBoxItem Content="-90" Tag="-90"/>
                                                    <ComboBoxItem Content="-180" Tag="-180"/>
                                                </hc:ComboBox>

                                                <!--<hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="手动图片拼接X偏移(um)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.OtherConfig.ManualOffsetX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="0" hc:InfoElement.Title="手动图片拼接Y偏移(um)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.OtherConfig.ManualOffsetY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>-->

                                            </StackPanel>
                                        </ScrollViewer>

                                    </WxGroupBox:WxGroupBox>
                                   
                                    <WxGroupBox:WxGroupBox Header="标准值预设">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                            <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch">
                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="刻蚀点标准半径(um)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.StandardPointRadius,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="刻蚀点标准高度(um)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.StandardPointHeight,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="刻蚀线标准宽(um)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.StandardEtchingLineWidthReal,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="刻蚀线标准间距(um)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.StandardEtchingPointDistReal,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="刻蚀线标准深度(um)：" Width="400" Style="{StaticResource NumericUpDownExtend}" hc:InfoElement.TitleWidth="auto" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" HorizontalAlignment="Left"
                                                  Value="{Binding ModelParam.MeasureParam.StandardEtchingLineDepthReal,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </WxGroupBox:WxGroupBox>
                                    </StackPanel>

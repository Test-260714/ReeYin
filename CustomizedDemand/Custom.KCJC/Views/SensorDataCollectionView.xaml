                                                        <ComboBoxItem Content="查表" Tag="LookupTable"/>
                                                    </ComboBox>

                                                    <CheckBox Content="是否已完成俯仰标定"
                                  IsChecked="{Binding ModelParam.ConcatenationParam.sPitchCalib, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5"/>

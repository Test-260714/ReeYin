                                                <hc:TextBox Width="400" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="拼接图片路径:"  HorizontalAlignment="Left" Margin="5 3 0 0" hc:InfoElement.TitleWidth="auto"

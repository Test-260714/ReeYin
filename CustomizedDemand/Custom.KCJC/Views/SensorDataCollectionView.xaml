                                   VerticalAlignment="Center" Margin="0 5"/>
                                                <TextBox Grid.Row="3" Grid.Column="1"
                                 Text="{Binding ModelParam.ConcatenationParam.OffsetY, StringFormat=F4, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" VerticalContentAlignment="Center" Margin="5"/>


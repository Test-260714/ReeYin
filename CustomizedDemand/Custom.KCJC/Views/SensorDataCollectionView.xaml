                                                  Value="{Binding ModelParam.ConcatenationParam.MaxDepth,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                    <CheckBox Content="图片是否需要翻转"
                                  IsChecked="{Binding ModelParam.ConcatenationParam.IsFlip, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5"/>

                                                    <ComboBox hc:InfoElement.Title="俯仰姿态校正模式:" Width="auto" Style="{StaticResource ComboBoxExtend}" hc:InfoElement.TitleWidth="auto" hc:InfoElement.TitlePlacement="Left"

                                                        helper:ItemsControlHelper.EnumValuesToItemsSource="True" Text="{Binding ModelParam.CalibPath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <Button Content="&#xe7b9;" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30"

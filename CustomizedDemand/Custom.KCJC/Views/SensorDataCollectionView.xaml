                                                <hc:TextBox Width="auto" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="度图高度参考值数组长度:"  HorizontalAlignment="Left" Margin="5 3 0 0" hc:InfoElement.TitleWidth="auto"

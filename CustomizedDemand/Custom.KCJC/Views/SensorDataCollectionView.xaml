                                 Text="{Binding ModelParam.ConcatenationParam.PlaneFilterThreshold, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" VerticalContentAlignment="Center" Margin="5"/>
                                            </Grid>
                                        </Border>
                                    </Expander>


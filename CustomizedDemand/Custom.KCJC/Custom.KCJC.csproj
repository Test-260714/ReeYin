    <ProjectReference Include="..\..\Hardware\PLC\ReeYin_V.Hardware.PLC\ReeYin_V.Hardware.PLC.csproj" />
    <ProjectReference Include="..\..\Hardware\Sensor\ReeYin.Hardware.Sensor\ReeYin.Hardware.Sensor.csproj" />
    <ProjectReference Include="..\..\Hardware\Sensor\ReeYin.Hardware.Sensor.Hyperson\ReeYin.Hardware.Sensor.Hyperson.csproj" />
    <ProjectReference Include="..\..\Tools\Logical\LogicalTool.Loop\LogicalTool.Loop.csproj" />
  </ItemGroup>


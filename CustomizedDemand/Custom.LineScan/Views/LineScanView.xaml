<UserControl x:Class="Custom.LineScan.Views.LineScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:prism="http://prismlibrary.com/"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600" d:DesignWidth="800">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <TabItem Header="采集参数">
                <StackPanel Margin="10">
                    <GroupBox Header="相机设置">
                        <StackPanel Margin="10">
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="选择相机:" Width="100" VerticalAlignment="Center"/>
                                <ComboBox Width="200" ItemsSource="{Binding ModelParam.Cameras}" 
                                          DisplayMemberPath="CameraNo" 
                                          SelectedItem="{Binding ModelParam.SelectedCamera}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="SelectionChanged">
                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换相机"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="曝光时间:" Width="100" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding ModelParam.ExposureTime}" Width="150"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="增益:" Width="100" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding ModelParam.Gain}" Width="150"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="扫描参数" Margin="0,10,0,0">
                        <StackPanel Margin="10">
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="扫描行数:" Width="100" VerticalAlignment="Center"/>
                                <TextBox Text="{Binding ModelParam.ScanLineCount}" Width="150"/>
                            </StackPanel>
                            <CheckBox Content="由运动触发" IsChecked="{Binding ModelParam.TriggerByMotion}" Margin="0,10"/>
                        </StackPanel>
                    </GroupBox>

                    <Button Content="测试采集" Width="120" Height="35" Margin="0,20" 
                            Command="{Binding GeneralCommand}" CommandParameter="执行"/>
                </StackPanel>
            </TabItem>

            <TabItem Header="输出信息">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                        <TextBlock Text="输出参数:" VerticalAlignment="Center"/>
                        <ComboBox Width="300" ItemsSource="{Binding ModelParam.OutputParamResource.Keys}" 
                                  SelectedItem="{Binding SltOutputParamName}" Height="25" Margin="5,0"/>
                        <Button Content="添加" Width="60" Margin="5,0" 
                                Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                        <Button Content="删除" Width="60" Margin="5,0" 
                                Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" AutoGenerateColumns="False" 
                              ItemsSource="{Binding ModelParam.OutputParams}" 
                              SelectedItem="{Binding CurrentOutputParam}"
                              Margin="5" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="参数名称" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="数据类型" Binding="{Binding Type}" Width="Auto"/>
                            <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="*"/>
                            <DataGridTextColumn Header="备注" Binding="{Binding Describe}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="取消" Width="80" Height="30" Margin="0,0,10,0" 
                    Command="{Binding GeneralCommand}" CommandParameter="取消"/>
            <Button Content="确认" Width="80" Height="30" 
                    Command="{Binding GeneralCommand}" CommandParameter="确认"/>
        </StackPanel>
    </Grid>
</UserControl>

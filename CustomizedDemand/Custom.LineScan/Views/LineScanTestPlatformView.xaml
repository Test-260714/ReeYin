<UserControl x:Class="Custom.LineScan.Views.LineScanTestPlatformView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:prism="http://prismlibrary.com/"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
             xmlns:converters="clr-namespace:Custom.LineScan.Converters"
             mc:Ignorable="d" 
             prism:ViewModelLocator.AutoWireViewModel="True"
             FontSize="14"
             Width="1600" Height="950"
             d:DesignHeight="950" d:DesignWidth="1600"
             Background="#F5F5F5"
             ScrollViewer.VerticalScrollBarVisibility="Disabled"
             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.NodifyManager;component/UI/Style/Converter.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:PositionToWidthConverter x:Key="PositionToWidthConverter"/>
            <converters:RemainingWidthConverter x:Key="RemainingWidthConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="700"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="480" MinWidth="460" MaxWidth="520"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 左侧：实时画面和状态监控 -->
        <Grid Grid.Column="0" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="240"/>
            </Grid.RowDefinitions>

            <!-- 实时画面显示区域 - 卡片式 -->
            <Border Grid.Row="0" Background="White" CornerRadius="8" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                </Border.Effect>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="实时画面" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                    <Grid Grid.Row="1">
                        <Border Background="#1a1a1a" CornerRadius="6">
                            <Image x:Name="ImageDisplay" Source="{Binding DisplayImage}" Stretch="Uniform" 
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        </Border>
                        <!-- 图像信息叠加层 -->
                        <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="12" 
                                Background="#CC000000" CornerRadius="4" Padding="12,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="分辨率: " Foreground="White" FontSize="13"/>
                                <TextBlock Text="{Binding ModelParam.ImageWidth, FallbackValue=0}" Foreground="#4CAF50" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text=" x " Foreground="White" FontSize="13"/>
                                <TextBlock Text="{Binding ModelParam.ImageHeight, FallbackValue=0}" Foreground="#4CAF50" FontWeight="Bold" FontSize="13"/>
                            </StackPanel>
                        </Border>
                        <!-- 采集按钮叠加层 -->
                        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="12"
                                Background="#EE000000" CornerRadius="8" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="单次采集" Width="90" Height="36" Margin="6,0" FontSize="13"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="单次采集"
                                        IsEnabled="{Binding ModelParam.CameraConnected}"/>
                                <Button Content="连续采集" Width="90" Height="36" Margin="6,0" FontSize="13"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Background="#388E3C" Foreground="White"
                                        Command="{Binding GeneralCommand}" CommandParameter="连续采集"
                                        IsEnabled="{Binding ModelParam.CameraConnected}"/>
                                <Button Content="停止采集" Width="90" Height="36" Margin="6,0" FontSize="13"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Background="#D32F2F" Foreground="White"
                                        Command="{Binding GeneralCommand}" CommandParameter="停止采集"/>
                                <Border Width="1" Background="#555" Margin="16,6"/>
                                <Button Content="保存图像" Width="90" Height="36" Margin="6,0" FontSize="13"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Background="#1976D2" Foreground="White"
                                        Command="{Binding GeneralCommand}" CommandParameter="保存图像"
                                        ToolTip="保存当前显示的图像"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- 状态监控面板 - 三个卡片 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 运动控制卡状态 -->
                <Border Grid.Column="0" Background="White" CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel Margin="20,16">
                        <TextBlock Text="运动控制卡状态" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="连接状态" VerticalAlignment="Center" Foreground="#666"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <WxLED:WxLED Width="16" Height="16" Margin="0,0,10,0"
                                             IsActive="{Binding ModelParam.ZMotionConnected}" IsBreathing="True"/>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="未连接"/>
                                            <Setter Property="Foreground" Value="#D32F2F"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModelParam.ZMotionConnected}" Value="True">
                                                    <Setter Property="Text" Value="已连接"/>
                                                    <Setter Property="Foreground" Value="#388E3C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="当前位置" VerticalAlignment="Center" Foreground="#666"/>
                            <TextBlock Grid.Column="1" Foreground="#1976D2" FontWeight="Bold" FontSize="18">
                                <Run Text="{Binding ModelParam.CurrentPosition, StringFormat={}{0:F3}}"/>
                                <Run Text=" mm" FontSize="12" Foreground="#999"/>
                            </TextBlock>
                        </Grid>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="运动状态" VerticalAlignment="Center" Foreground="#666"/>
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="静止"/>
                                        <Setter Property="Foreground" Value="#757575"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ModelParam.IsMoving}" Value="True">
                                                <Setter Property="Text" Value="运动中..."/>
                                                <Setter Property="Foreground" Value="#F57C00"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="返回速度" VerticalAlignment="Center" Foreground="#666"/>
                            <TextBlock Grid.Column="1" Foreground="#F57C00" FontWeight="SemiBold" FontSize="14">
                                <Run Text="{Binding ModelParam.ForwardSpeed, StringFormat={}{0:F0}}"/>
                                <Run Text=" mm/s" FontSize="12" Foreground="#999"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 光源控制器状态 -->
                <Border Grid.Column="2" Background="White" CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel Margin="16,14">
                        <TextBlock Text="光源控制器状态" FontSize="14" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="连接状态" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <WxLED:WxLED Width="14" Height="14" Margin="0,0,8,0"
                                             IsActive="{Binding ModelParam.LightControllerConnected}" IsBreathing="True"/>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="未连接"/>
                                            <Setter Property="Foreground" Value="#D32F2F"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModelParam.LightControllerConnected}" Value="True">
                                                    <Setter Property="Text" Value="已连接"/>
                                                    <Setter Property="Foreground" Value="#388E3C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                        
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="当前亮度" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                            <TextBlock Grid.Column="1" Foreground="#FF9800" FontWeight="Bold" FontSize="16">
                                <Run Text="{Binding ModelParam.LightBrightness}"/>
                                <Run Text=" / 255" FontSize="11" Foreground="#999"/>
                            </TextBlock>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="通道数" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                            <TextBlock Grid.Column="1" FontSize="13">
                                <Run Text="{Binding ModelParam.LightChannelCount}"/>
                                <Run Text=" 通道" FontSize="11" Foreground="#999"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 相机状态 -->
                <Border Grid.Column="4" Background="White" CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                    </Border.Effect>
                    <StackPanel Margin="20,16">
                        <TextBlock Text="线扫相机状态" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="连接状态" VerticalAlignment="Center" Foreground="#666"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <WxLED:WxLED Width="16" Height="16" Margin="0,0,10,0"
                                             IsActive="{Binding ModelParam.CameraConnected}" IsBreathing="True"/>
                                <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="未连接"/>
                                            <Setter Property="Foreground" Value="#D32F2F"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModelParam.CameraConnected}" Value="True">
                                                    <Setter Property="Text" Value="已连接"/>
                                                    <Setter Property="Foreground" Value="#388E3C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="采集状态" VerticalAlignment="Center" Foreground="#666"/>
                            <TextBlock Grid.Column="1" FontWeight="SemiBold" FontSize="13">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="停止"/>
                                        <Setter Property="Foreground" Value="#757575"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ModelParam.IsContinuousGrab}" Value="True">
                                                <Setter Property="Text" Value="采集中..."/>
                                                <Setter Property="Foreground" Value="#F57C00"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="曝光时间" VerticalAlignment="Center" Foreground="#666"/>
                            <TextBlock Grid.Column="1" FontSize="14">
                                <Run Text="{Binding ModelParam.ExposureTime, StringFormat={}{0:F0}}"/>
                                <Run Text=" μs" FontSize="12" Foreground="#999"/>
                            </TextBlock>
                        </Grid>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="增益" VerticalAlignment="Center" Foreground="#666"/>
                            <TextBlock Grid.Column="1" FontSize="14">
                                <Run Text="{Binding ModelParam.Gain, StringFormat={}{0:F1}}"/>
                                <Run Text=" dB" FontSize="12" Foreground="#999"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 右侧：控制面板 -->
        <Border Grid.Column="2" Grid.Row="0" Background="White" CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <Grid Margin="8">
                <TabControl x:Name="MainTabControl" Style="{DynamicResource TabControlStyle}" TabStripPlacement="Top" FontSize="13">

                <!-- 运动控制 -->
                <TabItem Header="运动" Style="{DynamicResource SingleTabItemStyle}" Width="80">
                    <Grid Margin="16,12" MinHeight="580">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 连接设置 -->
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="连接设置" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="IP地址" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.ZMotionIpAddress}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}"/>
                            </Grid>
                            <UniformGrid Columns="3" Margin="0,0,0,12">
                                <Button Content="连接" Height="28" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="连接控制卡"
                                        IsEnabled="{Binding ModelParam.ZMotionConnected, Converter={StaticResource InverseBooleanConverter}}"/>
                                <Button Content="断开" Height="28" Margin="3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="断开控制卡"
                                        IsEnabled="{Binding ModelParam.ZMotionConnected}"/>
                                <Button Content="设置" Height="28" Margin="3,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="控制卡设置"
                                        IsEnabled="{Binding ModelParam.ZMotionConnected}"/>
                            </UniformGrid>
                        </StackPanel>

                        <!-- 运动参数 -->
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="运动参数" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="返回速度" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.ForwardSpeed, StringFormat={}{0:F0}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}" ToolTip="往复运动返回速度，单位：mm/s"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="工作距离" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.WorkDistance, StringFormat={}{0:F0}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}" ToolTip="往复运动终点位置，单位：mm"/>
                            </Grid>
                            <UniformGrid Columns="2" Margin="0,6,0,12">
                                <Button Content="读取参数" Height="28" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="读取参数"
                                        IsEnabled="{Binding ModelParam.ZMotionConnected}"/>
                                <Button Content="保存参数" Height="28" Margin="3,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="保存参数"
                                        IsEnabled="{Binding ModelParam.ZMotionConnected}"/>
                            </UniformGrid>
                        </StackPanel>

                        <!-- 运动控制 -->
                        <StackPanel Grid.Row="2" VerticalAlignment="Top">
                            <TextBlock Text="运动控制" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <Button Content="开始往复" Height="36" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Background="#388E3C" Foreground="White"
                                        Command="{Binding GeneralCommand}" CommandParameter="开始往复运动"
                                        IsEnabled="{Binding ModelParam.ZMotionConnected}"/>
                                <Button Content="停止往复" Height="36" Margin="3,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Background="#D32F2F" Foreground="White"
                                        Command="{Binding GeneralCommand}" CommandParameter="停止往复运动"
                                        IsEnabled="{Binding ModelParam.ZMotionConnected}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- 相机控制 -->
                <TabItem Header="相机" Style="{DynamicResource SingleTabItemStyle}" Width="80">
                    <Grid Margin="16,12" MinHeight="580">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 连接设置 -->
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="连接设置" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="设备索引" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.CameraDeviceIndex}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="采集卡" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.CameraBoardIndex}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}" ToolTip="-1表示不使用采集卡"/>
                            </Grid>
                            <UniformGrid Columns="3" Margin="0,0,0,12">
                                <Button Content="枚举" Height="28" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="枚举相机"/>
                                <Button Content="连接" Height="28" Margin="3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="连接相机"
                                        IsEnabled="{Binding ModelParam.CameraConnected, Converter={StaticResource InverseBooleanConverter}}"/>
                                <Button Content="断开" Height="28" Margin="3,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="断开相机"
                                        IsEnabled="{Binding ModelParam.CameraConnected}"/>
                            </UniformGrid>
                        </StackPanel>

                        <!-- 采集参数 -->
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="采集参数" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="曝光时间" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.ExposureTime}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}" ToolTip="单位：μs"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="行频" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.LineRate}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}" ToolTip="单位：Hz"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="增益" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.Gain}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}" ToolTip="单位：dB"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="扫描行数" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.ScanLineCount}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}" ToolTip="单帧线扫图像的目标行数"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="当前行数" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.CurrentLineCount}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}" IsReadOnly="True"/>
                            </Grid>
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <Button Content="读取参数" Height="28" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="读取采集参数"
                                        IsEnabled="{Binding ModelParam.CameraConnected}"/>
                                <Button Content="应用参数" Height="28" Margin="3,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="应用采集参数"
                                        IsEnabled="{Binding ModelParam.CameraConnected}"/>
                            </UniformGrid>
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <Button Content="开始扫描" Height="28" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="开始扫描"
                                        IsEnabled="{Binding ModelParam.CameraConnected}"/>
                                <Button Content="停止扫描" Height="28" Margin="3,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="停止扫描"
                                        IsEnabled="{Binding ModelParam.IsScanning}"/>
                            </UniformGrid>
                        </StackPanel>

                        <!-- 图像保存 -->
                        <StackPanel Grid.Row="2">
                            <TextBlock Text="图像保存" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="保存路径" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.ImageSavePath}" IsReadOnly="True" Height="28"
                                         Style="{DynamicResource TextBoxExtend}"/>
                                <Button Grid.Column="2" Content="..." Width="32" Height="28" Margin="6,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="选择保存路径"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="文件前缀" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.ImagePrefix}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="保存格式" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <ComboBox Grid.Column="1" SelectedValue="{Binding ModelParam.ImageFormat}" Height="28">
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">bmp</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">png</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">jpg</System:String>
                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">tiff</System:String>
                                </ComboBox>
                            </Grid>
                            <UniformGrid Columns="3" Margin="0,6,0,0">
                                <Button Content="保存图像" Height="28" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="保存图像"/>
                                <Button Content="开始连续" Height="28" Margin="3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="开始连续保存"
                                        IsEnabled="{Binding ModelParam.IsContinuousSave, Converter={StaticResource InverseBooleanConverter}}"/>
                                <Button Content="停止连续" Height="28" Margin="3,0,0,0" FontSize="12" Background="#FFCC00"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="停止连续保存"
                                        IsEnabled="{Binding ModelParam.IsContinuousSave}"/>
                            </UniformGrid>
                        </StackPanel>
                        
                        <!-- 保存状态 - 固定在底部 -->
                        <Border Grid.Row="3" Background="#F5F5F5" CornerRadius="4" Padding="12,10" VerticalAlignment="Bottom">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="已保存：" VerticalAlignment="Center" Foreground="#666" FontSize="13"/>
                                <TextBlock Text="{Binding ModelParam.SavedImageCount}" Foreground="#1976D2" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>
                                <TextBlock Text=" 张" VerticalAlignment="Center" Foreground="#666" FontSize="13"/>
                                <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value=""/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModelParam.IsContinuousSave}" Value="True">
                                                    <Setter Property="Text" Value="[保存中...]"/>
                                                    <Setter Property="Foreground" Value="#F57C00"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- 光源控制 -->
                <TabItem Header="光源" Style="{DynamicResource SingleTabItemStyle}" Width="80">
                    <Grid Margin="16,12" MinHeight="580">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 连接设置 -->
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="连接设置" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="IP地址" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <TextBox Grid.Column="1" Text="{Binding ModelParam.LightControllerIp}" Height="28"
                                         Style="{DynamicResource TextBoxExtend}"/>
                            </Grid>
                            <UniformGrid Columns="3" Margin="0,0,0,12">
                                <Button Content="连接" Height="28" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="连接光源"
                                        IsEnabled="{Binding ModelParam.LightControllerConnected, Converter={StaticResource InverseBooleanConverter}}"/>
                                <Button Content="断开" Height="28" Margin="3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="断开光源"
                                        IsEnabled="{Binding ModelParam.LightControllerConnected}"/>
                                <Button Content="设置" Height="28" Margin="3,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="光源设置"
                                        IsEnabled="{Binding ModelParam.LightControllerConnected}"/>
                            </UniformGrid>
                        </StackPanel>

                        <!-- 脉宽控制 -->
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="脉宽控制" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="脉宽映射" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <Slider Grid.Column="1" Minimum="0" Maximum="255" 
                                        Value="{Binding ModelParam.LightBrightness}" 
                                        VerticalAlignment="Center" Margin="0,0,8,0"
                                        IsEnabled="{Binding ModelParam.LightControllerConnected}"/>
                                <TextBox Grid.Column="2" Text="{Binding ModelParam.LightBrightness}" Height="28" 
                                         HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                         IsEnabled="{Binding ModelParam.LightControllerConnected}"/>
                            </Grid>
                            <UniformGrid Columns="3" Margin="0,0,0,12">
                                <Button Content="应用脉宽" Height="28" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="应用光源脉宽"
                                        IsEnabled="{Binding ModelParam.LightControllerConnected}"/>
                                <Button Content="全开" Height="28" Margin="3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="光源全开"
                                        IsEnabled="{Binding ModelParam.LightControllerConnected}"/>
                                <Button Content="全关" Height="28" Margin="3,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding GeneralCommand}" CommandParameter="光源全关"
                                        IsEnabled="{Binding ModelParam.LightControllerConnected}"/>
                            </UniformGrid>
                        </StackPanel>

                        <!-- 状态信息 -->
                        <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="4" Padding="12,10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="通道数：" Foreground="#666" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelParam.LightChannelCount}" FontWeight="Bold" Foreground="#1976D2" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="当前脉宽：" Foreground="#666" FontSize="12"/>
                                    <TextBlock Text="{Binding ModelParam.LightPulseWidthUs}" FontWeight="Bold" Foreground="#FF9800" FontSize="14"/>
                                    <TextBlock Text=" us" Foreground="#999" FontSize="11"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 提示信息 -->
                        <Border Grid.Row="3" Background="#FFF3E0" CornerRadius="4" Padding="12,10" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="基础型控制器" FontWeight="SemiBold" Foreground="#E65100" Margin="0,0,0,4"/>
                                <TextBlock Text="锐视控制器通过脉宽控制光源。触发模式和内触发周期请点击【设置】打开完整设置界面。" 
                                           Foreground="#666666" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- 日志 -->
                <TabItem Header="日志" Style="{DynamicResource SingleTabItemStyle}" Width="80">
                    <Grid Margin="16,12" MinHeight="580">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="运行日志" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" Text="{Binding LogText, Mode=OneWay}" 
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="12"
                                 Background="#FAFAFA" Foreground="#333333"
                                 Padding="12" BorderBrush="#E0E0E0"/>
                        <Button Grid.Row="2" Content="清空日志" Height="36" Margin="0,12,0,0" FontSize="12"
                                Style="{DynamicResource GeneralButtonStyle}"
                                Command="{Binding GeneralCommand}" CommandParameter="清空日志"/>
                    </Grid>
                </TabItem>

                <!-- 输出参数 -->
                <TabItem Header="输出" Style="{DynamicResource SingleTabItemStyle}" Width="80">
                    <Grid Margin="16,12" MinHeight="580">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="参数列表" FontSize="13" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,8"/>
                        
                        <StackPanel Grid.Row="1" Margin="0,0,0,12">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="参数类型" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
                                <ComboBox Grid.Column="1" ItemsSource="{Binding ModelParam.OutputParamResource.Keys}" 
                                          SelectedItem="{Binding SltOutputParamName}" Height="28"/>
                            </Grid>
                            <UniformGrid Columns="2">
                                <Button Content="添加" Height="28" Margin="0,0,3,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="删除" Height="28" Margin="3,0,0,0" FontSize="12"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </UniformGrid>
                        </StackPanel>

                        <DataGrid Grid.Row="2" AutoGenerateColumns="False" 
                                  ItemsSource="{Binding ModelParam.OutputParams}" 
                                  SelectedItem="{Binding CurrentOutputParam}"
                                  CanUserAddRows="False" FontSize="12"
                                  Style="{DynamicResource DefaultDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="80"/>
                                <DataGridTextColumn Header="值" Binding="{Binding Value}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <!-- 底部区域：位置可视化 + 按钮栏 -->
        <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="1" 
                Background="White" CornerRadius="8" Margin="0,16,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
            </Border.Effect>
            <Grid Margin="24,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- 位置可视化轨道 -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="位置监控" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                    
                    <!-- 轨道区域 -->
                    <Grid Grid.Column="1" Margin="16,0">
                        <Grid Height="24">
                            <!-- 轨道背景 -->
                            <Border Background="#E0E0E0" CornerRadius="4" Height="8" VerticalAlignment="Center"/>
                            <!-- 位置指示点 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding ModelParam.CurrentPosition, Converter={StaticResource PositionToWidthConverter}, ConverterParameter=860}"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition>
                                        <ColumnDefinition.Width>
                                            <MultiBinding Converter="{StaticResource RemainingWidthConverter}" ConverterParameter="860">
                                                <Binding Path="ModelParam.CurrentPosition"/>
                                            </MultiBinding>
                                        </ColumnDefinition.Width>
                                    </ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1" Width="16" Height="16" CornerRadius="8" Background="#F57C00" VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.3" Color="#F57C00"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Grid>
                        <!-- 刻度 -->
                        <TextBlock Text="0" FontSize="10" Foreground="#999" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-14"/>
                        <TextBlock Text="860" FontSize="10" Foreground="#999" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,-14"/>
                    </Grid>
                    
                    <!-- 位置数值显示 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock Text="位置: " Foreground="#666" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ModelParam.CurrentPosition, StringFormat={}{0:F1}}" 
                                   Foreground="#F57C00" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text=" mm" Foreground="#999" FontSize="12" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <Border CornerRadius="4" Padding="8,4" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#EEEEEE"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ModelParam.IsMoving}" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontWeight="SemiBold" FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="停止"/>
                                        <Setter Property="Foreground" Value="#757575"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ModelParam.IsMoving}" Value="True">
                                                <Setter Property="Text" Value="运动中"/>
                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Grid>
                
                <!-- 按钮栏 -->
                <Grid Grid.Row="1">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="执行测试" Width="120" Height="44" Margin="0,0,16,0" FontSize="14"
                                Style="{DynamicResource GeneralButtonStyle}"
                                Background="#1976D2" Foreground="White" FontWeight="SemiBold"
                                Command="{Binding GeneralCommand}" CommandParameter="执行测试"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="取消" Width="100" Height="44" Margin="0,0,16,0" FontSize="14"
                                Style="{DynamicResource GeneralButtonStyle}"
                                Command="{Binding GeneralCommand}" CommandParameter="取消"/>
                        <Button Content="确认" Width="100" Height="44" FontSize="14"
                                Style="{DynamicResource GeneralButtonStyle}"
                                Background="#388E3C" Foreground="White" FontWeight="SemiBold"
                                Command="{Binding GeneralCommand}" CommandParameter="确认"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

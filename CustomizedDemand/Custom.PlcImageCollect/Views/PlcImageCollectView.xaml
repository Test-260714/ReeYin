<UserControl x:Class="Custom.PlcImageCollect.Views.PlcImageCollectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid Margin="0 0 0 0">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition/>
            <RowDefinition Height="0.1*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2">
            <Button Name="btnLogin" Margin="5 0 5 0" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30" Command="{Binding GeneralCommand}" CommandParameter="ImportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe645;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}"/>
                            <TextBlock Text="导入配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button Margin="5 0 5 0" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30" Command="{Binding GeneralCommand}" CommandParameter="ExportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe646;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}"/>
                            <TextBlock Text="导出配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <Grid Grid.ColumnSpan="2" Margin="0,37,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Width="auto">
                <Border x:Name="bd" CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="720" Style="{StaticResource TabControlWithUnderLineStyle}">
                        <TabItem Header="基础配置" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="采集模式" Margin="5 5 5 10">
                                    <Grid>
                                        <Border CornerRadius="10" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TabControl Width="600" Height="550" SelectedIndex="{Binding ModelParam.SltTriggerPicIndex,Mode=TwoWay}" Style="{DynamicResource TabControlStyle}">
                                                <TabItem Header="指定图像" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="PLC触发采集模块不使用离线指定图像。" Foreground="Black" FontSize="16"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                                <TabItem Header="文件目录" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="停止采集后会自动写入存储参数中的存图路径。" Foreground="Black" FontSize="16"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                                <TabItem Header="指定采集" Style="{DynamicResource SingleTabItemStyle}">
                                                    <Grid>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Top">
                                                            <UniformGrid Columns="2" Margin="0,0,0,8" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                                <TextBlock Text="传感器选择:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                                <ComboBox Width="200" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center" ItemsSource="{Binding ModelParam.Models}" DisplayMemberPath="NickName" SelectedItem="{Binding ModelParam.SltModel,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                                    <i:Interaction.Triggers>
                                                                        <i:EventTrigger EventName="SelectionChanged">
                                                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="切换模块"/>
                                                                        </i:EventTrigger>
                                                                    </i:Interaction.Triggers>
                                                                </ComboBox>

                                                                <TextBlock Text="最近数据行数:" Foreground="Black" VerticalAlignment="Center"/>
                                                                <TextBox Width="200" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Text="{Binding ModelParam.LastDataCount}" IsReadOnly="True" HorizontalContentAlignment="Center"/>
                                                            </UniformGrid>

                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发开始采集" Width="auto" Margin="0 0 0 10" HorizontalAlignment="Left" FontSize="16" IsChecked="{Binding ModelParam.StartCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                            <RadioButton Style="{StaticResource ToggleButtonSwitch}" Content="触发停止采集并后台存图" Width="auto" HorizontalAlignment="Left" FontSize="16" Margin="0 0 0 10" IsChecked="{Binding ModelParam.StopCollect,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                            <StackPanel Orientation="Horizontal" Margin="0 15 0 0">
                                                                <Button Content="开始采集" Width="100" Height="30" Margin="0 0 10 0" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="开始采集"/>
                                                                <Button Content="停止采集" Width="100" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="停止采集"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </TabItem>
                                            </TabControl>
                                        </Border>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="采集配置" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}" Height="45" VerticalAlignment="Top">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="像素当量" Margin="5">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="5">
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="X方向像素当量(um)：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="180" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PixelEquivalentX,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="Y方向像素当量(um)：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="180" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PixelEquivalentY,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" DecimalPlaces="4" hc:InfoElement.Title="Z方向像素当量(um)：" Width="350" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="180" BorderThickness="0 0 0 1" Foreground="Black" Margin="5" HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.PixelEquivalentZ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                                <WxGroupBox:WxGroupBox Header="PLC事件说明" Margin="5">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" Margin="5">
                                        <TextBlock Text="开始采集事件：TrrigerStartCollect" Foreground="Black" Margin="5"/>
                                        <TextBlock Text="停止采集事件：TrrigerStopCollect" Foreground="Black" Margin="5"/>
                                        <TextBlock Text="停止采集会先取出本段数据快照，再后台保存 depth\\1_tif_0.tif 和 gray\\1_tif.tif，不阻塞下一次采集。" Foreground="Black" TextWrapping="Wrap" Margin="5"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="存储参数" Width="100" Height="45" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid>
                                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top">
                                    <WxGroupBox:WxGroupBox BorderThickness="0 5 0 0" Header="存图设置>>" Height="{Binding ElementName=bd,Path=ActualHeight}" VerticalAlignment="Top" Width="{Binding ElementName=bd,Path=ActualWidth}" HorizontalAlignment="Stretch" Margin="2 0 0 0">
                                        <StackPanel Orientation="Vertical">
                                            <CheckBox Content="启用存图" Width="auto" Margin="10 10 0 10" HorizontalAlignment="Left" FontSize="16" IsChecked="{Binding ModelParam.IsSaveImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
                                                <TextBlock Text="存图路径:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                <WxLink:WxLink Width="500" Margin="5 0" Order="OpenFile" Text="{Binding ModelParam.SavePath,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="10" HorizontalAlignment="Center">
                                                <TextBlock Text="最近一次目录:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0"/>
                                                <TextBox Width="500" Margin="5 0" HorizontalAlignment="Left" IsReadOnly="True" Text="{Binding ModelParam.LastSaveDirectory}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </WxGroupBox:WxGroupBox>
                                </StackPanel>
                            </Grid>
                        </TabItem>

                        <TabItem Header="其他" Width="100" FontSize="20" Style="{StaticResource TabItemExWithUnderLineStyle}">
                            <Grid/>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <Grid Grid.Column="2">
                <StackPanel Orientation="Vertical">
                    <Expander Width="auto" Margin="5,5,5,0" Header="图像预览" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel/>
                    </Expander>

                    <Expander Width="auto" MaxHeight="200" Margin="5,5,5,0" Header="输出信息" ExpandDirection="Down" SnapsToDevicePixels="True" VerticalAlignment="Top" Style="{DynamicResource ExpanderStyle}">
                        <StackPanel>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="数据:" VerticalAlignment="Center"/>
                                <ComboBox Width="500" ItemsSource="{Binding ModelParam.OutputParamNames}" SelectedItem="{Binding SltOutputParamName,Mode=TwoWay}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"/>
                                <Button Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}" Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                                <Button Content="&#xe74b;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}" Background="White" FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Delete"/>
                            </StackPanel>
                            <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}" EnableColumnVirtualization="True" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" ItemsSource="{Binding ModelParam.OutputParams}" SelectedItem="{Binding CurrentOutputParam}" FontSize="12" ScrollViewer.HorizontalScrollBarVisibility="Auto" Height="160" RowHeaderWidth="20" SelectionUnit="FullRow" HeadersVisibility="Column" GridLinesVisibility="All" IsReadOnly="False" CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="False" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" Background="Transparent" SelectedItem="{Binding Type}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="全局" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox IsChecked="{Binding IsGlobal,UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" CornerRadius="5" Padding="5" Grid.ColumnSpan="2" Margin="0,748,0,0" Grid.RowSpan="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical">
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="耗时:"/>
                        <Run Text="{Binding ModelParam.Output.RunTime}"/>
                        <Run Text="ms"/>
                    </TextBlock>
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14">
                        <Run Text="执行状态:"/>
                        <Run Text="{Binding ModelParam.Output.RunStatus}"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding GeneralCommand}" CommandParameter="打开图像预览" Style="{StaticResource GeneralButtonStyle}" Height="35" Width="auto" Content="打开图像预览" Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Command="{Binding GeneralCommand}" CommandParameter="执行" Style="{StaticResource GeneralButtonStyle}" Height="35" Width="80" Content="执行" Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="取消" Height="auto" Width="80" Style="{StaticResource GeneralButtonStyle}" Content="取消" Cursor="Hand"/>
                    <Button Margin="0,0,15,0" FontSize="18" Command="{Binding GeneralCommand}" CommandParameter="确认" Style="{StaticResource GeneralButtonStyle}" Height="auto" Width="80" Content="确认" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="ReeYin.Customized.Algo.Views.HeightDifferenceMeasureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:halconPreview="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             FontFamily="Microsoft YaHei UI"
             FontSize="13"
             d:DesignHeight="920"
             d:DesignWidth="1600">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <UserControl.Resources>
        <Style x:Key="HeightDifferenceResultHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="#F8FAFC" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="Foreground" Value="#334155" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeightDifferenceResultCellStyle" TargetType="DataGridCell">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EEF2F7" />
                    <Setter Property="Foreground" Value="#1F2933" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeightDifferenceResultRowStyle" TargetType="DataGridRow">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Tag" Value="{Binding DataContext.DeleteMeasureItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
            <Setter Property="ContextMenu">
                <Setter.Value>
                    <ContextMenu>
                        <MenuItem Header="删除该结果"
                                  Command="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    </ContextMenu>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#F1F5F9" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeightDifferenceResultDataGridStyle" TargetType="DataGrid">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="ColumnHeaderHeight" Value="32" />
            <Setter Property="MinRowHeight" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0" />
            <Setter Property="VerticalGridLinesBrush" Value="#E2E8F0" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="RowStyle" Value="{StaticResource HeightDifferenceResultRowStyle}" />
            <Setter Property="CellStyle" Value="{StaticResource HeightDifferenceResultCellStyle}" />
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource HeightDifferenceResultHeaderStyle}" />
        </Style>

        <Style x:Key="HeightDifferenceResultTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="Padding" Value="6,0" />
        </Style>
    </UserControl.Resources>

    <Grid Background="#F2EFE8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="430" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="18,18,14,18"
                Padding="20"
                Background="#FBFAF7"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.14" />
            </Border.Effect>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="高度差测量"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#213547" />

                    <Border Margin="0,0,0,16"
                            Padding="14"
                            Background="#F4F0E6"
                            CornerRadius="0">
                        <StackPanel>
                            <TextBlock Text="文件设置"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#5A4326" />

                            <TextBlock Margin="0,10,0,6"
                                       Foreground="#52606D"
                                       FontSize="12"
                                       Text="高度图 / PCD 路径" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="36" />
                                </Grid.ColumnDefinitions>
                                <TextBox Height="30"
                                         Padding="8,0"
                                         FontSize="12"
                                         VerticalContentAlignment="Center"
                                         Style="{DynamicResource TextBoxExtend}"
                                         Text="{Binding ModelParam.ManualImagePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        Margin="6,0,0,0"
                                        Height="30"
                                        FontSize="11"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding BrowseImageCommand}"
                                        Content="..." />
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.ColumnSpan="2"
                                          Height="30"
                                          DisplayMemberPath="DisplayName"
                                          ItemsSource="{Binding MeasureModeOptions}"
                                          SelectedItem="{Binding SelectedMeasureModeOption, Mode=TwoWay}" />

                                <Button Grid.Row="1"
                                        Margin="0,10,6,0"
                                        Height="32"
                                        Padding="4,0"
                                        FontSize="11"
                                        Background="#0E7490"
                                        Foreground="White"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding StartMeasureCommand}"
                                        Content="{Binding MeasureActionText}" />
                                <Button Grid.Row="1"
                                        Grid.Column="1"
                                        Margin="6,10,0,0"
                                        Height="32"
                                        Padding="4,0"
                                        FontSize="11"
                                        Style="{DynamicResource GeneralButtonStyle}"
                                        Command="{Binding ToggleCenterViewCommand}"
                                        Content="{Binding ToggleCenterViewText}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,0,16"
                            Padding="14"
                            Background="#EFF6F3"
                            CornerRadius="0">
                        <StackPanel>
                            <TextBlock Text="测量参数"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#21543D" />
                            <WrapPanel Margin="0,12,0,0"
                                       ItemWidth="300"
                                       ItemHeight="38">
                                <Grid Width="300"
                                      Margin="0,0,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="165" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#52606D"
                                               FontSize="11"
                                               Text="X方向像素间距 (mm)" />
                                    <hc:NumericUpDown Grid.Column="1"
                                                      Height="28"
                                                      FontSize="11"
                                                      BorderThickness="0 0 0 1"
                                                      HorizontalContentAlignment="Center"
                                                      Value="{Binding ModelParam.IntervalX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Grid Width="300"
                                      Margin="0,0,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="165" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#52606D"
                                               FontSize="11"
                                               Text="Y方向像素间距 (mm)" />
                                    <hc:NumericUpDown Grid.Column="1"
                                                      Height="28"
                                                      FontSize="11"
                                                      BorderThickness="0 0 0 1"
                                                      HorizontalContentAlignment="Center"
                                                      Value="{Binding ModelParam.IntervalY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Grid Width="300"
                                      Margin="0,0,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="165" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#52606D"
                                               FontSize="11"
                                               Text="Z方向数值单位" />
                                    <hc:NumericUpDown Grid.Column="1"
                                                      Height="28"
                                                      FontSize="11"
                                                      Minimum="0.000000001"
                                                      BorderThickness="0 0 0 1"
                                                      HorizontalContentAlignment="Center"
                                                      Value="{Binding ModelParam.ZValueScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Grid.Column="3"
                                              Height="28"
                                              FontSize="11"
                                              BorderThickness="0 0 0 1"
                                              HorizontalContentAlignment="Center"
                                              Background="White"
                                              helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                              SelectedItem="{Binding ModelParam.ZValueUnit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Grid Width="300"
                                      Margin="0,0,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="165" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#52606D"
                                               FontSize="11"
                                               Text="无效灰度中心值" />
                                    <hc:NumericUpDown Grid.Column="1"
                                                      Height="28"
                                                      FontSize="11"
                                                      BorderThickness="0 0 0 1"
                                                      HorizontalContentAlignment="Center"
                                                      Value="{Binding ModelParam.InvalidGrayCenter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Grid Width="300"
                                      Margin="0,0,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="165" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#52606D"
                                               FontSize="11"
                                               Text="无效灰度容差" />
                                    <hc:NumericUpDown Grid.Column="1"
                                                      Height="28"
                                                      FontSize="11"
                                                      BorderThickness="0 0 0 1"
                                                      HorizontalContentAlignment="Center"
                                                      Value="{Binding ModelParam.InvalidGrayTolerance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Grid Width="300"
                                      Margin="0,0,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="165" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#52606D"
                                               FontSize="11"
                                               Text="截尾均值比例" />
                                    <hc:NumericUpDown Grid.Column="1"
                                                      Height="28"
                                                      FontSize="11"
                                                      Minimum="0"
                                                      Maximum="0.49"
                                                      BorderThickness="0 0 0 1"
                                                      HorizontalContentAlignment="Center"
                                                      Value="{Binding ModelParam.TrimRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <Grid Width="300"
                                      Margin="0,0,8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="165" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="#52606D"
                                               FontSize="11"
                                               Text="测量精度(小数位数)" />
                                    <hc:NumericUpDown Grid.Column="1"
                                                      Height="28"
                                                      FontSize="11"
                                                      Minimum="0"
                                                      Maximum="6"
                                                      BorderThickness="0 0 0 1"
                                                      HorizontalContentAlignment="Center"
                                                      Value="{Binding ModelParam.MeasurementPrecision, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </WrapPanel>

                            <StackPanel Margin="0,10,0,0"
                                        Visibility="{Binding AutomaticParameterVisibility}">
                                <TextBlock Text="自动测量专用参数"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#52606D" />
                                <WrapPanel Margin="0,8,0,0"
                                           ItemWidth="300"
                                           ItemHeight="38">
                                    <Grid Width="300"
                                          Margin="0,0,8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="165" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   Foreground="#52606D"
                                                   FontSize="11"
                                                   Text="测量框高度比例" />
                                        <hc:NumericUpDown Grid.Column="1"
                                                          Height="28"
                                                          FontSize="11"
                                                          Minimum="0.01"
                                                          Maximum="1"
                                                          BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.ShrinkHeightRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Width="300"
                                          Margin="0,0,8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="165" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   Foreground="#52606D"
                                                   FontSize="11"
                                                   Text="测量框宽度比例" />
                                        <hc:NumericUpDown Grid.Column="1"
                                                          Height="28"
                                                          FontSize="11"
                                                          Minimum="0.01"
                                                          Maximum="1"
                                                          BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.ShrinkWidthRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Width="300"
                                          Margin="0,0,8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="165" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   Foreground="#52606D"
                                                   FontSize="11"
                                                   Text="左区域移动比例" />
                                        <hc:NumericUpDown Grid.Column="1"
                                                          Height="28"
                                                          FontSize="11"
                                                          Minimum="0"
                                                          BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.LeftRegionMoveRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid Width="300"
                                          Margin="0,0,8,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="165" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center"
                                                   Foreground="#52606D"
                                                   FontSize="11"
                                                   Text="右区域移动比例" />
                                        <hc:NumericUpDown Grid.Column="1"
                                                          Height="28"
                                                          FontSize="11"
                                                          Minimum="0"
                                                          BorderThickness="0 0 0 1"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.RightRegionMoveRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                </WrapPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Padding="14"
                            Background="#EEF7FF"
                            CornerRadius="0">
                        <StackPanel>
                            <TextBlock Text="交互说明"
                                       FontWeight="SemiBold"
                                       Foreground="#0F4C81" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#4E5D6C"
                                       TextWrapping="Wrap"
                                       Text="1. 先在切换列表中选择自动测量、画线测量、矩形1测量或矩形2测量，再点击统一测量按钮。&#10;2. 自动测量会直接执行算法；画线测量需在热力图上拖动一条线，并在下方曲线拖动两次选择区间。&#10;3. 矩形1测量依次框选两个水平矩形；矩形2测量依次绘制两个旋转矩形。&#10;4. 开始测量会清空图像上的临时绘制；测量结果列表选中哪条，只显示对应线、区间或矩形。" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1"
                Margin="0,18,0,18"
                Padding="16"
                Background="#FBFAF7"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.14" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="280" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="热力图与剖面"
                                   x:Name="CenterTitleText"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#213547" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#5C6B73"
                                   Text="{Binding InputFileName}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="10,6"
                            Background="#E8F1EC"
                            CornerRadius="20"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding RunStatusText}"
                                   FontWeight="SemiBold"
                                   Foreground="#21543D" />
                    </Border>
                </Grid>

                <Border Grid.Row="1"
                        Grid.RowSpan="2"
                        Margin="0,16,0,0"
                        Background="#171C23"
                        BorderBrush="#CCD5DF"
                        BorderThickness="1"
                        Padding="1"
                        Visibility="{Binding PointCloudViewVisibility}"
                        CornerRadius="0">
                    <ContentControl x:Name="PointCloudHost"
                                    ClipToBounds="True"
                                    prism:ViewModelLocator.AutoWireViewModel="False" />
                </Border>

                <Border Grid.Row="1"
                        Margin="0,16,0,16"
                        Background="#171C23"
                        BorderBrush="#CCD5DF"
                        BorderThickness="1"
                        Padding="1"
                        Visibility="{Binding HeatmapViewVisibility}"
                        CornerRadius="0">
                    <Grid ClipToBounds="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>

                        <Grid>
                            <halconPreview:VMHWindowControl x:Name="HeatmapHalconPreview"
                                                            Image="{Binding ModelParam.HeatmapPreviewObject}"
                                                            IsStatusBarVisible="True"
                                                            IsShapeDrawingEnabled="False" />
                        </Grid>

                        <Border Grid.Column="1"
                                Margin="0"
                                Padding="12,18,12,18"
                                Background="#111827"
                                BorderBrush="#334155"
                                BorderThickness="1,0,0,0"
                                CornerRadius="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock HorizontalAlignment="Center"
                                           Foreground="#CBD5E1"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="热力区间" />

                                <TextBlock Grid.Row="1"
                                           Margin="0,10,0,10"
                                           HorizontalAlignment="Center"
                                           Foreground="#F8FAFC"
                                           FontSize="11"
                                           Text="{Binding HeatmapRangeMaxText}" />

                                <Grid Grid.Row="2"
                                      Width="30"
                                      Margin="0,0,0,10"
                                      HorizontalAlignment="Center">
                                    <Border CornerRadius="0"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            ClipToBounds="True">
                                        <Image Source="{Binding ModelParam.HeatmapColorBarImage}"
                                               Stretch="Fill" />
                                    </Border>
                                    <TextBlock VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="52,0,0,0"
                                               Foreground="#CBD5E1"
                                               FontSize="11"
                                               Text="{Binding HeatmapRangeMidText}" />
                                </Grid>

                                <TextBlock Grid.Row="3"
                                           HorizontalAlignment="Center"
                                           Foreground="#F8FAFC"
                                           FontSize="11"
                                           Text="{Binding HeatmapRangeMinText}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Padding="0"
                        Background="#171C23"
                        BorderBrush="#CCD5DF"
                        BorderThickness="1"
                        Visibility="{Binding HeatmapViewVisibility}"
                        CornerRadius="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Margin="14,14,14,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="高度曲线"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#E5EDF5" />
                                <TextBlock Margin="0,4,0,0"
                                           Foreground="#9FB3C8"
                                           FontSize="12"
                                           Text="{Binding ProfileInstructionText}" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1"
                              x:Name="ProfileChartHost"
                              Margin="0,12,0,0"
                              SizeChanged="ProfileChartHost_SizeChanged">
                            <halconPreview:VMHWindowControl x:Name="ProfileHalconPreview"
                                                            IsStatusBarVisible="False"
                                                            IsShapeDrawingEnabled="False" />
                            <Canvas x:Name="ProfileLabelCanvas"
                                    Background="Transparent"
                                    IsHitTestVisible="False">
                                <TextBlock x:Name="ProfileYAxisTopLabel"
                                           Foreground="#E2E8F0"
                                           FontSize="11" />
                                <TextBlock x:Name="ProfileYAxisBottomLabel"
                                           Foreground="#E2E8F0"
                                           FontSize="11" />
                                <TextBlock x:Name="ProfileXAxisStartLabel"
                                           Foreground="#E2E8F0"
                                           FontSize="11" />
                                <TextBlock x:Name="ProfileXAxisEndLabel"
                                           Foreground="#E2E8F0"
                                           FontSize="11" />
                                <TextBlock x:Name="ProfileYAxisTitleLabel"
                                           Foreground="#94A3B8"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="Z (mm)" />
                                <TextBlock x:Name="ProfileXAxisTitleLabel"
                                           Foreground="#94A3B8"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Text="X/Y (mm)" />
                            </Canvas>
                            <TextBlock x:Name="ProfileChartMessageLabel"
                                       MaxWidth="560"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Foreground="#DDE7F0"
                                       FontSize="13"
                                       Visibility="Collapsed" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Margin="14,18,18,18"
                Padding="14"
                Background="#FBFAF7"
                CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.14" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <TextBlock Text="测量结果"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="#213547" />

                <Border Grid.Row="1"
                        Margin="0,14,0,12"
                        Padding="10"
                        Background="#F8FAFC"
                        BorderBrush="#D8E0E8"
                        BorderThickness="1"
                        CornerRadius="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="#1F2933"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Text="测量统计" />

                        <Button Height="28"
                                MinWidth="64"
                                Padding="10,0"
                                HorizontalAlignment="Right"
                                FontSize="12"
                                Style="{DynamicResource GeneralButtonStyle}"
                                Command="{Binding ClearMeasureItemsCommand}"
                                Content="清空" />

                        <DataGrid Grid.Row="1"
                                  Style="{StaticResource HeightDifferenceResultDataGridStyle}"
                                  Margin="0,8,0,0"
                                  ItemsSource="{Binding ModelParam.MeasureItems}"
                                  SelectedItem="{Binding SelectedMeasureItem, Mode=TwoWay}"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="序号"
                                                    Binding="{Binding Index}"
                                                    ElementStyle="{StaticResource HeightDifferenceResultTextStyle}"
                                                    Width="40" />
                                <DataGridTextColumn Header="方式"
                                                    Binding="{Binding MeasureKindText}"
                                                    ElementStyle="{StaticResource HeightDifferenceResultTextStyle}"
                                                    Width="100" />
                                <DataGridTextColumn Header="高度差"
                                                    Binding="{Binding HeightDiffText}"
                                                    ElementStyle="{StaticResource HeightDifferenceResultTextStyle}"
                                                    Width="*" />
                                <DataGridTextColumn Header="执行状态"
                                                    Binding="{Binding ExecutionStatus}"
                                                    ElementStyle="{StaticResource HeightDifferenceResultTextStyle}"
                                                    Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Padding="10"
                        Background="#F8FAFC"
                        BorderBrush="#D8E0E8"
                        BorderThickness="1"
                        CornerRadius="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#1F2933"
                                   Text="执行日志" />

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,8,0,0"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Foreground="#52606D"
                                           FontSize="12"
                                           Text="{Binding ModelParam.InputSourceText, Mode=OneWay}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#52606D"
                                           FontSize="12"
                                           Text="{Binding ModelParam.ProfileStatusText, Mode=OneWay}"
                                           TextWrapping="Wrap" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#52606D"
                                           FontSize="12"
                                           Text="{Binding ModelParam.ResultMessage, Mode=OneWay}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>

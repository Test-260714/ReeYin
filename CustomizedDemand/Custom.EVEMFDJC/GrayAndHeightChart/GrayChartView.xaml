<UserControl x:Class="Custom.EVEMFDJC.GrayAndHeightChart.GrayChartView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Custom.EVEMFDJC.GrayAndHeightChart"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:drawingCanvasViewer="clr-namespace:Custom.EVEMFDJC"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="600">
    <UserControl.Resources>
        <Style x:Key="Page.Styles.Button.Base" TargetType="{x:Type ButtonBase}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style
			x:Key="Page.Styles.Button.Color"
			BasedOn="{StaticResource Page.Styles.Button.Base}"
			TargetType="{x:Type ToggleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                            <StackPanel>
                                <Border
									Width="24"
									Height="24"
									Padding="1"
									Background="Transparent"
									BorderBrush="Transparent"
									BorderThickness="1"
									CornerRadius="2">
                                    <Rectangle
										Fill="{TemplateBinding Foreground}"
										RadiusX="2"
										RadiusY="2" />
                                </Border>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style BasedOn="{StaticResource ButtonPrimary}" TargetType="{x:Type Button}" />
        <Style
			x:Key="toolButtonStyle"
			BasedOn="{StaticResource ButtonPrimary}"
			TargetType="{x:Type Button}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <!--<Setter Property="FontFamily" Value="{StaticResource IconFont}" />-->
            <Setter Property="FontSize" Value="22" />
        </Style>
        <Style BasedOn="{StaticResource RadioButtonIconBaseStyle}" TargetType="RadioButton">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Content" Value="&#xe637;" />
            <!--<Setter Property="FontFamily" Value="{StaticResource IconFont}" />-->
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Foreground" Value="{DynamicResource MainPrimaryTextBrush}" />
        </Style>

        <Style TargetType="{x:Type drawingCanvasViewer:DrawingCanvasViewer}">
            <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="ScrollViewer.VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type drawingCanvasViewer:DrawingCanvasViewer}">
                        <Grid>
                            <Label
                            x:Name="Part_Label"
                            Height="20"
                            Padding="5,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Bottom"
                            Panel.ZIndex="9999"
                            Visibility="Hidden" />

                            <Border x:Name="Part_ImageBorder" ClipToBounds="True">
                                <Grid>
                                    <Image
                                    x:Name="Part_Image"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    RenderOptions.EdgeMode="Aliased"
                                    Stretch="Uniform" />
                                    <Viewbox>
                                        <Viewbox.ContextMenu>
                                            <ContextMenu Visibility="Hidden" />
                                        </Viewbox.ContextMenu>
                                        <ContentPresenter x:Name="Part_ContentPresenter" Content="{TemplateBinding DrawingCanvas}" />
                                    </Viewbox>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!--绘制形状-->
        <Grid MinWidth="600">
            <Grid.RowDefinitions>
                <RowDefinition></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <drawingCanvasViewer:DrawingCanvasViewer x:Name="drawViewer">
                <drawingCanvasViewer:DrawingCanvas x:Name="drawCanvas" Background="Transparent" >
                    <hc:Magnifier.Instance>
                        <hc:Magnifier Scale="6" HorizontalOffset="-16" VerticalOffset="-16"/>
                    </hc:Magnifier.Instance>
                </drawingCanvasViewer:DrawingCanvas>
            </drawingCanvasViewer:DrawingCanvasViewer>
            <ToolBarTray
				Grid.Row="1"
				HorizontalAlignment="Center"
				Orientation="Horizontal">
                <ToolBar
					x:Name="toolbar"
					Background="Transparent"
					ToolBarTray.IsLocked="True">
                    <Button FontFamily="{StaticResource Iconfont}"
						x:Name="btn_SaveImage"
						Content="&#xe641;"
						IsEnabled="{Binding Model.IsEnabeld}"
						Click="btn_SaveImage_Click"
						Style="{DynamicResource toolButtonStyle}" />
                    <Button FontFamily="{StaticResource Iconfont}"
						x:Name="btn_OriginalScale"
						Content="&#xe611;"
						IsEnabled="{Binding Model.IsEnabeld}"
						Style="{DynamicResource toolButtonStyle}" />
                    <Button FontFamily="{StaticResource Iconfont}"
						x:Name="btn_Ellipse"
						Content="&#xe61d;"
						IsEnabled="{Binding Model.IsEnabeld}"
						Style="{DynamicResource toolButtonStyle}" />

                    <Button FontFamily="{StaticResource Iconfont}"
						x:Name="btn_ClearTools"
						Content="&#xeaf2;"
						IsEnabled="{Binding Model.IsEnabeld}"
						Style="{DynamicResource toolButtonStyle}" />

                    <Popup
						IsOpen="{Binding IsChecked, ElementName=btn_color}"
						Placement="Bottom"
						PlacementTarget="{Binding ElementName=btn_color}">
                        <hc:ColorPicker x:Name="color_picker" />
                    </Popup>
                </ToolBar>
            </ToolBarTray>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="Custom.Semiconductor.Test.Views.ConcentricPointsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="320"
             MinHeight="240">
    <Grid Background="#FFF8FAFC">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Canvas Width="160" Height="160" Margin="0,0,0,16">
                <Ellipse Width="150" Height="150" Canvas.Left="5" Canvas.Top="5" Stroke="#FF2563EB" StrokeThickness="2"/>
                <Ellipse Width="100" Height="100" Canvas.Left="30" Canvas.Top="30" Stroke="#FF16A34A" StrokeThickness="2"/>
                <Ellipse Width="50" Height="50" Canvas.Left="55" Canvas.Top="55" Stroke="#FFEA580C" StrokeThickness="2"/>
                <Ellipse Width="8" Height="8" Canvas.Left="76" Canvas.Top="76" Fill="#FF111827"/>
            </Canvas>
            <TextBlock Text="Concentric points preview"
                       Foreground="#FF334155"
                       FontSize="16"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>

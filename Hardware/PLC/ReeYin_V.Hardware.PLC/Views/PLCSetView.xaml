                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="离线"/>
                                                            <Setter Property="Foreground" Value="#888888"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ModelParam.CurSlt.IsHeartbeatAlive}" Value="True">
                                                                    <Setter Property="Text" Value="存活"/>
                                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="最近值：" Foreground="#555555" FontWeight="Medium" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ModelParam.CurSlt.LastHeartbeatValue, FallbackValue='--'}" Foreground="#2196F3" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                                <TextBlock Text="最近成功：" Foreground="#555555" FontWeight="Medium" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding ModelParam.CurSlt.LastHeartbeatTime, FallbackValue='--'}" Foreground="#222222" FontSize="12" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!--轴组管理Tab-->
                <TabItem Header="轴组管理" Width="150" FontSize="20" Style="{DynamicResource SingleTabItemStyle}" HorizontalAlignment="Center" Margin="0,-2,0,0">
                    <local:PLCAxisGroupView/>
                </TabItem>

            </TabControl>
        </Grid>

        <!--底部操作栏-->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!--状态信息-->
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="就绪" Foreground="#666666" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  " Foreground="#CCCCCC" Margin="10,0"/>
                    <TextBlock Foreground="#666666" FontSize="13" VerticalAlignment="Center">
                        <Run Text="PLC数量："/>
                        <Run Text="{Binding ModelParam.Models.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <!--操作按钮-->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button IsEnabled="{Binding ModelParam.IsCurSltCardIsNotNull}"
                            Style="{StaticResource GeneralButtonStyle}"
                            Height="36" Width="100"
                            Content="运动调试" FontSize="14"
                            Background="#607D8B" Foreground="White" BorderBrush="#607D8B"
                            Cursor="Hand"
                            Command="{Binding GeneralCommand}" CommandParameter="PLC运动调试"
                            Margin="0,0,10,0"/>
                    <Button Style="{StaticResource GeneralButtonStyle}"
                            Height="36" Width="100"
                            Content="保存" FontSize="14"
                            Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                            Cursor="Hand"
                            Command="{Binding GeneralCommand}" CommandParameter="保存"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

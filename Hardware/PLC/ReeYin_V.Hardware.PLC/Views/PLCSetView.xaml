<UserControl x:Class="ReeYin_V.Hardware.PLC.Views.PLCSetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
              xmlns:prism="http://prismlibrary.com/"
              xmlns:hc="https://handyorg.github.io/handycontrol"
              xmlns:local="clr-namespace:ReeYin_V.Hardware.PLC.Views"
              xmlns:models="clr-namespace:ReeYin_V.Hardware.PLC.Models"
              FontSize="14"
              prism:ViewModelLocator.AutoWireViewModel="True"
              d:DesignHeight="980" d:DesignWidth="1280">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--顶部标题栏-->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!--标题-->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PLC配置" FontSize="18" FontWeight="SemiBold" Foreground="#222222"/>
                    <TextBlock Text="/" Margin="10,0" Foreground="#CCCCCC" FontSize="16"/>
                    <TextBlock Text="设备管理" FontSize="16" Foreground="#666666"/>
                </StackPanel>

                <!--操作按钮-->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="操作：" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#666666" FontWeight="Medium"/>
                    <Button Name="btnLogin" IsEnabled="{Binding IsEnabled}" Style="{StaticResource GeneralButtonStyle}"
                            Width="36" Height="32" FontSize="16"
                            Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                            FontFamily="{StaticResource Iconfont}"
                            Content="&#xe645;" ToolTip="导入配置" Cursor="Hand"
                            Command="{Binding GeneralCommand}" CommandParameter="ImportConfig"
                            Margin="0,0,8,0"/>
                    <Button IsEnabled="{Binding IsEnabled}" Style="{StaticResource GeneralButtonStyle}"
                            Width="36" Height="32" FontSize="16"
                            Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                            FontFamily="{StaticResource Iconfont}"
                            Content="&#xe646;" ToolTip="导出配置" Cursor="Hand"
                            Command="{Binding GeneralCommand}" CommandParameter="ExportConfig"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--主体-->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.35*" MinWidth="300"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="0.65*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!--左侧面板-->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--操作区卡片-->
                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!--操作区标题栏-->
                        <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                            <Grid>
                                <TextBlock Text="添加设备" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="&#xe630;" Width="30" Height="28" FontSize="14"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                                            FontFamily="{StaticResource Iconfont}"
                                            ToolTip="添加" Cursor="Hand"
                                            Command="{Binding DataOperateCommand}" CommandParameter="Add"
                                            Margin="0,0,6,0"/>
                                    <Button Content="&#xe74b;" Width="30" Height="28" FontSize="14"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#F44336" Foreground="White" BorderBrush="#F44336"
                                            FontFamily="{StaticResource Iconfont}"
                                            ToolTip="删除" Cursor="Hand"
                                            Command="{Binding DataOperateCommand}" CommandParameter="Del"
                                            Margin="0,0,6,0"/>
                                    <Button Content="&#xe621;" Width="30" Height="28" FontSize="14"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                                            FontFamily="{StaticResource Iconfont}"
                                            ToolTip="修改" Cursor="Hand"
                                            Command="{Binding DataOperateCommand}" CommandParameter="Modify"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--操作区表单-->
                        <Grid Grid.Row="1" Margin="15,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="PLC类型" VerticalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,10,0"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                      Height="28" VerticalContentAlignment="Center"
                                      SelectedItem="{Binding ModelParam.SltType, Mode=TwoWay}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,10,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="PLC网口"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ModelParam.SltType}" Value="{x:Static models:PLCType.ModbusRtu}">
                                                <Setter Property="Text" Value="串口名"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Grid.Row="2" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="#CCCCCC" BorderThickness="1"
                                     Text="{Binding ModelParam.IP, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding VenderName, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,10,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="PLC端口"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ModelParam.SltType}" Value="{x:Static models:PLCType.ModbusRtu}">
                                                <Setter Property="Text" Value="波特率"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Grid.Row="4" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Padding="8,0"
                                     BorderBrush="#CCCCCC" BorderThickness="1"
                                     Text="{Binding ModelParam.Port, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding VenderName, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!--PLC列表卡片-->
                <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!--PLC列表标题栏-->
                        <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                            <TextBlock Text="PLC列表" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </Border>

                        <!--PLC列表DataGrid-->
                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                  EnableColumnVirtualization="True" SelectedIndex="0"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ItemsSource="{Binding ModelParam.Models}"
                                  SelectedItem="{Binding ModelParam.CurSlt}"
                                  FontSize="12"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  RowHeaderWidth="0"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  IsReadOnly="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="品牌" IsReadOnly="False" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                     Text="{Binding Config.Brand, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Config, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="类型" IsReadOnly="False" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Width="150" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0" Margin="5,0"
                                                      Background="Transparent"
                                                      SelectedItem="{Binding Config.PlcType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="自定义名称" IsReadOnly="True" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="False" HorizontalContentAlignment="Center"
                                                     Text="{Binding Config.DisplayName, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Config.DisplayName, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="状态" IsReadOnly="False" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <WxLED:WxLED Width="20" Height="20" HorizontalAlignment="Center" IsActive="{Binding Config.IsConnected, UpdateSourceTrigger=PropertyChanged}" IsBreathing="True"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!--底部状态-->
                        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,6">
                            <TextBlock Foreground="#888888" FontSize="11" VerticalAlignment="Center">
                                <Run Text="设备数量："/>
                                <Run Text="{Binding ModelParam.Models.Count, FallbackValue=0, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!--分隔符-->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          Background="Transparent"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Cursor="SizeWE"/>

            <!--右侧面板：TabControl-->
            <TabControl Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Style="{DynamicResource TabControlStyle}"
                        IsEnabled="{Binding ModelParam.IsCurSltCardIsNotNull, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                <!--基础配置Tab-->
                <TabItem Header="基础配置" Width="150" FontSize="20" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!--连接配置卡片-->
                        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                                    <TextBlock Text="连接配置" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="15,12">
                                    <!--连接参数-->
                                    <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="PLC类型" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                <ComboBox Height="30" VerticalContentAlignment="Center"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding ModelParam.CurSlt.Config.PlcType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="PLC网口"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.ModbusRtu}">
                                                                    <Setter Property="Text" Value="串口名"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBox Height="30" VerticalContentAlignment="Center" Padding="8,0"
                                                         BorderBrush="#CCCCCC" BorderThickness="1"
                                                         Text="{Binding ModelParam.CurSlt.Config.Ip, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4">
                                                <TextBlock Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="PLC端口"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.ModbusRtu}">
                                                                    <Setter Property="Text" Value="波特率"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBox Height="30" VerticalContentAlignment="Center" Padding="8,0"
                                                         BorderBrush="#CCCCCC" BorderThickness="1"
                                                         Text="{Binding ModelParam.CurSlt.Config.Port, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!--按PLC类型显示的高级参数-->
                                    <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="高级配置" Foreground="#555555" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>

                                            <Border Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.InovanceTcpNet}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="15"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="汇川系列" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                        <ComboBox Height="30" VerticalContentAlignment="Center"
                                                                  helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                                  SelectedItem="{Binding ModelParam.CurSlt.Config.InovanceSeries, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="数据格式" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                        <ComboBox Height="30" VerticalContentAlignment="Center"
                                                                  helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                                  SelectedItem="{Binding ModelParam.CurSlt.Config.DataFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.SiemensS7Net}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="西门子系列" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                    <ComboBox Height="30" VerticalContentAlignment="Center"
                                                              helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                              SelectedItem="{Binding ModelParam.CurSlt.Config.SiemensType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.XinJETcpNetModbus}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.XinJEInternalNet}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="15"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="15"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="信捷系列" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                        <ComboBox Height="30" VerticalContentAlignment="Center"
                                                                  helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                                  SelectedItem="{Binding ModelParam.CurSlt.Config.XinJESeries, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="站号" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                        <TextBox Height="30" VerticalContentAlignment="Center" Padding="8,0"
                                                                 BorderBrush="#CCCCCC" BorderThickness="1"
                                                                 Text="{Binding ModelParam.CurSlt.Config.Station, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="数据格式" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                        <ComboBox Height="30" VerticalContentAlignment="Center"
                                                                  helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                                  SelectedItem="{Binding ModelParam.CurSlt.Config.DataFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.BeckhoffAdsNet}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="15"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="发送AMSNetId" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                        <TextBox Height="30" VerticalContentAlignment="Center" Padding="8,0"
                                                                 BorderBrush="#CCCCCC" BorderThickness="1"
                                                                 Text="{Binding ModelParam.CurSlt.Config.SenderNetId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="目标AMSNetId" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                        <TextBox Height="30" VerticalContentAlignment="Center" Padding="8,0"
                                                                 BorderBrush="#CCCCCC" BorderThickness="1"
                                                                 Text="{Binding ModelParam.CurSlt.Config.TargetNetId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <Border Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.AllenBradleyNet}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.OmronCipNet}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="插槽" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                    <TextBox Height="30" VerticalContentAlignment="Center" Padding="8,0"
                                                             BorderBrush="#CCCCCC" BorderThickness="1"
                                                             Text="{Binding ModelParam.CurSlt.Config.Slot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Margin="0,0,0,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.ModbusTcpNet}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ModelParam.CurSlt.Config.PlcType}" Value="{x:Static models:PLCType.ModbusRtuOverTcp}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="站号" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                                    <TextBox Height="30" VerticalContentAlignment="Center" Padding="8,0"

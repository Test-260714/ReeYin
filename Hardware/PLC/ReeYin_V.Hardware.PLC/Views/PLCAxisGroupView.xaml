<UserControl x:Class="ReeYin_V.Hardware.PLC.Views.PLCAxisGroupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:local="clr-namespace:ReeYin_V.Hardware.PLC.Models"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             FontSize="14"
             d:DesignHeight="680" d:DesignWidth="1180">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!--轴组列表-->
        <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                    <Grid>
                        <TextBlock Text="轴组列表" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="30" Height="28" Content="&#xe630;"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    FontFamily="{StaticResource Iconfont}"
                                    Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                                    Command="{Binding GeneralCommand}" CommandParameter="添加轴组"
                                    Margin="0,0,6,0"/>
                            <Button Width="30" Height="28" Content="&#xe74b;"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    FontFamily="{StaticResource Iconfont}"
                                    Background="#F44336" Foreground="White" BorderBrush="#F44336"
                                    Command="{Binding GeneralCommand}" CommandParameter="删除轴组"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="当前PLC轴组定义" Foreground="#666666" FontSize="12"/>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding ModelParam.CurSlt.AxisGroups}"
                             SelectedItem="{Binding ModelParam.SltAxisGroup}"
                             BorderThickness="1" BorderBrush="#E0E0E0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,6">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GroupName}" FontWeight="SemiBold" Foreground="#333333"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888888" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" Width="8" Background="Transparent" HorizontalAlignment="Stretch"/>

        <!--轴列表-->
        <Border Grid.Column="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                    <Grid>
                        <TextBlock Text="轴列表" Foreground="White" FontWeight="SemiBold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Width="30" Height="28" Content="&#xe630;"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    FontFamily="{StaticResource Iconfont}"
                                    Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                                    Command="{Binding GeneralCommand}" CommandParameter="添加轴项"
                                    Margin="0,0,6,0"/>
                            <Button Width="30" Height="28" Content="&#xe74b;"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    FontFamily="{StaticResource Iconfont}"
                                    Background="#F44336" Foreground="White" BorderBrush="#F44336"
                                    Command="{Binding GeneralCommand}" CommandParameter="删除轴项"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1"
                          AutoGenerateColumns="False"
                          Style="{StaticResource DefaultDataGridStyle}"
                          EnableColumnVirtualization="True"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          ItemsSource="{Binding ModelParam.SltAxisGroup.AxisItems}"
                          SelectedItem="{Binding ModelParam.SltAxisItem}"
                          MouseDoubleClick="AxisDataGrid_MouseDoubleClick"
                          FontSize="12"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          RowHeaderWidth="0"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          IsReadOnly="False" CanUserAddRows="False">
                    <DataGrid.ContextMenu>
                        <ContextMenu IsEnabled="True">
                            <MenuItem Header="添加新项" Command="{Binding GeneralCommand}" CommandParameter="添加轴项"/>
                            <Separator/>
                            <MenuItem Header="删除选中项" Command="{Binding GeneralCommand}" CommandParameter="删除轴项"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="轴名" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding AxisName, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="5,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="类型" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                              helper:ItemsControlHelper.EnumType="{x:Type local:EnumAxisType}"
                                              SelectedItem="{Binding AxisType, UpdateSourceTrigger=PropertyChanged}"
                                              BorderThickness="0" Background="Transparent"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="轴号" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <hc:NumericUpDown Minimum="1" Maximum="32" Value="{Binding AxisNo, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="启用" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsUsing, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="编辑" Width="55" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="编辑" FontSize="11" Height="22" Padding="8,0"
                                            HorizontalAlignment="Center"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="{DynamicResource BtnCheckedColor}"
                                            Foreground="White"
                                            BorderBrush="{DynamicResource BtnCheckedColor}"
                                            Click="AxisEditButton_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,6">
                    <TextBlock Foreground="#888888" FontSize="11" VerticalAlignment="Center">
                        <Run Text="双击或点编辑按钮查看详情  |  轴数量："/>
                        <Run Text="{Binding ModelParam.SltAxisGroup.AxisItems.Count, FallbackValue=0, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <!--轴详情侧边抽屉-->
        <hc:Drawer x:Name="DrawerRight" MaskCanClose="True">
            <Border Background="{DynamicResource RegionBrush}" BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource BorderBrush}" Margin="10,10,30,10" Width="700">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!--抽屉标题栏-->
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,10">
                        <Grid>
                            <TextBlock Style="{StaticResource TextBlockTitle}" VerticalAlignment="Center">
                                <Run Text="{Binding ModelParam.SltAxisItem.AxisName, FallbackValue='未选择'}"/>
                                <Run Text=" - 轴详情"/>
                            </TextBlock>
                            <Button HorizontalAlignment="Right"
                                    Content="关闭" Height="28" Width="60" FontSize="12"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Background="White" Foreground="#666666" BorderBrush="#CCCCCC"
                                    Click="DrawerCloseButton_Click"/>
                        </Grid>
                    </Border>

                    <!--可滚动内容区-->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="15" DataContext="{Binding ModelParam.SltAxisItem}">

                            <!--基础参数-->
                            <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="轴名称" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding AxisName, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="描述" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock Text="默认点动量" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                        <hc:NumericUpDown Minimum="0" Maximum="1000" DecimalPlaces="3" Value="{Binding DefaultJogStep, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <TextBlock Text="默认速度" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="3" Value="{Binding DefaultRunSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!--运动参数-->
                            <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="默认加速度" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="3" Value="{Binding DefaultAcc, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="默认减速度" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="3" Value="{Binding DefaultDec, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock Text="最小限位" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                        <hc:NumericUpDown Minimum="-100000" Maximum="100000" DecimalPlaces="3" Value="{Binding MinLimit, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="2">
                                        <TextBlock Text="最大限位" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                                        <hc:NumericUpDown Minimum="-100000" Maximum="100000" DecimalPlaces="3" Value="{Binding MaxLimit, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!--速度档配置-->
                            <Expander Header="速度档配置" IsExpanded="True" Margin="0,0,0,12">
                                <Grid Margin="0,10,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <DataGrid Grid.Row="0"
                                              AutoGenerateColumns="False"
                                              Style="{StaticResource DefaultDataGridStyle}"
                                              ItemsSource="{Binding SpeedProfiles}"
                                              SelectedItem="{Binding DataContext.ModelParam.SltSpeedProfile, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              RowHeaderWidth="0"
                                              SelectionUnit="FullRow"
                                              CanUserAddRows="False"
                                              MaxHeight="200"
                                              MinWidth="400">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="档位名称" MinWidth="70" Width="Auto">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 BorderThickness="0" Background="Transparent"
                                                                 MinWidth="60" Padding="5,0"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="运行速度" MinWidth="100" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="2"
                                                                          Value="{Binding RunSpeed, UpdateSourceTrigger=PropertyChanged}"
                                                                          BorderThickness="0" MinWidth="90"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="加速度" MinWidth="100" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="2"
                                                                          Value="{Binding Acc, UpdateSourceTrigger=PropertyChanged}"
                                                                          BorderThickness="0" MinWidth="90"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="减速度" MinWidth="100" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="2"
                                                                          Value="{Binding Dec, UpdateSourceTrigger=PropertyChanged}"
                                                                          BorderThickness="0" MinWidth="90"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Button Grid.Row="2" HorizontalAlignment="Right"
                                            Height="30" Width="120" FontSize="12" Content="写入选中档到PLC"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#607D8B" Foreground="White" BorderBrush="#607D8B"
                                            Command="{Binding DataContext.GeneralCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="写入速度档"
                                            ToolTip="将选中速度档的参数写入PLC"/>
                                </Grid>
                            </Expander>

                            <!--运动点位配置-->
                            <Expander Header="运动点位配置" IsExpanded="True" Margin="0,0,0,12">
                                <StackPanel Margin="0,10,0,0">
                                    <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="跑位位置写入" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.RunPositionWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.RunPositionWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="当前位置读取" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.CurrentPosRead.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.CurrentPosRead.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="移动到位读取" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.MoveDoneRead.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.MoveDoneRead.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="轴报警读取" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.AlarmRead.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.AlarmRead.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="4" Grid.Column="0">
                                                <TextBlock Text="点动量写入" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.JogStepWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.JogStepWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="4" Grid.Column="2">
                                                <TextBlock Text="运行速度写入" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.RunSpeedWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.RunSpeedWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="加速度写入" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.AccWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.AccWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="减速度写入" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.DecWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.DecWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="最大限位写入" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.MaxLimitWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.MaxLimitWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="最小限位写入" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.MinLimitWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.MinLimitWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="跑位触发命令" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.RunTriggerWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.RunTriggerWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Height="30" Text="{Binding MotionConfig.RunTriggerWrite.ActiveValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBox Grid.Column="2" Height="30" Text="{Binding MotionConfig.RunTriggerWrite.ClearValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="15"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" Content="自动清除" IsChecked="{Binding MotionConfig.RunTriggerWrite.AutoClear, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                                    <hc:NumericUpDown Grid.Column="2" Minimum="10" Maximum="60000" Value="{Binding MotionConfig.RunTriggerWrite.PulseMs, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="到位复位命令" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.MoveDoneResetWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.MoveDoneResetWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Height="30" Text="{Binding MotionConfig.MoveDoneResetWrite.ActiveValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBox Grid.Column="2" Height="30" Text="{Binding MotionConfig.MoveDoneResetWrite.ClearValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="15"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" Content="自动清除" IsChecked="{Binding MotionConfig.MoveDoneResetWrite.AutoClear, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                                    <hc:NumericUpDown Grid.Column="2" Minimum="10" Maximum="60000" Value="{Binding MotionConfig.MoveDoneResetWrite.PulseMs, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="正向点动命令" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.JogPositiveWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.JogPositiveWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Height="30" Text="{Binding MotionConfig.JogPositiveWrite.ActiveValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBox Grid.Column="2" Height="30" Text="{Binding MotionConfig.JogPositiveWrite.ClearValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="15"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" Content="自动清除" IsChecked="{Binding MotionConfig.JogPositiveWrite.AutoClear, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                                    <hc:NumericUpDown Grid.Column="2" Minimum="10" Maximum="60000" Value="{Binding MotionConfig.JogPositiveWrite.PulseMs, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="负向点动命令" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.JogNegativeWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.JogNegativeWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="10"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Height="30" Text="{Binding MotionConfig.JogNegativeWrite.ActiveValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBox Grid.Column="2" Height="30" Text="{Binding MotionConfig.JogNegativeWrite.ClearValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="15"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" Content="自动清除" IsChecked="{Binding MotionConfig.JogNegativeWrite.AutoClear, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                                    <hc:NumericUpDown Grid.Column="2" Minimum="10" Maximum="60000" Value="{Binding MotionConfig.JogNegativeWrite.PulseMs, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Expander>

                            <Expander Header="扩展PLC点位" IsExpanded="True" Margin="0,0,0,12">
                                <StackPanel Margin="0,10,0,0">
                                    <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="使能屏蔽" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.EnableShieldWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.EnableShieldWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Grid.Column="0" Height="30" Text="{Binding MotionConfig.EnableShieldWrite.ActiveValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBox Grid.Column="2" Height="30" Text="{Binding MotionConfig.EnableShieldWrite.ClearValue, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                                <Grid Margin="0,6,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" Content="自动清除" IsChecked="{Binding MotionConfig.EnableShieldWrite.AutoClear, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                                    <hc:NumericUpDown Grid.Column="2" Minimum="10" Maximum="60000" Value="{Binding MotionConfig.EnableShieldWrite.PulseMs, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="停止触发" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.StopTriggerWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.StopTriggerWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="回原触发" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.HomeTriggerWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.HomeTriggerWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="设定位置触发" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.SetPositionTriggerWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.SetPositionTriggerWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                        </Grid>
                                    </Border>

                                    <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="设定位置" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.SetPositionWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.SetPositionWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="手动速度" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.ManualSpeedWrite.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.ManualSpeedWrite.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="15"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="10"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="回原完成读取" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.HomeDoneRead.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.HomeDoneRead.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="运行中读取" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.BusyRead.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.BusyRead.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="使能状态读取" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                                <TextBox Text="{Binding MotionConfig.EnabledRead.Address, UpdateSourceTrigger=PropertyChanged}" Height="30"/>
                                                <ComboBox Height="30" Margin="0,6,0,0"
                                                          helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                          SelectedItem="{Binding MotionConfig.EnabledRead.DataType, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Expander>

                            <!--运行时状态-->
                            <Expander Header="运行时状态" IsExpanded="True">
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="15"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="当前位置" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding RuntimeState.CurrentPos, Mode=OneWay, StringFormat=F3}" Height="30" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="目标位置" Foreground="#555555" FontSize="12" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding RuntimeState.TargetPos, Mode=OneWay, StringFormat=F3}" Height="30" IsReadOnly="True"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal">
                                        <CheckBox IsChecked="{Binding RuntimeState.IsMoving, Mode=OneWay}" IsEnabled="False" Margin="0,0,20,0" Content="运动中"/>
                                        <CheckBox IsChecked="{Binding RuntimeState.IsInPosition, Mode=OneWay}" IsEnabled="False" Margin="0,0,20,0" Content="已到位"/>
                                        <CheckBox IsChecked="{Binding RuntimeState.IsAlarm, Mode=OneWay}" IsEnabled="False" Content="轴报警"/>
                                    </StackPanel>
                                </Grid>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </hc:Drawer>

    </Grid>
</UserControl>

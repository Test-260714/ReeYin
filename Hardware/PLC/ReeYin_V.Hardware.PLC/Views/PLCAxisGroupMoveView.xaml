<Window x:Class="ReeYin_V.Hardware.PLC.Views.PLCAxisGroupMoveView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
        xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        prism:ViewModelLocator.AutoWireViewModel="True"
        FontSize="14"
        Width="1180"
        Height="650"
        MinWidth="1000"
        MinHeight="620"
        d:DesignHeight="650" d:DesignWidth="1180">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closed">
            <i:InvokeCommandAction Command="{Binding StopAllCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Window.Resources>
        <Style x:Key="AxisActionButtonStyle" TargetType="Button" BasedOn="{StaticResource GeneralButtonStyle}">
            <Setter Property="Width" Value="78"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource BtnCheckedColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BtnCheckedColor}"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
        <Style x:Key="SmallAxisButtonStyle" TargetType="Button" BasedOn="{StaticResource GeneralButtonStyle}">
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="StateTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部PLC状态区 -->
        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="当前轴组" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Model.AxisGroup.GroupName, FallbackValue='未选择'}" FontWeight="SemiBold" Foreground="#1976D2"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="PLC状态" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Model.PlcDevice.DeviceRuntimeState.PLCStateText, FallbackValue='--'}" FontWeight="SemiBold" Foreground="#222222"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="运行提示" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Model.StatusMessage}" TextWrapping="Wrap" Foreground="#333333"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="报警信息" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding Model.PlcDevice.DeviceRuntimeState.AlarmText, FallbackValue='--'}" TextWrapping="Wrap" Foreground="#D32F2F"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="285"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧轴选择列表 -->
            <WxGroupBox:WxGroupBox Grid.Column="0" Header="轴列表">
                <ListBox Margin="10"
                         ItemsSource="{Binding Model.ActiveAxes}"
                         SelectedItem="{Binding Model.SelectedAxis, Mode=TwoWay}"
                         BorderBrush="#DDDDDD"
                         BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding AxisName}" FontWeight="SemiBold" Foreground="#222222"/>
                                            <TextBlock Text=" / " Foreground="#999999"/>
                                            <TextBlock Text="{Binding AxisType}" Foreground="#555555"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <TextBlock Text="当前位置：" Style="{StaticResource StateTextStyle}"/>
                                            <TextBlock Text="{Binding RuntimeState.CurrentPos, StringFormat=F3}" Foreground="#1976D2"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" IsBreathing="True" IsActive="{Binding RuntimeState.IsInPosition, Mode=OneWay}" Margin="0,0,6,0"/>
                                        <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" IsBreathing="True" IsActive="{Binding RuntimeState.IsAlarm, Mode=OneWay}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </WxGroupBox:WxGroupBox>

            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center" Background="{DynamicResource SplitBrush}"/>

            <!-- 中间当前轴点动区 -->
            <WxGroupBox:WxGroupBox Grid.Column="2" Header="当前轴点动">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FAFAFA" BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="4" Padding="10">
                        <StackPanel>
                            <TextBlock Text="当前轴" Foreground="#555555" FontSize="12"/>
                            <TextBlock Text="{Binding Model.SelectedAxis.AxisName, FallbackValue='未选择轴'}" FontSize="20" FontWeight="SemiBold" Foreground="#1976D2" Margin="0,5,0,0"/>
                            <TextBlock Text="{Binding Model.SelectedAxis.AxisType, FallbackValue='--'}" Foreground="#777777" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Content="反向点动" Style="{StaticResource AxisActionButtonStyle}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding StartJogNegativeCommand}" CommandParameter="{Binding Model.SelectedAxis}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding StopAxisCommand}" CommandParameter="{Binding Model.SelectedAxis}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="MouseLeave">
                                    <i:InvokeCommandAction Command="{Binding StopAxisCommand}" CommandParameter="{Binding Model.SelectedAxis}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>

                        <Button Grid.Row="0" Grid.Column="1" Content="停止" Style="{StaticResource AxisActionButtonStyle}"
                                Command="{Binding ForceStopAxisCommand}"
                                CommandParameter="{Binding Model.SelectedAxis}"/>

                        <Button Grid.Row="0" Grid.Column="2" Content="正向点动" Style="{StaticResource AxisActionButtonStyle}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding StartJogPositiveCommand}" CommandParameter="{Binding Model.SelectedAxis}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding StopAxisCommand}" CommandParameter="{Binding Model.SelectedAxis}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="MouseLeave">
                                    <i:InvokeCommandAction Command="{Binding StopAxisCommand}" CommandParameter="{Binding Model.SelectedAxis}"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </Button>

                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                   Text="点动按钮：按下启动，松开或移出停止"
                                   Foreground="#777777"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                    </Grid>

                    <UniformGrid Grid.Row="2" Columns="3" Margin="0,10,0,0">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="到位" Style="{StaticResource StateTextStyle}" HorizontalAlignment="Center"/>
                            <WxLED:WxLED Width="16" Height="16" BreathingDuration="1" IsBreathing="True" IsActive="{Binding Model.SelectedAxis.RuntimeState.IsInPosition, Mode=OneWay}"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="运行中" Style="{StaticResource StateTextStyle}" HorizontalAlignment="Center"/>
                            <WxLED:WxLED Width="16" Height="16" BreathingDuration="1" IsBreathing="True" IsActive="{Binding Model.SelectedAxis.RuntimeState.IsBusy, Mode=OneWay}"/>
                        </StackPanel>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="报警" Style="{StaticResource StateTextStyle}" HorizontalAlignment="Center"/>
                            <WxLED:WxLED Width="16" Height="16" BreathingDuration="1" IsBreathing="True" IsActive="{Binding Model.SelectedAxis.RuntimeState.IsAlarm, Mode=OneWay}"/>
                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </WxGroupBox:WxGroupBox>

            <GridSplitter Grid.Column="3" Width="3" HorizontalAlignment="Center" Background="{DynamicResource SplitBrush}"/>

            <!-- 右侧参数和单轴操作区 -->
            <WxGroupBox:WxGroupBox Grid.Column="4" Header="参数与跑位">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0" Columns="2" Rows="3">
                        <hc:NumericUpDown Minimum="-100000" Maximum="100000" DecimalPlaces="3" Margin="0,0,10,8"
                                          hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="90" hc:InfoElement.Title="目标位置:"
                                          Style="{StaticResource NumericUpDownPlus}"
                                          BorderThickness="0,0,0,1" BorderBrush="#BF9000"
                                          Value="{Binding Model.SelectedAxis.RuntimeState.InputTargetPos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="3" Margin="0,0,0,8"
                                          hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="90" hc:InfoElement.Title="点动量:"
                                          Style="{StaticResource NumericUpDownPlus}"
                                          BorderThickness="0,0,0,1" BorderBrush="#BF9000"
                                          Value="{Binding Model.SelectedAxis.RuntimeState.InputJogStep, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="3" Margin="0,0,10,8"
                                          hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="90" hc:InfoElement.Title="手动速度:"
                                          Style="{StaticResource NumericUpDownPlus}"
                                          BorderThickness="0,0,0,1" BorderBrush="#BF9000"
                                          Value="{Binding Model.SelectedAxis.RuntimeState.InputJogSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="3" Margin="0,0,0,8"
                                          hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="90" hc:InfoElement.Title="跑位速度:"
                                          Style="{StaticResource NumericUpDownPlus}"
                                          BorderThickness="0,0,0,1" BorderBrush="#BF9000"
                                          Value="{Binding Model.SelectedAxis.RuntimeState.InputRunSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="3" Margin="0,0,10,0"
                                          hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="90" hc:InfoElement.Title="加速度:"
                                          Style="{StaticResource NumericUpDownPlus}"
                                          BorderThickness="0,0,0,1" BorderBrush="#BF9000"
                                          Value="{Binding Model.SelectedAxis.RuntimeState.InputAcc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <hc:NumericUpDown Minimum="0" Maximum="100000" DecimalPlaces="3" Margin="0,0,0,0"
                                          hc:InfoElement.TitlePlacement="Left" hc:InfoElement.TitleWidth="90" hc:InfoElement.Title="减速度:"
                                          Style="{StaticResource NumericUpDownPlus}"
                                          BorderThickness="0,0,0,1" BorderBrush="#BF9000"
                                          Value="{Binding Model.SelectedAxis.RuntimeState.InputDec, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </UniformGrid>

                    <WrapPanel Grid.Row="2">
                        <Button Content="同步当前位置" Style="{StaticResource SmallAxisButtonStyle}"
                                Command="{Binding SyncAxisTargetCommand}"
                                CommandParameter="{Binding Model.SelectedAxis}"/>
                        <Button Content="设定位置" Style="{StaticResource SmallAxisButtonStyle}"
                                Command="{Binding SetAxisPositionCommand}"
                                CommandParameter="{Binding Model.SelectedAxis}"/>
                        <Button Content="跑位" Style="{StaticResource SmallAxisButtonStyle}"
                                Command="{Binding RunAxisCommand}"
                                CommandParameter="{Binding Model.SelectedAxis}"/>
                        <Button Content="回原" Style="{StaticResource SmallAxisButtonStyle}"
                                Command="{Binding HomeAxisCommand}"
                                CommandParameter="{Binding Model.SelectedAxis}"/>
                        <Button Content="当前轴停止" Style="{StaticResource SmallAxisButtonStyle}"
                                Command="{Binding ForceStopAxisCommand}"
                                CommandParameter="{Binding Model.SelectedAxis}"/>
                        <StackPanel Orientation="Horizontal" Height="34" VerticalAlignment="Top" Margin="0,0,8,8">
                            <TextBlock Text="使能屏蔽" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#555555"/>
                            <ToggleButton Style="{StaticResource ToggleButtonSwitch}" VerticalAlignment="Center">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="Checked">
                                        <i:InvokeCommandAction Command="{Binding EnableShieldCommand}" CommandParameter="{Binding Model.SelectedAxis}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="Unchecked">
                                        <i:InvokeCommandAction Command="{Binding DisableShieldCommand}" CommandParameter="{Binding Model.SelectedAxis}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </ToggleButton>
                        </StackPanel>
                    </WrapPanel>

                    <Border Grid.Row="4" Background="#FAFAFA" BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="4" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <UniformGrid Grid.Row="0" Columns="2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="当前位置：" Style="{StaticResource StateTextStyle}"/>
                                    <TextBlock Text="{Binding Model.SelectedAxis.RuntimeState.CurrentPos, StringFormat=F3, FallbackValue='--'}" Foreground="#1976D2"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="目标位置：" Style="{StaticResource StateTextStyle}"/>
                                    <TextBlock Text="{Binding Model.SelectedAxis.RuntimeState.TargetPos, StringFormat=F3, FallbackValue='--'}" Foreground="#1976D2"/>
                                </StackPanel>
                            </UniformGrid>

                            <UniformGrid Grid.Row="2" Columns="3">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="回原完成" Style="{StaticResource StateTextStyle}"/>
                                    <WxLED:WxLED Width="12" Height="12" BreathingDuration="1" IsBreathing="True" IsActive="{Binding Model.SelectedAxis.RuntimeState.IsHomeDone, Mode=OneWay}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="使能" Style="{StaticResource StateTextStyle}"/>
                                    <WxLED:WxLED Width="12" Height="12" BreathingDuration="1" IsBreathing="True" IsActive="{Binding Model.SelectedAxis.RuntimeState.IsEnabled, Mode=OneWay}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="报警" Style="{StaticResource StateTextStyle}"/>
                                    <WxLED:WxLED Width="12" Height="12" BreathingDuration="1" IsBreathing="True" IsActive="{Binding Model.SelectedAxis.RuntimeState.IsAlarm, Mode=OneWay}"/>
                                </StackPanel>
                            </UniformGrid>

                            <StackPanel Grid.Row="4" Orientation="Horizontal">
                                <TextBlock Text="复位完成：" Style="{StaticResource StateTextStyle}"/>
                                <TextBlock Text="{Binding Model.PlcDevice.DeviceRuntimeState.ResetCompleted, FallbackValue='False'}" Foreground="#222222"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </WxGroupBox:WxGroupBox>
        </Grid>

        <!-- 底部全局操作栏 -->
        <Border Grid.Row="4" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding Model.StatusMessage}" VerticalAlignment="Center" Foreground="#333333"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Width="90" Height="34" Content="跑位全部"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding MoveAllCommand}" Margin="0,0,10,0"/>
                    <Button Width="90" Height="34" Content="全部停止"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding StopAllCommand}" Margin="0,0,10,0"/>
                    <Button Width="90" Height="34" Content="复位"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding ResetCommand}" Margin="0,0,10,0"/>
                    <Button Width="90" Height="34" Content="清报警"
                            Style="{StaticResource GeneralButtonStyle}"
                            Command="{Binding ClearAlarmCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

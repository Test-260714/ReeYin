
<Window x:Class="ReeYin_V.Hardware.ControlCard.ZMotion.CustomUI.Views.MotionCardSettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
        xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="运动控制卡参数设置" Width="1150" Height="900"
        MinWidth="1150" MaxWidth="1150" MinHeight="900" MaxHeight="900"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None"
        Background="#FAFAFA"
        AllowsTransparency="False">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="4" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Generic.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <!-- 左侧导航样式 -->
            <Style x:Key="MotionCardTabItemStyle" TargetType="TabItem" BasedOn="{StaticResource SingleTabItemStyle}">
                <Setter Property="Padding" Value="12 8"/>
                <Setter Property="Width" Value="140"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,4"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Padding" Value="12 8"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Margin" Value="0,4"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Padding" Value="12 8"/>
                        <Setter Property="Height" Value="40"/>
                        <Setter Property="Margin" Value="0,4"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="MotionCardTabControlStyle" TargetType="TabControl" BasedOn="{StaticResource TabControlStyle}">
                <Setter Property="Padding" Value="16"/>
                <Setter Property="TabStripPlacement" Value="Left"/>
                <Setter Property="ItemsPanel">
                    <Setter.Value>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical" IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Grid SnapsToDevicePixels="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Background="#F2F2F2"
                                        CornerRadius="8"
                                        Margin="0,0,12,0">
                                    <ItemsPresenter Margin="8" VerticalAlignment="Top"/>
                                </Border>
                                <Border Grid.Column="1"
                                        CornerRadius="5"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        Background="{TemplateBinding Background}">
                                    <ContentPresenter ContentSource="SelectedContent"
                                                      SnapsToDevicePixels="True"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题栏 -->
        <Border Grid.Row="0" Background="#C69200" CornerRadius="6,6,0,0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="运动控制卡参数设置" Foreground="White" FontSize="16"
                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Button Grid.Column="1" Content="×" Width="36" Height="28"
                        Background="Transparent" Foreground="White" BorderBrush="Transparent"
                        FontSize="14" Cursor="Hand" Click="CloseButton_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <TabControl Style="{DynamicResource MotionCardTabControlStyle}" ItemContainerStyle="{DynamicResource MotionCardTabItemStyle}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                <TabItem Header="运行/参数">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                                <!-- 连接配置 -->
                        <Border Grid.Row="0" Background="White" CornerRadius="8" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid Margin="24,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="IP地址" VerticalAlignment="Center" Foreground="#666"/>
                                <TextBox Grid.Column="1" Text="{Binding IpAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32" MinWidth="220"
                                         Style="{DynamicResource TextBoxExtend}"/>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <TextBlock Text="连接状态" Foreground="#666" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <WxLED:WxLED Width="16" Height="16" IsActive="{Binding IsConnected}" IsBreathing="True"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Button Content="连接" Width="88" Height="36" Margin="6" FontSize="12" HorizontalAlignment="Center"
                                            Style="{DynamicResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="连接"/>
                                    <Button Content="断开" Width="88" Height="36" Margin="6" FontSize="12" HorizontalAlignment="Center"
                                            Style="{DynamicResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="断开"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 顶部状态栏 -->
                        <Border Grid.Row="1" Background="White" CornerRadius="8" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid Margin="24,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="当前位置" FontSize="13" Foreground="#666" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Settings.CurrentPosition, StringFormat={}{0:F4}}" 
                                                   Foreground="#1976D2" FontWeight="Bold" FontSize="30" VerticalAlignment="Bottom"/>
                                        <TextBlock Text=" mm" FontSize="13" Foreground="#999" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="36,0">
                                    <TextBlock Text="运行状态" FontSize="13" Foreground="#666" Margin="0,0,0,6" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <WxLED:WxLED Width="18" Height="18" Margin="0,0,10,0"
                                                     IsActive="{Binding Settings.IsRunning}" IsBreathing="True"/>
                                        <Border Background="#FF5722" CornerRadius="6" Padding="20,8">
                                            <TextBlock Text="{Binding Settings.WorkStateText}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="当前循环" FontSize="13" Foreground="#666" Margin="0,0,0,6" HorizontalAlignment="Right"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Settings.CurrentCycles}" 
                                                   Foreground="#388E3C" FontWeight="Bold" FontSize="30" VerticalAlignment="Bottom"/>
                                        <TextBlock Text=" 次" FontSize="13" Foreground="#999" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 参数设置区域 -->
                        <Grid Grid.Row="2" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="White" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                                </Border.Effect>
                                <StackPanel Margin="20,16">
                                    <TextBlock Text="触发位置参数" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,16"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="前进触发1" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ForwardTrigger1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32" 
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="前进触发2" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ForwardTrigger2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="返回触发" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ReturnTrigger, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="工作距离(负)" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ReciprocateNegPos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="工作距离(正)" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ReciprocatePosPos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="定位触发" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.PositionTrigger, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="White" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                                </Border.Effect>
                                <StackPanel Margin="20,16">
                                    <TextBlock Text="速度参数" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,16"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="前进速度" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ReciprocateSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="定位速度" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.PositionSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="扫描加速" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ReciprocateAccel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="扫描减速" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ReciprocateDecel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="回原速度" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.HomeFastSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="回原慢速" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.HomeSlowSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="4" Background="White" CornerRadius="8">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                                </Border.Effect>
                                <StackPanel Margin="20,16">
                                    <TextBlock Text="定位与循环参数" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,16"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="定位位置" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.PositionTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="定长距离" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.PositionLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="起始速度" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.StartSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="定位加速" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.PositionAccel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="循环次数" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ReciprocateCycles, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="到位延时" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding Settings.ReciprocateDelay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 运动控制按钮区域 -->
                        <Border Grid.Row="3" Background="White" CornerRadius="8" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid Margin="24,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="点动控制" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                                    <UniformGrid Columns="2" Rows="1">
                                        <Button Content="← 左移" Height="36" Width="88" Margin="6" FontSize="13" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                PreviewMouseLeftButtonDown="JogLeft_MouseDown" 
                                                PreviewMouseLeftButtonUp="JogLeft_MouseUp"/>
                                        <Button Content="右移 →" Height="36" Width="88" Margin="6" FontSize="13" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                PreviewMouseLeftButtonDown="JogRight_MouseDown" 
                                                PreviewMouseLeftButtonUp="JogRight_MouseUp"/>
                                    </UniformGrid>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="运动命令" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                                    <UniformGrid Columns="3" Rows="2">
                                        <Button Content="回原" Height="36" Width="88" Margin="6" FontSize="12" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="回原"/>
                                        <Button Content="定位" Height="36" Width="88" Margin="6" FontSize="12" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="定位"/>
                                        <Button Content="急停" Height="36" Width="88" Margin="6" FontSize="12" Background="#D32F2F" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="急停"/>
                                        <Button Content="开始往复" Height="36" Width="88" Margin="6" FontSize="12" Background="#388E3C" Foreground="White" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="开始往复"/>
                                        <Button Content="暂停往复" Height="36" Width="88" Margin="6" FontSize="12" Background="#F57C00" Foreground="White" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="暂停往复"/>
                                        <Button Content="清空循环" Height="36" Width="88" Margin="6" FontSize="12" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="清空循环"/>
                                    </UniformGrid>
                                </StackPanel>

                                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                    <TextBlock Text="参数操作" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                                    <UniformGrid Columns="2" Rows="2">
                                        <Button Content="读取参数" Height="36" Width="88" Margin="6" FontSize="12" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="读取参数"/>
                                        <Button Content="保存参数" Height="36" Width="88" Margin="6" FontSize="12" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="保存参数"/>
                                        <Button Content="正等距" Height="36" Width="88" Margin="6" FontSize="12" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="正等距"/>
                                        <Button Content="负等距" Height="36" Width="88" Margin="6" FontSize="12" HorizontalAlignment="Center"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="负等距"/>
                                    </UniformGrid>
                                </StackPanel>
                            </Grid>
                        </Border>
                            </Grid>

                    </Grid>
                </TabItem>
                <TabItem Header="IO控制">
                    <Grid Margin="0,8,0,0">
                        <Border Background="White" CornerRadius="8" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid Margin="20,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="IO控制" FontSize="15" FontWeight="SemiBold" Foreground="#333" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding IoStatusText}" Foreground="#777" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <Button Content="刷新IO" Width="88" Height="32" FontSize="12"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="刷新IO"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="输入 IN" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,8"/>
                                        <DataGrid Grid.Row="1"
                                                  ItemsSource="{Binding InputPoints}"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserResizeRows="False"
                                                  IsReadOnly="True"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="点位" Binding="{Binding Name}" Width="*"/>
                                                <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="80"/>
                                                <DataGridTemplateColumn Header="状态" Width="90">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ToggleButton IsChecked="{Binding State, Mode=OneWay}"
                                                                          HorizontalAlignment="Center"
                                                                          IsHitTestVisible="False"
                                                                          Focusable="False"
                                                                          Style="{StaticResource ToggleButtonSwitch}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>

                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="输出 OUT" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,8"/>
                                        <DataGrid Grid.Row="1"
                                                  ItemsSource="{Binding OutputPoints}"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserResizeRows="False"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="点位" Binding="{Binding Name}" Width="*"/>
                                                <DataGridTextColumn Header="端口" Binding="{Binding Port}" Width="80"/>
                                                <DataGridTemplateColumn Header="状态" Width="90">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <ToggleButton IsChecked="{Binding State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          HorizontalAlignment="Center"
                                                                          Style="{StaticResource ToggleButtonSwitch}"
                                                                          Command="{Binding DataContext.ToggleOutputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="编码器">
                    <Grid Margin="0,8,0,0">
                        <!-- 编码器与行频 -->
                        <Border Background="White" CornerRadius="8" Margin="0,0,0,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid Margin="20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="编码器设置" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,16"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="输入类型" VerticalAlignment="Center" Foreground="#666"/>
                                        <ComboBox Grid.Column="1" Height="32" SelectedIndex="{Binding EncoderSignalType, Mode=TwoWay}">
                                            <ComboBoxItem Content="单端"/>
                                            <ComboBoxItem Content="差分"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="P/R" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding EncoderPpr, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="倍频" VerticalAlignment="Center" Foreground="#666"/>
                                        <ComboBox Grid.Column="1" Height="32" SelectedValue="{Binding EncoderMultiply, Mode=TwoWay}" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="1x" Tag="1"/>
                                            <ComboBoxItem Content="2x" Tag="2"/>
                                            <ComboBoxItem Content="4x" Tag="4"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="脉冲/mm" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding EncoderPulsesPerMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="像素尺寸" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding PixelSizeMm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="轴号" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBox Grid.Column="1" Text="{Binding EncoderAxisIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="32"
                                                 Style="{DynamicResource TextBoxExtend}"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="计数/转" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBlock Grid.Column="1" Text="{Binding EncoderCountsPerRev}" VerticalAlignment="Center" Foreground="#333"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                                        <Button Content="应用编码器" Width="96" Height="32" Margin="0,0,8,0"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="应用编码器"/>
                                        <Button Content="清零MPOS" Width="96" Height="32"
                                                Style="{DynamicResource GeneralButtonStyle}"
                                                Command="{Binding GeneralCommand}" CommandParameter="清零编码器"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="实时显示" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,16"/>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="位置(mm)" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBlock Grid.Column="1" Text="{Binding EncoderPosition, StringFormat={}{0:F6}}" VerticalAlignment="Center" Foreground="#1976D2" FontWeight="SemiBold"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="速度(mm/s)" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBlock Grid.Column="1" Text="{Binding EncoderSpeed, StringFormat={}{0:F6}}" VerticalAlignment="Center" Foreground="#1976D2" FontWeight="SemiBold"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="行频(Hz)" VerticalAlignment="Center" Foreground="#666"/>
                                        <TextBlock Grid.Column="1" Text="{Binding LineRate, StringFormat={}{0:F2}}" VerticalAlignment="Center" Foreground="#388E3C" FontWeight="SemiBold"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="日志">
                    <Grid Margin="0,8,0,0">
                        <Border Background="White" CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.1"/>
                            </Border.Effect>
                            <Grid Margin="20,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="操作日志" FontSize="15" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>
                                <ListBox Grid.Row="1" ItemsSource="{Binding LogMessages}" 
                                         BorderThickness="1" BorderBrush="#E0E0E0" Background="#FAFAFA"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         MinHeight="80">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#424242" FontFamily="Consolas" FontSize="12" Margin="8,6"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>


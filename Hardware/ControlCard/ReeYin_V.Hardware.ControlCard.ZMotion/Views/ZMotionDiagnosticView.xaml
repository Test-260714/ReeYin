<UserControl x:Class="ReeYin_V.Hardware.ControlCard.ZMotion.Views.ZMotionDiagnosticView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             Width="1220"
             Height="720"
             MinWidth="1024"
             MinHeight="640"
             FontFamily="Microsoft YaHei UI"
             FontSize="13"
             Background="#EEF1F3"
             d:DesignWidth="1220"
             d:DesignHeight="720">
    <UserControl.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#26343D"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#68777F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D97837"/>
        <SolidColorBrush x:Key="TealBrush" Color="#3F8796"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#C4473A"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="#DCE2E5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="92"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Background" Value="#F4F6F7"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="BorderBrush" Value="#CBD3D7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8ECEE"/>
                    <Setter Property="BorderBrush" Value="{StaticResource TealBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A93B31"/>
                    <Setter Property="BorderBrush" Value="#A93B31"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConnectionPillStyle" TargetType="Border">
            <Setter Property="Background" Value="#FCE9E6"/>
            <Setter Property="BorderBrush" Value="#E1A8A1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,5"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                    <Setter Property="Background" Value="#E5F5EB"/>
                    <Setter Property="BorderBrush" Value="#9AC8AA"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IoInputBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F5F7F8"/>
            <Setter Property="BorderBrush" Value="#D9E0E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Height" Value="29"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="True">
                    <Setter Property="Background" Value="#E3F3E9"/>
                    <Setter Property="BorderBrush" Value="#6AAF83"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IoOutputButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F5F7F8"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="BorderBrush" Value="#D9E0E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Height" Value="29"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="True">
                    <Setter Property="Background" Value="#DDEEF1"/>
                    <Setter Property="BorderBrush" Value="{StaticResource TealBrush}"/>
                    <Setter Property="Foreground" Value="#1E6775"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.55"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="66"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource InkBrush}" CornerRadius="8" Padding="18,0" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="ZMotion 通用诊断" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="当前系统控制卡实例 · 轴与数字 IO 联调" Foreground="#B9C5CB" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConnectionDescription}" Foreground="#D5DDE1" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Border Style="{StaticResource ConnectionPillStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Margin="0,0,7,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#C4473A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                <Setter Property="Fill" Value="#4E9C69"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding ConnectionStatusText}" Foreground="{StaticResource InkBrush}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="轴测试" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                            <TextBlock Text="连续点动、绝对定位与使能诊断" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Height="36"
                                  ItemsSource="{Binding Axes}"
                                  SelectedItem="{Binding SelectedAxis}"
                                  DisplayMemberPath="DisplayName"
                                  VerticalContentAlignment="Center"/>
                    </Grid>

                    <Border Grid.Row="1" Background="#F5F7F8" CornerRadius="6" Padding="20" Margin="0,20,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="当前位置" Foreground="{StaticResource MutedBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding SelectedAxis.Position, StringFormat=F3}" FontSize="38" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                                    <TextBlock Text=" mm" FontSize="16" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <Border Background="#E7EEF1" CornerRadius="4" Padding="12,5" Margin="0,0,0,6">
                                    <TextBlock Text="{Binding SelectedAxis.EnableStateText}" Foreground="{StaticResource InkBrush}" HorizontalAlignment="Center"/>
                                </Border>
                                <Border Background="#E7EEF1" CornerRadius="4" Padding="12,5">
                                    <TextBlock Text="{Binding SelectedAxis.MotionStateText}" Foreground="{StaticResource InkBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="手动点动" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                        <TextBlock Text="按住运动，松开、移出按钮或窗口失焦均停止" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,10"/>
                        <WrapPanel>
                            <Button Style="{StaticResource ActionButtonStyle}" Command="{Binding ToggleAxisEnableCommand}">
                                <Button.Content>
                                    <TextBlock Text="{Binding AxisEnableButtonText}"/>
                                </Button.Content>
                            </Button>
                            <Button Content="◀ 反向点动" Style="{StaticResource ActionButtonStyle}" IsEnabled="{Binding CanOperateAxis}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding StartJogCommand}" CommandParameter="Reverse"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding StopJogCommand}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="MouseLeave">
                                        <i:InvokeCommandAction Command="{Binding StopJogCommand}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="LostMouseCapture">
                                        <i:InvokeCommandAction Command="{Binding StopJogCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                            <Button Content="正向点动 ▶" Style="{StaticResource ActionButtonStyle}" IsEnabled="{Binding CanOperateAxis}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                        <i:InvokeCommandAction Command="{Binding StartJogCommand}" CommandParameter="Forward"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                        <i:InvokeCommandAction Command="{Binding StopJogCommand}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="MouseLeave">
                                        <i:InvokeCommandAction Command="{Binding StopJogCommand}"/>
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="LostMouseCapture">
                                        <i:InvokeCommandAction Command="{Binding StopJogCommand}"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </Button>
                        </WrapPanel>

                        <Separator Margin="0,20,0,16"/>
                        <TextBlock Text="绝对定位" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                        <TextBlock Text="执行前检查连接、使能、空闲状态及已配置软限位" Foreground="{StaticResource MutedBrush}" Margin="0,3,0,10"/>
                        <WrapPanel>
                            <TextBox Width="180"
                                     Height="38"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding TargetPositionText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>
                            <Button Content="绝对定位" Style="{StaticResource ActionButtonStyle}" Command="{Binding MoveAbsoluteCommand}"/>
                            <Button Content="停止当前轴" Style="{StaticResource DangerButtonStyle}" Command="{Binding StopAxisCommand}"/>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Row="3" Background="#FFF6EF" BorderBrush="#E9C5AA" BorderThickness="1" CornerRadius="5" Padding="12,8" Margin="0,18,0,0">
                        <TextBlock Text="诊断操作会直接驱动真实机构，请先确认运动空间和人员安全。" Foreground="#8A4B22" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="数字 IO" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"/>
                            <TextBlock Text="IN0–IN31 / OUT0–OUT31 · 200 ms 刷新" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1"
                                  Content="允许输出操作"
                                  IsChecked="{Binding IsOutputUnlocked}"
                                  VerticalAlignment="Center"
                                  Foreground="#8A4B22"
                                  FontWeight="SemiBold"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#FAFBFB" BorderBrush="#E2E7E9" BorderThickness="1" CornerRadius="6" Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="输入 · 只读" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="4,2,4,8"/>
                                <ItemsControl ItemsSource="{Binding Inputs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource IoInputBorderStyle}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <Ellipse Width="8" Height="8" Margin="0,0,7,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#9DA9AF"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding State}" Value="True">
                                                                        <Setter Property="Fill" Value="#4E9C69"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Name}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#FAFBFB" BorderBrush="#E2E7E9" BorderThickness="1" CornerRadius="6" Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="输出 · 解锁后可切换" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="4,2,4,8"/>
                                <ItemsControl ItemsSource="{Binding Outputs}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}"
                                                    Style="{StaticResource IoOutputButtonStyle}"
                                                    Command="{Binding DataContext.ToggleOutputCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="White" BorderBrush="#DCE2E5" BorderThickness="1" CornerRadius="6" Padding="14,0" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusTime}" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource InkBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="GoogolMotion.Views.GoogolCustomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GoogolMotion.Views"
             mc:Ignorable="d" 
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:prism="http://prismlibrary.com/" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             FontSize="14"
             Height="880" Width="1280"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closed">
            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="关闭">
            </i:InvokeCommandAction>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Vertical">
                <WxGroupBox:WxGroupBox Grid.Row="0" Grid.Column="0" FontSize="12" Header="基础设置">
                    <StackPanel Orientation="Vertical">
                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="卡总轴数：" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140"
                                 Text="{}" />
                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="模块号：" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140"
                                 Text="{}" />
                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="通信状态：" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140"
                                 Text="{}"/>
                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="实际资源：" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140">
                            
                        </TextBox>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                            <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}" Height="30"
                                                    Content="启动watch" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="IO操作面板"/>

                            <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="关闭watch" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="运动轴操作面板"/>
                        </StackPanel>

                    </StackPanel>
                </WxGroupBox:WxGroupBox>
                <WxGroupBox:WxGroupBox Grid.Row="0" Grid.Column="0" FontSize="12" Header="轴号">
                    <StackPanel Orientation="Vertical">
                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="卡总轴数：" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="当前操作核：" Style="{StaticResource TextBoxExtend}" Text="{Binding core}" hc:InfoElement.TitleWidth="140"/>
                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="起始轴号：" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="轴数：" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                        <UniformGrid Columns="2">
                            <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}" Height="30"
                                                    Content="多轴使能" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="多轴使能"/>

                            <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="关闭多轴" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="关闭多轴"/>
                            
                            <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}" Height="30"
                                                    Content="多轴清零" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="多轴清零"/>

                            <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="多轴清状态" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="多轴清状态"/>
                        </UniformGrid>
                    </StackPanel>
                </WxGroupBox:WxGroupBox>
                <WxGroupBox:WxGroupBox Grid.Row="0" Grid.Column="0" FontSize="12" Header="其他">
                    <StackPanel Orientation="Horizontal">
                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="路径：" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="60" Width="180"/>
                        <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}" Height="30"
                                                    Content="加载图档" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="加载图档"/>
                    </StackPanel>
                </WxGroupBox:WxGroupBox>
            </StackPanel>

            <GridSplitter Grid.Column="1" Height="auto" Width="3" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <TabControl Grid.Column="2" Height="auto" FontSize="18" Style="{DynamicResource TabControlStyle}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <TabItem Header="基本运动" Width="100" Style="{DynamicResource SingleTabItemStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <WxGroupBox:WxGroupBox Grid.Row="0" Grid.Column="0" Header="Jog运动" FontSize="12">
                                <StackPanel Orientation="Vertical">
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="加速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="减速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="平滑系数" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 0 0" >
                                        <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="正向" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="IO操作面板"/>

                                        <Button  HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="负向" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="运动轴操作面板"/>
                                    </StackPanel>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Grid.Row="0" Grid.Column="1" FontSize="12" Header="增量位置移动">
                                <StackPanel Orientation="Vertical">
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="移动增量" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="加速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="减速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="平滑时间" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 0 0">
                                        <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                    Content="正向" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="IO操作面板"/>

                                        <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                    Content="负向" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="运动轴操作面板"/>
                                    </StackPanel>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Grid.Row="0" Grid.Column="2" FontSize="12"  Header="绝对位置移动">
                                <StackPanel Orientation="Vertical">
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="目标位置" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="加速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="减速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="平滑时间" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 0 0">
                                        <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
Content="正向" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="IO操作面板"/>

                                        <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
Content="负向" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="运动轴操作面板"/>
                                    </StackPanel>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Grid.Row="1" Grid.Column="0" FontSize="12" Header="往复运动">
                                <StackPanel Orientation="Vertical">
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="速度" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="距离" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="加减速" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="往返次数" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="平滑时间" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 0 0">
                                        <Button Margin="0,0,5,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
Content="正向" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="IO操作面板"/>

                                        <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
Content="负向" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="运动轴操作面板"/>
                                    </StackPanel>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Grid.Row="1" Grid.Column="1" FontSize="12" Header="电子齿轮">
                                <StackPanel Orientation="Vertical">
                                    <CheckBox IsChecked="{Binding IsUsing,UpdateSourceTrigger=PropertyChanged}" Content="启用" HorizontalAlignment="Center"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="跟随轴" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <ComboBox IsEditable="True" Width="300" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="跟随方式" Style="{StaticResource ComboBoxExtend}" hc:InfoElement.TitleWidth="140"
                                                        helper:ItemsControlHelper.EnumValuesToItemsSource="True" SelectedItem="{Binding ModelParam.PosComparisonParam.CompareMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="齿轮比a/b" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="离合区" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Grid.Row="1" Grid.Column="2" FontSize="12" Header="电子凸轮">
                                <StackPanel Orientation="Vertical">
                                    <CheckBox IsChecked="{Binding IsUsing,UpdateSourceTrigger=PropertyChanged}" Content="启用" HorizontalAlignment="Center"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="跟随轴" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="跟随方式" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="齿轮比a/b" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="离合区" Style="{StaticResource TextBoxExtend}" Text="{}" hc:InfoElement.TitleWidth="140"/>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>
                        </Grid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="配置" Height="45" Style="{DynamicResource SingleTabItemStyle}">

                </TabItem>

                <TabItem Header="回零" Height="45" Style="{DynamicResource SingleTabItemStyle}">

                </TabItem>

                <TabItem Header="插补运动" Style="{DynamicResource SingleTabItemStyle}">

                </TabItem>

                <TabItem Header="本地IO" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid>

                    </Grid>
                </TabItem>

                <TabItem Header="拓展模块" Style="{DynamicResource SingleTabItemStyle}">

                </TabItem>

                <TabItem Header="位置比较" Style="{DynamicResource SingleTabItemStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="200"/>
                                <RowDefinition/>
                                <RowDefinition Height="40"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="250"/>
                            </Grid.ColumnDefinitions>

                            <WxGroupBox:WxGroupBox Grid.Row="0" FontSize="12" Grid.Column="0" Header="控制权设置" >
                                <StackPanel Orientation="Vertical">
                                    <UniformGrid Columns="2">
                                        <ComboBox helper:ItemsControlHelper.EnumValuesToItemsSource="True" IsEditable="True" Width="280" Height="30" hc:InfoElement.TitleWidth="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="HSO0控制权" Style="{StaticResource ComboBoxExtend}" 
                                                SelectedItem="{Binding ModelParam.HSO0,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="读取HSO0控制权" Height="30" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="180" 
                                                Text="{Binding ModelParam.ReadHSOControlPower[0] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <ComboBox helper:ItemsControlHelper.EnumValuesToItemsSource="True" IsEditable="True" Height="30" Width="280" hc:InfoElement.TitleWidth="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="HSO1控制权" Style="{StaticResource ComboBoxExtend}"
                                                SelectedItem="{Binding ModelParam.HSO1,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="读取HSO1控制权" Height="30" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="180"
                                                Text="{Binding ModelParam.ReadHSOControlPower[1],Mode=TwoWay,UpdateSourceTrigger=PropertyChanged }"/>
                                        <ComboBox helper:ItemsControlHelper.EnumValuesToItemsSource="True" IsEditable="True" Height="30" Width="280" hc:InfoElement.TitleWidth="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="HSO2控制权" Style="{StaticResource ComboBoxExtend}"
                                                SelectedItem="{Binding ModelParam.HSO2,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="读取HSO2控制权" Height="30" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="180"
                                                Text="{Binding ModelParam.ReadHSOControlPower[2],Mode=TwoWay,UpdateSourceTrigger=PropertyChanged }"/>
                                        <ComboBox helper:ItemsControlHelper.EnumValuesToItemsSource="True" IsEditable="True" Height="30" Width="280" hc:InfoElement.TitleWidth="100" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="HSO3控制权" Style="{StaticResource ComboBoxExtend}"
                                                SelectedItem="{Binding ModelParam.HSO3,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="读取HSO3控制权" Height="30" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="180"
                                                Text="{Binding ModelParam.ReadHSOControlPower[3] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    </UniformGrid>

                                    <StackPanel Orientation="Horizontal" Margin="0 10 0 0" HorizontalAlignment="Right">
                                        <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}" Height="30"
                                                    Content="设置控制权" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="设置控制权"/>

                                        <Button Margin="0,0,15,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="读取控制权" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="读取控制权"/>

                                        <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                                    Content="设置GPO控制权" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="设置GPO控制权"/>
                                    </StackPanel>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Grid.Row="0" Grid.Column="2" FontSize="12" Height="250" Header="单次输出测试">
                                <StackPanel Orientation="Vertical">
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="硬件通道选择" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140"
                                            Text="{Binding ModelParam.OnceHardChannel ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="位置比较索引" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140"
                                            Text="{Binding ModelParam.OncePSOIndex ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="脉宽" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140"
                                            Text="{Binding ModelParam.OncePulseWidth ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
                                        <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}" Height="30"
                                        Content="单次输出" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="单次输出"/>
                                    </StackPanel>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Grid.Row="1" Grid.Column="0" FontSize="12" Height="250" Header="位置比较输出">
                                <StackPanel Orientation="Vertical">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <UniformGrid Columns="2">
                                                <ComboBox IsEditable="True" Width="280" hc:InfoElement.TitleWidth="140" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="位置比较索引" Style="{StaticResource ComboBoxExtend}" 
                                                        SelectedItem="{Binding ModelParam.PosComparisonParam.PSOIndex,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                                                    <ComboBox.ItemsSource>
                                                        <x:Array Type="{x:Type sys:String}">
                                                            <sys:String>1</sys:String>
                                                            <sys:String>2</sys:String>
                                                            <sys:String>3</sys:String>
                                                            <sys:String>4</sys:String>
                                                            <sys:String>5</sys:String>
                                                            <sys:String>6</sys:String>
                                                            <sys:String>7</sys:String>
                                                            <sys:String>8</sys:String>
                                                        </x:Array>
                                                    </ComboBox.ItemsSource>
                                                </ComboBox>
                                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="二维误差带(pulse)" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="180"
                                                        Text="{Binding ModelParam.PosComparisonParam.CompareErrBand ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <ComboBox IsEditable="True" Width="280" hc:InfoElement.TitleWidth="140" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="比较输出模式" Style="{StaticResource ComboBoxExtend}"
                                                        helper:ItemsControlHelper.EnumValuesToItemsSource="True" SelectedItem="{Binding ModelParam.PosComparisonParam.CompareMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="PSO输出间隔(pulse)" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="200"
                                                        Text="{Binding ModelParam.PosComparisonParam.SyncPos ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <ComboBox IsEditable="True" Width="280" hc:InfoElement.TitleWidth="140" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="位置比较维数" Style="{StaticResource ComboBoxExtend}" 
                                                        helper:ItemsControlHelper.EnumValuesToItemsSource="True" SelectedItem="{Binding ModelParam.PosComparisonParam.CompareDimension,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="比较源" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140"
                                                        Text="{Binding ModelParam.PosComparisonParam.SourceMode ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="X方向轴号" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140" Width="280"
                                                        Text="{Binding ModelParam.PosComparisonParam.Compare_X ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="Y方向轴号" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140"
                                                        Text="{Binding ModelParam.PosComparisonParam.Compare_Y ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                                <ComboBox IsEditable="True" Width="280" hc:InfoElement.TitleWidth="140" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="输出模式" Style="{StaticResource ComboBoxExtend}" 
                                                        helper:ItemsControlHelper.EnumValuesToItemsSource="True" SelectedItem="{Binding ModelParam.PosComparisonParam.CompareOutputMode,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                                <TextBox hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="脉冲宽度(us)" Style="{StaticResource TextBoxExtend}" hc:InfoElement.TitleWidth="140"
                                                        Text="{Binding ModelParam.PosComparisonParam.ComparePulseWidth ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>

                                            </UniformGrid>
                                            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="5" HorizontalAlignment="Center">
                                                <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}" Height="30"
                                        Content="开启DMA" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="开启DMA" Margin="0 0 5 0"/>
                                                <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                        Content="关闭DMA" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="关闭DMA" Margin="0 0 5 0"/>
                                                <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                        Content="测试Y" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="测试Y" Margin="0 0 5 0"/>
                                                <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                        Content="测试X" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="测试X" Margin="0 0 5 0"/>
                                                <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                        Content="锁存编码器位置" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="锁存编码器位置" Margin="0 0 5 0"/>
                                                <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                        Content="绝对位置输出测试" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="绝对位置输出测试" Margin="0 0 5 0"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
                                        <Button Margin="0,0,5,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}" Height="30"
                                        Content="开启位置比较输出" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="开启位置比较输出"/>

                                        <Button Margin="0,0,5,0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                        Content="关闭位置比较输出" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="关闭位置比较输出"/>

                                        <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                        Content="清除数据" Cursor="Hand" Command="{Binding PSOCommand}" CommandParameter="清除数据"/>
                                    </StackPanel>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Grid.Row="1" Grid.Column="2" FontSize="12" Header="状态监控">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Foreground="Black" VerticalAlignment="Center" FontSize="12" HorizontalAlignment="Left">
                                        <Run Text="开启状态:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[0] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="FIFO剩余空间:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[1] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="输出次数:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[2] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="数据段号:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[3] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="输出模式:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[4] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="S:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[5] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="fifoEmpty:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[6] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="commandReceive:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[7] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="commandSend:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[7] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="posX:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[7] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="posY:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[7] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                        <LineBreak/>
                                        <Run Text="SendCount:"/>
                                        <Run Text="{Binding ModelParam.PSOOutputStatus[7] ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                    </TextBlock>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>
                        </Grid>
                    </StackPanel>
                </TabItem>

                <TabItem Header="捕获功能" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid>

                    </Grid>
                </TabItem>

                <TabItem Header="补偿功能" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid>

                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
        <GridSplitter Background="{DynamicResource BtnOverColor}" Grid.Row="1" Height="3" Width="auto" HorizontalAlignment="Stretch"/>
        <Grid Grid.Row="2">
            <WxGroupBox:WxGroupBox FontSize="12" Header="轴状态" >
                <DataGrid AutoGenerateColumns="False" x:Name="dg" Style="{StaticResource DefaultDataGridStyle}"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ItemsSource="{Binding ModelParam.AllAxisStatus}" 
                                  SelectedItem="{Binding ModelParam.SltAxisStatus,Mode=TwoWay}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  MinHeight="150"
                                  FontSize="12" 
                                  RowHeaderWidth="20"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  IsReadOnly="False" CanUserAddRows="False" >
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDoubleClick">
                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="DoubleClickCachePos"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>

                    <DataGrid.ContextMenu>
                        <ContextMenu IsEnabled="True">
                            <MenuItem Header="获取当前位置" Command="{Binding GeneralCommand}" CommandParameter="获取当前位置" />
                            <MenuItem Header="移动至此位置" Command="{Binding GeneralCommand}" CommandParameter="移动至此位置" />
                            <Separator/>
                            <!-- 分隔线 -->
                            <MenuItem Header="添加新项" Command="{Binding GeneralCommand}" CommandParameter="添加新项" />
                            <MenuItem Header="删除选中项" Command="{Binding GeneralCommand}" CommandParameter="删除选中项" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="轴号" IsReadOnly="True" Width="50" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Width="150" HorizontalAlignment="Center" BorderThickness="0 0 0 1" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                          Text="{Binding Name}" ToolTip="{Binding Name}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="规划位置" IsReadOnly="True" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Width="150" HorizontalAlignment="Center" BorderThickness="0 0 0 1" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                          Text="{Binding PrfPos}" ToolTip="{Binding PrfPos}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="实际位置" IsReadOnly="True" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Width="150" HorizontalAlignment="Center" BorderThickness="0 0 0 1" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                          Text="{Binding RealPos}" ToolTip="{Binding RealPos}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="规划速度" IsReadOnly="true" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Width="150" HorizontalAlignment="Center" BorderThickness="0 0 0 1" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                          Text="{Binding PrfSpeed}" ToolTip="{Binding PrfSpeed}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="实际速度" IsReadOnly="False" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Width="150" HorizontalAlignment="Center" BorderThickness="0 0 0 1" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                          Text="{Binding PrfSpeed}" ToolTip="{Binding PrfSpeed}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="使能" IsReadOnly="False" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" 
                                 IsActive="{Binding Enabled,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="轴报警" IsReadOnly="False" Width="55">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" 
                                 IsActive="{Binding Alarm,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="正限位" IsReadOnly="False" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WxLED:WxLED Width="10" Height="10" BreathingDuration="1"
                                 IsActive="{Binding PLimit,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="负限位" IsReadOnly="False" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" 
                                 IsActive="{Binding NLimit,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="规划器" IsReadOnly="False" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" 
                                        IsActive="{Binding IsPrf,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="到位" IsReadOnly="False" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" 
                                        IsActive="{Binding IsArrival,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="平滑停止" IsReadOnly="False" Width="65">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" 
                                        IsActive="{Binding IsSmoothStop,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="紧急停止" IsReadOnly="False" Width="65">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" 
                                        IsActive="{Binding IsAbruptStop,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="跟随误差超限" IsReadOnly="False" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <WxLED:WxLED Width="10" Height="10" BreathingDuration="1" 
                                        IsActive="{Binding IsFollowError,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="轴运动模式" IsReadOnly="False" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Width="150" HorizontalAlignment="Center" BorderThickness="0 0 0 1" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                          Text="{Binding PrfMode}" ToolTip="{Binding PrfMode}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="操作" IsReadOnly="False" Width="210">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                            Content="清轴状态" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="清轴状态"/>
                                        <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                            Content="清零" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="清零"/>
                                        <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                            Content="上使能" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="上使能"/>
                                        <Button HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Style="{StaticResource GeneralButtonStyle}"
                                            Content="下使能" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="下使能"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                    </DataGrid>
            </WxGroupBox:WxGroupBox>
        </Grid>
    </Grid>
</UserControl>

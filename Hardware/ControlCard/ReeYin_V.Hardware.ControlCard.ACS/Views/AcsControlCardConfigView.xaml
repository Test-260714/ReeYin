<Window x:Class="ReeYin_V.Hardware.ControlCard.ACS.Views.AcsControlCardConfigView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
        mc:Ignorable="d"
        Title="ACS控制卡配置/测试" Width="1360" Height="820" MinWidth="1180" MinHeight="700"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource RegionBackgroundBrush}"
        d:DesignHeight="820" d:DesignWidth="1360">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Generic.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/ReeYin_V.UI;component/Style/Themes/LightTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="AcsCardStyle" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SplitBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="6"/>
                <Setter Property="Padding" Value="12"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="390"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="3" Style="{StaticResource AcsCardStyle}" Margin="0,0,0,10">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ACS配置/调试" FontSize="20" FontWeight="SemiBold" Margin="0,0,14,0"/>
                    <TextBlock Text="{Binding DisplayName}" FontSize="16" VerticalAlignment="Center" Margin="0,0,18,0"/>
                    <TextBlock Text="连接状态" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ConnectionStateText}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" HorizontalAlignment="Right" MaxWidth="560"/>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="110"/>
            </Grid.RowDefinitions>
            <TabControl Grid.Row="0" Style="{StaticResource TabControlStyle}" FontSize="16" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <TabItem Header="连接" Width="100" Style="{DynamicResource SingleTabItemStyle}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12">
                            <Border Style="{StaticResource AcsCardStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="150"/><ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="150"/><ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/><RowDefinition Height="10"/><RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/><RowDefinition Height="Auto"/><RowDefinition Height="14"/><RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="连接方式" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Options.ConnectionModes}" SelectedItem="{Binding Options.ConnectionMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="IP地址" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="0" Grid.Column="4" Text="{Binding Options.RemoteAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="6" Text="使用TCP" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <CheckBox Grid.Row="0" Grid.Column="7" IsChecked="{Binding Options.UseTcp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="以太网端口" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Options.EthernetPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="串口号" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding Options.SerialPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="2" Grid.Column="6" Text="波特率" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="7" Text="{Binding Options.SerialBaudRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="内部超时(ms)" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Options.InternalTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Grid.Row="4" Grid.Column="3" Text="DI/DO数量" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Row="4" Grid.Column="4" Orientation="Horizontal"><TextBox Width="70" Text="{Binding Options.DigitalInputCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/><TextBox Width="70" Margin="8,0,0,0" Text="{Binding Options.DigitalOutputCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                    <TextBlock Grid.Row="4" Grid.Column="6" Text="回零前停止" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Grid.Row="4" Grid.Column="7" helper:ItemsControlHelper.EnumValuesToItemsSource="True" SelectedItem="{Binding Options.HomeBeforeRunStopMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <StackPanel Grid.Row="6" Grid.ColumnSpan="8" Orientation="Horizontal">
                                        <Button Content="初始化连接" Width="100" Height="32" Margin="0,0,8,0" Style="{StaticResource GeneralButtonStyle}" Command="{Binding InitializeCommand}"/>
                                        <Button Content="关闭连接" Width="100" Height="32" Margin="0,0,8,0" Style="{StaticResource GeneralButtonStyle}" Command="{Binding CloseCommand}"/>
                                        <Button Content="刷新状态" Width="100" Height="32" Margin="0,0,8,0" Style="{StaticResource GeneralButtonStyle}" Command="{Binding RefreshStateCommand}"/>
                                        <Button Content="打开Buffer脚本" Width="120" Height="32" Style="{StaticResource GeneralButtonStyle}" Command="{Binding OpenBufferScriptCommand}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="轴控制" Width="110" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="AxisContextBar"
                                Grid.Row="0"
                                Style="{StaticResource AcsCardStyle}">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Margin="12,0,0,0">
                                    <Button Content="刷新状态"
                                            Width="86"
                                            Height="30"
                                            Margin="0,0,8,0"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding RefreshAxisStatusCommand}"/>
                                    <Button Content="打开Buffer脚本"
                                            Width="112"
                                            Height="30"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding OpenBufferScriptCommand}"/>
                                </StackPanel>
                                <WrapPanel VerticalAlignment="Center">
                                    <TextBlock Text="当前轴" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox ItemsSource="{Binding AxisOptions}"
                                              SelectedItem="{Binding SelectedAxis, Mode=TwoWay}"
                                              Width="94"
                                              Height="28"
                                              Margin="0,0,12,0"/>
                                    <TextBlock Text="物理轴" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SelectedAxisConfig.AxisNo, Mode=OneWay}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="名称" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SelectedAxisConfig.NickName, Mode=OneWay}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <CheckBox Content="启用"
                                              IsChecked="{Binding SelectedAxisConfig.IsUsing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,12,0"/>
                                    <TextBlock Text="回零Buffer" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding SelectedAxisHomeBufferNo, Mode=OneWay}" VerticalAlignment="Center"/>
                                </WrapPanel>
                            </DockPanel>
                        </Border>

                        <Grid x:Name="AxisWorkspaceGrid" Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.85*" MinWidth="210"/>
                                <ColumnDefinition Width="1.25*" MinWidth="270"/>
                                <ColumnDefinition Width="0.9*" MinWidth="220"/>
                            </Grid.ColumnDefinitions>

                            <ScrollViewer x:Name="AxisConfigColumn"
                                          Grid.Column="0"
                                          Margin="0,0,8,0"
                                          VerticalScrollBarVisibility="Auto">
                                <Border Style="{StaticResource AcsCardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="86"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="当前轴基础配置" FontWeight="SemiBold"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="物理轴号" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAxisConfig.AxisNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="轴昵称" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SelectedAxisConfig.NickName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>

                                        <CheckBox Grid.Row="6" Grid.ColumnSpan="2" Content="启用该轴" IsChecked="{Binding SelectedAxisConfig.IsUsing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="脉冲当量/mm" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding SelectedAxisConfig.PulseEquivalent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>

                                        <TextBlock Grid.Row="10" Grid.Column="0" Text="原点偏移" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding SelectedAxisConfig.OriginOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>

                                        <TextBlock Grid.Row="12" Grid.Column="0" Text="正/负软限位" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Grid Grid.Row="12" Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding SelectedAxisConfig.SoftLimitPositive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                                            <TextBox Grid.Column="2" Text="{Binding SelectedAxisConfig.SoftLimitNegative, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                                        </Grid>

                                        <TextBlock Grid.Row="14" Grid.Column="0" Text="安全/减速" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Grid Grid.Row="14" Grid.Column="1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="6"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0" Text="{Binding SelectedAxisConfig.SafetyDis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                                            <TextBox Grid.Column="2" Text="{Binding SelectedAxisConfig.DecelerateDis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </ScrollViewer>

                            <ScrollViewer x:Name="AxisSettingsColumn"
                                          Grid.Column="1"
                                          Margin="0,0,8,0"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <Border Style="{StaticResource AcsCardStyle}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <DockPanel Grid.Row="0" LastChildFill="True">
                                                <TextBlock Text="速度参数" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="当前轴 SpeedDict1"
                                                           Foreground="#777777"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                            <DataGrid Grid.Row="2"
                                                      MinHeight="190"
                                                      MaxHeight="240"
                                                      AutoGenerateColumns="False"
                                                      Style="{StaticResource DefaultDataGridStyle}"
                                                      ItemsSource="{Binding SelectedAxisSpeedRows}"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="False"
                                                      RowHeaderWidth="0"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="All"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="速度类型" Binding="{Binding SpeedType}" Width="86"/>
                                                    <DataGridTextColumn Header="描述" Binding="{Binding SpeedDescribe, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="110"/>
                                                    <DataGridTextColumn Header="起始速度" Binding="{Binding StartSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="86"/>
                                                    <DataGridTextColumn Header="最大速度" Binding="{Binding MaxSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="86"/>
                                                    <DataGridTextColumn Header="加减速" Binding="{Binding AccSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="86"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource AcsCardStyle}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="单轴回零 Buffer" FontWeight="SemiBold"/>
                                            <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                                                <TextBlock Text="Buffer" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBox Text="{Binding SelectedAxisHomeBufferNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="64" Height="28" HorizontalContentAlignment="Center" Margin="0,0,10,0"/>
                                                <CheckBox Content="启用" IsChecked="{Binding SelectedAxisHomeBufferEnabled, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Text="超时" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBox Text="{Binding SelectedAxisHomeBufferTimeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="78" Height="28" Margin="0,0,10,0"/>
                                                <Button Content="回零" Width="58" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GoHomeCommand}"/>
                                            </WrapPanel>
                                            <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                                                <CheckBox Content="运行前停止轴" IsChecked="{Binding SelectedAxisStopBeforeHomeBuffer, Mode=TwoWay}" Margin="0,0,14,0"/>
                                                <CheckBox Content="成功后清反馈" IsChecked="{Binding SelectedAxisResetFeedbackAfterHome, Mode=TwoWay}" Margin="0,0,14,0"/>
                                                <TextBlock Text="清零位置" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <TextBox Text="{Binding SelectedAxisHomeResetPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="76" Height="28"/>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource AcsCardStyle}" Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="ACS运动参数" FontWeight="SemiBold"/>
                                            <DataGrid Grid.Row="2"
                                                      MinHeight="120"
                                                      MaxHeight="180"
                                                      AutoGenerateColumns="False"
                                                      Style="{StaticResource DefaultDataGridStyle}"
                                                      ItemsSource="{Binding AxisMotionProfiles}"
                                                      SelectedItem="{Binding SelectedMotionProfile, Mode=TwoWay}"
                                                      CanUserAddRows="False"
                                                      IsReadOnly="True"
                                                      RowHeaderWidth="0"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="All"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="轴" Binding="{Binding Axis}" Width="64"/>
                                                    <DataGridTextColumn Header="速度" Binding="{Binding Velocity}" Width="76"/>
                                                    <DataGridTextColumn Header="加速度" Binding="{Binding Acceleration}" Width="86"/>
                                                    <DataGridTextColumn Header="减速度" Binding="{Binding Deceleration}" Width="86"/>
                                                    <DataGridTextColumn Header="急停减速" Binding="{Binding KillDeceleration}" Width="86"/>
                                                    <DataGridTextColumn Header="Jerk" Binding="{Binding Jerk}" Width="70"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                            <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                                                <Button Content="刷新参数" Width="78" Height="30" Margin="0,0,8,0" Style="{StaticResource GeneralButtonStyle}" Command="{Binding RefreshMotionProfilesCommand}"/>
                                                <Button Content="下发当前轴" Width="88" Height="30" Margin="0,0,8,0" Style="{StaticResource GeneralButtonStyle}" Command="{Binding ApplySelectedMotionProfileCommand}"/>
                                                <Button Content="下发全部轴" Width="88" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding ApplyAllMotionProfilesCommand}"/>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Expander Header="X/Y合并回零（ACS全局）"
                                              IsExpanded="False"
                                              Style="{DynamicResource ExpanderStyle}">
                                        <Border Style="{StaticResource AcsCardStyle}" Margin="0,8,0,0">
                                            <StackPanel>
                                                <WrapPanel VerticalAlignment="Center" Margin="0,0,0,8">
                                                    <CheckBox Content="启用" IsChecked="{Binding Options.XyHomeBuffer.IsEnabled, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="X Buffer" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBox Text="{Binding Options.XyHomeBuffer.XBufferNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58" Height="28" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Y Buffer" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBox Text="{Binding Options.XyHomeBuffer.YBufferNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58" Height="28"/>
                                                </WrapPanel>
                                                <WrapPanel VerticalAlignment="Center" Margin="0,0,0,8">
                                                    <CheckBox Content="运行前停止X/Y" IsChecked="{Binding Options.XyHomeBuffer.StopAxesBeforeRun, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    <TextBlock Text="X ACS轴" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBox Text="{Binding Options.XyHomeBuffer.XPhysicalAxis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58" Height="28" Margin="0,0,10,0"/>
                                                    <TextBlock Text="Y ACS轴" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBox Text="{Binding Options.XyHomeBuffer.YPhysicalAxis, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58" Height="28"/>
                                                </WrapPanel>
                                                <WrapPanel VerticalAlignment="Center">
                                                    <TextBlock Text="超时(ms)" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBox Text="{Binding Options.XyHomeBuffer.Timeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="86" Height="28"/>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </Expander>
                                </StackPanel>
                            </ScrollViewer>

                            <Border x:Name="AxisDebugColumn"
                                    Grid.Column="2"
                                    Style="{StaticResource AcsCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Text="调试操作" FontWeight="SemiBold"/>

                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="使能" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding EnableAxisCommand}"/>
                                        <Button Grid.Column="2" Content="失能" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding DisableAxisCommand}"/>
                                        <Button Grid.Column="4" Content="停止轴" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding StopAxisCommand}"/>
                                    </Grid>

                                    <Grid Grid.Row="4">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="相对距离"/>
                                            <TextBox Text="{Binding RelativeDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="绝对目标"/>
                                            <TextBox Text="{Binding AbsoluteTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Row="2" Grid.Column="0" Content="相对移动" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding MoveRelativeCommand}"/>
                                        <Button Grid.Row="2" Grid.Column="2" Content="绝对移动" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding MoveAbsoluteCommand}"/>
                                    </Grid>

                                    <StackPanel Grid.Row="6">
                                        <TextBlock Text="点动 / 连续移动" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="86"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="步长" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding JogStep, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                                            <TextBlock Grid.Column="3" Text="速度" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <ComboBox Grid.Column="4" ItemsSource="{Binding SpeedTypeOptions}" SelectedItem="{Binding ContinuousMoveSpeedType, Mode=TwoWay}" Height="28"/>
                                        </Grid>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="正向点动" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding JogPositiveCommand}"/>
                                            <Button Grid.Column="2" Content="反向点动" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding JogNegativeCommand}"/>
                                        </Grid>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="按住正向" Height="30" Style="{StaticResource GeneralButtonStyle}">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="PreviewMouseDown">
                                                        <i:InvokeCommandAction Command="{Binding StartPositiveContinuousMoveCommand}"/>
                                                    </i:EventTrigger>
                                                    <i:EventTrigger EventName="PreviewMouseUp">
                                                        <i:InvokeCommandAction Command="{Binding StopContinuousMoveCommand}"/>
                                                    </i:EventTrigger>
                                                    <i:EventTrigger EventName="MouseLeave">
                                                        <i:InvokeCommandAction Command="{Binding StopContinuousMoveCommand}"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Button>
                                            <Button Grid.Column="2" Content="按住反向" Height="30" Style="{StaticResource GeneralButtonStyle}">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="PreviewMouseDown">
                                                        <i:InvokeCommandAction Command="{Binding StartNegativeContinuousMoveCommand}"/>
                                                    </i:EventTrigger>
                                                    <i:EventTrigger EventName="PreviewMouseUp">
                                                        <i:InvokeCommandAction Command="{Binding StopContinuousMoveCommand}"/>
                                                    </i:EventTrigger>
                                                    <i:EventTrigger EventName="MouseLeave">
                                                        <i:InvokeCommandAction Command="{Binding StopContinuousMoveCommand}"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </Button>
                                        </Grid>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="76"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="反馈" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBox Grid.Column="1" Text="{Binding ResetPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="28"/>
                                            <Button Grid.Column="3" Content="反馈清零" Height="30" Style="{StaticResource GeneralButtonStyle}" Command="{Binding ResetFeedbackCommand}"/>
                                        </Grid>
                                    </StackPanel>

                                    <Grid Grid.Row="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <DockPanel Grid.Row="0" LastChildFill="True">
                                            <TextBlock Text="轴状态" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Button DockPanel.Dock="Right" Content="刷新" Width="58" Height="28" Style="{StaticResource GeneralButtonStyle}" Command="{Binding RefreshAxisStatusCommand}"/>
                                        </DockPanel>
                                        <TextBox Grid.Row="2"
                                                 Text="{Binding AxisStatusText, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 FontFamily="Consolas"
                                                 TextWrapping="Wrap"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="IO测试" Width="100" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="320"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource AcsCardStyle}">
                            <StackPanel>
                                <TextBlock Text="选中IO" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                <TextBlock Text="编号"/><TextBox Text="{Binding SelectedIoIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,4,0,10"/>
                                <CheckBox Content="读取输入（取消勾选读取输出）" IsChecked="{Binding SelectedIoIsInput, Mode=TwoWay}" Margin="0,0,0,10"/>
                                <CheckBox Content="输出为ON" IsChecked="{Binding SelectedIoOutputValue, Mode=TwoWay}" Margin="0,0,0,10"/>
                                <Button Content="设置输出" Height="32" Margin="0,0,0,8" Style="{StaticResource GeneralButtonStyle}" Command="{Binding SetOutputCommand}"/>
                                <Button Content="读取选中IO" Height="32" Margin="0,0,0,8" Style="{StaticResource GeneralButtonStyle}" Command="{Binding ReadSelectedIoCommand}"/>
                                <Button Content="刷新输入" Height="32" Margin="0,0,0,8" Style="{StaticResource GeneralButtonStyle}" Command="{Binding RefreshInputsCommand}"/>
                                <Button Content="刷新输出" Height="32" Style="{StaticResource GeneralButtonStyle}" Command="{Binding RefreshOutputsCommand}"/>
                                <TextBlock Text="{Binding IoStatusText}" TextWrapping="Wrap" Margin="0,14,0,0"/>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding InputStatusText, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" Background="White"/>
                            <TextBox Grid.Column="2" Text="{Binding OutputStatusText, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" Background="White"/>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="LCI" Width="90" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="500" MinWidth="420"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*" MinWidth="360"/>
                        </Grid.ColumnDefinitions>
                        <TabControl Grid.Column="0">
                            <TabItem Header="固定距离脉冲" Style="{DynamicResource SingleTabItemStyle}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Border Style="{StaticResource AcsCardStyle}" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="LCI固定距离脉冲（XSEG）" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <TextBlock Text="Buffer编号"/>
                                            <TextBox Text="{Binding Options.LciFixedDistancePulse.BufferNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,4,0,8"/>
                                            <TextBlock Text="运动轴 X / Y"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.AxisX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.AxisY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="脉冲宽度 / 间距"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.PulseWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.Interval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="速度 / 加速度"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.Velocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.Acceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="减速度 / 急停减速"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.Deceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.KillDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="Jerk"/>
                                            <TextBox Text="{Binding Options.LciFixedDistancePulse.Jerk, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,4,0,8" HorizontalAlignment="Left"/>
                                            <TextBlock Text="起始距离 / 结束距离"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.StartDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.EndDistance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <CheckBox Content="输出ConfigOut" IsChecked="{Binding Options.LciFixedDistancePulse.RouteConfigOutput, Mode=TwoWay}" Margin="0,0,0,8"/>
                                            <TextBlock Text="ConfigOut索引 / 代码"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.ConfigOutputIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciFixedDistancePulse.ConfigOutputCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="超时(ms)"/>
                                            <TextBox Text="{Binding Options.LciFixedDistancePulse.Timeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,4,0,8"/>
                                            <TextBlock Text="XSEG点位（每行X,Y）"/>
                                            <TextBox Text="{Binding Options.LciFixedDistancePulse.PointsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="140" Margin="0,4,0,12" AcceptsReturn="True" FontFamily="Consolas" VerticalScrollBarVisibility="Auto"/>
                                            <Button Content="运行LCI脉冲" Height="32" Width="120" HorizontalAlignment="Left" Style="{StaticResource GeneralButtonStyle}" Command="{Binding RunLciFixedDistancePulseXsegCommand}"/>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>
                            <TabItem Header="圆弧分段" Style="{DynamicResource SingleTabItemStyle}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <Border Style="{StaticResource AcsCardStyle}" Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="LCI圆弧分段测试" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                            <TextBlock Text="使用XSEG分段和ARC2/p圆弧指令生成LCI轨迹。" TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#777777"/>
                                            <TextBlock Text="Buffer编号"/>
                                            <TextBox Text="{Binding Options.LciSegmentCircle.BufferNo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,4,0,8"/>
                                            <TextBlock Text="运动轴 X / Y"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciSegmentCircle.AxisX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciSegmentCircle.AxisY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="速度 / 加速度"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciSegmentCircle.Velocity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciSegmentCircle.Acceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="减速度 / 急停减速"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciSegmentCircle.Deceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciSegmentCircle.KillDeceleration, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="Jerk / Gate状态"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciSegmentCircle.Jerk, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciSegmentCircle.GateActiveState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="XSEG起点 X / Y"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciSegmentCircle.StartX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciSegmentCircle.StartY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="圆心 X / Y"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                                <TextBox Text="{Binding Options.LciSegmentCircle.CenterX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciSegmentCircle.CenterY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <TextBlock Text="半径 / 超时(ms)"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                                                <TextBox Text="{Binding Options.LciSegmentCircle.Radius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120" Margin="0,0,8,0"/>
                                                <TextBox Text="{Binding Options.LciSegmentCircle.Timeout, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Height="30" Width="120"/>
                                            </StackPanel>
                                            <Button Content="运行圆弧分段" Height="32" Width="120" HorizontalAlignment="Left" Style="{StaticResource GeneralButtonStyle}" Command="{Binding RunLciSegmentCircleCommand}"/>
                                        </StackPanel>
                                    </Border>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="120"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0" Text="{Binding LciFixedDistancePulseStatusText, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="White"/>
                            <TextBox Grid.Row="2" Text="{Binding LciFixedDistancePulseScript, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="White"/>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
            <TextBox Grid.Row="1" Text="{Binding OperationLog, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Margin="0,10,0,0" Background="White"/>
        </Grid>

        <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource AcsCardStyle}">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Left" Text="状态监控" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right"><TextBox Text="{Binding Monitor.RefreshIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="60" Height="28" HorizontalContentAlignment="Center" Margin="0,0,6,0"/><CheckBox Content="自动" IsChecked="{Binding Monitor.IsAutoRefreshEnabled, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0"/><Button Content="刷新" Width="60" Height="28" Style="{StaticResource GeneralButtonStyle}" Command="{Binding Monitor.RefreshMonitorCommand}"/></StackPanel>
                </DockPanel>
                <UniformGrid Grid.Row="1" Columns="2" Margin="0,0,0,10">
                    <Border Style="{StaticResource AcsCardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="连接状态" Foreground="#777777"/><TextBlock Text="{Binding Monitor.ConnectionStateText}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel></Border>
                    <Border Style="{StaticResource AcsCardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="控制器状态" Foreground="#777777"/><TextBlock Text="{Binding Monitor.ControllerStateText}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel></Border>
                    <Border Style="{StaticResource AcsCardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="轴数量" Foreground="#777777"/><TextBlock Text="{Binding Monitor.AxisCount}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel></Border>
                    <Border Style="{StaticResource AcsCardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="最后刷新" Foreground="#777777"/><TextBlock Text="{Binding Monitor.LastRefreshText}" FontSize="18" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel></Border>
                </UniformGrid>
                <DataGrid Grid.Row="2" AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}" ItemsSource="{Binding Monitor.AxisRows}" CanUserAddRows="False" IsReadOnly="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" RowHeaderWidth="0" SelectionUnit="FullRow" HeadersVisibility="Column" GridLinesVisibility="All">
                    <DataGrid.Columns><DataGridTextColumn Header="轴" Binding="{Binding AxisName, Mode=OneWay}" Width="55"/><DataGridTextColumn Header="状态" Binding="{Binding StateText, Mode=OneWay}" Width="80"/><DataGridTextColumn Header="当前位置" Binding="{Binding CurrentPositionText, Mode=OneWay}" Width="92"/><DataGridTextColumn Header="速度" Binding="{Binding SpeedText, Mode=OneWay}" Width="78"/><DataGridTextColumn Header="使能" Binding="{Binding IsEnabledText, Mode=OneWay}" Width="58"/><DataGridTextColumn Header="运动中" Binding="{Binding IsMovingText, Mode=OneWay}" Width="68"/><DataGridTextColumn Header="消息" Binding="{Binding Message, Mode=OneWay}" Width="*"/></DataGrid.Columns>
                </DataGrid>
                <Border Grid.Row="3" Background="#F8F9FA" BorderBrush="{DynamicResource SplitBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,10,0,0"><TextBox Text="{Binding Monitor.StatusText, Mode=OneWay}" IsReadOnly="True" BorderThickness="0" Background="Transparent" TextWrapping="Wrap" MinHeight="42" VerticalScrollBarVisibility="Auto"/></Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#F8F9FA" BorderBrush="{DynamicResource SplitBrush}" BorderThickness="0,1,0,0" Padding="12" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="连接" Width="90" Height="32" Margin="0,0,8,0" Style="{StaticResource GeneralButtonStyle}" Command="{Binding ConnectCommand}"/><Button Content="关闭" Width="90" Height="32" Style="{StaticResource GeneralButtonStyle}" Click="CloseButton_Click"/></StackPanel>
        </Border>
    </Grid>
</Window>

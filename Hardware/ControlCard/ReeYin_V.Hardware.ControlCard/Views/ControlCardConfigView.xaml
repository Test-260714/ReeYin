<UserControl x:Class="ReeYin_V.Hardware.ControlCard.Views.ControlCardConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ReeYin_V.Hardware.ControlCard.Views"
             mc:Ignorable="d"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             FontSize="14"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="880" d:DesignWidth="1280">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--顶部标题栏-->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="控制卡配置" FontSize="18" FontWeight="SemiBold" Foreground="#222222"/>
                    <TextBlock Text="/" Margin="10,0" Foreground="#CCCCCC" FontSize="16"/>
                    <TextBlock Text="设备管理" FontSize="16" Foreground="#666666"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="操作：" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#666666" FontWeight="Medium"/>
                    <Button Name="btnLogin" IsEnabled="{Binding IsEnabled}" Style="{StaticResource GeneralButtonStyle}"
                            Width="36" Height="32" FontSize="16"
                            Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                            FontFamily="{StaticResource Iconfont}"
                            Content="&#xe645;" ToolTip="导入配置" Cursor="Hand"
                            Command="{Binding GeneralCommand}" CommandParameter="ImportConfig"
                            Margin="0,0,8,0"/>
                    <Button IsEnabled="{Binding IsEnabled}" Style="{StaticResource GeneralButtonStyle}"
                            Width="36" Height="32" FontSize="16"
                            Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                            FontFamily="{StaticResource Iconfont}"
                            Content="&#xe646;" ToolTip="导出配置" Cursor="Hand"
                            Command="{Binding GeneralCommand}" CommandParameter="ExportConfig"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--主体-->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.35*" MinWidth="300"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="0.65*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!--左侧面板-->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!--操作区卡片-->
                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                            <Grid>
                                <TextBlock Text="添加设备" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="&#xe630;" Width="30" Height="28" FontSize="14"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                                            FontFamily="{StaticResource Iconfont}"
                                            ToolTip="添加" Cursor="Hand"
                                            Command="{Binding DataOperateCommand}" CommandParameter="Add"
                                            Margin="0,0,6,0"/>
                                    <Button Content="&#xe74b;" Width="30" Height="28" FontSize="14"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#F44336" Foreground="White" BorderBrush="#F44336"
                                            FontFamily="{StaticResource Iconfont}"
                                            ToolTip="删除" Cursor="Hand"
                                            Command="{Binding DataOperateCommand}" CommandParameter="Del"
                                            Margin="0,0,6,0"/>
                                    <Button Content="&#xe621;" Width="30" Height="28" FontSize="14"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                                            FontFamily="{StaticResource Iconfont}"
                                            ToolTip="修改" Cursor="Hand"
                                            Command="{Binding DataOperateCommand}" CommandParameter="Modify"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1" Margin="15,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="轴卡品牌" VerticalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,10,0"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" Height="28" VerticalContentAlignment="Center"
                                      ItemsSource="{Binding VenderTypes}" SelectedItem="{Binding ModelParam.SltVendorType, Mode=TwoWay}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="轴卡类型" VerticalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12" Margin="0,0,10,0"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" Height="28" VerticalContentAlignment="Center"
                                      ItemsSource="{Binding CardTypes}" SelectedItem="{Binding ModelParam.SltCardName, Mode=TwoWay}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!--控制卡列表卡片-->
                <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                            <TextBlock Text="控制卡列表" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </Border>

                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                  EnableColumnVirtualization="True" SelectedIndex="0"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ItemsSource="{Binding ModelParam.CardModels, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  SelectedItem="{Binding ModelParam.CurSltCard}"
                                  FontSize="12"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  RowHeaderWidth="0"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  IsReadOnly="False" CanUserAddRows="False">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="MouseDoubleClick">
                                    <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="打开调试面板"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="品牌" IsReadOnly="False" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                     Text="{Binding VenderName, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="轴卡类型" IsReadOnly="False" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                     Text="{Binding CardType, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="自定义名称" IsReadOnly="True" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="False" HorizontalContentAlignment="Center"
                                                     Text="{Binding NickName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="状态" IsReadOnly="False" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <WxLED:WxLED Width="20" Height="20" HorizontalAlignment="Center" IsActive="{Binding IsConnected, UpdateSourceTrigger=PropertyChanged}" IsBreathing="True"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,6">
                            <TextBlock Foreground="#888888" FontSize="11" VerticalAlignment="Center">
                                <Run Text="双击打开调试面板  |  设备数量："/>
                                <Run Text="{Binding ModelParam.CardModels.Count, FallbackValue=0, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!--分隔符-->
            <GridSplitter Grid.Column="1" Width="6" Background="Transparent"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Cursor="SizeWE"/>

            <!--右侧面板：TabControl-->
            <TabControl Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Style="{DynamicResource TabControlStyle}"
                        IsEnabled="{Binding ModelParam.IsCurSltCardIsNotNull, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

                <!--基础配置Tab-->
                <TabItem Header="基础配置" Width="100" FontSize="20" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!--轴列表卡片-->
                        <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                                    <TextBlock Text="轴列表" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                          EnableColumnVirtualization="True"
                                          EnableRowVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          ItemsSource="{Binding ModelParam.CurSltCard.Config.AllAxis}"
                                          SelectedItem="{Binding ModelParam.SltAxis}"
                                          FontSize="12"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          RowHeaderWidth="0"
                                          SelectionUnit="FullRow"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="All"
                                          IsReadOnly="False" CanUserAddRows="False">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="编辑参数"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu IsEnabled="True">
                                            <MenuItem Header="预留" Command="{Binding GeneralCommand}" CommandParameter="预留"/>
                                            <Separator/>
                                            <MenuItem Header="添加新项" Command="{Binding GeneralCommand}" CommandParameter="添加新项"/>
                                            <MenuItem Header="删除选中项" Command="{Binding GeneralCommand}" CommandParameter="删除选中项"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="轴ID" IsReadOnly="False" Width="Auto">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="120" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0" Margin="5,0"
                                                              Background="Transparent" HorizontalContentAlignment="Center"
                                                              SelectedItem="{Binding AxisNum, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="轴号" IsReadOnly="False" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox HorizontalAlignment="Stretch" Background="Transparent" IsReadOnly="False" BorderThickness="0" HorizontalContentAlignment="Center"
                                                             Text="{Binding AxisNo, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="轴名称" IsReadOnly="True" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox HorizontalAlignment="Stretch" Background="Transparent" IsReadOnly="False" BorderThickness="0" HorizontalContentAlignment="Center"
                                                             Text="{Binding NickName, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox HorizontalAlignment="Stretch" Background="Transparent" IsReadOnly="False" BorderThickness="0" HorizontalContentAlignment="Center"
                                                             Text="{Binding Describe, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="启用" IsReadOnly="False" Width="55">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsUsing, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="编辑" IsReadOnly="False" Width="70">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ToggleButton Content="编辑" FontSize="12" Height="24" HorizontalAlignment="Stretch" BorderThickness="0"
                                                                  IsChecked="{Binding IsOpen, ElementName=DrawerRight}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <!--轴状态卡片-->
                        <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                                    <TextBlock Text="轴状态" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                </Border>

                                <UniformGrid Grid.Row="1" Columns="8" Rows="4" Margin="8,5">
                                    <TextBlock Text="使能" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12"/>
                                    <TextBlock Text="原点" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12"/>
                                    <TextBlock Text="正限位" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12"/>
                                    <TextBlock Text="负限位" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12"/>
                                    <TextBlock Text="报警" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12"/>
                                    <TextBlock Text="急停" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12"/>
                                    <TextBlock Text="回零完成" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12"/>
                                    <TextBlock Text="运动中" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#555555" FontWeight="Medium" FontSize="12"/>
                                    <WxLED:WxLED Width="20" Height="20" Margin="8" BreathingDuration="1"
                                                 IsActive="{Binding ModelParam.SltAxis.IsEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsBreathing="True"/>
                                    <WxLED:WxLED Width="20" Height="20" Margin="8"
                                                 IsActive="{Binding ModelParam.SltAxis.IsOrigin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsBreathing="True"/>
                                    <WxLED:WxLED Width="20" Height="20" Margin="8"
                                                 IsActive="{Binding ModelParam.SltAxis.IsPositiveLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsBreathing="True"/>
                                    <WxLED:WxLED Width="20" Height="20" Margin="8"
                                                 IsActive="{Binding ModelParam.SltAxis.IsNegativeLimit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsBreathing="True"/>
                                    <WxLED:WxLED Width="20" Height="20" Margin="8"
                                                 IsActive="{Binding ModelParam.SltAxis.IsAlarm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsBreathing="{Binding IsBreathingEnabled}"/>
                                    <WxLED:WxLED Width="20" Height="20" Margin="8"
                                                 IsActive="{Binding ModelParam.SltAxis.IsEStop, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsBreathing="{Binding IsBreathingEnabled}"/>
                                    <WxLED:WxLED Width="20" Height="20" Margin="8"
                                                 IsActive="{Binding ModelParam.SltAxis.IsResetCompleted, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsBreathing="{Binding IsBreathingEnabled}"/>
                                    <WxLED:WxLED Width="20" Height="20" Margin="8"
                                                 IsActive="{Binding ModelParam.SltAxis.IsMoving, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsBreathing="{Binding IsBreathingEnabled}"/>
                                </UniformGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!--插补配置Tab-->
                <TabItem Header="插补配置" Width="100" FontSize="20" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid Margin="5">
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="插补坐标系" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="  支持2~5轴，自定义选择参与轴，且同时仅允许一个坐标系启用" Foreground="#D6EAF8" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="新增" Width="60" Height="26" FontSize="12"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                                                    Cursor="Hand"
                                                    Command="{Binding GeneralCommand}" CommandParameter="添加插补坐标系"
                                                    Margin="0,0,6,0"/>
                                            <Button Content="删除" Width="60" Height="26" FontSize="12"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Background="#F44336" Foreground="White" BorderBrush="#F44336"
                                                    Cursor="Hand"
                                                    Command="{Binding GeneralCommand}" CommandParameter="删除选中插补坐标系"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                          EnableColumnVirtualization="True"
                                          EnableRowVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          ItemsSource="{Binding ModelParam.CurSltCard.Config.InterpolationCoordinateSystems}"
                                          SelectedItem="{Binding ModelParam.SltInterPoCoordinateSystem}"
                                          FontSize="12"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          RowHeaderWidth="0"
                                          SelectionUnit="FullRow"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="All"
                                          IsReadOnly="False" CanUserAddRows="False">
                                    <DataGrid.ContextMenu>
                                        <ContextMenu IsEnabled="True">
                                            <MenuItem Header="添加插补坐标系" Command="{Binding GeneralCommand}" CommandParameter="添加插补坐标系"/>
                                            <MenuItem Header="删除选中插补坐标系" Command="{Binding GeneralCommand}" CommandParameter="删除选中插补坐标系"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="启用" IsReadOnly="False" Width="55">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsUsing, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              ToolTip="当前只允许一个插补坐标系生效"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="坐标系名称" IsReadOnly="True" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                             Text="{Binding Name, Mode=OneWay}" Padding="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="轴数量" IsReadOnly="False" Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="70" Height="25" BorderThickness="0" Margin="5,0"
                                                              Background="Transparent" HorizontalContentAlignment="Center"
                                                              ItemsSource="{Binding AxisCountOptions}"
                                                              SelectedItem="{Binding AxisCount, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="轴1" IsReadOnly="False" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="100" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0" Margin="5,0"
                                                              Background="Transparent" HorizontalContentAlignment="Center"
                                                              SelectedItem="{Binding Axis1, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="轴2" IsReadOnly="False" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="100" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0" Margin="5,0"
                                                              Background="Transparent" HorizontalContentAlignment="Center"
                                                              SelectedItem="{Binding Axis2, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="轴3" IsReadOnly="False" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="100" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0" Margin="5,0"
                                                              Background="Transparent" HorizontalContentAlignment="Center"
                                                              IsEnabled="{Binding IsAxis3Enabled}"
                                                              SelectedItem="{Binding Axis3, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="轴4" IsReadOnly="False" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="100" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0" Margin="5,0"
                                                              Background="Transparent" HorizontalContentAlignment="Center"
                                                              IsEnabled="{Binding IsAxis4Enabled}"
                                                              SelectedItem="{Binding Axis4, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="轴5" IsReadOnly="False" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="100" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0" Margin="5,0"
                                                              Background="Transparent" HorizontalContentAlignment="Center"
                                                              IsEnabled="{Binding IsAxis5Enabled}"
                                                              SelectedItem="{Binding Axis5, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="参与轴" IsReadOnly="True" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                             Text="{Binding InterPoAxisDescription, Mode=OneWay}" Padding="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="脉冲当量/mm" IsReadOnly="False" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <hc:NumericUpDown Maximum="1000000" Minimum="0" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0,0,0,1"
                                                                      Value="{Binding PulseEquivalent, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="起始速度(mm/s)" IsReadOnly="False" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <hc:NumericUpDown Maximum="100000" Minimum="0" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0,0,0,1"
                                                                      Value="{Binding StartSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="合成最大速度(mm/s)" IsReadOnly="False" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <hc:NumericUpDown Maximum="100000" Minimum="0" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0,0,0,1"
                                                                      Value="{Binding MaxSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="加速度(mm/s²)" IsReadOnly="False" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <hc:NumericUpDown Maximum="100000" Minimum="0" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0,0,0,1"
                                                                      Value="{Binding AccSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="终点速度(mm/s)" IsReadOnly="False" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <hc:NumericUpDown Maximum="100000" Minimum="0" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0,0,0,1"
                                                                      Value="{Binding EndSpeed, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,6">
                                    <TextBlock Text="右键或顶部按钮可新增/删除插补坐标系；保存时会校验轴数范围、轴是否重复以及是否仅启用一个坐标系" Foreground="#888888" FontSize="11"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!--限位配置Tab-->
                <TabItem Header="限位配置" Width="100" FontSize="20" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid Margin="5">
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6,6,0,0" Padding="12,8">
                                    <Grid>
                                        <TextBlock Text="限位列表" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="请谨慎修改此项" Foreground="#FFCDD2" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <DataGrid Grid.Row="1"
                                          AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                                          EnableColumnVirtualization="True"
                                          EnableRowVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          ItemsSource="{Binding ModelParam.AllLimitPos, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedItem="{Binding ModelParam.SltLimitPos}"
                                          FontSize="8"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          RowHeaderWidth="0"
                                          SelectionUnit="FullRow"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="All"
                                          IsReadOnly="False" CanUserAddRows="False">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="MouseDoubleClick">
                                            <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="编辑参数"/>
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                    <DataGrid.ContextMenu>
                                        <ContextMenu IsEnabled="True">
                                            <MenuItem Header="预留" Command="{Binding GeneralCommand}" CommandParameter="预留"/>
                                            <Separator/>
                                            <MenuItem Header="添加新项" Command="{Binding GeneralCommand}" CommandParameter="添加限位"/>
                                            <MenuItem Header="删除选中项" Command="{Binding GeneralCommand}" CommandParameter="删除选中限位"/>
                                        </ContextMenu>
                                    </DataGrid.ContextMenu>
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="被限制轴ID" IsReadOnly="False" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="120" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0" Margin="5,0"
                                                              Background="Transparent" HorizontalContentAlignment="Center"
                                                              SelectedItem="{Binding LimitAxisNum, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="条件" IsReadOnly="False" Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox HorizontalAlignment="Center" helper:ItemsControlHelper.EnumValuesToItemsSource="True"
                                                              Background="Transparent" IsReadOnly="False" BorderThickness="0" Width="90" HorizontalContentAlignment="Center"
                                                              SelectedItem="{Binding TriggerCondition, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="最小坐标(mm)" IsReadOnly="False" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox HorizontalAlignment="Stretch" Background="Transparent" IsReadOnly="False" BorderThickness="0" HorizontalContentAlignment="Center"
                                                             Text="{Binding MinLimitValue, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTemplateColumn Header="条件轴ID" IsReadOnly="False" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox Width="120" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0" Margin="5,0"
                                                              Background="Transparent" HorizontalContentAlignment="Center"
                                                              SelectedItem="{Binding ByLimitAxisNum, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="条件值(mm)" IsReadOnly="False" Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox HorizontalAlignment="Stretch" Background="Transparent" IsReadOnly="False" BorderThickness="0" HorizontalContentAlignment="Center"
                     Text="{Binding LimitValue, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="最大坐标(mm)" IsReadOnly="False" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox HorizontalAlignment="Stretch" Background="Transparent" IsReadOnly="False" BorderThickness="0" HorizontalContentAlignment="Center"
                                                             Text="{Binding MaxLimitValue, UpdateSourceTrigger=PropertyChanged}" Padding="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="运动区域" IsReadOnly="True" Width="150">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                             Text="{Binding LimitRangeDescription, Mode=OneWay}" Padding="5,0"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="启用" IsReadOnly="False" Width="55">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsUsing, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,6">
                                    <TextBlock Text="右键菜单可添加/删除限位项" Foreground="#888888" FontSize="11"/>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!--其他设置Tab-->
                <TabItem Header="其他" Width="100" FontSize="20" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid Margin="5">
                        <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                                    <TextBlock Text="其他设置" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="18" VerticalAlignment="Top">
                                    <CheckBox Content="软件启动自动复位"
                                              IsChecked="{Binding ModelParam.IsAutoResetOnStartup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              FontSize="15"
                                              VerticalAlignment="Center"/>
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="自动复位超时：" VerticalAlignment="Center" Foreground="#444444"/>
                                        <hc:NumericUpDown Grid.Column="1"
                                                          Minimum="1"
                                                          Maximum="3600"
                                                          Value="{Binding ModelParam.StartupAutoResetTimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalContentAlignment="Center"
                                                          Style="{StaticResource NumericUpDownPlus}"
                                                          Margin="8,0"/>
                                        <TextBlock Grid.Column="2" Text="秒" VerticalAlignment="Center" Foreground="#666666"/>
                                    </Grid>
                                    <TextBlock Text="启用后，软件启动并完成控制卡初始化后，会对当前选中的控制卡自动执行一次复位。"
                                               Margin="0,14,0,0"
                                               Foreground="#666666"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="如果复位超过设定时间，页面提示会自动退出，避免界面长期不可操作。"
                                               Margin="0,4,0,0"
                                               Foreground="#666666"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="修改后请点击底部保存按钮写入配置；为避免升级后自动动轴，默认不启用。"
                                               Margin="0,4,0,0"
                                               Foreground="#999999"
                                               TextWrapping="Wrap"/>
                                    <Border Margin="0,22,0,0" Padding="14" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock Text="AxisView IO方向控制"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#333333"/>
                                            <CheckBox Content="启用 AxisView IO方向控制"
                                                      IsChecked="{Binding ModelParam.IsAxisViewIoJogEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      FontSize="14"
                                                      Margin="0,12,0,0"
                                                      VerticalAlignment="Center"/>
                                            <UniformGrid Columns="2" Margin="0,14,0,0">
                                                <Grid Margin="0,0,18,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="160"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="向上输入 IO：" VerticalAlignment="Center" Foreground="#444444"/>
                                                    <hc:NumericUpDown Grid.Column="1"
                                                                      Minimum="0"
                                                                      Maximum="1024"
                                                                      Value="{Binding ModelParam.AxisViewIoJogUpInputPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalContentAlignment="Center"
                                                                      Style="{StaticResource NumericUpDownPlus}"
                                                                      Margin="8,0,0,0"/>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="160"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="向下输入 IO：" VerticalAlignment="Center" Foreground="#444444"/>
                                                    <hc:NumericUpDown Grid.Column="1"
                                                                      Minimum="0"
                                                                      Maximum="1024"
                                                                      Value="{Binding ModelParam.AxisViewIoJogDownInputPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalContentAlignment="Center"
                                                                      Style="{StaticResource NumericUpDownPlus}"
                                                                      Margin="8,0,0,0"/>
                                                </Grid>
                                                <Grid Margin="0,0,18,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="160"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="向左输入 IO：" VerticalAlignment="Center" Foreground="#444444"/>
                                                    <hc:NumericUpDown Grid.Column="1"
                                                                      Minimum="0"
                                                                      Maximum="1024"
                                                                      Value="{Binding ModelParam.AxisViewIoJogLeftInputPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalContentAlignment="Center"
                                                                      Style="{StaticResource NumericUpDownPlus}"
                                                                      Margin="8,0,0,0"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="160"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="向右输入 IO：" VerticalAlignment="Center" Foreground="#444444"/>
                                                    <hc:NumericUpDown Grid.Column="1"
                                                                      Minimum="0"
                                                                      Maximum="1024"
                                                                      Value="{Binding ModelParam.AxisViewIoJogRightInputPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      HorizontalContentAlignment="Center"
                                                                      Style="{StaticResource NumericUpDownPlus}"
                                                                      Margin="8,0,0,0"/>
                                                </Grid>
                                            </UniformGrid>
                                            <TextBlock Text="仅在运动轴操作面板打开时生效。按住输入 IO 连续移动，松开后停止；默认 IO3/IO4/IO5/IO6 对应 Y+/Y-/X-/X+；多方向同时触发会停止当前运动。"
                                                       Margin="0,10,0,0"
                                                       Foreground="#666666"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!--底部操作栏-->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="就绪" Foreground="#666666" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  " Foreground="#CCCCCC" Margin="10,0"/>
                    <TextBlock Foreground="#666666" FontSize="13" VerticalAlignment="Center">
                        <Run Text="控制卡数量："/>
                        <Run Text="{Binding ModelParam.CardModels.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GeneralButtonStyle}"
                            Height="34" Width="110" FontSize="14"
                            Content="IO操作面板" Cursor="Hand"
                            Background="White" Foreground="#666666" BorderBrush="#CCCCCC"
                            Command="{Binding GeneralCommand}" CommandParameter="IO操作面板"
                            Margin="0,0,10,0"/>
                    <Button Style="{StaticResource GeneralButtonStyle}"
                            Height="34" Width="130" FontSize="14"
                            Content="运动轴操作面板" Cursor="Hand"
                            Background="White" Foreground="#666666" BorderBrush="#CCCCCC"
                            Command="{Binding GeneralCommand}" CommandParameter="运动轴操作面板"
                            Margin="0,0,10,0"/>
                    <Button Style="{StaticResource GeneralButtonStyle}"
                            Height="36" Width="100" FontSize="14"
                            Content="保存" Cursor="Hand"
                            Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                            Command="{Binding GeneralCommand}" CommandParameter="保存"/>
                </StackPanel>
            </Grid>
        </Border>

        <!--打开参数页面-->
        <hc:Drawer Name="DrawerRight" MaskCanClose="True" IsOpen="{Binding IsOpen, Mode=TwoWay}" Margin="10">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="Closed">
                    <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="单轴参数设置关闭"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="Loaded">
                    <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="单轴参数设置打开"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Border Background="{DynamicResource RegionBrush}" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" Margin="10,10,30,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Margin="10,0,0,0" Style="{StaticResource TextBlockTitle}" HorizontalAlignment="Left">
                        <Run Text="{Binding ModelParam.SltAxis.NickName}"/>
                        <Run Text="参数设置"/>
                    </TextBlock>
                    <hc:PropertyGrid Grid.Row="1" Width="600" SelectedObject="{Binding ModelParam.SltAxis}" PreviewMouseWheel="PropertyGrid_PreviewMouseWheel"/>
                    <Expander Grid.Row="2" Header="速度设置" Margin="10" IsExpanded="True">
                        <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}" HorizontalAlignment="Center" VerticalAlignment="Top"
                                  EnableColumnVirtualization="True" BorderBrush="Transparent"
                                  EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                                  ItemsSource="{Binding ModelParam.SltAxis.SpeedDict1}" SelectedItem="{Binding CurSltCard}"
                                  FontSize="12" ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Height="260" Width="600" RowHeaderWidth="20"
                                  SelectionUnit="FullRow" HeadersVisibility="Column" GridLinesVisibility="All"
                                  IsReadOnly="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="速度类型" IsReadOnly="False" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                     Text="{Binding SpeedDescribe, UpdateSourceTrigger=PropertyChanged}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="起始速度(mm/s)" IsReadOnly="False" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:NumericUpDown Maximum="200" Minimum="1" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0,0,0,1"
                                                              Value="{Binding StartSpeed, UpdateSourceTrigger=PropertyChanged}" ToolTip="轴运动的起始速度"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="最大速度(mm/s)" IsReadOnly="False" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:NumericUpDown Maximum="400" Minimum="1" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0,0,0,1"
                                                              Value="{Binding MaxSpeed, UpdateSourceTrigger=PropertyChanged}" ToolTip="轴运动的最大速度"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="加速(mm/s²)" IsReadOnly="True" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:NumericUpDown Maximum="400" Minimum="1" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0,0,0,1"
                                                              Value="{Binding AccSpeed, UpdateSourceTrigger=PropertyChanged}" ToolTip="轴运动的加速度"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Center"
                                                     Text="{Binding Describe, UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>
                </Grid>
            </Border>
        </hc:Drawer>

    </Grid>
</UserControl>

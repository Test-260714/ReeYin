<UserControl x:Class="ReeYin_V.Hardware.ControlCard.Views.CoordinateCacheView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin_V.Hardware.ControlCard.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             Height="620" Width="880"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="620" d:DesignWidth="880">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Border CornerRadius="0" Padding="0" VerticalAlignment="Stretch" HorizontalAlignment="Center">
            <TabControl Width="880" Height="610" Style="{DynamicResource TabControlStyle}">
                <TabItem Header="缓存坐标"  Style="{DynamicResource SingleTabItemStyle}" Width="auto">
                    <Grid>
                        <StackPanel>
                            <DataGrid AutoGenerateColumns="False" x:Name="dg" Style="{StaticResource DefaultDataGridStyle}"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="False"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ItemsSource="{Binding ModelParam.AllPosInfo}" 
                                  SelectedItem="{Binding ModelParam.SltPosInfo,Mode=TwoWay}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  Height="450"
                                  FontSize="12" 
                                  RowHeaderWidth="20"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  IsReadOnly="False" CanUserAddRows="False" >
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseDoubleClick">
                                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="DoubleClickCachePos"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                
                                <DataGrid.ContextMenu>
                                    <ContextMenu IsEnabled="True">
                                        <MenuItem Header="获取当前位置" Command="{Binding GeneralCommand}" CommandParameter="获取当前位置" />
                                        <MenuItem Header="移动至此位置" Command="{Binding GeneralCommand}" CommandParameter="移动至此位置" />
                                        <Separator/>
                                        <!-- 分隔线 -->
                                        <MenuItem Header="添加新项" Command="{Binding GeneralCommand}" CommandParameter="添加新项" />
                                        <MenuItem Header="删除选中项" Command="{Binding GeneralCommand}" CommandParameter="删除选中项" />
                                    </ContextMenu>
                                </DataGrid.ContextMenu>

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="序号" IsReadOnly="True" Width="50" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"
                                                            Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}">
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="名称" IsReadOnly="True" Width="150">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Width="150" HorizontalAlignment="Center" BorderThickness="0 0 0 1" Background="Transparent" IsReadOnly="false" HorizontalContentAlignment="Center"
                                                          Text="{Binding Name,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Name}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="X(mm)" IsReadOnly="True" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:NumericUpDown Maximum="{Binding PLimitPos[0]}" Minimum="{Binding NLimitPos[0]}" DecimalPlaces="4" Style="{StaticResource NumericUpDownPlus}" Increment="0.1" HorizontalContentAlignment="Center"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding TargetPos[0],Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Y(mm)" IsReadOnly="true" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:NumericUpDown Maximum="{Binding PLimitPos[1]}" Minimum="{Binding NLimitPos[1]}" DecimalPlaces="4" Style="{StaticResource NumericUpDownPlus}" Increment="0.1" HorizontalContentAlignment="Center"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding TargetPos[1],Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Z(mm)" IsReadOnly="False" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:NumericUpDown Maximum="{Binding PLimitPos[2]}" Minimum="{Binding NLimitPos[2]}" DecimalPlaces="4" Style="{StaticResource NumericUpDownPlus}" Increment="0.1" HorizontalContentAlignment="Center"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding TargetPos[2],Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Z1(mm)" IsReadOnly="False" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:NumericUpDown Maximum="{Binding PLimitPos[3]}" Minimum="{Binding NLimitPos[3]}" DecimalPlaces="4" Style="{StaticResource NumericUpDownPlus}" Increment="0.1" HorizontalContentAlignment="Center"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding TargetPos[3],Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Z2(mm)" IsReadOnly="False" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <hc:NumericUpDown Maximum="{Binding PLimitPos[4]}" Minimum="{Binding NLimitPos[4]}" DecimalPlaces="4" Style="{StaticResource NumericUpDownPlus}" Increment="0.1" HorizontalContentAlignment="Center"
                                      BorderThickness="0 0 0 1" BorderBrush="{DynamicResource PrimaryBrush}" Value="{Binding TargetPos[4],Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Orientation="Horizontal" Margin="5 2">
                                <TextBlock Text="Tips：右击进行操作" Width="auto" Height="30" FontSize="18" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Background="Transparent"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="其他" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid>
                        <StackPanel>
                            <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                              EnableColumnVirtualization="True"
                              EnableRowVirtualization="False"
                              VirtualizingPanel.IsVirtualizing="True"
                              ItemsSource="{Binding InputParams}" 
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              Height="450"
                              FontSize="12" 
                              RowHeaderWidth="20"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              IsReadOnly="False" CanUserAddRows="False" >
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="MouseDoubleClick">
                                        <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="DoubleClickLastNode"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="序号" IsReadOnly="True" Width="100" >
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock  HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"
                                                            Text="{Binding RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type DataGridRow}}, Path=Header}">

                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="参数名称" IsReadOnly="True" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Name}" ToolTip="{Binding Name}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent" IsReadOnly="True"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="数据类型" IsReadOnly="True" Width="auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox Width="130" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 2" Margin="5 0" Background="Transparent" HorizontalContentAlignment="Center" IsReadOnly="True"
                                                    SelectedItem="{Binding Type,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="值" IsReadOnly="true" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Value,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Value}" IsReadOnly="True" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBox Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}" HorizontalAlignment="Center" BorderThickness="0" Background="Transparent"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>

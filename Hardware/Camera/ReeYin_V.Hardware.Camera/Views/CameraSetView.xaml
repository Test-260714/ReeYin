<UserControl
    x:Class="ReeYin_V.Hardware.Camera.Views.CameraSetView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ReeYin_V.Hardware.Camera.Views"
    xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
    xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
    xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:prism="http://prismlibrary.com/"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d" FontSize="14"
    x:Name="window"
    Height="780" Width="1200"
    d:DesignHeight="780" d:DesignWidth="1200">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!--顶部标题栏-->
        <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="15,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="相机配置" FontSize="18" FontWeight="SemiBold" Foreground="#222222"/>
                <TextBlock Text="/" Margin="10,0" Foreground="#CCCCCC" FontSize="16"/>
                <TextBlock Text="设备管理" FontSize="16" Foreground="#666666"/>
            </StackPanel>
        </Border>

        <!--主体-->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="350"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="350"/>
            </Grid.ColumnDefinitions>

            <!--左侧-->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.5*" MinHeight="200"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!--相机列表卡片-->
                <Border Grid.Row="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!--标题栏-->
                        <Border Grid.Row="0" Background="{DynamicResource BtnCheckedColor}" CornerRadius="6,6,0,0" Padding="12,8">
                            <Grid>
                                <TextBlock Text="相机列表" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="&#xe630;" Width="30" Height="28" FontSize="14"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#4CAF50" Foreground="White" BorderBrush="#4CAF50"
                                            FontFamily="{StaticResource Iconfont}"
                                            ToolTip="添加" Cursor="Hand"
                                            Command="{Binding DataOperateCommand}" CommandParameter="Add"
                                            Margin="0,0,6,0"/>
                                    <Button Content="&#xe74b;" Width="30" Height="28" FontSize="14"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#F44336" Foreground="White" BorderBrush="#F44336"
                                            FontFamily="{StaticResource Iconfont}"
                                            ToolTip="删除" Cursor="Hand"
                                            Command="{Binding DataOperateCommand}" CommandParameter="Delete"
                                            Margin="0,0,6,0"/>
                                    <Button Content="&#xe621;" Width="30" Height="28" FontSize="14"
                                            Style="{StaticResource GeneralButtonStyle}"
                                            Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                                            FontFamily="{StaticResource Iconfont}"
                                            ToolTip="修改" Cursor="Hand"
                                            Command="{Binding DataOperateCommand}" CommandParameter="Modify"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--选择表单-->
                        <Border Grid.Row="1" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="相机类型" Foreground="#555555" FontWeight="Medium" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox Height="26" FontSize="12" VerticalContentAlignment="Center" x:Name="cmbCameraType"
                                              ItemsSource="{Binding CameraTypes}" SelectedItem="{Binding ModelParam.SelectedCameraType}">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="SelectionChanged">
                                                <i:InvokeCommandAction Command="{Binding CameraTypesChangedCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ComboBox}}"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="相机序号" Foreground="#555555" FontWeight="Medium" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox Height="26" FontSize="12" VerticalContentAlignment="Center" x:Name="cmbCameraNo"
                                              DisplayMemberPath="SerialNO" SelectedValuePath="SerialNO"
                                              ItemsSource="{Binding ModelParam.CameraNos, Mode=TwoWay}"
                                              SelectedItem="{Binding ModelParam.CameraNo, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!--DataGrid-->
                        <DataGrid Grid.Row="2" AutoGenerateColumns="False" x:Name="dg" Style="{StaticResource DefaultDataGridStyle}"
                                  EnableColumnVirtualization="True"
                                  EnableRowVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  ItemsSource="{Binding ModelParam.CameraModels}"
                                  SelectedItem="{Binding SelectedCameraModel, Mode=TwoWay}"
                                  SelectedIndex="{Binding SelectedIndex}"
                                  RowHeaderWidth="0"
                                  SelectionUnit="FullRow"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="All"
                                  FontSize="12"
                                  IsReadOnly="True" CanUserAddRows="False">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="SelectedCellsChanged">
                                    <i:InvokeCommandAction Command="{Binding SelectedCellsChanged}"/>
                                </i:EventTrigger>
                                <i:EventTrigger EventName="MouseDoubleClick">
                                    <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="配置"/>
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="名称" IsReadOnly="True" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CameraNo, UpdateSourceTrigger=PropertyChanged}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="序列号" IsReadOnly="True" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding SerialNo}" Foreground="#888888"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="备注" IsReadOnly="True" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Remarks}"
                                                       HorizontalAlignment="Left" VerticalAlignment="Center" Padding="5,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="类型" IsReadOnly="True" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="面阵"/>
                                                        <Setter Property="Foreground" Value="#2196F3"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsLineScan}" Value="True">
                                                                <Setter Property="Text" Value="线扫"/>
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="状态" IsReadOnly="True" Width="55">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="16" Height="16" CornerRadius="8" HorizontalAlignment="Center"
                                                    Background="{Binding Connected, Mode=TwoWay, Converter={StaticResource Bool2ColorConverter}}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!--底部状态-->
                        <Border Grid.Row="3" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12,6">
                            <TextBlock Foreground="#888888" FontSize="11" VerticalAlignment="Center">
                                <Run Text="双击配置  |  相机数量："/>
                                <Run Text="{Binding ModelParam.CameraModels.Count, FallbackValue=0, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>
                    </Grid>
                </Border>

                <!--相机参数卡片-->
                <Border Grid.Row="2" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6,6,0,0" Padding="12,8">
                            <TextBlock Text="相机参数" Foreground="White" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid Margin="15,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="当前相机" Foreground="#555555" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBox Grid.Row="0" Grid.Column="1" Height="28" VerticalContentAlignment="Center" Padding="8,0"
                                         BorderBrush="#CCCCCC" BorderThickness="1"
                                         Text="{Binding SelectedCameraModel.CameraNo, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="相机类型" Foreground="#555555" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="面阵"/>
                                            <Setter Property="Foreground" Value="#2196F3"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCameraModel.IsLineScan}" Value="True">
                                                    <Setter Property="Text" Value="线扫"/>
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedCameraModel}" Value="{x:Null}">
                                                    <Setter Property="Text" Value="—"/>
                                                    <Setter Property="Foreground" Value="#888888"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="触发模式" Foreground="#555555" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <ComboBox Grid.Row="4" Grid.Column="1" Height="28" VerticalContentAlignment="Center"
                                          SelectedItem="{Binding SelectedCameraModel.TrigMode}"
                                          ItemsSource="{Binding SelectedCameraModel.TrigModes}"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="曝光" Foreground="#555555" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <WxNumericUpDown:WxNumericUpDown Grid.Row="6" Grid.Column="1" Minimum="0" Maximum="99999999" SmallChange="1" Height="28"
                                                                 Value="{Binding SelectedCameraModel.Config.ExposeTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="8" Grid.Column="0" Text="增益" Foreground="#555555" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <WxNumericUpDown:WxNumericUpDown Grid.Row="8" Grid.Column="1" Minimum="0" Maximum="99999999" SmallChange="1" Height="28"
                                                                 Value="{Binding SelectedCameraModel.Config.Gain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                <!-- 线扫拼帧行数（仅线扫相机显示） -->
                                <TextBlock Grid.Row="10" Grid.Column="0" Text="拼帧行数" Foreground="#555555" FontWeight="Medium" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCameraModel.IsLineScan}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Grid.Row="10" Grid.Column="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCameraModel.IsLineScan}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <WxNumericUpDown:WxNumericUpDown Minimum="1" Maximum="99999999" SmallChange="100" Height="28"
                                        Value="{Binding SelectedCameraModel.Config.LineScanFrameHeight, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!--相机操作卡片-->
                <Border Grid.Row="4" Background="White" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}" CornerRadius="6,6,0,0" Padding="12,6">
                            <TextBlock Text="相机操作" Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Row="1" Margin="10,8" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="连接" Margin="0,0,8,0" Height="30" Width="75" FontSize="13"
                                    Command="{Binding ButtonOperateCommand}" CommandParameter="Connect">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GeneralButtonStyle}">
                                        <Setter Property="Background" Value="#4CAF50"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#4CAF50"/>
                                        <Setter Property="IsEnabled" Value="True"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedCameraModel.Connected}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="断开" Margin="0,0,8,0" Height="30" Width="75" FontSize="13"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Background="White" Foreground="#666666" BorderBrush="#CCCCCC"
                                    IsEnabled="{Binding SelectedCameraModel.Connected}"
                                    Command="{Binding ButtonOperateCommand}" CommandParameter="Disconnect"/>
                            <Button Content="单次采集" Margin="0,0,8,0" Height="30" Width="80" FontSize="13"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                                    IsEnabled="{Binding SelectedCameraModel.Connected}"
                                    Command="{Binding ButtonOperateCommand}" CommandParameter="SingleAcq"/>
                            <Button Content="连续采集" Margin="0,0,8,0" Height="30" Width="80" FontSize="13"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Background="#FF9800" Foreground="White" BorderBrush="#FF9800"
                                    IsEnabled="{Binding SelectedCameraModel.Connected}"
                                    Command="{Binding ButtonOperateCommand}" CommandParameter="ContinuousAcq"/>
                            <Button Content="应用参数" Height="30" Width="80" FontSize="13"
                                    Style="{StaticResource GeneralButtonStyle}"
                                    Background="#9C27B0" Foreground="White" BorderBrush="#9C27B0"
                                    IsEnabled="{Binding SelectedCameraModel.Connected}"
                                    Command="{Binding ApplyParamsCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!--分隔符-->
            <GridSplitter Grid.Column="1" Width="6" Background="Transparent"
                          HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Cursor="SizeWE"/>

            <!--右侧：图像预览-->
            <Controls:ImageEditView Grid.Column="2"
                                     Image="{Binding Image, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PreserveViewOnImageChange="True"
                                     VerticalAlignment="Stretch"
                                     Background="{StaticResource BackgroudBrush}"/>
        </Grid>

        <!--底部操作栏-->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="就绪" Foreground="#666666" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  " Foreground="#CCCCCC" Margin="10,0"/>
                    <TextBlock Foreground="#666666" FontSize="13" VerticalAlignment="Center">
                        <Run Text="相机数量："/>
                        <Run Text="{Binding ModelParam.CameraModels.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource GeneralButtonStyle}"
                            Height="34" Width="90" FontSize="14"
                            Content="取消" Cursor="Hand"
                            Background="White" Foreground="#666666" BorderBrush="#CCCCCC"
                            Command="{Binding GeneralCommand}" CommandParameter="取消"
                            Margin="0,0,10,0"/>
                    <Button Style="{StaticResource GeneralButtonStyle}"
                            Height="36" Width="100" FontSize="14"
                            Content="确认" Cursor="Hand"
                            Background="#2196F3" Foreground="White" BorderBrush="#2196F3"
                            Command="{Binding GeneralCommand}" CommandParameter="确认"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

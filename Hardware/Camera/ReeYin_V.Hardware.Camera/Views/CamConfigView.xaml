<UserControl x:Class="ReeYin_V.Hardware.Camera.Views.CamConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin_V.Hardware.Camera.Views"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
        prism:ViewModelLocator.AutoWireViewModel="True"
        xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
        xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
        mc:Ignorable="d" FontSize="14"
        Height="550" Width="400">
    <Grid>
        <Border CornerRadius="0" Padding="0" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" Margin="10">
            <TabControl Style="{DynamicResource TabControlStyle}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <TabItem Header="基本设置"  Style="{DynamicResource SingleTabItemStyle}" Width="auto">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="线扫参数" Margin="0,5,0,10" FontWeight="Bold"/>

                            <hc:NumericUpDown hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="行频(Hz)：" Style="{StaticResource NumericUpDownExtendGlobal}" hc:InfoElement.TitleWidth="140" BorderThickness="0 0 0 1"
                                                  Value="{Binding Model.LineRate,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" Minimum="0" Maximum="100000">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="ValueChanged">
                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="行频"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </hc:NumericUpDown>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="其他配置" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid>
                        <StackPanel>

                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>


                                            <hc:NumericUpDown Width="260" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="Y最小值：" hc:InfoElement.TitleWidth="120" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.RangeUYmin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="260" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="Y最大值：" hc:InfoElement.TitleWidth="120" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.RangeUYmax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="260" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="Z最小值：" hc:InfoElement.TitleWidth="120" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.RangeUZmin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="260" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="Z最大值：" hc:InfoElement.TitleWidth="120" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.RangeUZmax, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </WrapPanel>
                                    </StackPanel>
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 用户RT矩阵" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                    <StackPanel Margin="24,0,0,0">
                                        <CheckBox Margin="8,0,8,8" Content="启用用户RT矩阵" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <WrapPanel Orientation="Horizontal" IsEnabled="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixEnabled}">
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="R00：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixR00, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="R01：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixR01, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="R02：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixR02, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="R10：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixR10, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="R11：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixR11, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="R12：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixR12, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="R20：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixR20, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="R21：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixR21, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="R22：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixR22, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="T0：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixT0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="T1：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixT1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <hc:NumericUpDown Width="220" Margin="8" DecimalPlaces="4" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="T2：" hc:InfoElement.TitleWidth="70" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserRTMatrixT2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>

        <GridSplitter Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource BtnOverColor}" />

        <Border Grid.Row="0" Grid.Column="2" Margin="0,10,10,10" Padding="5" Background="White" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="4">
            <TabControl Width="Auto" Height="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Style="{DynamicResource TabControlStyle}">
                <TabItem Header="2D图像" Width="110" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                    <WxGroupBox:WxGroupBox Header="2D图显示">
                        <Controls:ImageEditView Image="{Binding DisposeImage}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" MinHeight="300" MinWidth="300"/>
                    </WxGroupBox:WxGroupBox>
                </TabItem>
                <TabItem Header="3D图像" Width="110" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                    <WxGroupBox:WxGroupBox Header="3D图显示">
                        <Chart:GrayAndHeightChartView HorizontalAlignment="Stretch" VerticalAlignment="Stretch" DisplayResult="{Binding HeightDisplayResult}" MinHeight="300" MinWidth="300"/>
                    </WxGroupBox:WxGroupBox>
                </TabItem>
            </TabControl>
        </Border>

        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,10">
            <Button Width="100" Height="32" Margin="0,0,10,0" Content="确认" Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="确认" />
            <Button Width="100" Height="32" Content="取消" Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="取消" />
        </StackPanel>
    </Grid>
</UserControl>

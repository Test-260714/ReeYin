<UserControl x:Class="ReeYin.Hardware.Sensor.MEGAPHASE.Views.MegAphaseSensorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:Chart="clr-namespace:ReeYin_V.UI.UserControls.GrayAndHeightChart;assembly=ReeYin_V.UI"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True"
             FontSize="14"
             d:DesignHeight="980" d:DesignWidth="1280"
             Height="880" Width="1480">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.5*" />
            <ColumnDefinition Width="3" />
            <ColumnDefinition Width="0.5*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Margin="10,10,0,10" Padding="5" Background="White" BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="4">
            <TabControl Width="Auto" Height="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Style="{DynamicResource TabControlStyle}">
                <TabItem Header="设置" Width="110" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <WxGroupBox:WxGroupBox Grid.Row="0" Header="触发控制" Margin="5 5 5 10">
                            <StackPanel Margin="10" Orientation="Vertical" HorizontalAlignment="Left">
                                <Button Width="180" Height="32" Margin="0,0,0,10" Content="开始采集" Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="开始采集" />
                                <Button Width="180" Height="32" Margin="0,0,0,10" Content="结束采集" Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="结束采集" />
                                <Button Width="180" Height="32" Margin="0,0,0,10" Content="发送软件触发" Cursor="Hand" Style="{StaticResource GeneralButtonStyle}" Command="{Binding GeneralCommand}" CommandParameter="发送软件触发" />
                                <Button Width="180" Height="32" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="切换Hold状态">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource GeneralButtonStyle}">
                                            <Setter Property="Content" Value="Click to Run" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ModelParam.MegAphaseSensor.Settings.HoldState}" Value="0">
                                                    <Setter Property="Content" Value="Click to Hold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </WxGroupBox:WxGroupBox>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="5">
                                <WxGroupBox:WxGroupBox Header="基本" Margin="5 5 5 10">
                                <WrapPanel Margin="10" Orientation="Horizontal">
                                    <ComboBox Width="260" Margin="8" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="工作模式：" hc:InfoElement.TitleWidth="110" Style="{StaticResource ComboBoxExtend}" BorderThickness="0 0 0 1" ItemsSource="{Binding WorkingModeItems}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding ModelParam.MegAphaseSensor.Settings.WorkingMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <ComboBox Width="260" Margin="8" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="触发源：" hc:InfoElement.TitleWidth="110" Style="{StaticResource ComboBoxExtend}" BorderThickness="0 0 0 1" ItemsSource="{Binding TriggerSourceItems}" DisplayMemberPath="DisplayName" SelectedValuePath="Value" SelectedValue="{Binding ModelParam.MegAphaseSensor.Settings.TriggerSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <CheckBox Width="260" Margin="8,10,8,8" Content="Binning启用" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.BinningEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                </WrapPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Header="图像区域" Margin="5 5 5 10">
                                <WrapPanel Margin="10" Orientation="Horizontal">
                                    <hc:NumericUpDown Width="260" Margin="8" Minimum="0" Maximum="255" DecimalPlaces="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="起点X：" hc:InfoElement.TitleWidth="110" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ROIX0Ratio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <hc:NumericUpDown Width="260" Margin="8" Minimum="0" Maximum="255" DecimalPlaces="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="起点Y：" hc:InfoElement.TitleWidth="110" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ROIY0Ratio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <hc:NumericUpDown Width="260" Margin="8" Minimum="0" Maximum="255" DecimalPlaces="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="宽度：" hc:InfoElement.TitleWidth="110" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ROIWidthRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <hc:NumericUpDown Width="260" Margin="8" Minimum="0" Maximum="255" DecimalPlaces="0" hc:InfoElement.TitlePlacement="Left" hc:InfoElement.Title="高度：" hc:InfoElement.TitleWidth="110" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ROIHeightRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </WrapPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Header="多头" Margin="5 5 5 10">
                                <StackPanel Margin="10">
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 投影模式" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <WrapPanel Margin="24,0,0,10" Orientation="Horizontal">
                                        <CheckBox Width="140" Margin="8,4" Content="启用投影0" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.Projection0Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Width="140" Margin="8,4" Content="启用投影1" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.Projection1Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Width="140" Margin="8,4" Content="启用投影2" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.Projection2Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Width="140" Margin="8,4" Content="启用投影3" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.Projection3Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </WrapPanel>
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 合并参数" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                    <Grid Margin="24,0,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="阈值：" VerticalAlignment="Center"/>
                                        <hc:NumericUpDown Grid.Row="0" Grid.Column="1" Width="55" Height="30" Minimum="0" Maximum="255" DecimalPlaces="0" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="12,0,0,8">
                                            <Slider Width="300" Minimum="0" Maximum="7" TickFrequency="25" IsSnapToTickEnabled="False" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="←严格                                                   宽松→"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="数量：" VerticalAlignment="Center"/>
                                        <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Width="55" Height="30" Minimum="1" Maximum="4" DecimalPlaces="0" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="12,0,0,8">
                                            <Slider Width="300" Minimum="1" Maximum="4" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="←宽松                                                   严格→" />
                                        </StackPanel>
                                        <CheckBox x:Name="ProfessionalSettingCheckBox" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,8,0,12" Content="专业设置">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ModelParam.MegAphaseSensor.Settings.MergeNumber}" Value="1">
                                                            <Setter Property="IsEnabled" Value="True" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                        <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="IsEnabled" Value="False" />
                                                    <Style.Triggers>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsChecked, ElementName=ProfessionalSettingCheckBox}" Value="True" />
                                                                <Condition Binding="{Binding ModelParam.MegAphaseSensor.Settings.MergeNumber}" Value="1" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="IsEnabled" Value="True" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="0.2*" />
                                                <ColumnDefinition Width="0.2*" />
                                                <ColumnDefinition Width="0.6*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="接近度：" VerticalAlignment="Center" />
                                            <hc:NumericUpDown Grid.Row="0" Grid.Column="1" Width="55" Height="30" Minimum="0" Maximum="255" DecimalPlaces="0" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeParam0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="12,0,0,8">
                                                <Slider Width="300" Minimum="0" Maximum="7" TickFrequency="25" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeParam0, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="←宽松                                                   严格→" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="高度差：" VerticalAlignment="Center"  />
                                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Width="55" Height="30" Minimum="0" Maximum="255" DecimalPlaces="0" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeParam1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="12,0,0,8">
                                                <Slider Width="300" Minimum="0" Maximum="7" TickFrequency="25" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeParam1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="←宽松                                                   严格→" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="条纹清晰：" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Width="55" Height="30" Minimum="0" Maximum="255" DecimalPlaces="0" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeParam2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="12,0,0,8">
                                                <Slider Width="300" Minimum="0" Maximum="7" TickFrequency="25" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeParam2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="←宽松                                                   严格→"/>
                                            </StackPanel>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="编码清晰：" VerticalAlignment="Center"/>
                                            <hc:NumericUpDown Grid.Row="3" Grid.Column="1" Width="55" Height="30" Minimum="0" Maximum="255" DecimalPlaces="0" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeParam3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <StackPanel Grid.Row="3" Grid.Column="2" Margin="12,0,0,0">
                                                <Slider Width="300" Minimum="0" Maximum="7" TickFrequency="25" Value="{Binding ModelParam.MegAphaseSensor.Settings.MergeParam3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="←宽松                                                   严格→"/>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Header="曝光" Margin="5 5 5 10">
                                <StackPanel Margin="10">
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 曝光模式" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                    <StackPanel Margin="24,0,0,10" Orientation="Horizontal">
                                        <RadioButton GroupName="ExposureMode" Margin="8,4" Content="手动模式" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.ExposureModeManualSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <RadioButton GroupName="ExposureMode" Margin="8,4" Content="手动多次平均模式" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.ExposureModeManualRepeatSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <RadioButton GroupName="ExposureMode" Margin="8,4" Content="指定次数自动曝光" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.ExposureModeAutoNHDRSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <RadioButton GroupName="ExposureMode" Margin="8,4" Content="指定质量自动曝光" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.ExposureModeAutoPHDRSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 曝光次数" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                    <StackPanel Margin="24,0,0,10" Orientation="Horizontal">
                                        <RadioButton GroupName="ExposureNumber" Margin="8,4" Content="1次曝光" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.ExposureNumberSingleSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <RadioButton GroupName="ExposureNumber" Margin="8,4" Content="2次曝光" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.ExposureNumberDoubleSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <RadioButton GroupName="ExposureNumber" Margin="8,4" Content="3次曝光" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.ExposureNumberTripleSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 用户增益" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                    <Grid Margin="24,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="用户增益" VerticalAlignment="Center" />
                                        <hc:NumericUpDown Grid.Column="1" Width="100" Height="30" Minimum="0" Maximum="5" DecimalPlaces="0" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserGain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Slider Grid.Column="2" Width="300" Margin="12,0,0,0" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ModelParam.MegAphaseSensor.Settings.UserGain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 3D曝光强度(手动模式)" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                    <Grid Margin="24,0,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="10" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="第1次" VerticalAlignment="Center" />
                                        <hc:NumericUpDown Grid.Row="0" Grid.Column="1" Width="100" Height="30" Minimum="0.1" DecimalPlaces="1" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ExposureIntensity3D_1st, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Slider Grid.Row="0" Grid.Column="2" Width="300" Margin="12,0,0,8" Minimum="0.1" Maximum="100" TickFrequency="0.1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ExposureIntensity3D_1st, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="第2次" VerticalAlignment="Center" />
                                        <hc:NumericUpDown Grid.Row="2" Grid.Column="1" Width="100" Height="30" Minimum="0.1" DecimalPlaces="1" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ExposureIntensity3D_2nd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Slider Grid.Row="2" Grid.Column="2" Width="300" Margin="12,0,0,8" Minimum="0.1" Maximum="100" TickFrequency="0.1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ExposureIntensity3D_2nd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="第3次" VerticalAlignment="Center" />
                                        <hc:NumericUpDown Grid.Row="4" Grid.Column="1" Width="100" Height="30" Minimum="0.1" DecimalPlaces="1" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ExposureIntensity3D_3rd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Slider Grid.Row="4" Grid.Column="2" Width="300" Margin="12,0,0,0" Minimum="0.1" Maximum="100" TickFrequency="0.1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ExposureIntensity3D_3rd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 2D曝光强度" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                    <Grid Margin="24,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="2D" VerticalAlignment="Center" />
                                        <hc:NumericUpDown Grid.Column="1" Width="100" Height="30" Minimum="0.1" DecimalPlaces="1" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.ExposureIntensity2D, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Slider Grid.Column="2" Width="300" Margin="12,0,0,0" Minimum="0.1" Maximum="100" Value="{Binding ModelParam.MegAphaseSensor.Settings.ExposureIntensity2D, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" TickFrequency="0.1"/>
                                    </Grid>
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 自动曝光设置" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                    <Grid Margin="24,0,0,10">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="优先级" VerticalAlignment="Center" />
                                        <hc:NumericUpDown Grid.Row="0" Grid.Column="1" Width="100" Height="30" Minimum="0" Maximum="7" DecimalPlaces="0" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.AutoHDRPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="12,0,0,8">
                                            <Slider Width="300" Minimum="0" Maximum="7" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding ModelParam.MegAphaseSensor.Settings.AutoHDRPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="  ←完整性                                       重复精度→"/>
                                        </StackPanel>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="质量阈值" VerticalAlignment="Center" />
                                        <hc:NumericUpDown Grid.Row="1" Grid.Column="1" Width="100" Height="30" Minimum="0" Maximum="100" DecimalPlaces="0" Style="{StaticResource NumericUpDownExtend}" BorderThickness="0 0 0 1" Value="{Binding ModelParam.MegAphaseSensor.Settings.AutoPHDRQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="12,0,0,0">
                                            <Slider Width="300" Minimum="0" Maximum="100" TickFrequency="5" Value="{Binding ModelParam.MegAphaseSensor.Settings.AutoPHDRQuality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="  ←宽松                                                 严格→" />
                                        </StackPanel>
                                    </Grid>
                                    <Border Background="#BF9000" Padding="6,3" Margin="0,0,0,8">
                                        <TextBlock Text="● 多头曝光差异" FontWeight="SemiBold" Foreground="White" />
                                    </Border>
                                    <StackPanel Margin="24,0,0,0">
                                        <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <RadioButton GroupName="MultiHeadExpoVarMode" Margin="8,4" Content="关闭" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.MultiHeadExpoVarModeCloseSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            <RadioButton GroupName="MultiHeadExpoVarMode" Margin="8,4" Content="01模式" IsChecked="{Binding ModelParam.MegAphaseSensor.Settings.MultiHeadExpoVarMode01Selected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

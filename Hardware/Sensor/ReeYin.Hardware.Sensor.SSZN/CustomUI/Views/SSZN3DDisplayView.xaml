<Window x:Class="ReeYin.Hardware.Sensor.SSZN.CustomUI.Views.SSZN3DDisplayView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:Chart="clr-namespace:ReeYin_V.UI.UserControls.GrayAndHeightChart;assembly=ReeYin_V.UI"
        mc:Ignorable="d"
        Title="3D图像显示" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroudBrush}">
    <Grid>
        <Border Margin="10"
                Background="White"
                BorderBrush="#D9D9D9"
                BorderThickness="1"
                CornerRadius="4">
            <Chart:GrayAndHeightChartView Margin="5"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          DisplayResult="{Binding HeightDisplayResult}" />
        </Border>
    </Grid>
</Window>

<UserControl x:Class="ReeYin.Hardware.Sensor.Views.SensorSetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             FontSize="14"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="980" d:DesignWidth="1280">
    <UserControl.Resources>

    </UserControl.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="0.05*"/>
            <RowDefinition Height="0.9*"/>
            <RowDefinition Height="0.05*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Grid.ColumnSpan="2" Margin="10 0 0 0">
            <Button Name="btnLogin" Margin="5 0 5 0" IsEnabled="{Binding IsEnabled}" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ImportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe645;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导入配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
            <Button IsEnabled="{Binding IsEnabled}" Margin="5 0 5 0" Content="{Binding}" Style="{StaticResource GeneralButtonStyle}" Width="100" Height="30"
                                    Command="{Binding GeneralCommand}" CommandParameter="ExportConfig">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#xe646;" VerticalAlignment="Center" HorizontalAlignment="Center" FontFamily="{StaticResource Iconfont}" />
                            <TextBlock Text="导出配置" TextWrapping="Wrap" FontSize="16" Margin="0,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>

        <!--主体-->
        <Grid Grid.Row="1" HorizontalAlignment="Stretch" Margin="10" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.35*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="0.65*"/>

            </Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <WxGroupBox:WxGroupBox Grid.Row="0" Header="操作" Margin="5 5 5 10">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="5 2">
                            <TextBlock Text="传感器类型:" VerticalAlignment="Center"/>
                            <ComboBox Width="160" ItemsSource="{Binding SensorTypes}" Height="25" BorderThickness="0 0 0 1" Margin="5 0"
                                      SelectedItem="{Binding ModelParam.SltVendorType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                            <Button  Content="&#xe630;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                     FontFamily="{StaticResource Iconfont}" BorderBrush="White" 
                     ToolTip="添加" Command="{Binding DataOperateCommand}" CommandParameter="Add"/>
                            <Button  Content="&#xe74b;"  Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                     FontFamily="{StaticResource Iconfont}" BorderBrush="White" Margin="5 0" 
                     ToolTip="删除" Command="{Binding DataOperateCommand}" CommandParameter="Del"/>
                            <Button  Content="&#xe621;" Width="30" Height="26" FontSize="18" Style="{StaticResource GeneralButtonStyle}"
                     FontFamily="{StaticResource Iconfont}" BorderBrush="White"
                     ToolTip="修改" Command="{Binding DataOperateCommand}" CommandParameter="Modify"/>
                        </StackPanel>

                        
                        <StackPanel Orientation="Horizontal" Margin="5 2" HorizontalAlignment="Center">

                        </StackPanel>

                    </StackPanel>
                </WxGroupBox:WxGroupBox>

                <WxGroupBox:WxGroupBox Grid.Row="1" Header="传感器列表(双击打开调试面板)" Margin="5 5 5 10">
                    <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}"
                          EnableColumnVirtualization="True" SelectedIndex="0"
                          EnableRowVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          ItemsSource="{Binding ModelParam.Models}"
                          SelectedItem="{Binding ModelParam.CurSlt}"
                          FontSize="12"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          RowHeaderWidth="20"
                          SelectionUnit="FullRow"
                          HeadersVisibility="Column"
                          GridLinesVisibility="All"
                          IsReadOnly="False" CanUserAddRows="False">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseDoubleClick">
                                <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="打开调试面板"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="厂家" IsReadOnly="False" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                     Text="{Binding VenderName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Config,UpdateSourceTrigger=PropertyChanged}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="类型" IsReadOnly="False" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox HorizontalAlignment="Stretch" Background="Transparent" IsReadOnly="False" HorizontalContentAlignment="Center" BorderThickness="0 0 0 1"
                                      Text="{Binding VenderType,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding VenderType,UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="自定义名称" IsReadOnly="True" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox HorizontalAlignment="Stretch" Background="Transparent" IsReadOnly="False" HorizontalContentAlignment="Center" BorderThickness="0 0 0 1"
                                      Text="{Binding NickName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Config.DisplayName,UpdateSourceTrigger=PropertyChanged}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="连接状态" IsReadOnly="False" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <WxLED:WxLED Width="25" Height="25" Margin="10" IsActive="{Binding IsConnected,UpdateSourceTrigger=PropertyChanged}" IsBreathing="True"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </WxGroupBox:WxGroupBox>

            </Grid>
            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>
            <StackPanel Orientation="Vertical" Width="auto" Grid.Column="2">
                <Border CornerRadius="0" Padding="5">
                    <TabControl Width="auto" Height="auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Style="{DynamicResource TabControlStyle}" IsEnabled="{Binding ModelParam.IsCurSltCardIsNotNull,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}">
                        <TabItem Header="基础配置" Width="100" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="连接配置" Margin="5 5 5 10">
                                    <StackPanel Orientation="Vertical">
                                        <StackPanel Orientation="Horizontal" Margin="5 2" HorizontalAlignment="Center">
                                            <TextBlock Text="通信类型:" VerticalAlignment="Center" Foreground="Black"/>
                                            <ComboBox Width="160" helper:ItemsControlHelper.EnumValuesToItemsSource="True" Height="25" BorderThickness="0 0 0 1" Margin="5 0" HorizontalContentAlignment="Center"
                                      SelectedItem="{Binding ComType ,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Text="网口:" VerticalAlignment="Center" Foreground="Black"/>
                                            <TextBox Width="120" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5 0" 
                                     Text="{Binding ModelParam.CurSlt.IP,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding VenderName,UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="端口:" VerticalAlignment="Center" Foreground="Black"/>
                                            <TextBox Width="120" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5 0"
                                     Text="{Binding ModelParam.CurSlt.Port,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding VenderName,UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="5 2 0 0 " HorizontalAlignment="Right">
                                            <Button Margin="0,0,15,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="35" Width="60" Style="{StaticResource GeneralButtonStyle}"
                                                     Content="连接" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="连接"/>

                                            <Button Margin="0,0,0,0" FontSize="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Height="35" Width="60" Style="{StaticResource GeneralButtonStyle}"
                                                     Content="断开" Cursor="Hand" Command="{Binding GeneralCommand}" CommandParameter="断开"/>
                                        </StackPanel>
                                    </StackPanel>

                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="状态" Margin="5 5 5 10">

                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </TabItem>




                        <TabItem Header="其他" Width="100" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                            <StackPanel>

                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Border>
            </StackPanel>
        </Grid>

        <!--底部运行状态栏-->
        <Border Grid.Row="2" BorderThickness="0 2 0 0" BorderBrush="{DynamicResource SelectedBrush}" MaxHeight="100" VerticalAlignment="Bottom" >
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical"
                                                        WindowChrome.IsHitTestVisibleInChrome="True" >
                    <TextBlock Margin="10,0,0,0" HorizontalAlignment="Left" FontSize="14" >
                        <!--<Run Text="占位符"/>-->
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Margin="0 10 0 0"
                                                WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Margin="0,0,15,0" FontSize="18" MinHeight="40" Width="80" Content="保存" Cursor="Hand" Style="{StaticResource GeneralButtonStyle}"
                                                    Command="{Binding GeneralCommand}" CommandParameter="保存" />
                </StackPanel>
            </Grid>
        </Border>

        <!--打开参数页面-->
        <hc:Drawer Name="DrawerRight" MaskCanClose="True" IsOpen="{Binding IsOpen,Mode=TwoWay}" Margin="10 10 10 10 ">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="Closed">
                    <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="单轴参数设置关闭"/>
                </i:EventTrigger>
                <i:EventTrigger EventName="Loaded">
                    <i:InvokeCommandAction Command="{Binding GeneralCommand}" CommandParameter="单轴参数设置打开"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Border Background="{DynamicResource RegionBrush}" Width="auto" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}" Margin="10 10 30 10 ">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Margin="10,0,0,0" Style="{StaticResource TextBlockTitle}" HorizontalAlignment="Left">
                        <Run Text="{Binding ModelParam.SltAxis.NickName}"/>
                        <Run Text="参数设置"/>
                    </TextBlock>

                    <hc:PropertyGrid Grid.Row="1" Width="600" Height="auto" SelectedObject="{Binding ModelParam.SltAxis}" PreviewMouseWheel="PropertyGrid_PreviewMouseWheel" />

                    <Expander Grid.Row="2" Header="速度设置" Margin="10 10 10 10 " IsExpanded="True">
                        <DataGrid AutoGenerateColumns="False" Style="{StaticResource DefaultDataGridStyle}" HorizontalAlignment="Center" VerticalAlignment="Top"
                                      EnableColumnVirtualization="True" BorderBrush="Transparent" 
                                      EnableRowVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      ItemsSource="{Binding ModelParam.SltAxis.SpeedDict1}" 
                                      SelectedItem="{Binding CurSltCard}"
                                      FontSize="12" 
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      Height="260" Width="600"
                                      RowHeaderWidth="20"
                                      SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="All"
                                      IsReadOnly="False" CanUserAddRows="False" >
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="速度类型" IsReadOnly="False" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" IsReadOnly="True" HorizontalContentAlignment="Center"
                                                                 Text="{Binding SpeedDescribe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding VenderName,UpdateSourceTrigger=PropertyChanged}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="起始速度(mm/s)" IsReadOnly="False" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:NumericUpDown Maximum="200" Minimum="1" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0 0 0 1"
                                                              Value="{Binding StartSpeed,UpdateSourceTrigger=PropertyChanged}" ToolTip="轴运动的起始速度" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="最大速度(mm/s)" IsReadOnly="False" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:NumericUpDown Maximum="400" Minimum="1" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0 0 0 1"
                                                              Value="{Binding MaxSpeed,UpdateSourceTrigger=PropertyChanged}" ToolTip="轴运动的最大速度" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="加速(mm/s²)" IsReadOnly="True" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <hc:NumericUpDown Maximum="400" Minimum="1" HorizontalAlignment="Stretch" Background="Transparent" HorizontalContentAlignment="Center" BorderThickness="0 0 0 1"
                                                              Value="{Binding AccSpeed,UpdateSourceTrigger=PropertyChanged}" ToolTip="轴运动的加速度" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="备注" IsReadOnly="False" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBox HorizontalAlignment="Stretch" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Center"
                                                                 Text="{Binding Describe,UpdateSourceTrigger=PropertyChanged}" ToolTip="{Binding Describe}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Expander>

                </Grid>
            </Border>
        </hc:Drawer>
    </Grid>
</UserControl>

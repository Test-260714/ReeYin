<UserControl x:Class="ReeYin.Hardware.Sensor.TronSight.CustomUI.Views.TronSightSensorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin.Hardware.Sensor.TronSight.CustomUI.Views"
             mc:Ignorable="d" 
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/" 
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:defines="clr-namespace:ReeYin.Hardware.Sensor.TronSight.CustomUI.Defines"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             FontSize="14"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Height="880" Width="1480"
             d:DesignHeight="880" d:DesignWidth="1480">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="MeasureModeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:MeasureMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="TriggerSamplingModeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:TriggerSamplingMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="SamplingEnableLevelEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:SamplingEnableLevel"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="TriggerFilterWidthEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:TriggerFilterWidth"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="TriggerChannelEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:TriggerChannel"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="TriggerModeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:TriggerMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="TriggerDirectionEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:TriggerDirection"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="TrackingModeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:TrackingMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="EncoderInputModeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:EncoderInputMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="EncoderDecodeModeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:EncoderDecodeMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="CalibrationMethodEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:CalibrationMethod"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="ThicknessCalibrationModeEnum" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="defines:ThicknessCalibrationMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        
        <!-- 转换器 -->
        <defines:BoolInverseConverter x:Key="BoolInverseConverter"/>
        <defines:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <defines:BoolToVisibilityReverseConverter x:Key="BoolToVisibilityReverseConverter"/>
        <defines:CalibrationMethodToVisibilityConverter x:Key="CalibrationMethodToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Left Side: Settings -->
            <Border CornerRadius="0" Padding="5">
                <TabControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Style="{DynamicResource TabControlStyle}">
                        
                    <!-- 1. Basic Settings -->
                    <TabItem Header="基础设置" Width="90" FontSize="14" Style="{DynamicResource SingleTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="5">
                                <!-- 测量模式 -->
                                <WxGroupBox:WxGroupBox Header="测量模式" Margin="3">
                                    <ComboBox ItemsSource="{Binding Source={StaticResource MeasureModeEnum}}"
                                              SelectedItem="{Binding ModelParam.BasicSettings.SelectedMeasureMode}"
                                              Style="{StaticResource ComboBoxExtend}" Margin="5"
                                              Width="250" HorizontalAlignment="Left">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="SelectionChanged">
                                                <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="测量模式"/>
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </ComboBox>
                                </WxGroupBox:WxGroupBox>

                                <!-- 通道使能 -->
                                <WxGroupBox:WxGroupBox Header="通道使能" Margin="3">
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <CheckBox Content="通道1" IsChecked="{Binding ModelParam.BasicSettings.Channel1Enable}" Margin="5" FontSize="14">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="通道使能"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </CheckBox>
                                        <CheckBox Content="通道2" IsChecked="{Binding ModelParam.BasicSettings.Channel2Enable}" Margin="5" FontSize="14">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="通道使能"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </CheckBox>
                                        <CheckBox Content="通道3" IsChecked="{Binding ModelParam.BasicSettings.Channel3Enable}" Margin="5" FontSize="14">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="通道使能"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </CheckBox>
                                        <CheckBox Content="通道4" IsChecked="{Binding ModelParam.BasicSettings.Channel4Enable}" Margin="5" FontSize="14">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="Click">
                                                    <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="通道使能"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </CheckBox>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <!-- 基础参数 -->
                                <WxGroupBox:WxGroupBox Header="基础参数" Margin="3">
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.8*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <hc:NumericUpDown Grid.Row="0" Grid.Column="0" hc:InfoElement.Title="无效数据保持" hc:InfoElement.TitlePlacement="Left"
                                                          Value="{Binding ModelParam.BasicSettings.InvalidDataHold}" Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3"
                                                          Width="200" HorizontalAlignment="Left">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="ValueChanged">
                                                    <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="无效数据保持"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </hc:NumericUpDown>
                                        
                                        <ComboBox Grid.Row="0" Grid.Column="1" hc:InfoElement.Title="采样间隔" hc:InfoElement.TitlePlacement="Left"
                                                  ItemsSource="{Binding ModelParam.BasicSettings.SamplingIntervals}"
                                                  SelectedItem="{Binding ModelParam.BasicSettings.SelectedSamplingInterval}"
                                                  Style="{StaticResource ComboBoxExtend}" Margin="3"
                                                  Width="200" HorizontalAlignment="Left">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="SelectionChanged">
                                                    <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="采样间隔"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </ComboBox>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>

                                <!-- 滤波设置 -->
                                <WxGroupBox:WxGroupBox Header="滤波设置" Margin="3">
                                    <StackPanel Margin="5">
                                        <!-- 滤波器设置 -->
                                        <Grid Margin="0 5 0 5">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <ComboBox Grid.Row="0" hc:InfoElement.Title="滑动平均滤波窗口宽度" hc:InfoElement.TitlePlacement="Left" 
                                                      ItemsSource="{Binding ModelParam.BasicSettings.FilterWindowWidths}"
                                                      SelectedItem="{Binding ModelParam.BasicSettings.MovingAverageWindow}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3" Width="280" HorizontalAlignment="Left">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="滑动平均窗口宽度"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            
                                            <ComboBox Grid.Row="1" hc:InfoElement.Title="中值滤波窗口宽度       " hc:InfoElement.TitlePlacement="Left"
                                                      ItemsSource="{Binding ModelParam.BasicSettings.FilterWindowWidths}"
                                                      SelectedItem="{Binding ModelParam.BasicSettings.MedianWindow}"
                                                      IsEnabled="False" ToolTip="API暂不支持"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3" Width="280" HorizontalAlignment="Left">
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- 2. Trigger Config -->
                    <TabItem Header="触发配置" Width="90" FontSize="14" Style="{DynamicResource SingleTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="5">
                                <!-- 触发配置 -->
                                <WxGroupBox:WxGroupBox Header="触发配置" Margin="3">
                                    <StackPanel Margin="5">
                                        <!-- 第一行：触发采样模式、采样使能电平、单脉冲采样个数、滤波宽度 -->
                                        <Grid Margin="0 0 0 5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" hc:InfoElement.Title="触发采样模式" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource TriggerSamplingModeEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.TriggerSamplingMode}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="触发采样模式"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <ComboBox Grid.Column="1" hc:InfoElement.Title="采样使能电平" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource SamplingEnableLevelEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.SamplingEnableLevel}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="采样使能电平"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <hc:NumericUpDown Grid.Column="2" hc:InfoElement.Title="单脉冲采样个数" hc:InfoElement.TitlePlacement="Top"
                                                              Value="{Binding ModelParam.TriggerConfig.SinglePulseSamplingCount}" Minimum="1" Maximum="65535"
                                                              Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="ValueChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="单脉冲采样个数"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </hc:NumericUpDown>
                                            <ComboBox Grid.Column="3" hc:InfoElement.Title="滤波宽度" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource TriggerFilterWidthEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.TriggerFilterWidth}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="触发滤波宽度"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                        </Grid>
                                        <!-- 第二行：触发通道、触发模式、触发方向、追踪模式、触发间隔 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0" hc:InfoElement.Title="触发通道" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource TriggerChannelEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.TriggerChannel}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="触发通道"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <ComboBox Grid.Column="1" hc:InfoElement.Title="触发模式" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource TriggerModeEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.TriggerMode}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="触发模式"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <ComboBox Grid.Column="2" hc:InfoElement.Title="触发方向" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource TriggerDirectionEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.TriggerDirection}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="触发方向"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <ComboBox Grid.Column="3" hc:InfoElement.Title="追踪模式" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource TrackingModeEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.TrackingMode}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="追踪模式"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <hc:NumericUpDown Grid.Column="4" hc:InfoElement.Title="触发间隔" hc:InfoElement.TitlePlacement="Top"
                                                              Value="{Binding ModelParam.TriggerConfig.TriggerInterval}" Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="ValueChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="触发间隔"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </hc:NumericUpDown>
                                        </Grid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                                
                                <!-- 触发复位 -->
                                <WxGroupBox:WxGroupBox Header="触发复位" Margin="3">
                                    <Button Content="复位" Width="80" Height="30" HorizontalAlignment="Left" Margin="5" Style="{StaticResource GeneralButtonStyle}" 
                                            Command="{Binding GeneralCommand}" CommandParameter="触发复位"/>
                                </WxGroupBox:WxGroupBox>

                                <!-- 编码器1 -->
                                <WxGroupBox:WxGroupBox Header="编码器1" Margin="3">
                                    <StackPanel Margin="5">
                                        <!-- 第一行：使能、输入模式、解码模式、Z相使能 -->
                                        <Grid Margin="0 0 0 5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="3">
                                                <TextBlock Text="使能" VerticalAlignment="Center" Margin="0 0 5 0" Foreground="Black"/>
                                                <ToggleButton IsChecked="{Binding ModelParam.TriggerConfig.Encoder1.IsEnabled}" Style="{StaticResource ToggleButtonSwitch}">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="Checked">
                                                            <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder1_Enable"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="Unchecked">
                                                            <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder1_Enable"/>
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                </ToggleButton>
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" hc:InfoElement.Title="输入模式" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource EncoderInputModeEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.Encoder1.InputMode}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder1_InputMode"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <ComboBox Grid.Column="2" hc:InfoElement.Title="解码模式" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource EncoderDecodeModeEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.Encoder1.DecodeMode}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder1_DecodeMode"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="3">
                                                <TextBlock Text="Z相使能" VerticalAlignment="Center" Margin="0 0 5 0" Foreground="Black"/>
                                                <ToggleButton IsChecked="{Binding ModelParam.TriggerConfig.Encoder1.ZPhaseEnable}" Style="{StaticResource ToggleButtonSwitch}">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="Checked">
                                                            <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder1_ZPhaseEnable"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="Unchecked">
                                                            <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder1_ZPhaseEnable"/>
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                </ToggleButton>
                                            </StackPanel>
                                        </Grid>
                                        <!-- 第二行：脉冲比例系数、手动置位、Z信号置位 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <hc:NumericUpDown Grid.Column="0" hc:InfoElement.Title="脉冲比例系数(mm/pulse)" hc:InfoElement.TitlePlacement="Top" DecimalPlaces="6"
                                                              Value="{Binding ModelParam.TriggerConfig.Encoder1.PulseRatio}" Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="ValueChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder1_PulseRatio"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </hc:NumericUpDown>
                                            <hc:NumericUpDown Grid.Column="1" hc:InfoElement.Title="手动置位(mm)" hc:InfoElement.TitlePlacement="Top" DecimalPlaces="6"
                                                              Value="{Binding ModelParam.TriggerConfig.Encoder1.ManualResetValue}" Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="ValueChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder1_ManualResetValue"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </hc:NumericUpDown>
                                            <hc:NumericUpDown Grid.Column="2" hc:InfoElement.Title="Z信号置位(mm)" hc:InfoElement.TitlePlacement="Top" DecimalPlaces="6"
                                                              Value="{Binding ModelParam.TriggerConfig.Encoder1.ZSignalResetValue}" Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="ValueChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder1_ZSignalResetValue"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </hc:NumericUpDown>
                                        </Grid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <!-- 编码器2 -->
                                <WxGroupBox:WxGroupBox Header="编码器2" Margin="3">
                                    <StackPanel Margin="5">
                                        <!-- 第一行：使能、输入模式、解码模式、Z相使能 -->
                                        <Grid Margin="0 0 0 5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="3">
                                                <TextBlock Text="使能" VerticalAlignment="Center" Margin="0 0 5 0" Foreground="Black"/>
                                                <ToggleButton IsChecked="{Binding ModelParam.TriggerConfig.Encoder2.IsEnabled}" Style="{StaticResource ToggleButtonSwitch}">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="Checked">
                                                            <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder2_Enable"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="Unchecked">
                                                            <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder2_Enable"/>
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                </ToggleButton>
                                            </StackPanel>
                                            <ComboBox Grid.Column="1" hc:InfoElement.Title="输入模式" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource EncoderInputModeEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.Encoder2.InputMode}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder2_InputMode"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <ComboBox Grid.Column="2" hc:InfoElement.Title="解码模式" hc:InfoElement.TitlePlacement="Top"
                                                      ItemsSource="{Binding Source={StaticResource EncoderDecodeModeEnum}}"
                                                      SelectedItem="{Binding ModelParam.TriggerConfig.Encoder2.DecodeMode}"
                                                      Style="{StaticResource ComboBoxExtend}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="SelectionChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder2_DecodeMode"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </ComboBox>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="3">
                                                <TextBlock Text="Z相使能" VerticalAlignment="Center" Margin="0 0 5 0" Foreground="Black"/>
                                                <ToggleButton IsChecked="{Binding ModelParam.TriggerConfig.Encoder2.ZPhaseEnable}" Style="{StaticResource ToggleButtonSwitch}">
                                                    <i:Interaction.Triggers>
                                                        <i:EventTrigger EventName="Checked">
                                                            <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder2_ZPhaseEnable"/>
                                                        </i:EventTrigger>
                                                        <i:EventTrigger EventName="Unchecked">
                                                            <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder2_ZPhaseEnable"/>
                                                        </i:EventTrigger>
                                                    </i:Interaction.Triggers>
                                                </ToggleButton>
                                            </StackPanel>
                                        </Grid>
                                        <!-- 第二行：脉冲比例系数、手动置位、Z信号置位 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <hc:NumericUpDown Grid.Column="0" hc:InfoElement.Title="脉冲比例系数(mm/pulse)" hc:InfoElement.TitlePlacement="Top" DecimalPlaces="6"
                                                              Value="{Binding ModelParam.TriggerConfig.Encoder2.PulseRatio}" Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="ValueChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder2_PulseRatio"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </hc:NumericUpDown>
                                            <hc:NumericUpDown Grid.Column="1" hc:InfoElement.Title="手动置位(mm)" hc:InfoElement.TitlePlacement="Top" DecimalPlaces="6"
                                                              Value="{Binding ModelParam.TriggerConfig.Encoder2.ManualResetValue}" Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="ValueChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder2_ManualResetValue"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </hc:NumericUpDown>
                                            <hc:NumericUpDown Grid.Column="2" hc:InfoElement.Title="Z信号置位(mm)" hc:InfoElement.TitlePlacement="Top" DecimalPlaces="6"
                                                              Value="{Binding ModelParam.TriggerConfig.Encoder2.ZSignalResetValue}" Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3">
                                                <i:Interaction.Triggers>
                                                    <i:EventTrigger EventName="ValueChanged">
                                                        <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="Encoder2_ZSignalResetValue"/>
                                                    </i:EventTrigger>
                                                </i:Interaction.Triggers>
                                            </hc:NumericUpDown>
                                        </Grid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- 3. Multi-Math -->
                    <TabItem Header="多光点运算" Width="100" FontSize="14" Style="{DynamicResource SingleTabItemStyle}">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <WxGroupBox:WxGroupBox Grid.Row="0" Header="说明" Margin="3">
                                <StackPanel Margin="5">
                                    <TextBlock Text="用于配置控制器的 Multi-Math1~4 计算方式和数据源，采集开始前会自动下发到设备。" Foreground="Black" TextWrapping="Wrap"/>
                                    <TextBlock Text="勾选“启用输出”后，该通道结果会追加到控制器输出流中，便于后续采集或联动。" Foreground="Gray" Margin="0 4 0 0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </WxGroupBox:WxGroupBox>

                            <WxGroupBox:WxGroupBox Grid.Row="1" Header="Multi-Math 配置" Margin="3">
                                <DataGrid ItemsSource="{Binding ModelParam.MultiMathConfig.Channels}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="All"
                                          Style="{StaticResource DataGridBaseStyle}"
                                          Margin="3">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="通道" Binding="{Binding DisplayName}" Width="150" IsReadOnly="True"/>

                                        <DataGridTemplateColumn Header="启用输出" Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <CheckBox IsChecked="{Binding IsEnabled, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center">
                                                        <i:Interaction.Triggers>
                                                            <i:EventTrigger EventName="Checked">
                                                                <i:InvokeCommandAction Command="{Binding DataContext.ValueChangedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="MultiMath配置"/>
                                                            </i:EventTrigger>
                                                            <i:EventTrigger EventName="Unchecked">
                                                                <i:InvokeCommandAction Command="{Binding DataContext.ValueChangedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="MultiMath配置"/>
                                                            </i:EventTrigger>
                                                        </i:Interaction.Triggers>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="数据源" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding DataSources}"
                                                              SelectedItem="{Binding SelectedSource, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ComboBoxExtend}"
                                                              Margin="3">
                                                        <i:Interaction.Triggers>
                                                            <i:EventTrigger EventName="DropDownClosed">
                                                                <i:InvokeCommandAction Command="{Binding DataContext.ValueChangedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="MultiMath配置"/>
                                                            </i:EventTrigger>
                                                        </i:Interaction.Triggers>
                                                    </ComboBox>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="计算方式" Width="*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <ComboBox ItemsSource="{Binding CalcModes}"
                                                              SelectedItem="{Binding SelectedMode, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ComboBoxExtend}"
                                                              Margin="3">
                                                        <i:Interaction.Triggers>
                                                            <i:EventTrigger EventName="DropDownClosed">
                                                                <i:InvokeCommandAction Command="{Binding DataContext.ValueChangedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="MultiMath配置"/>
                                                            </i:EventTrigger>
                                                        </i:Interaction.Triggers>
                                                    </ComboBox>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </WxGroupBox:WxGroupBox>
                        </Grid>
                    </TabItem>

                    <!-- 4. Config Settings -->
                    <TabItem Header="配置设置" Width="90" FontSize="14" Style="{DynamicResource SingleTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="5">
                                <WxGroupBox:WxGroupBox Header="设备配置管理" Margin="3">
                                    <StackPanel Margin="5">
                                        <CheckBox Content="固化参数 (选择固化参数后，恢复出厂配置或从文件读取配置并发送到设备，断电重启后依然会生效)" 
                                                  IsChecked="{Binding ModelParam.DeviceConfig.IsSolidifyParams}" Margin="3"/>
                                        <Grid Margin="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="恢复出厂配置" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="恢复出厂配置"/>
                                            <Button Grid.Column="1" Content="保存配置到文件" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="保存配置到文件"/>
                                            <Button Grid.Column="2" Content="从文件读取配置" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="从文件读取配置"/>
                                        </Grid>
                                        <Grid Margin="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" Content="写入配置到Flash" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="写入配置到Flash"/>
                                            <Button Grid.Column="1" Content="从传感器读取配置" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="从传感器读取配置"/>
                                        </Grid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <!-- 5. Calibration Settings (MATH标定) -->
                    <TabItem Header="厚度标定" Width="90" FontSize="14" Style="{DynamicResource SingleTabItemStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="5">
                                <!-- 测量方式 -->
                                <WxGroupBox:WxGroupBox Header="测量方式" Margin="3">
                                    <ComboBox ItemsSource="{Binding Source={StaticResource ThicknessCalibrationModeEnum}}"
                                              SelectedItem="{Binding ModelParam.CalibrationConfig.ThicknessCalibrationMode}"
                                              Style="{StaticResource ComboBoxExtend}" Width="200" Margin="5" HorizontalAlignment="Left"/>
                                </WxGroupBox:WxGroupBox>

                                <!-- 标定方式 -->
                                <WxGroupBox:WxGroupBox Header="标定方式" Margin="3">
                                    <StackPanel Orientation="Horizontal" Margin="5">
                                        <ComboBox ItemsSource="{Binding Source={StaticResource CalibrationMethodEnum}}"
                                                  SelectedItem="{Binding ModelParam.CalibrationConfig.CalibrationMethod}"
                                                  Style="{StaticResource ComboBoxExtend}" Width="120" Margin="3"/>
                                        <hc:NumericUpDown hc:InfoElement.Title="数据平均次数" hc:InfoElement.TitlePlacement="Left" Minimum="1" Maximum="100"
                                                          Value="{Binding ModelParam.CalibrationConfig.AverageCount}" Style="{StaticResource NumericUpDownExtendGlobal}" Width="200" Margin="3"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <!-- 标定值采集 -->
                                <WxGroupBox:WxGroupBox Header="标定值采集" Margin="3">
                                    <StackPanel Margin="5">
                                        <!-- 标定值1 -->
                                        <TextBlock Text="标定值1" FontWeight="Bold" Margin="3" Foreground="Black"/>
                                        <Grid Margin="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="实际值" VerticalAlignment="Center" Width="50" Margin="3" Foreground="Black"/>
                                            <hc:NumericUpDown Grid.Row="0" Grid.Column="1" DecimalPlaces="6"
                                                              Value="{Binding ModelParam.CalibrationConfig.StandardValue}" 
                                                              Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3" Width="150" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="测量值" VerticalAlignment="Center" Width="50" Margin="3" Foreground="Black"/>
                                            <hc:NumericUpDown Grid.Row="1" Grid.Column="1" DecimalPlaces="6" IsReadOnly="True"
                                                              Value="{Binding ModelParam.CalibrationConfig.MeasuredValue}" 
                                                              Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3" Width="150" HorizontalAlignment="Left"/>
                                            <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Content="采集" Width="60" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="采集标定数据1"/>
                                        </Grid>
                                        
                                        <!-- 标定值2（两点标定时显示） -->
                                        <StackPanel Visibility="{Binding ModelParam.CalibrationConfig.CalibrationMethod, Converter={StaticResource CalibrationMethodToVisibilityConverter}}">
                                            <TextBlock Text="标定值2" FontWeight="Bold" Margin="3 10 3 3" Foreground="Black"/>
                                            <Grid Margin="3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="实际值" VerticalAlignment="Center" Width="50" Margin="3" Foreground="Black"/>
                                                <hc:NumericUpDown Grid.Row="0" Grid.Column="1" DecimalPlaces="6"
                                                                  Value="{Binding ModelParam.CalibrationConfig.StandardValue2}" 
                                                                  Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3" Width="150" HorizontalAlignment="Left"/>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="测量值" VerticalAlignment="Center" Width="50" Margin="3" Foreground="Black"/>
                                                <hc:NumericUpDown Grid.Row="1" Grid.Column="1" DecimalPlaces="6" IsReadOnly="True"
                                                                  Value="{Binding ModelParam.CalibrationConfig.MeasuredValue2}" 
                                                                  Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3" Width="150" HorizontalAlignment="Left"/>
                                                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Content="采集" Width="60" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}" 
                                                        Command="{Binding GeneralCommand}" CommandParameter="采集标定数据2"/>
                                            </Grid>
                                        </StackPanel>
                                        
                                        <TextBlock Text="注意：单点标定只需采集一组数据，两点标定需采集两组不同厚度的数据" Foreground="Red" Margin="3 10 3 3" TextWrapping="Wrap"/>
                                        <StackPanel Orientation="Horizontal" Margin="3">
                                            <Button Content="标定" Width="80" Height="30" Style="{StaticResource GeneralButtonStyle}" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="执行标定"/>
                                            <Button Content="取消" Width="80" Height="30" Margin="10 0 0 0" Style="{StaticResource GeneralButtonStyle}" 
                                                    Command="{Binding GeneralCommand}" CommandParameter="取消标定"/>
                                        </StackPanel>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                                
                                <!-- 修正系数 -->
                                <WxGroupBox:WxGroupBox Header="修正系数" Margin="3">
                                    <StackPanel Margin="5">
                                        <TextBlock Text="通过修正系数，修正厚度值 T = k*(CH1*D1 + CH2*D2 + b)" Foreground="Gray" Margin="3"/>
                                        <hc:NumericUpDown hc:InfoElement.Title="修正系数" hc:InfoElement.TitlePlacement="Left" DecimalPlaces="3" Minimum="0" Maximum="10"
                                                          Value="{Binding ModelParam.CalibrationConfig.CorrectionFactor}" 
                                                          Style="{StaticResource NumericUpDownExtendGlobal}" Margin="3" Width="200" HorizontalAlignment="Left">
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="ValueChanged">
                                                    <i:InvokeCommandAction Command="{Binding ValueChangedCommand}" CommandParameter="CorrectionFactor"/>
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </hc:NumericUpDown>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    
                    <!-- 6. Refractive Index -->
                    <TabItem Header="折射率" Width="90" FontSize="14" Style="{DynamicResource SingleTabItemStyle}">
                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- 模式选择 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="3">
                                <RadioButton Content="折射率表修改" IsChecked="{Binding ModelParam.RefractiveConfig.IsEditMode, Mode=TwoWay}" GroupName="RefractiveMode" Margin="0 0 20 0"/>
                                <RadioButton Content="折射率表选择" GroupName="RefractiveMode"/>
                            </StackPanel>
                            
                            <!-- 折射率表修改模式 -->
                            <Grid Grid.Row="1" Visibility="{Binding ModelParam.RefractiveConfig.IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 路径选择 -->
                                <Grid Grid.Row="0" Margin="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="路径" VerticalAlignment="Center" Margin="0 0 5 0" Foreground="Black"/>
                                    <TextBox Grid.Column="1" Text="{Binding ModelParam.RefractiveConfig.FilePath}" Style="{StaticResource TextBoxExtend}" Margin="3"/>
                                    <Button Grid.Column="2" Content="选择路径" Width="70" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="选择折射率文件路径"/>
                                </Grid>
                                
                                <!-- 折射率标定和清空 -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="3">
                                    <Button Content="折射率标定" Width="90" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="折射率标定" IsEnabled="False" ToolTip="暂无对应API"/>
                                    <Button Content="清空" Width="60" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="清空折射率表"/>
                                </StackPanel>
                                
                                <!-- 折射率表格 -->
                                <DataGrid Grid.Row="2" ItemsSource="{Binding ModelParam.RefractiveConfig.RefractiveTableItems}" 
                                          SelectedItem="{Binding ModelParam.RefractiveConfig.SelectedItem}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                          HeadersVisibility="Column" GridLinesVisibility="All"
                                          Style="{StaticResource DataGridBaseStyle}" Margin="3">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="50" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="材料" Binding="{Binding Material}" Width="*"/>
                                        <DataGridTextColumn Header="486nm" Binding="{Binding C486nm}" Width="*"/>
                                        <DataGridTextColumn Header="587nm" Binding="{Binding C587nm}" Width="*"/>
                                        <DataGridTextColumn Header="656nm" Binding="{Binding C656nm}" Width="*"/>
                                        <DataGridCheckBoxColumn Header="选择" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                            
                            <!-- 折射率表选择模式 -->
                            <Grid Grid.Row="1" Visibility="{Binding ModelParam.RefractiveConfig.IsEditMode, Converter={StaticResource BoolToVisibilityReverseConverter}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                
                                <!-- 折射率表格（选择模式） -->
                                <DataGrid Grid.Row="0" ItemsSource="{Binding ModelParam.RefractiveConfig.RefractiveTableItems}" 
                                          SelectedItem="{Binding ModelParam.RefractiveConfig.SelectedItem}"
                                          AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                                          HeadersVisibility="Column" GridLinesVisibility="All"
                                          Style="{StaticResource DataGridBaseStyle}" Margin="3">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="序号" Binding="{Binding Index}" Width="50" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="材料" Binding="{Binding Material}" Width="*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="486nm" Binding="{Binding C486nm}" Width="*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="587nm" Binding="{Binding C587nm}" Width="*" IsReadOnly="True"/>
                                        <DataGridTextColumn Header="656nm" Binding="{Binding C656nm}" Width="*" IsReadOnly="True"/>
                                        <DataGridCheckBoxColumn Header="选择" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                
                                <!-- 选择控制 -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="3" HorizontalAlignment="Left">
                                    <TextBlock Text="当前探头通道" VerticalAlignment="Center" Margin="0 0 5 0" Foreground="Black"/>
                                    <ComboBox ItemsSource="{Binding ModelParam.RefractiveConfig.Channels}" 
                                              SelectedItem="{Binding ModelParam.RefractiveConfig.CurrentChannel}"
                                              Style="{StaticResource ComboBoxExtend}" Width="80" Margin="3"/>
                                    <TextBlock Text="层序号" VerticalAlignment="Center" Margin="10 0 5 0" Foreground="Black"/>
                                    <ComboBox ItemsSource="{Binding ModelParam.RefractiveConfig.Labels}" 
                                              SelectedItem="{Binding ModelParam.RefractiveConfig.CurrentLabel}"
                                              Style="{StaticResource ComboBoxExtend}" Width="60" Margin="3"/>
                                    <Button Content="使用选中折射率" Width="120" Height="30" Margin="10 3 3 3" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="使用选中折射率"/>
                                </StackPanel>
                            </Grid>
                            
                            <!-- 底部按钮 -->
                            <Grid Grid.Row="2" Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="由控制器读取" Width="100" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="由控制器读取折射率"/>
                                    <Button Content="上传到控制器" Width="100" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="上传折射率到控制器"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="下载到硬盘" Width="100" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="下载折射率到硬盘"/>
                                    <Button Content="由硬盘读取" Width="100" Height="30" Margin="3" Style="{StaticResource GeneralButtonStyle}"
                                            Command="{Binding GeneralCommand}" CommandParameter="由硬盘读取折射率"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource BtnOverColor}"/>

            <!-- Right Side: Chart -->
            <Border Grid.Column="2" Margin="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="数据图表" FontSize="14" FontWeight="Bold" Margin="5" Foreground="Black"/>
                    <ContentControl Grid.Row="1" Content="{Binding SinglePointChartGrid}"/>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Bottom Bar -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Margin="0 0 15 0">
            <Button Content="原始图像" Width="90" MinHeight="30" Margin="5" FontSize="14" Style="{StaticResource GeneralButtonStyle}"
                    Command="{Binding GeneralCommand}" CommandParameter="原始图像" Cursor="Hand"/>
            <Button Content="取消" Width="80" MinHeight="30" Margin="5" FontSize="14" Style="{StaticResource GeneralButtonStyle}"
                    Command="{Binding GeneralCommand}" CommandParameter="取消" Cursor="Hand"/>
            <Button Content="确认" Width="80" Height="auto" Margin="5" FontSize="14" Style="{StaticResource GeneralButtonStyle}"
                    Command="{Binding GeneralCommand}" CommandParameter="确认" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>


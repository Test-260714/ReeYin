

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <TronSight2NativeDir>$(MSBuildThisFileDirectory)..\..\..\packages\A_ThirdParty\HardAPI\Sensor\TronSight2\</TronSight2NativeDir>
    <OutputExeModulesDir>$(MSBuildThisFileDirectory)..\..\..\OutputExe\$(Configuration)\$(TargetFramework)\Modules\</OutputExeModulesDir>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\Application\ReeYin_V.Share\ReeYin_V.Share.csproj" />
    <ProjectReference Include="..\ReeYin.Hardware.Sensor\ReeYin.Hardware.Sensor.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="$(TronSight2NativeDir)TSCMCAPIC.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>Native\TronSight2\TSCMCAPIC.dll</Link>
      <TargetPath>Native\TronSight2\TSCMCAPIC.dll</TargetPath>
    </None>
    <None Include="$(TronSight2NativeDir)TSCMCAPINET.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <Link>Native\TronSight2\TSCMCAPINET.dll</Link>
      <TargetPath>Native\TronSight2\TSCMCAPINET.dll</TargetPath>
    </None>
  </ItemGroup>

  <Target Name="PostBuild" AfterTargets="PostBuildEvent">
    <Exec Command="set SOURCE_DEBUG=&quot;$(ProjectDir)bin\Debug\net8.0-windows\$(ProjectName).dll&quot;&#xD;&#xA;set TARGET_DEBUG=&quot;$(SolutionDir)\OutputExe\Debug\net8.0-windows\Modules\&quot;&#xD;&#xA;&#xD;&#xA;set SOURCE_RELEASE=&quot;$(ProjectDir)bin\Release\net8.0-windows\$(ProjectName).dll&quot;&#xD;&#xA;set TARGET_RELEASE=&quot;$(SolutionDir)\OutputExe\Release\net8.0-windows\Modules\&quot;&#xD;&#xA;&#xD;&#xA;:: 检查Debug配置文件&#xD;&#xA;IF EXIST %25SOURCE_DEBUG%25 (&#xD;&#xA;    echo 找到Debug源文件: %25SOURCE_DEBUG%25&#xD;&#xA;    xcopy %25SOURCE_DEBUG%25 %25TARGET_DEBUG%25 /Y /I&#xD;&#xA;    echo Debug文件复制成功！&#xD;&#xA;) ELSE (&#xD;&#xA;    echo 警告：Debug源文件不存在 - %25SOURCE_DEBUG%25&#xD;&#xA;)&#xD;&#xA;&#xD;&#xA;:: 检查Release配置文件&#xD;&#xA;IF EXIST %25SOURCE_RELEASE%25 (&#xD;&#xA;    echo 找到Release源文件: %25SOURCE_RELEASE%25&#xD;&#xA;    xcopy %25SOURCE_RELEASE%25 %25TARGET_RELEASE%25 /Y /I&#xD;&#xA;    echo Release文件复制成功！&#xD;&#xA;) ELSE (&#xD;&#xA;    echo 警告：Release源文件不存在 - %25SOURCE_RELEASE%25&#xD;&#xA;)&#xD;&#xA;" />
  </Target>

  <Target Name="CopyNativeToOutputModules" AfterTargets="PostBuild">
    <ItemGroup>
      <_TronSight2NativeDlls Include="$(TronSight2NativeDir)TSCMCAPIC.dll" />
      <_TronSight2NativeDlls Include="$(TronSight2NativeDir)TSCMCAPINET.dll" />
    </ItemGroup>

    <Copy SourceFiles="@(_TronSight2NativeDlls)"
          DestinationFolder="$(OutputExeModulesDir)Native\TronSight2\"
          SkipUnchangedFiles="true" />
  </Target>

</Project>

<Window x:Class="ReeYin.Hardware.Sensor.TronSight2.CustomUI.Views.TronSight2RefractiveIndexWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
        Title="折射率页面"
        Width="980"
        Height="760"
        MinWidth="900"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#F4F4F4"
        FontSize="14">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <WxGroupBox:WxGroupBox Grid.Row="0" Header="折射率表" Margin="0 0 0 10">
            <Grid Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0 0 0 10">
                    <RadioButton Margin="0 0 20 0"
                                 GroupName="RefractiveTableMode"
                                 IsChecked="{Binding IsRefractiveTableEditMode, Mode=TwoWay}"
                                 VerticalAlignment="Center"
                                 Content="折射率表修改"/>
                    <RadioButton GroupName="RefractiveTableMode"
                                 IsChecked="{Binding IsRefractiveTableSelectMode, Mode=TwoWay}"
                                 VerticalAlignment="Center"
                                 Content="折射率表选择"/>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0 0 0 10"
                      Visibility="{Binding IsRefractiveTableEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="路径"/>
                    <TextBox Grid.Column="1"
                             Height="30"
                             Margin="8 0 8 0"
                             VerticalContentAlignment="Center"
                             Text="{Binding RefractiveIndexTableFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="2"
                            Height="30"
                            Margin="0 0 8 0"
                            Command="{Binding RefractiveTableCommand}"
                            CommandParameter="选择路径"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="选择路径"/>
                    <Button Grid.Column="3"
                            Height="30"
                            Command="{Binding RefractiveTableCommand}"
                            CommandParameter="清空"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="清空"/>
                </Grid>

                <TextBlock Grid.Row="2"
                           Margin="0 0 0 10"
                           FontWeight="Bold"
                           Text="【提示：干涉测厚时，折射率需使用群折射率】"/>

                <Border Grid.Row="3" BorderBrush="#D0D0D0" BorderThickness="1">
                    <DataGrid x:Name="RefractiveTableDataGrid"
                              Height="440"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              SelectionUnit="CellOrRowHeader"
                              IsReadOnly="{Binding IsRefractiveTableSelectMode}"
                              ItemsSource="{Binding RefractiveIndexTableItems}"
                              LoadingRow="RefractiveTableDataGrid_LoadingRow"
                              PreviewMouseDoubleClick="RefractiveTableDataGrid_PreviewMouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="序号"
                                                Width="60"
                                                IsReadOnly="True"
                                                Binding="{Binding Label}"/>
                            <DataGridTextColumn Header="材料"
                                                Width="180"
                                                Binding="{Binding MaterialName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                            <DataGridTextColumn Header="1285nm"
                                                Width="130"
                                                Binding="{Binding RefractiveIndex1285, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F5}"/>
                            <DataGridTextColumn Header="1310nm"
                                                Width="130"
                                                Binding="{Binding RefractiveIndex1310, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F5}"/>
                            <DataGridTextColumn Header="1335nm"
                                                Width="130"
                                                Binding="{Binding RefractiveIndex1335, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F5}"/>
                            <DataGridCheckBoxColumn Header="选择"
                                                    Width="80"
                                                    Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Grid Grid.Row="4"
                      Margin="0 12 0 0"
                      Visibility="{Binding IsRefractiveTableEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Height="34"
                            Command="{Binding RefractiveTableCommand}"
                            CommandParameter="由控制器读取"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="由控制器读取"/>
                    <Button Grid.Column="2"
                            Height="34"
                            Command="{Binding RefractiveTableCommand}"
                            CommandParameter="上传到控制器"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="上传到控制器"/>
                    <Button Grid.Column="4"
                            Height="34"
                            Command="{Binding RefractiveTableCommand}"
                            CommandParameter="下载到硬盘"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="下载到硬盘"/>
                    <Button Grid.Column="6"
                            Height="34"
                            Command="{Binding RefractiveTableCommand}"
                            CommandParameter="由硬盘读取"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="由硬盘读取"/>
                </Grid>

                <Grid Grid.Row="5"
                      Margin="0 12 0 0"
                      Visibility="{Binding IsRefractiveTableSelectMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="当前探头通道"/>
                    <ComboBox Grid.Column="1"
                              Width="120"
                              Margin="8 0 8 0"
                              ItemsSource="{Binding RefractiveProbeChannelOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedRefractiveProbeChannel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ComboBoxExtend}"/>
                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="层序号"/>
                    <ComboBox Grid.Column="3"
                              Width="80"
                              Margin="8 0 8 0"
                              ItemsSource="{Binding RefractiveLayerOptions}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedRefractiveLayer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource ComboBoxExtend}"/>
                    <Button Grid.Column="4"
                            Width="140"
                            Height="34"
                            Command="{Binding RefractiveTableCommand}"
                            CommandParameter="使用选中折射率"
                            Style="{StaticResource GeneralButtonStyle}"
                            Content="使用选中折射率"/>
                </Grid>
            </Grid>
        </WxGroupBox:WxGroupBox>

        <StackPanel Grid.Row="1"
                    Margin="0 10 0 0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="100"
                    Height="34"
                    IsCancel="True"
                    Style="{StaticResource GeneralButtonStyle}"
                    Content="关闭"/>
        </StackPanel>
    </Grid>
</Window>

<UserControl x:Class="ReeYin.Hardware.Sensor.TronSight2.CustomUI.Views.TronSight2SensorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ReeYin.Hardware.Sensor.TronSight2.CustomUI.Views"
             mc:Ignorable="d"
             xmlns:helper="clr-namespace:ReeYin_V.Core.Helper;assembly=ReeYin_V.Core"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLED="clr-namespace:ReeYin_V.UI.UserControls.WxLED;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             FontSize="14"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Height="880" Width="1480"
             d:DesignHeight="800" d:DesignWidth="1280">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        
        <!-- 主体区域 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.5*"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="0.5*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧配置区域 -->
            <Grid Grid.Column="0">
                <Border CornerRadius="0" Padding="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <TabControl HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                Style="{DynamicResource TabControlStyle}" SelectionChanged="TabControl_SelectionChanged">

                        <!-- 基础配置 -->
                        <TabItem Header="基础配置" Width="110" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                <WxGroupBox:WxGroupBox Header="测量模式" Margin="5 5 5 10">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                        <Grid Margin="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="测量模式"/>
                                            <ComboBox Grid.Column="2"
                                                      Width="220"
                                                      ItemsSource="{Binding MeasureModeOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedMeasureMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource ComboBoxExtend}"/>
                                        </Grid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="基础参数" Margin="5 5 5 10">
                                    <Grid Margin="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="无效数据保持"/>
                                        <hc:NumericUpDown Grid.Column="1"
                                                          Width="160"
                                                          Height="30"
                                                          Margin="10 0 0 0"
                                                          Minimum="0"
                                                          Maximum="1000"
                                                          DecimalPlaces="0"
                                                          Increment="1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          BorderThickness="0 0 0 1"
                                                          Foreground="Black"
                                                          HorizontalContentAlignment="Center"
                                                          Value="{Binding ModelParam.TronSight2Sensor.InvalidDataHoldPoints, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="采样间隔"/>
                                        <ComboBox Grid.Column="4"
                                                  Width="160"
                                                  Margin="10 0 0 0"
                                                  ItemsSource="{Binding SamplingIntervalOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedSamplingInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ComboBoxExtend}"/>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="滤波设置" Margin="5 5 5 10">
                                    <Grid Margin="6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="220"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="滑动平均滤波窗口宽度"/>
                                        <ComboBox Grid.Row="0"
                                                  Grid.Column="1"
                                                  Width="180"
                                                  Margin="10 0 0 0"
                                                  ItemsSource="{Binding FilterWindowWidthOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedMoveAverageWindow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ComboBoxExtend}"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="中值滤波窗口宽度"/>
                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="1"
                                                  Width="180"
                                                  Margin="10 0 0 0"
                                                  ItemsSource="{Binding MedianFilterWidthOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedMedianFilterWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ComboBoxExtend}"/>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="参数固化" Margin="5 5 5 10">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="6">
                                        <Button Margin="0,0,15,0"
                                                Width="160"
                                                Height="34"
                                                Command="{Binding ConfigCommand}"
                                                CommandParameter="写入配置到传感器"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                Content="写入配置到传感器"
                                                Cursor="Hand"/>
                                        <Button Width="160"
                                                Height="34"
                                                Command="{Binding ConfigCommand}"
                                                CommandParameter="从传感器读取配置"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                Content="从传感器读取配置"
                                                Cursor="Hand"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- 触发设定 -->
                        <TabItem Header="触发配置" Width="100" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="触发配置" Margin="5 5 5 10">
                                    <Grid Margin="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="300"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="8"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0 0 8 0" Text="触发采样模式"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Margin="8 0" Text="采样使能电平"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Margin="8 0" Text="单次采样个数"/>
                                        <TextBlock Grid.Row="0" Grid.Column="3" Margin="8 0" Text="滤波宽度"/>

                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="0"
                                                  Width="300"
                                                  ItemsSource="{Binding TriggerSampleModeOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedTriggerSampleMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource ComboBoxExtend}"/>

                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="1"
                                                  Width="110"
                                                  Margin="8 0"
                                                  ItemsSource="{Binding SyncValidLevelOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedSyncValidLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding ModelParam.TronSight2Sensor.IsSyncValidLevelEnabled}"
                                                  Style="{StaticResource ComboBoxExtend}"/>

                                        <hc:NumericUpDown Grid.Row="2"
                                                          Grid.Column="2"
                                                          Width="100"
                                                          Height="30"
                                                          Margin="8 0"
                                                          Minimum="1"
                                                          Maximum="65535"
                                                          DecimalPlaces="0"
                                                          Increment="1"
                                                          Style="{StaticResource NumericUpDownExtend}"
                                                          BorderThickness="0 0 0 1"
                                                          Foreground="Black"
                                                          HorizontalContentAlignment="Center"
                                                          IsEnabled="{Binding ModelParam.TronSight2Sensor.IsSinglePulseSampleCountEnabled}"
                                                          Value="{Binding ModelParam.TronSight2Sensor.SinglePulseSampleCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="3"
                                                  Width="100"
                                                  Margin="8 0"
                                                  ItemsSource="{Binding SyncFilterWidthOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Value"
                                                  SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedSyncFilterWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEnabled="{Binding ModelParam.TronSight2Sensor.IsSyncFilterWidthEnabled}"
                                                  Style="{StaticResource ComboBoxExtend}"/>
                                    </Grid>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="编码配置" Margin="5 5 5 10">
                                    <StackPanel Orientation="Vertical" Margin="8">
                                        <Grid Margin="0 0 0 12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="190"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="8"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="触发通道"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Margin="8 0 0 0" Text="触发模式"/>
                                            <TextBlock Grid.Row="0" Grid.Column="2" Margin="8 0 0 0" Text="触发方向"/>
                                            <TextBlock Grid.Row="0" Grid.Column="3" Margin="8 0 0 0" Text="追踪模式"/>
                                            <TextBlock Grid.Row="0" Grid.Column="4" Margin="8 0 0 0" Text="触发间隔"/>
                                            <TextBlock Grid.Row="0" Grid.Column="5" Margin="8 0 0 0" Text="Z信号复用为编码器3"/>

                                            <ComboBox Grid.Row="2"
                                                      Grid.Column="0"
                                                      Width="110"
                                                      ItemsSource="{Binding EncoderTriggerChannelOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedTriggerEncoderChannel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource ComboBoxExtend}"/>

                                            <ComboBox Grid.Row="2"
                                                      Grid.Column="1"
                                                      Width="110"
                                                      Margin="8 0 0 0"
                                                      ItemsSource="{Binding TriggerModeOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedTriggerMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource ComboBoxExtend}"/>

                                            <ComboBox Grid.Row="2"
                                                      Grid.Column="2"
                                                      Width="100"
                                                      Margin="8 0 0 0"
                                                      ItemsSource="{Binding TriggerDirectionOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedTriggerDirection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource ComboBoxExtend}"/>

                                            <ComboBox Grid.Row="2"
                                                      Grid.Column="3"
                                                      Width="100"
                                                      Margin="8 0 0 0"
                                                      ItemsSource="{Binding TriggerTrackModeOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding ModelParam.TronSight2Sensor.SelectedTriggerTrackMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource ComboBoxExtend}"/>

                                            <hc:NumericUpDown Grid.Row="2"
                                                              Grid.Column="4"
                                                              Width="110"
                                                              Height="30"
                                                              Margin="8 0 0 0"
                                                              Minimum="1"
                                                              Maximum="999999999"
                                                              DecimalPlaces="0"
                                                              Increment="1"
                                                              Style="{StaticResource NumericUpDownExtend}"
                                                              BorderThickness="0 0 0 1"
                                                              Foreground="Black"
                                                              HorizontalContentAlignment="Center"
                                                              Value="{Binding ModelParam.TronSight2Sensor.TriggerInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                            <ToggleButton Grid.Row="2"
                                                          Grid.Column="5"
                                                          Margin="8 0 0 0"
                                                          HorizontalAlignment="Left"
                                                          Style="{StaticResource ToggleButtonSwitch}"
                                                          IsChecked="{Binding ModelParam.TronSight2Sensor.IsZSignalMultiplexedToEncoder3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                            <Button Grid.Row="4"
                                                    Grid.Column="0"
                                                    Width="90"
                                                    Height="32"
                                                    Command="{Binding ConfigCommand}"
                                                    CommandParameter="触发复位"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="触发复位"
                                                    Cursor="Hand"/>
                                        </Grid>

                                        <Border Margin="0 0 0 10" Padding="10" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4">
                                            <StackPanel>
                                                <TextBlock FontSize="20" FontWeight="Bold" Margin="0 0 0 10" Text="编码器1"/>

                                                <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                                    <TextBlock Width="70" VerticalAlignment="Center" Text="使能"/>
                                                    <ToggleButton Width="100"
                                                                  HorizontalAlignment="Left"
                                                                  Style="{StaticResource ToggleButtonSwitch}"
                                                                  IsChecked="{Binding ModelParam.TronSight2Sensor.Encoder1Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>

                                                <TextBlock FontWeight="Bold" Margin="0 0 0 8" Text="编码器运行参数"/>
                                                <Grid Margin="0 0 0 8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="150"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="滤波宽度"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="8 0 0 0" Text="输入模式"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="8 0 0 0" Text="解码模式"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="3" Margin="8 0 0 0" Text="Z相使能"/>

                                                    <ComboBox Grid.Row="2"
                                                              Grid.Column="0"
                                                              Width="120"
                                                              ItemsSource="{Binding EncoderFilterWidthOptions}"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValuePath="Value"
                                                              SelectedValue="{Binding ModelParam.TronSight2Sensor.Encoder1FilterWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ComboBoxExtend}"/>

                                                    <ComboBox Grid.Row="2"
                                                              Grid.Column="1"
                                                              Width="120"
                                                              Margin="8 0 0 0"
                                                              ItemsSource="{Binding EncoderInputModeOptions}"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValuePath="Value"
                                                              SelectedValue="{Binding ModelParam.TronSight2Sensor.Encoder1InputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ComboBoxExtend}"/>

                                                    <ComboBox Grid.Row="2"
                                                              Grid.Column="2"
                                                              Width="120"
                                                              Margin="8 0 0 0"
                                                              ItemsSource="{Binding EncoderOutputModeOptions}"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValuePath="Value"
                                                              SelectedValue="{Binding ModelParam.TronSight2Sensor.Encoder1OutputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ComboBoxExtend}"/>

                                                    <ToggleButton Grid.Row="2"
                                                                  Grid.Column="3"
                                                                  Margin="8 0 0 0"
                                                                  HorizontalAlignment="Left"
                                                                  Style="{StaticResource ToggleButtonSwitch}"
                                                                  IsEnabled="{Binding ModelParam.TronSight2Sensor.IsEncoder1ZPhaseAvailable}"
                                                                  IsChecked="{Binding ModelParam.TronSight2Sensor.Encoder1ZPhaseEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="170"/>
                                                        <ColumnDefinition Width="170"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="脉冲比例系数 (mm/pulse)"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="8 0 0 0" Text="手动置位 (mm)"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="8 0 0 0" Text="Z信号置位 (mm)"/>

                                                    <hc:NumericUpDown Grid.Row="2"
                                                                      Grid.Column="0"
                                                                      Width="170"
                                                                      Height="30"
                                                                      Minimum="0"
                                                                      Maximum="99999999"
                                                                      DecimalPlaces="6"
                                                                      Increment="0.000001"
                                                                      Style="{StaticResource NumericUpDownExtend}"
                                                                      BorderThickness="0 0 0 1"
                                                                      Foreground="Black"
                                                                      HorizontalContentAlignment="Center"
                                                                      Value="{Binding ModelParam.TronSight2Sensor.Encoder1Resolution, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                    <hc:NumericUpDown Grid.Row="2"
                                                                      Grid.Column="1"
                                                                      Width="140"
                                                                      Height="30"
                                                                      Margin="8 0 0 0"
                                                                      Minimum="-99999999"
                                                                      Maximum="99999999"
                                                                      DecimalPlaces="6"
                                                                      Increment="0.1"
                                                                      Style="{StaticResource NumericUpDownExtend}"
                                                                      BorderThickness="0 0 0 1"
                                                                      Foreground="Black"
                                                                      HorizontalContentAlignment="Center"
                                                                      Value="{Binding ModelParam.TronSight2Sensor.Encoder1ManualPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                    <hc:NumericUpDown Grid.Row="2"
                                                                      Grid.Column="2"
                                                                      Width="140"
                                                                      Height="30"
                                                                      Margin="8 0 0 0"
                                                                      Minimum="-99999999"
                                                                      Maximum="99999999"
                                                                      DecimalPlaces="6"
                                                                      Increment="0.1"
                                                                      Style="{StaticResource NumericUpDownExtend}"
                                                                      BorderThickness="0 0 0 1"
                                                                      Foreground="Black"
                                                                      HorizontalContentAlignment="Center"
                                                                      Value="{Binding ModelParam.TronSight2Sensor.Encoder1ZPhasePosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Padding="10" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4">
                                            <StackPanel>
                                                <TextBlock FontSize="20" FontWeight="Bold" Margin="0 0 0 10" Text="编码器2"/>

                                                <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                                    <TextBlock Width="70" VerticalAlignment="Center" Text="使能"/>
                                                    <ToggleButton Width="100"
                                                                  HorizontalAlignment="Left"
                                                                  Style="{StaticResource ToggleButtonSwitch}"
                                                                  IsChecked="{Binding ModelParam.TronSight2Sensor.Encoder2Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>

                                                <TextBlock FontWeight="Bold" Margin="0 0 0 8" Text="编码器运行参数"/>
                                                <Grid Margin="0 0 0 8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="150"/>
                                                        <ColumnDefinition Width="150"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="滤波宽度"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="8 0 0 0" Text="输入模式"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="8 0 0 0" Text="解码模式"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="3" Margin="8 0 0 0" Text="Z相使能"/>

                                                    <ComboBox Grid.Row="2"
                                                              Grid.Column="0"
                                                              Width="120"
                                                              ItemsSource="{Binding EncoderFilterWidthOptions}"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValuePath="Value"
                                                              SelectedValue="{Binding ModelParam.TronSight2Sensor.Encoder2FilterWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ComboBoxExtend}"/>

                                                    <ComboBox Grid.Row="2"
                                                              Grid.Column="1"
                                                              Width="120"
                                                              Margin="8 0 0 0"
                                                              ItemsSource="{Binding EncoderInputModeOptions}"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValuePath="Value"
                                                              SelectedValue="{Binding ModelParam.TronSight2Sensor.Encoder2InputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ComboBoxExtend}"/>

                                                    <ComboBox Grid.Row="2"
                                                              Grid.Column="2"
                                                              Width="120"
                                                              Margin="8 0 0 0"
                                                              ItemsSource="{Binding EncoderOutputModeOptions}"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValuePath="Value"
                                                              SelectedValue="{Binding ModelParam.TronSight2Sensor.Encoder2OutputMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                              Style="{StaticResource ComboBoxExtend}"/>

                                                    <ToggleButton Grid.Row="2"
                                                                  Grid.Column="3"
                                                                  Margin="8 0 0 0"
                                                                  HorizontalAlignment="Left"
                                                                  Style="{StaticResource ToggleButtonSwitch}"
                                                                  IsEnabled="{Binding ModelParam.TronSight2Sensor.IsEncoder2ZPhaseAvailable}"
                                                                  IsChecked="{Binding ModelParam.TronSight2Sensor.Encoder2ZPhaseEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="200"/>
                                                        <ColumnDefinition Width="170"/>
                                                        <ColumnDefinition Width="170"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="8"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="脉冲比例系数 (mm/pulse)"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Margin="8 0 0 0" Text="手动置位 (mm)"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="2" Margin="8 0 0 0" Text="Z信号置位 (mm)"/>

                                                    <hc:NumericUpDown Grid.Row="2"
                                                                      Grid.Column="0"
                                                                      Width="170"
                                                                      Height="30"
                                                                      Minimum="0"
                                                                      Maximum="99999999"
                                                                      DecimalPlaces="6"
                                                                      Increment="0.000001"
                                                                      Style="{StaticResource NumericUpDownExtend}"
                                                                      BorderThickness="0 0 0 1"
                                                                      Foreground="Black"
                                                                      HorizontalContentAlignment="Center"
                                                                      Value="{Binding ModelParam.TronSight2Sensor.Encoder2Resolution, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                    <hc:NumericUpDown Grid.Row="2"
                                                                      Grid.Column="1"
                                                                      Width="140"
                                                                      Height="30"
                                                                      Margin="8 0 0 0"
                                                                      Minimum="-99999999"
                                                                      Maximum="99999999"
                                                                      DecimalPlaces="6"
                                                                      Increment="0.1"
                                                                      Style="{StaticResource NumericUpDownExtend}"
                                                                      BorderThickness="0 0 0 1"
                                                                      Foreground="Black"
                                                                      HorizontalContentAlignment="Center"
                                                                      Value="{Binding ModelParam.TronSight2Sensor.Encoder2ManualPosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                                    <hc:NumericUpDown Grid.Row="2"
                                                                      Grid.Column="2"
                                                                      Width="140"
                                                                      Height="30"
                                                                      Margin="8 0 0 0"
                                                                      Minimum="-99999999"
                                                                      Maximum="99999999"
                                                                      DecimalPlaces="6"
                                                                      Increment="0.1"
                                                                      Style="{StaticResource NumericUpDownExtend}"
                                                                      BorderThickness="0 0 0 1"
                                                                      Foreground="Black"
                                                                      HorizontalContentAlignment="Center"
                                                                      Value="{Binding ModelParam.TronSight2Sensor.Encoder2ZPhasePosition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                                <WxGroupBox:WxGroupBox Header="采样模式" Margin="5 5 5 10">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                        <!-- 采样模式内容区域 -->
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- 配置设置 -->
                        <TabItem Header="配置设置" Width="100" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="设备配置管理" Margin="5 5 5 10">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                        <CheckBox Margin="8 4 8 8"
                                                  IsChecked="{Binding ModelParam.TronSight2Sensor.PersistConfigurationAfterImportOrRestore, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  VerticalAlignment="Center">
                                            <TextBlock TextWrapping="Wrap">
                                                <Run Text="固化参数"/>
                                                <Run Text="（选择固化参数后，恢复出厂配置或从文件读取配置并发送到设备，断电重启后依然会生效）"/>
                                            </TextBlock>
                                        </CheckBox>

                                        <WrapPanel Margin="8 0 8 4">
                                            <Button Margin="0,0,12,8"
                                                    Width="220"
                                                    Height="34"
                                                    Command="{Binding DeviceConfigCommand}"
                                                    CommandParameter="恢复出厂配置"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="恢复出厂配置"
                                                    Cursor="Hand"/>
                                            <Button Margin="0,0,12,8"
                                                    Width="220"
                                                    Height="34"
                                                    Command="{Binding DeviceConfigCommand}"
                                                    CommandParameter="保存配置到文件"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="保存配置到文件"
                                                    Cursor="Hand"/>
                                            <Button Margin="0,0,0,8"
                                                    Width="220"
                                                    Height="34"
                                                    Command="{Binding DeviceConfigCommand}"
                                                    CommandParameter="从文件读取配置"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="从文件读取配置"
                                                    Cursor="Hand"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                
                            </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- 折射率 -->
                        <TabItem Header="折射率" Width="100" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="折射率表" Margin="5 5 5 10">
                                    <StackPanel Margin="8">
                                        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                                            <RadioButton Margin="0 0 20 0"
                                                         GroupName="RefractiveTableMode"
                                                         IsChecked="{Binding IsRefractiveTableEditMode, Mode=TwoWay}"
                                                         VerticalAlignment="Center"
                                                         Content="折射率表修改"/>
                                            <RadioButton GroupName="RefractiveTableMode"
                                                         IsChecked="{Binding IsRefractiveTableSelectMode, Mode=TwoWay}"
                                                         VerticalAlignment="Center"
                                                         Content="折射率表选择"/>
                                        </StackPanel>

                                        <Grid Margin="0 0 0 10"
                                              Visibility="{Binding IsRefractiveTableEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="路径"/>
                                            <TextBox Grid.Column="1"
                                                     Height="30"
                                                     Margin="8 0 8 0"
                                                     VerticalContentAlignment="Center"
                                                     Text="{Binding RefractiveIndexTableFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <Button Grid.Column="2"
                                                    Height="30"
                                                    Margin="0 0 8 0"
                                                    Command="{Binding RefractiveTableCommand}"
                                                    CommandParameter="选择路径"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="选择路径"/>
                                            <Button Grid.Column="3"
                                                    Height="30"
                                                    Command="{Binding RefractiveTableCommand}"
                                                    CommandParameter="清空"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="清空"/>
                                        </Grid>

                                        <TextBlock Margin="0 0 0 10"
                                                   FontWeight="Bold"
                                                   Text="【提示：干涉测厚时，折射率需使用群折射率；最多可存储 32 条折射率】"/>

                                        <Border BorderBrush="#D0D0D0" BorderThickness="1">
                                            <DataGrid x:Name="RefractiveTableDataGrid"
                                                      Height="500"
                                                      AutoGenerateColumns="False"
                                                      CanUserAddRows="False"
                                                      CanUserDeleteRows="False"
                                                      HeadersVisibility="Column"
                                                      GridLinesVisibility="All"
                                                      RowHeaderWidth="0"
                                                      SelectionMode="Single"
                                                      SelectionUnit="CellOrRowHeader"
                                                      IsReadOnly="{Binding IsRefractiveTableSelectMode}"
                                                      ItemsSource="{Binding RefractiveIndexTableItems}"
                                                      LoadingRow="RefractiveTableDataGrid_LoadingRow"
                                                      PreviewMouseDoubleClick="RefractiveTableDataGrid_PreviewMouseDoubleClick">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="序号"
                                                                        Width="60"
                                                                        IsReadOnly="True"
                                                                        Binding="{Binding Label}"/>
                                                    <DataGridTextColumn Header="材料"
                                                                        Width="160"
                                                                        Binding="{Binding MaterialName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                                                    <DataGridTextColumn Header="1285nm"
                                                                        Width="120"
                                                                        Binding="{Binding RefractiveIndex1285, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F5}"/>
                                                    <DataGridTextColumn Header="1310nm"
                                                                        Width="120"
                                                                        Binding="{Binding RefractiveIndex1310, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F5}"/>
                                                    <DataGridTextColumn Header="1335nm"
                                                                        Width="120"
                                                                        Binding="{Binding RefractiveIndex1335, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F5}"/>
                                                    <DataGridCheckBoxColumn Header="选择"
                                                                            Width="80"
                                                                            Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Border>

                                        <WrapPanel Margin="0 12 0 0"
                                                   HorizontalAlignment="Center"
                                                   Visibility="{Binding IsRefractiveTableEditMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Button Margin="0 0 12 8"
                                                    Width="160"
                                                    Height="34"
                                                    Command="{Binding RefractiveTableCommand}"
                                                    CommandParameter="由控制器读取"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="由控制器读取"/>
                                            <Button Margin="0 0 12 8"
                                                    Width="160"
                                                    Height="34"
                                                    Command="{Binding RefractiveTableCommand}"
                                                    CommandParameter="上传到控制器"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="上传到控制器"/>
                                            <Button Margin="0 0 12 8"
                                                    Width="160"
                                                    Height="34"
                                                    Command="{Binding RefractiveTableCommand}"
                                                    CommandParameter="下载到硬盘"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="下载到硬盘"/>
                                            <Button Margin="0 0 0 8"
                                                    Width="160"
                                                    Height="34"
                                                    Command="{Binding RefractiveTableCommand}"
                                                    CommandParameter="由硬盘读取"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="由硬盘读取"/>
                                        </WrapPanel>

                                        <Grid Margin="0 12 0 0"
                                              Visibility="{Binding IsRefractiveTableSelectMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="160"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="当前探头通道"/>
                                            <ComboBox Grid.Column="1"
                                                      Width="120"
                                                      Margin="8 0 8 0"
                                                      ItemsSource="{Binding RefractiveProbeChannelOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding SelectedRefractiveProbeChannel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource ComboBoxExtend}"/>
                                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="层序号"/>
                                            <ComboBox Grid.Column="3"
                                                      Width="80"
                                                      Margin="8 0 8 0"
                                                      ItemsSource="{Binding RefractiveLayerOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Value"
                                                      SelectedValue="{Binding SelectedRefractiveLayer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Style="{StaticResource ComboBoxExtend}"/>
                                            <Button Grid.Column="4"
                                                    Width="140"
                                                    Height="34"
                                                    Command="{Binding RefractiveTableCommand}"
                                                    CommandParameter="使用选中折射率"
                                                    Style="{StaticResource GeneralButtonStyle}"
                                                    Content="使用选中折射率"/>
                                        </Grid>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>

                                <WxGroupBox:WxGroupBox Header="折射率标定" Margin="5 5 5 10">
                                    <StackPanel Orientation="Horizontal" Margin="8">
                                        <Button Width="140"
                                                Height="34"
                                                Command="{Binding RefractiveTableCommand}"
                                                CommandParameter="折射率标定"
                                                Style="{StaticResource GeneralButtonStyle}"
                                                Content="折射率标定"/>
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <!-- 其他 -->
                        <TabItem Header="其他" Width="100" FontSize="16" Style="{DynamicResource SingleTabItemStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <WxGroupBox:WxGroupBox Header="高级设置" Margin="5 5 5 10">
                                    <StackPanel Orientation="Vertical" HorizontalAlignment="Left">
                                        <!-- 高级设置内容区域 -->
                                    </StackPanel>
                                </WxGroupBox:WxGroupBox>
                            </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>

            <!-- 分隔线 -->
            <GridSplitter Grid.Column="1" Height="730" Background="{DynamicResource BtnOverColor}" HorizontalAlignment="Stretch"/>

            <!-- 右侧显示区域 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition/>
                    <RowDefinition Height="60"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <!-- 上方控制区域 -->
                <Grid Grid.Row="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="20,0,5,0" HorizontalAlignment="Left" VerticalAlignment="Center" 
                                   Text="显示控制" Foreground="Black"/>
                        <!-- 显示控制内容区域 -->
                    </StackPanel>
                </Grid>

                <!-- 上方图表区域 -->
                <ContentControl Grid.Row="1" Content="{Binding SinglePointChartGrid}"/>

                <!-- 中间控制区域 -->
                <Grid Grid.Row="2">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="20,0,5,0" HorizontalAlignment="Left" VerticalAlignment="Center" 
                                   Foreground="Black">
                            <Run Text="数据显示:"/>
                            <!-- 数据显示内容区域 -->
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- 下方图表区域 -->
                <ContentControl Grid.Row="3" Content="{Binding OutlineChartGrid}"/>
            </Grid>
        </Grid>

        <!-- 底部按钮区域 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
            <Button Margin="0,0,15,0" FontSize="18" MinHeight="30" Width="80"
                    Command="{Binding GeneralCommand}" CommandParameter="取消"
                    Style="{StaticResource GeneralButtonStyle}"
                    Content="取消" Cursor="Hand"/>
            <Button Margin="0,0,15,0" FontSize="18" Height="auto" Width="80"
                    Command="{Binding GeneralCommand}" CommandParameter="确认"
                    Style="{StaticResource GeneralButtonStyle}"
                    Content="确认" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>

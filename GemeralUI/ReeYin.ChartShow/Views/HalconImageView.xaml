<UserControl x:Class="ReeYin.ChartShow.Views.HalconImageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ReeYin.ChartShow.Views"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             xmlns:Controls="clr-namespace:ReeYin_V.UI.Controls;assembly=ReeYin_V.UI"
             xmlns:WxGroupBox="clr-namespace:ReeYin_V.UI.UserControls.WxGroupBox;assembly=ReeYin_V.UI"
             xmlns:WxLink="clr-namespace:ReeYin_V.UI.UserControls.WxLink;assembly=ReeYin_V.UI"
             xmlns:WxNumericUpDown="clr-namespace:ReeYin_V.UI.UserControls.WxNumericUpDown;assembly=ReeYin_V.UI"
             xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d" FontSize="14"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600" d:DesignWidth="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="链接图片:" Foreground="Black" VerticalAlignment="Center" Margin="0 0 0 0" />
                <WxLink:WxLink Grid.Row="0" Grid.Column="1" Width="300" OutputParam="{Binding InputImage,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"  Order="OpenParam" Margin="5 15" Text="{Binding InputImage.Name,Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"/>
                <Button Content="⏮" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30" ToolTip="上一张"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="上一张"/>

                <Button Content="⏭" Style="{StaticResource GeneralButtonStyle}" FontFamily="{StaticResource Iconfont}" Height="30" ToolTip="下一张"
                                                                        Command="{Binding GeneralCommand}" CommandParameter="下一张"/>
            </StackPanel>
        </StackPanel>
        
        <WxGroupBox:WxGroupBox Grid.Row="1" Header="2D图显示" >
            <DockPanel >
                <!--图像-->
                <Controls:ImageEditView Image="{Binding DisposeImage}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent" MinHeight="300" MinWidth="300"/>
                <!--<Controls:CvImageView Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                           x:Name="ImageViewer" 
                           ImageMat="{Binding MyOpenCVMat}" 
                           />-->
            </DockPanel>

        </WxGroupBox:WxGroupBox>
        <!--操作-->

    </Grid>
</UserControl>

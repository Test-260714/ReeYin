<UserControl x:Class="ReeYin.ChartShow.Views.DefectMapDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:defectMap="clr-namespace:ReeYin_V.UI.UserControls.DefectMap;assembly=ReeYin_V.UI"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             mc:Ignorable="d"
             FontSize="14"
             Unloaded="UserControl_Unloaded"
             d:DesignHeight="880"
             d:DesignWidth="1280">
    <Grid Background="{DynamicResource RegionBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="310" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="10"
                Padding="14"
                Background="White"
                BorderBrush="{DynamicResource SplitBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="卷材走带模拟"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#243547" />
                    <TextBlock Margin="0,6,0,14"
                               Text="随机生成缺陷点并映射到宽度 X / 长度 Y。"
                               Foreground="#66798B"
                               TextWrapping="Wrap" />

                    <TextBlock Text="卷材宽度" Foreground="#405466" />
                    <TextBox Margin="0,4,0,10"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Text="{Binding MaterialWidth, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F2}" />

                    <TextBlock Text="卷材长度" Foreground="#405466" />
                    <TextBox Margin="0,4,0,10"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Text="{Binding MaterialLength, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F2}" />

                    <TextBlock Text="每次走带长度" Foreground="#405466" />
                    <TextBox Margin="0,4,0,10"
                             Height="28"
                             VerticalContentAlignment="Center"
                             Text="{Binding SimulationStepLength, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat=F2}" />

                    <TextBlock Text="长度 0 点方向" Foreground="#405466" />
                    <ComboBox Margin="0,4,0,16"
                              Height="28"
                              ItemsSource="{Binding LengthOriginOptions}"
                              SelectedItem="{Binding LengthOrigin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <UniformGrid Columns="2" Rows="2" Margin="0,0,0,14">
                        <Button Margin="0,0,6,6"
                                Height="32"
                                Content="开始走带"
                                Command="{Binding StartSimulationCommand}" />
                        <Button Margin="6,0,0,6"
                                Height="32"
                                Content="停止"
                                Command="{Binding StopSimulationCommand}" />
                        <Button Margin="0,6,6,0"
                                Height="32"
                                Content="重置"
                                Command="{Binding ResetSimulationCommand}" />
                        <Button Margin="6,6,0,0"
                                Height="32"
                                Content="手动缺陷"
                                Command="{Binding GenerateDefectCommand}" />
                    </UniformGrid>

                    <ProgressBar Height="12"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressPercent, Mode=OneWay}" />
                    <TextBlock Margin="0,8,0,4"
                               Text="{Binding SimulationStatus, Mode=OneWay}"
                               Foreground="#405466"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ProgressText, Mode=OneWay}"
                               Foreground="#405466"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding DefectSummary, Mode=OneWay}"
                               Foreground="#405466"
                               TextWrapping="Wrap" />

                    <Border Margin="0,16,0,0"
                            Padding="10"
                            Background="#F7FAFD"
                            BorderBrush="#D8E4EF"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel>
                            <TextBlock Text="选中缺陷"
                                       FontWeight="SemiBold"
                                       Foreground="#243547" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding SelectedDefectText, Mode=OneWay}"
                                       Foreground="#405466"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1"
                Margin="0,10,10,10"
                Background="White"
                BorderBrush="{DynamicResource SplitBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <defectMap:DefectMapView Margin="8"
                                     MapTitle="卷材缺陷映射模拟"
                                     Defects="{Binding Defects}"
                                     DefectTypeStyles="{Binding DefectTypeStyles}"
                                     MaterialWidth="{Binding MaterialWidth}"
                                     MaterialLength="{Binding MaterialLength}"
                                     LengthOrigin="{Binding LengthOrigin}"
                                     SelectedDefect="{Binding SelectedDefect, Mode=TwoWay}"
                                     DefectSelectedCommand="{Binding DefectSelectedCommand}" />
        </Border>
    </Grid>
</UserControl>

<CustomWindow:VisionWindow
    x:Class="ReeYin_V.Shell.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:CustomWindow="clr-namespace:ReeYin_V.UI.Style.CustomWins;assembly=ReeYin_V.UI"
    xmlns:local="clr-namespace:ReeYin_V.Shell.Views"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:prism="http://prismlibrary.com/"
    Style="{StaticResource WPFWindow}"
    prism:ViewModelLocator.AutoWireViewModel="True" 
    xmlns:share="clr-namespace:ReeYin_V.Share.Prism;assembly=ReeYin_V.Share" 
    WindowStartupLocation="CenterScreen"
    Title="{Binding Title}" WindowState="Maximized"
    AlarmBlinkInterval="0:0:0.6"
    CustomButtonsVisibility="{Binding TitleActionButtonsVisibility}"
    ModeName="{Binding ModeName,Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"
    Menu="{Binding MainMenu}" Height="820" Width="1500">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadedCommand}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <ContentControl prism:RegionManager.RegionName="{x:Static share:RegionNames.MainRegion}"/>
</CustomWindow:VisionWindow>
